@prefix aieng: <https://example.com/aieng#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <http://example.org/aieng#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aieng: a owl:Ontology ;
    rdfs:label "AI Engineering Ontology" ;
    dcterms:created "2026-04-16T12:08:10.375291+00:00"^^xsd:dateTime ;
    dcterms:description "Ontology for concepts and relationships in AI engineering, covering processes, tools, roles, maturity models, challenges, provenance, and related artifacts." ;
    dcterms:identifier "hash:590257cb5075f479e4620b96a21a780c057f485fa900ef3246df272e976b8017" ;
    dcterms:title "aieng" ;
    rdfs:comment "Ontology for concepts and relationships in AI engineering, covering processes, tools, roles, maturity models, challenges, provenance, and related artifacts." ;
    owl:versionInfo "1.0.2" ;
    prov:wasDerivedFrom <urn:hash:3c297330825987614be4ca8244408b0f7bb4f02ee27a5674c68b01a524a1a473> .

<http://example.org/aieng#> dcterms:description "Extended ontology for AI engineering with added abstract concepts for MLOps research, including processes, maturity models, attributes, benefits, challenges, research questions, and search strategies."^^xsd:string,
        "Ontology for AI engineering, with emphasis on MLOps processes, tools, maturity models, challenges, and scholarly artifacts."^^xsd:string .

ns1:AIOpsFramework a owl:Class ;
    rdfs:label "AIOps Framework"^^xsd:string ;
    rdfs:comment "Framework for goal-driven operationalization of distributed analytical pipelines."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:AgileProcess a owl:Class ;
    rdfs:label "Agile Process"^^xsd:string ;
    rdfs:comment "Iterative and incremental approach to software and model development."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:BusinessTeam a owl:Class ;
    rdfs:label "Business Team"^^xsd:string ;
    rdfs:comment "Team representing business stakeholders and goals."^^xsd:string ;
    rdfs:subClassOf ns1:Team .

ns1:CICDPractice a owl:Class ;
    rdfs:label "CI/CD Practice"^^xsd:string ;
    rdfs:comment "Practice of continuous integration and continuous delivery for ML models."^^xsd:string ;
    rdfs:subClassOf ns1:AutomationPractice ;
    owl:sameAs ns1:CI_CD_Tool .

ns1:CRISPDMMethodology a owl:Class ;
    rdfs:label "CRISP-DM Methodology"^^xsd:string ;
    rdfs:comment "Cross-Industry Standard Process for Data Mining, a methodology for data science projects."^^xsd:string ;
    rdfs:subClassOf ns1:Methodology .

ns1:Collaboration a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "collaborates with"^^xsd:string ;
    rdfs:comment "Indicates collaborative relationship between teams."^^xsd:string ;
    rdfs:domain ns1:Team ;
    rdfs:range ns1:Team .

ns1:CommunicationChallenge a owl:Class ;
    rdfs:label "Communication Challenge"^^xsd:string ;
    rdfs:comment "Challenge concerning communication among stakeholders in ML-enabled system development."^^xsd:string ;
    rdfs:subClassOf ns1:CollaborationChallenge .

ns1:ContinuousDelivery a owl:Class ;
    rdfs:label "Continuous Delivery"^^xsd:string ;
    rdfs:comment "Practice of automatically delivering validated changes to staging or production."^^xsd:string ;
    rdfs:subClassOf ns1:Process .

ns1:Cost a owl:Class ;
    rdfs:label "Cost"^^xsd:string ;
    rdfs:comment "Monetary expense associated with computational resources or MLOps activities."^^xsd:string ;
    rdfs:subClassOf schema1:PriceSpecification .

ns1:CrossTeamCollaboration a owl:Class ;
    rdfs:label "CrossâTeam Collaboration"^^xsd:string ;
    rdfs:comment "Enhanced collaboration across teams resulting from MLOps adoption."^^xsd:string ;
    rdfs:subClassOf ns1:Benefit .

ns1:Customer a owl:Class ;
    rdfs:label "Customer"^^xsd:string ;
    rdfs:comment "Endâuser or stakeholder who receives the AI product."^^xsd:string ;
    rdfs:subClassOf ns1:Role .

ns1:DataCleaningProcess a owl:Class ;
    rdfs:label "Data Cleaning Process"^^xsd:string ;
    rdfs:comment "Activity that cleanses and validates raw data to ensure quality."^^xsd:string ;
    rdfs:subClassOf prov:Activity ;
    owl:sameAs ns1:DataCollectionProcess,
        ns1:DataVersioningProcess .

ns1:DataDrivenScrumMethodology a owl:Class ;
    rdfs:label "Data-Driven Scrum Methodology"^^xsd:string ;
    rdfs:comment "An agile methodology adapted for data science and machine learning projects."^^xsd:string ;
    rdfs:subClassOf ns1:Methodology .

ns1:DataEngineer a owl:Class ;
    rdfs:label "Data Engineer"^^xsd:string ;
    rdfs:comment "Builds and maintains data pipelines and feature stores."^^xsd:string,
        "Designs and maintains data infrastructure and pipelines."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsRole,
        ns1:MLRole .

ns1:DataManagementChallenge a owl:Class ;
    rdfs:label "Data Management Challenge"^^xsd:string ;
    rdfs:comment "Difficulty managing data throughout the ML lifecycle."^^xsd:string ;
    rdfs:subClassOf ns1:Challenge .

ns1:DataOpsPractice a owl:Class ;
    rdfs:label "DataOps Practice"^^xsd:string ;
    rdfs:comment "Practice related to automated data management and feature engineering."^^xsd:string ;
    rdfs:subClassOf ns1:AutomationPractice .

ns1:DataQualityChallenge a owl:Class ;
    rdfs:label "Data Quality Challenge"^^xsd:string ;
    ns1:involvesRole ns1:DataEngineerRole,
        ns1:DataScientistRole ;
    ns1:requiresDataStrategy ns1:DataStrategy ;
    rdfs:comment "Challenge related to low quality of data used for training machine learning models."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsAdoptionChallenge .

ns1:DataQuantityChallenge a owl:Class ;
    rdfs:label "Data Quantity Challenge"^^xsd:string ;
    ns1:involvesRole ns1:DataEngineerRole,
        ns1:DataScientistRole ;
    ns1:requiresDataStrategy ns1:DataStrategy ;
    rdfs:comment "Challenge concerning insufficient volume of relevant data for training deep learning models."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsAdoptionChallenge .

ns1:DataScienceMethodology a owl:Class ;
    rdfs:label "Data Science Methodology"^^xsd:string ;
    rdfs:comment "A structured approach to conducting data science projects."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork .

ns1:DataScientist a owl:Class ;
    rdfs:label "Data Scientist"^^xsd:string ;
    rdfs:comment "Professional responsible for data analysis, feature engineering, and model development."^^xsd:string,
        "Professional responsible for data analysis, model development, and experimentation."^^xsd:string,
        "Responsible for developing ML models and experiments."^^xsd:string,
        "Responsible for problem definition, data analysis, and model development."^^xsd:string,
        "Role responsible for data analysis and model development."^^xsd:string,
        "Stakeholder responsible for data analysis and model training."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsRole,
        ns1:MLRole,
        ns1:Role,
        ns1:StakeholderRole .

ns1:DataStorage a owl:Class ;
    rdfs:label "Data Storage"^^xsd:string ;
    rdfs:comment "Persistent repository where processed data sets are kept."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:DeepLearningEra a owl:Class ;
    rdfs:label "Deep Learning Era"^^xsd:string ;
    rdfs:comment "The period characterized by widespread adoption of deep learning techniques."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:DeployedProductQuality a owl:Class ;
    rdfs:label "Deployed Product Quality"^^xsd:string ;
    rdfs:comment "Higher quality of deployed machineâlearning products as a benefit of MLOps."^^xsd:string ;
    rdfs:subClassOf ns1:Benefit .

ns1:DeploymentStage a owl:Class ;
    rdfs:label "Deployment Stage"^^xsd:string ;
    rdfs:comment "Stage where model versions are deployed to production environments."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsStage .

ns1:DevOpsEngineer a owl:Class ;
    rdfs:label "DevOps Engineer"^^xsd:string ;
    rdfs:comment "Manages CI/CD pipelines and infrastructure for ML deployments."^^xsd:string,
        "Manages CI/CD pipelines, infrastructure, and deployment automation."^^xsd:string,
        "Role that manages CI/CD pipelines and infrastructure for ML systems."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsRole,
        ns1:MLRole,
        ns1:Role .

ns1:DevelopmentTeam a owl:Class ;
    rdfs:label "Development Team"^^xsd:string ;
    rdfs:comment "Team responsible for developing models and code."^^xsd:string ;
    rdfs:subClassOf ns1:Team .

ns1:Docker a owl:Class ;
    rdfs:label "Docker"^^xsd:string ;
    rdfs:comment "Container platform used to package ML models and services."^^xsd:string ;
    rdfs:subClassOf ns1:ContainerizationTechnology .

ns1:DocumentationChallenge a owl:Class ;
    rdfs:label "Documentation Challenge"^^xsd:string ;
    rdfs:comment "Challenge concerning documentation practices in ML-enabled system development."^^xsd:string ;
    rdfs:subClassOf ns1:CollaborationChallenge .

ns1:EngineeringChallenge a owl:Class ;
    rdfs:label "Engineering Challenge"^^xsd:string ;
    rdfs:comment "Challenge concerning engineering activities in ML-enabled system development."^^xsd:string ;
    rdfs:subClassOf ns1:CollaborationChallenge .

ns1:Experiment a owl:Class ;
    rdfs:label "Experiment"^^xsd:string ;
    rdfs:comment "A tracked run of model training with specific parameters."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:ExperimentalNatureChallenge a owl:Class ;
    rdfs:label "Experimental Nature Challenge"^^xsd:string ;
    rdfs:comment "The inherently experimental nature of ML that hampers repeatability."^^xsd:string ;
    rdfs:subClassOf ns1:Challenge .

ns1:FeatureEngineeringProcess a owl:Class ;
    rdfs:label "Feature Engineering Process"^^xsd:string ;
    rdfs:comment "Process that creates and transforms features for model training."^^xsd:string ;
    rdfs:subClassOf ns1:Process .

ns1:GPU a owl:Class ;
    rdfs:label "GPU"^^xsd:string ;
    rdfs:comment "Graphics Processing Unit used to accelerate model training."^^xsd:string ;
    rdfs:subClassOf ns1:Hardware .

ns1:GitHubActions a owl:Class ;
    rdfs:label "GitHub Actions"^^xsd:string ;
    rdfs:comment "CI/CD platform provided by GitHub."^^xsd:string ;
    rdfs:subClassOf ns1:CI_CD_Tool .

ns1:GoalDrivenOperationalization a owl:Class ;
    rdfs:label "Goal-Driven Operationalization"^^xsd:string ;
    rdfs:comment "Process of operationalizing analytical pipelines based on defined goals."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:IntegrationChallenge a owl:Class ;
    rdfs:label "Integration Challenge"^^xsd:string ;
    ns1:involvesRole ns1:DataScientistRole,
        ns1:SoftwareEngineerRole ;
    rdfs:comment "Challenge arising from the need to integrate data science and software engineering work within MLOps."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsAdoptionChallenge ;
    owl:sameAs ns1:CollaborationChallenge,
        ns1:TeamIntegrationChallenge .

ns1:Jenkins a owl:Class ;
    rdfs:label "Jenkins"^^xsd:string ;
    rdfs:comment "CI/CD automation server used in MLOps pipelines."^^xsd:string,
        "Open-source automation server for CI/CD."^^xsd:string ;
    rdfs:subClassOf ns1:CI_CD_Tool,
        ns1:Tool .

ns1:Kubeflow a owl:Class ;
    rdfs:label "Kubeflow"^^xsd:string ;
    rdfs:comment "MLOpsâspecific platform built on Kubernetes for managing ML workflows."^^xsd:string ;
    rdfs:subClassOf ns1:Tool .

ns1:Kubernetes a owl:Class ;
    rdfs:label "Kubernetes"^^xsd:string ;
    rdfs:comment "Container orchestration platform used to deploy ML services."^^xsd:string,
        "Container orchestrator commonly used for ML model deployment."^^xsd:string ;
    rdfs:subClassOf ns1:Orchestrator,
        ns1:Tool .

ns1:MLComponent a owl:Class ;
    rdfs:label "ML Component"^^xsd:string ;
    rdfs:comment "A reusable machine learning component, such as a model, feature extractor, or pipeline step."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:MLEnabledSystem a owl:Class ;
    rdfs:label "ML-Enabled System"^^xsd:string ;
    rdfs:comment "A software system that incorporates machine learning components."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:MLEngineer a owl:Class ;
    rdfs:label "ML Engineer"^^xsd:string ;
    rdfs:comment "Bridges model development and production, handling deployment and pipelines."^^xsd:string,
        "Bridges model development and production, handling model packaging and deployment."^^xsd:string,
        "Role that bridges data science and engineering, focusing on model deployment and scaling."^^xsd:string,
        "Stakeholder bridging machine learning and software engineering."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsRole,
        ns1:MLRole,
        ns1:Role,
        ns1:StakeholderRole .

ns1:MLOpsAdoptionBenefitCategory a owl:Class ;
    rdfs:label "MLOps Adoption Benefit Category" ;
    rdfs:comment "High-level grouping of benefits from MLOps adoption." ;
    rdfs:subClassOf ns1:BenefitCategory .

ns1:MLOpsAdoptionChallengeCategory a owl:Class ;
    rdfs:label "MLOps Adoption Challenge Category" ;
    rdfs:comment "High-level grouping of challenges from MLOps adoption." ;
    rdfs:subClassOf ns1:ChallengeCategory .

ns1:MLOpsAttribute a owl:Class ;
    rdfs:label "MLOps Attribute"^^xsd:string ;
    rdfs:comment "An essential attribute or principle that contributes to successful MLOps implementation."^^xsd:string ;
    rdfs:subClassOf skos:Concept .

ns1:MLOpsEngineer a owl:Class ;
    rdfs:label "MLOps Engineer"^^xsd:string ;
    rdfs:comment "Professional responsible for operationalizing ML models, pipelines, and monitoring."^^xsd:string,
        "Role dedicated to implementing and maintaining MLOps practices."^^xsd:string ;
    rdfs:subClassOf ns1:Role .

ns1:MappingStudy a owl:Class ;
    rdfs:label "Mapping Study"^^xsd:string ;
    rdfs:comment "A systematic mapping study that surveys literature to identify research trends and gaps."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork .

ns1:MediumCompany a owl:Class ;
    rdfs:label "Medium Company"^^xsd:string ;
    rdfs:comment "Software development company with 51 to 200 employees."^^xsd:string ;
    rdfs:subClassOf ns1:OrganizationSizeCategory .

ns1:ModelDeploymentProcess a owl:Class ;
    rdfs:label "Model Deployment Process"^^xsd:string ;
    rdfs:comment "Process that deploys a trained model to a target environment."^^xsd:string ;
    rdfs:subClassOf ns1:Process .

ns1:ModelEffectiveness a owl:Class ;
    rdfs:label "Model Effectiveness"^^xsd:string ;
    rdfs:comment "Overall suitability of a model for its intended operational purpose."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ModelInterpretability a owl:Class ;
    rdfs:label "Model Interpretability"^^xsd:string ;
    rdfs:comment "The degree to which a human can understand the internal mechanics of a model."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ModelQuality a owl:Class ;
    rdfs:label "Model Quality"^^xsd:string ;
    rdfs:comment "Overall measure of model accuracy, precision, and suitability."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ModelRegistry a owl:Class ;
    rdfs:label "Model Registry"^^xsd:string ;
    rdfs:comment "Centralized store for model versions and metadata."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ModelRelevance a owl:Class ;
    rdfs:label "Model Relevance"^^xsd:string ;
    rdfs:comment "Extent to which a model remains applicable to current business needs."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ModelReliability a owl:Class ;
    rdfs:label "Model Reliability"^^xsd:string ;
    rdfs:comment "Consistency of a model's performance over time."^^xsd:string,
        "Consistency of model performance over time."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ModelRobustness a owl:Class ;
    rdfs:label "Model Robustness"^^xsd:string ;
    rdfs:comment "Ability of a model to maintain performance under varying conditions."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ModelTeam a owl:Class ;
    rdfs:label "Model Team"^^xsd:string ;
    rdfs:comment "Team focused on model development and maintenance."^^xsd:string ;
    rdfs:subClassOf ns1:Role .

ns1:ModelTrainingProcess a owl:Class ;
    rdfs:label "Model Training Process"^^xsd:string ;
    rdfs:comment "Process that trains a machine learning model."^^xsd:string ;
    rdfs:subClassOf ns1:Process .

ns1:MonitoringTool a owl:Class ;
    rdfs:label "Monitoring Tool"^^xsd:string ;
    rdfs:comment "Tool used to monitor model performance and data drift."^^xsd:string ;
    rdfs:subClassOf ns1:Tool ;
    owl:sameAs ns1:ModelMonitoringProcess,
        ns1:MonitoringPractice,
        ns1:MonitoringStage .

ns1:MultidisciplinaryCollaboration a owl:Class ;
    rdfs:label "Multidisciplinary Collaboration"^^xsd:string ;
    rdfs:comment "Collaboration among professionals from different domains (e.g., data science, software engineering, domain experts) in AI projects."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:OperationalEfficiency a owl:Class ;
    rdfs:label "Operational Efficiency"^^xsd:string ;
    rdfs:comment "Improved efficiency of AI engineering operations as a benefit of MLOps."^^xsd:string ;
    rdfs:subClassOf ns1:Benefit .

ns1:OperationsExpert a owl:Class ;
    rdfs:label "Operations Expert"^^xsd:string ;
    rdfs:comment "Stakeholder responsible for deployment, monitoring, and operational reliability."^^xsd:string ;
    rdfs:subClassOf ns1:StakeholderRole .

ns1:OperationsTeam a owl:Class ;
    rdfs:label "Operations Team"^^xsd:string ;
    rdfs:comment "Team responsible for deploying and maintaining models in production."^^xsd:string ;
    rdfs:subClassOf ns1:Team .

ns1:Pipeline a owl:Class ;
    rdfs:label "Pipeline"^^xsd:string ;
    rdfs:comment "A sequence of steps that process data and/or models."^^xsd:string ;
    rdfs:subClassOf ns1:DataPipeline ;
    owl:sameAs ns1:CICDPipeline,
        ns1:JenkinsPipeline .

ns1:ProbabilisticOutput a owl:Class ;
    rdfs:label "Probabilistic Output"^^xsd:string ;
    rdfs:comment "Model output that represents probabilities or distributions."^^xsd:string ;
    rdfs:subClassOf ns1:Output ;
    owl:sameAs ns1:DeterministicOutput .

ns1:ProblemDefinitionStage a owl:Class ;
    rdfs:label "Problem Definition Stage"^^xsd:string ;
    rdfs:comment "Stage where business objectives and requirements are defined."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsStage .

ns1:ProcessChallenge a owl:Class ;
    rdfs:label "Process Challenge"^^xsd:string ;
    rdfs:comment "Challenge concerning process management in ML-enabled system development."^^xsd:string ;
    rdfs:subClassOf ns1:CollaborationChallenge .

ns1:Product a owl:Class ;
    rdfs:label "Product"^^xsd:string ;
    rdfs:comment "A deliverable that incorporates ML components for end users."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ProductOwner a owl:Class ;
    rdfs:label "Product Owner"^^xsd:string ;
    rdfs:comment "Defines product requirements and success criteria for ML solutions."^^xsd:string ;
    rdfs:subClassOf ns1:MLRole .

ns1:ProductTeam a owl:Class ;
    rdfs:label "Product Team"^^xsd:string ;
    rdfs:comment "Team representing product requirements and business value."^^xsd:string ;
    rdfs:subClassOf ns1:Role .

ns1:RequirementEngineeringPaperClassification a owl:Class ;
    rdfs:label "Requirement Engineering Paper Classification"^^xsd:string ;
    rdfs:comment "A classification scheme for requirement engineering research papers."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ResourceConstraint a owl:Class ;
    rdfs:label "Resource Constraint"^^xsd:string ;
    rdfs:comment "Limitation of resources such as compute, data, or personnel affecting AI development."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ResponsibleDevelopment a owl:Class ;
    rdfs:label "Responsible Development"^^xsd:string ;
    rdfs:comment "Practices ensuring ethical and accountable development of AI systems."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:RetrainingPractice a owl:Class ;
    rdfs:label "Retraining Practice"^^xsd:string ;
    rdfs:comment "Practice of automatically retraining models when performance degrades or data changes."^^xsd:string ;
    rdfs:subClassOf ns1:AutomationPractice .

ns1:ServerlessPlatform a owl:Class ;
    rdfs:label "Serverless Platform"^^xsd:string ;
    rdfs:comment "Cloud service providing serverless compute for training and inference."^^xsd:string ;
    rdfs:subClassOf ns1:CloudResource .

ns1:SmallCompany a owl:Class ;
    rdfs:label "Small Company"^^xsd:string ;
    rdfs:comment "Software development company with 11 to 50 employees."^^xsd:string ;
    rdfs:subClassOf ns1:OrganizationSizeCategory .

ns1:SoftSkill a owl:Class ;
    rdfs:label "Soft Skill"^^xsd:string ;
    rdfs:comment "Nonâtechnical competencies such as communication, collaboration, and adaptability."^^xsd:string ;
    rdfs:subClassOf ns1:Skill,
        prov:Entity ;
    owl:sameAs ns1:SoftCompetency .

ns1:SoftwareDeveloper a owl:Class ;
    rdfs:label "Software Developer"^^xsd:string ;
    rdfs:comment "Implements software components and integrates ML models into applications."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsRole .

ns1:SoftwareDevelopmentCompany a owl:Class ;
    rdfs:label "Software Development Company"^^xsd:string ;
    rdfs:comment "An organization that develops software, considered in the study."^^xsd:string ;
    rdfs:subClassOf prov:Agent .

ns1:SoftwareEngineer a owl:Class ;
    rdfs:label "Software Engineer"^^xsd:string ;
    rdfs:comment "Professional responsible for software development, integration, and deployment."^^xsd:string,
        "Stakeholder responsible for software development and engineering best practices."^^xsd:string ;
    rdfs:subClassOf ns1:Role,
        ns1:StakeholderRole .

ns1:SoftwareEngineeringPractice a owl:Class ;
    rdfs:label "Software Engineering Practice"^^xsd:string ;
    rdfs:comment "A practice within software engineering, such as testing, version control, or code review."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:Stakeholder a owl:Class ;
    rdfs:label "Stakeholder"^^xsd:string ;
    rdfs:comment "Any party with interest in the AI system's outcomes."^^xsd:string ;
    rdfs:subClassOf ns1:Role .

ns1:Standardization a owl:Class ;
    rdfs:label "Standardization"^^xsd:string ;
    rdfs:comment "Process of establishing common standards for development processes."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsPractice .

ns1:TPU a owl:Class ;
    rdfs:label "TPU"^^xsd:string ;
    rdfs:comment "Tensor Processing Unit used to accelerate model training."^^xsd:string ;
    rdfs:subClassOf ns1:Hardware .

ns1:TalentShortageChallenge a owl:Class ;
    rdfs:label "Talent Shortage Challenge"^^xsd:string ;
    rdfs:comment "Lack of specialized MLOps talent within an organization."^^xsd:string ;
    rdfs:subClassOf ns1:Challenge .

ns1:TrainingStage a owl:Class ;
    rdfs:label "Training Stage"^^xsd:string ;
    rdfs:comment "Stage where model training runs are executed."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsStage ;
    owl:sameAs ns1:ContinuousTraining,
        ns1:ContinuousTrainingStage .

ns1:ValidationPractice a owl:Class ;
    rdfs:label "Validation Practice"^^xsd:string ;
    rdfs:comment "Systematic validation of model outputs and data to ensure correctness."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsPractice .

ns1:addressesChallenge a owl:ObjectProperty ;
    rdfs:label "addresses challenge"^^xsd:string ;
    rdfs:comment "Indicates that a practice or activity addresses a specific challenge in AI engineering."^^xsd:string,
        "Indicates that a process or practice mitigates a specific challenge."^^xsd:string,
        "Indicates that a success factor addresses a specific MLOps challenge."^^xsd:string,
        "The paper discusses or proposes solutions for a specific MLOps challenge."^^xsd:string ;
    rdfs:domain ns1:MLOpsCriticalSuccessFactor,
        ns1:MLOpsProcess,
        ns1:ResearchPaper,
        prov:Activity ;
    rdfs:range ns1:Challenge,
        ns1:MLOpsChallenge .

ns1:addressesResearchQuestion a owl:ObjectProperty ;
    rdfs:label "addresses research question"^^xsd:string ;
    rdfs:comment "Indicates that a document or study addresses a specific research question."^^xsd:string ;
    rdfs:domain prov:Entity ;
    rdfs:range ns1:ResearchQuestion .

ns1:allows a owl:ObjectProperty ;
    rdfs:label "allows"^^xsd:string ;
    rdfs:comment "Indicates that a practice enables a capability."^^xsd:string ;
    rdfs:domain ns1:MLOpsPractice ;
    rdfs:range prov:Entity .

ns1:appliesFilter a owl:ObjectProperty ;
    rdfs:label "applies filter"^^xsd:string ;
    rdfs:comment "A search strategy applies a filter constraint."^^xsd:string ;
    rdfs:domain ns1:SearchStrategy ;
    rdfs:range ns1:Filter .

ns1:appliesProgrammingPractice a owl:ObjectProperty ;
    rdfs:label "applies programming practice"^^xsd:string ;
    rdfs:comment "Associates a development activity with a programming practice principle."^^xsd:string ;
    rdfs:domain prov:Activity ;
    rdfs:range ns1:ProgrammingPracticePrinciple .

ns1:appliesToPaper a owl:ObjectProperty ;
    rdfs:label "applies to paper"^^xsd:string ;
    rdfs:comment "Indicates that a criterion applies to a specific paper."^^xsd:string ;
    rdfs:domain ns1:InclusionCriterion ;
    rdfs:range ns1:Paper .

ns1:assessesMaturity a owl:ObjectProperty ;
    rdfs:label "assesses maturity"^^xsd:string ;
    rdfs:comment "An agent (e.g., organization) uses a framework to assess its MLOps maturity level."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:MLOpsMaturityLevel .

ns1:associatedWithMaturityLevel a owl:ObjectProperty ;
    rdfs:label "associated with maturity level"^^xsd:string ;
    rdfs:comment "Links the MLOps discipline to its current maturity level."^^xsd:string ;
    rdfs:domain ns1:MLOpsDiscipline ;
    rdfs:range ns1:MaturityLevel .

ns1:causesPerformanceDegradation a owl:ObjectProperty ;
    rdfs:label "causes performance degradation"^^xsd:string ;
    rdfs:comment "Data drift can cause performance degradation of a model."^^xsd:string ;
    rdfs:domain ns1:DataDrift ;
    rdfs:range ns1:PerformanceDegradation ;
    rdfs:subPropertyOf prov:wasInfluencedBy .

ns1:cites a owl:ObjectProperty ;
    rdfs:label "cites"^^xsd:string ;
    rdfs:comment "Indicates that a research paper cites another paper."^^xsd:string ;
    rdfs:domain ns1:ResearchPaper ;
    rdfs:range ns1:ResearchPaper ;
    rdfs:subPropertyOf dcterms:references .

ns1:collaboratesWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "collaborates with"^^xsd:string ;
    rdfs:comment "Indicates collaboration between two roles."^^xsd:string ;
    rdfs:domain ns1:MLOpsRole ;
    rdfs:range ns1:MLOpsRole .

ns1:contributesTo a owl:ObjectProperty ;
    rdfs:label "contributes to"^^xsd:string ;
    rdfs:comment "Indicates that a practice contributes to a desired model attribute."^^xsd:string ;
    rdfs:domain ns1:MLOpsPractice ;
    rdfs:range prov:Entity .

ns1:contributesToChallenge a owl:ObjectProperty ;
    rdfs:label "contributes to challenge"^^xsd:string ;
    rdfs:comment "A complexity factor that contributes to a particular challenge category."^^xsd:string ;
    rdfs:domain ns1:ComplexityFactor ;
    rdfs:range ns1:ChallengeCategory .

ns1:definesLevel a owl:ObjectProperty ;
    rdfs:label "defines level"^^xsd:string ;
    rdfs:comment "A benchmark defines a specific maturity level."^^xsd:string ;
    rdfs:domain ns1:MLOpsBenchmark ;
    rdfs:range ns1:MLOpsMaturityLevel .

ns1:definesQualityCriteria a owl:ObjectProperty ;
    rdfs:label "defines quality criteria"^^xsd:string ;
    rdfs:comment "Specifies quality criteria for study selection."^^xsd:string ;
    rdfs:domain ns1:SearchObjective ;
    rdfs:range ns1:QualityCriteria .

ns1:definesRole a owl:ObjectProperty ;
    rdfs:label "defines role"^^xsd:string ;
    rdfs:comment "Relates an organization or process to a specific MLOps role."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:MLOpsRole .

ns1:describesMaturityModel a owl:ObjectProperty ;
    rdfs:label "describes maturity model"^^xsd:string ;
    rdfs:comment "Links a study to a maturity model it describes."^^xsd:string ;
    rdfs:domain ns1:MLOpsStudy ;
    rdfs:range ns1:MaturityModel .

ns1:detectsDrift a owl:ObjectProperty ;
    rdfs:label "detects drift"^^xsd:string ;
    rdfs:comment "Monitoring job identifies a drift condition."^^xsd:string ;
    rdfs:domain ns1:MonitoringJob ;
    rdfs:range ns1:Drift ;
    owl:sameAs ns1:detectsDataDrift,
        ns1:hasModelDrift .

ns1:emitsEvent a owl:ObjectProperty ;
    rdfs:label "emits event" ;
    rdfs:comment "Monitoring job can emit events such as data drift detection." ;
    rdfs:domain ns1:MonitoringJob ;
    rdfs:range ns1:Event .

ns1:enables a owl:ObjectProperty ;
    rdfs:label "enables"^^xsd:string ;
    rdfs:comment "Indicates that a practice enables a capability or process."^^xsd:string ;
    rdfs:domain prov:Activity ;
    rdfs:range prov:Activity .

ns1:encourages a owl:ObjectProperty ;
    rdfs:label "encourages"^^xsd:string ;
    rdfs:comment "Indicates that a practice encourages a certain outcome or concept."^^xsd:string ;
    rdfs:domain ns1:MLOpsPractice ;
    rdfs:range prov:Entity .

ns1:ensuresConfidentiality a owl:ObjectProperty ;
    rdfs:label "ensures confidentiality"^^xsd:string ;
    rdfs:comment "Process ensures that confidential data is protected."^^xsd:string ;
    rdfs:domain prov:Activity ;
    rdfs:range ns1:ConfidentialData .

ns1:evaluatesMaturityModel a owl:ObjectProperty ;
    rdfs:label "evaluates maturity model"^^xsd:string ;
    rdfs:comment "The paper evaluates or proposes an MLOps maturity model."^^xsd:string ;
    rdfs:domain ns1:ResearchPaper ;
    rdfs:range ns1:MLOpsMaturityModel .

ns1:excludesPaper a owl:ObjectProperty ;
    rdfs:label "excludes paper"^^xsd:string ;
    rdfs:comment "Indicates that an exclusion criterion excludes a specific paper."^^xsd:string ;
    rdfs:domain ns1:ExclusionCriterion ;
    rdfs:range ns1:Paper .

ns1:feedsDataPipeline a owl:ObjectProperty ;
    rdfs:label "feeds data pipeline" ;
    rdfs:comment "Model provides data to a pipeline for further processing." ;
    rdfs:domain ns1:MLModel ;
    rdfs:range ns1:DataPipeline .

ns1:followsMethodology a owl:ObjectProperty ;
    rdfs:label "follows methodology"^^xsd:string ;
    rdfs:comment "Indicates that a process follows a given methodology."^^xsd:string ;
    rdfs:domain ns1:Process ;
    rdfs:range ns1:Methodology ;
    rdfs:subPropertyOf ns1:hasMethodology .

ns1:hasAdoptionBenefit a owl:ObjectProperty ;
    rdfs:label "has adoption benefit" ;
    rdfs:comment "Links an MLOps adoption instance to a benefit realized." ;
    rdfs:domain ns1:Adoption ;
    rdfs:range ns1:MLOpsAdoptionBenefit .

ns1:hasAdoptionBenefitCategory a owl:ObjectProperty ;
    rdfs:label "has adoption benefit category" ;
    rdfs:comment "Associates an adoption case with a benefit category." ;
    rdfs:domain ns1:Adoption ;
    rdfs:range ns1:BenefitCategory .

ns1:hasAdoptionChallenge a owl:ObjectProperty ;
    rdfs:label "has adoption challenge" ;
    rdfs:comment "Links an MLOps adoption instance to a challenge encountered." ;
    rdfs:domain ns1:Adoption ;
    rdfs:range ns1:MLOpsAdoptionChallenge .

ns1:hasAdoptionChallengeCategory a owl:ObjectProperty ;
    rdfs:label "has adoption challenge category" ;
    rdfs:comment "Associates an adoption case with a challenge category." ;
    rdfs:domain ns1:Adoption ;
    rdfs:range ns1:ChallengeCategory .

ns1:hasAdoptionFactor a owl:ObjectProperty ;
    rdfs:label "has adoption factor"^^xsd:string ;
    rdfs:comment "Factor influencing MLOps adoption."^^xsd:string ;
    rdfs:domain ns1:Adoption ;
    rdfs:range ns1:AdoptionFactor .

ns1:hasArtifact a owl:ObjectProperty ;
    rdfs:label "has artifact"^^xsd:string ;
    rdfs:comment "Links a process to an artifact it produces."^^xsd:string ;
    rdfs:domain ns1:Process ;
    rdfs:range ns1:Artifact ;
    owl:sameAs ns1:producesArtifact .

ns1:hasAuthor a owl:ObjectProperty ;
    rdfs:label "has author"^^xsd:string ;
    rdfs:comment "Relates a research paper to its author(s)."^^xsd:string ;
    rdfs:domain ns1:ResearchPaper ;
    rdfs:range ns1:Author ;
    rdfs:subPropertyOf dcterms:creator .

ns1:hasAutomationDegree a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has automation degree"^^xsd:string ;
    rdfs:comment "Numeric representation of automation intensity for a maturity level (e.g., 0-4)."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityLevel ;
    rdfs:range xsd:integer .

ns1:hasAutomationPrinciple a owl:ObjectProperty ;
    rdfs:label "has automation principle"^^xsd:string ;
    rdfs:comment "Links a maturity level to an automation principle it embodies."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityLevel ;
    rdfs:range ns1:AutomationPrinciple .

ns1:hasBenchmark a owl:ObjectProperty ;
    rdfs:label "has benchmark"^^xsd:string ;
    rdfs:comment "Associates a maturity framework with external benchmark definitions."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityFramework ;
    rdfs:range ns1:MLOpsBenchmark .

ns1:hasBenefit a owl:ObjectProperty ;
    rdfs:label "has benefit"^^xsd:string ;
    rdfs:comment "Adoption yields a specific benefit."^^xsd:string,
        "Associates a study or adoption case with a reported benefit."^^xsd:string,
        "Links an MLOps practice to a reported benefit."^^xsd:string ;
    rdfs:domain ns1:Adoption,
        ns1:MLOpsPractice,
        prov:Entity ;
    rdfs:range ns1:Benefit,
        ns1:MLOpsBenefit .

ns1:hasBenefitCategory a owl:ObjectProperty ;
    rdfs:label "has benefit category"^^xsd:string ;
    rdfs:comment "Relates the MLOps discipline to a specific benefit category."^^xsd:string ;
    rdfs:domain ns1:MLOpsDiscipline ;
    rdfs:range ns1:BenefitCategory .

ns1:hasBestPractice a owl:ObjectProperty ;
    rdfs:label "has best practice"^^xsd:string ;
    rdfs:comment "Links a study to a best practice it reports."^^xsd:string ;
    rdfs:domain ns1:MLOpsStudy ;
    rdfs:range ns1:BestPractice .

ns1:hasChallenge a owl:ObjectProperty ;
    rdfs:label "has challenge"^^xsd:string ;
    rdfs:comment "Adoption faces a specific challenge."^^xsd:string,
        "Associates a study or adoption case with a reported challenge."^^xsd:string,
        "Links an AI system or project to a challenge it faces."^^xsd:string,
        "Links an MLOps practice to a reported challenge."^^xsd:string ;
    rdfs:domain ns1:Adoption,
        ns1:MLOpsPractice,
        prov:Entity ;
    rdfs:range ns1:Challenge,
        ns1:MLOpsChallenge .

ns1:hasChallengeCategory a owl:ObjectProperty ;
    rdfs:label "has challenge category"^^xsd:string ;
    rdfs:comment "Relates the MLOps discipline to a specific challenge category."^^xsd:string ;
    rdfs:domain ns1:MLOpsDiscipline ;
    rdfs:range ns1:ChallengeCategory .

ns1:hasCollaborationAspect a owl:ObjectProperty ;
    rdfs:label "has collaboration aspect"^^xsd:string ;
    rdfs:comment "Links a maturity framework to collaboration aspects considered."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityFramework ;
    rdfs:range ns1:CollaborationAspect .

ns1:hasComplexityFactor a owl:ObjectProperty ;
    rdfs:label "has complexity factor"^^xsd:string ;
    rdfs:comment "Associates the MLOps discipline with a factor contributing to its complexity."^^xsd:string ;
    rdfs:domain ns1:MLOpsDiscipline ;
    rdfs:range ns1:ComplexityFactor .

ns1:hasCost a owl:DatatypeProperty ;
    rdfs:label "has cost"^^xsd:string ;
    schema1:unitCode "USD"^^xsd:string ;
    rdfs:comment "Monetary cost associated with a process or implementation."^^xsd:string ;
    rdfs:domain ns1:Process ;
    rdfs:range xsd:decimal ;
    owl:sameAs ns1:costEffective,
        ns1:hasComputationalCost .

ns1:hasCulturalAspect a owl:ObjectProperty ;
    rdfs:label "has cultural aspect"^^xsd:string ;
    rdfs:comment "Links a maturity framework to cultural aspects considered."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityFramework ;
    rdfs:range ns1:CulturalAspect ;
    owl:sameAs ns1:hasOrganizationalCulture .

ns1:hasCustomerInvolvement a owl:DatatypeProperty ;
    rdfs:label "has customer involvement"^^xsd:string ;
    rdfs:comment "Indicates whether customers are involved in a given MLOps phase."^^xsd:string ;
    rdfs:domain ns1:MLOpsPhase ;
    rdfs:range xsd:boolean ;
    owl:sameAs ns1:hasDataScientistInvolvement .

ns1:hasDataManagement a owl:ObjectProperty ;
    rdfs:label "has data management"^^xsd:string ;
    rdfs:comment "Associates a project with its data management activities."^^xsd:string ;
    rdfs:domain prov:Entity ;
    rdfs:range ns1:DataManagement .

ns1:hasDataOpsConcept a owl:ObjectProperty ;
    rdfs:label "has DataOps concept"^^xsd:string ;
    rdfs:comment "Links a maturity framework to DataOps concepts it includes."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityFramework ;
    rdfs:range ns1:DataOpsConcept .

ns1:hasDataPrivacyPolicy a owl:ObjectProperty ;
    rdfs:label "has data privacy policy"^^xsd:string ;
    rdfs:comment "Links an AI system or model to its governing data privacy policy."^^xsd:string ;
    rdfs:domain ns1:MLModel ;
    rdfs:range ns1:DataPrivacyPolicy .

ns1:hasDegradation a owl:ObjectProperty ;
    rdfs:label "has degradation"^^xsd:string ;
    rdfs:comment "Indicates that a model version experiences performance degradation over time."^^xsd:string ;
    rdfs:domain ns1:ModelVersion ;
    rdfs:range ns1:ModelDegradation .

ns1:hasDeploymentEnvironment a owl:ObjectProperty ;
    rdfs:label "has deployment environment"^^xsd:string ;
    rdfs:comment "Specifies the environment where a model version is deployed."^^xsd:string ;
    rdfs:domain ns1:ModelVersion ;
    rdfs:range ns1:DeploymentEnvironment ;
    rdfs:subPropertyOf ns1:deployedTo .

ns1:hasDeploymentStrategy a owl:ObjectProperty ;
    rdfs:label "has deployment strategy" ;
    rdfs:comment "Specifies the strategy used to deploy a model version." ;
    rdfs:domain ns1:ModelVersion ;
    rdfs:range ns1:DeploymentStrategy .

ns1:hasDimension a owl:ObjectProperty ;
    rdfs:label "has dimension"^^xsd:string ;
    rdfs:comment "Links a maturity framework to one of its evaluation dimensions."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityFramework ;
    rdfs:range ns1:MLOpsDimension .

ns1:hasEducationProgram a owl:ObjectProperty ;
    rdfs:label "has education program"^^xsd:string ;
    rdfs:comment "Links an organization to an MLOps education program."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:EducationProgram .

ns1:hasEthicalConsideration a owl:ObjectProperty ;
    rdfs:label "has ethical consideration"^^xsd:string ;
    rdfs:comment "Links a project to ethical considerations taken into account."^^xsd:string ;
    rdfs:domain prov:Entity ;
    rdfs:range ns1:EthicalConsideration .

ns1:hasExclusionCriterion a owl:ObjectProperty ;
    rdfs:label "has exclusion criterion"^^xsd:string ;
    rdfs:comment "Links a selection process to an exclusion criterion."^^xsd:string ;
    rdfs:domain ns1:SelectionProcess ;
    rdfs:range ns1:ExclusionCriterion .

ns1:hasExpectationManagement a owl:ObjectProperty ;
    rdfs:label "has expectation management"^^xsd:string ;
    rdfs:comment "Associates a project with activities that manage stakeholder expectations."^^xsd:string ;
    rdfs:domain prov:Entity ;
    rdfs:range ns1:ExpectationManagement .

ns1:hasExperimentationProcess a owl:ObjectProperty ;
    rdfs:label "has experimentation process"^^xsd:string ;
    rdfs:comment "Associates a project with its experimentation process."^^xsd:string ;
    rdfs:domain prov:Entity ;
    rdfs:range ns1:ExperimentationProcess .

ns1:hasExperimentationTime a owl:DatatypeProperty ;
    rdfs:label "has experimentation time"^^xsd:string ;
    schema1:unitCode "DAY"^^xsd:string ;
    rdfs:comment "Amount of time allocated at the start of a project for experimentation, expressed in days."^^xsd:string ;
    rdfs:domain ns1:MLOpsPhase ;
    rdfs:range xsd:duration .

ns1:hasGoal a owl:ObjectProperty ;
    rdfs:label "has goal"^^xsd:string ;
    rdfs:comment "Links a GQM paradigm to its goal."^^xsd:string,
        "Links a research question to a GQM goal."^^xsd:string ;
    rdfs:domain ns1:GoalQuestionMetricParadigm,
        ns1:ResearchQuestion ;
    rdfs:range ns1:Goal .

ns1:hasInclusionCriterion a owl:ObjectProperty ;
    rdfs:label "has inclusion criterion"^^xsd:string ;
    rdfs:comment "Links a selection process to an inclusion criterion."^^xsd:string ;
    rdfs:domain ns1:SelectionProcess ;
    rdfs:range ns1:InclusionCriterion .

ns1:hasInfrastructure a owl:ObjectProperty ;
    rdfs:label "has infrastructure"^^xsd:string ;
    rdfs:comment "Links an MLOps process to required infrastructure components."^^xsd:string ;
    rdfs:domain ns1:MLOpsProcess ;
    rdfs:range ns1:InfrastructureComponent .

ns1:hasInterpretabilityScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has interpretability score"^^xsd:string ;
    rdfs:comment "Numeric score representing model interpretability."^^xsd:string ;
    rdfs:domain ns1:MLModel ;
    rdfs:range xsd:float .

ns1:hasLegalCompliance a owl:ObjectProperty ;
    rdfs:label "has legal compliance"^^xsd:string ;
    rdfs:comment "Links a project to legal compliance artifacts or activities."^^xsd:string ;
    rdfs:domain prov:Entity ;
    rdfs:range ns1:LegalCompliance .

ns1:hasMLOpsMaturityAttribute a owl:ObjectProperty ;
    rdfs:label "has MLOps maturity attribute" ;
    rdfs:comment "Links a maturity level to an attribute used for assessment." ;
    rdfs:domain ns1:MLOpsMaturityLevel ;
    rdfs:range ns1:MLOpsMaturityAttribute .

ns1:hasMLOpsMaturityBenefit a owl:ObjectProperty ;
    rdfs:label "has MLOps maturity benefit" ;
    rdfs:comment "Links a maturity level to a benefit associated with that level." ;
    rdfs:domain ns1:MLOpsMaturityLevel ;
    rdfs:range ns1:MLOpsMaturityBenefit .

ns1:hasMLOpsMaturityChallenge a owl:ObjectProperty ;
    rdfs:label "has MLOps maturity challenge" ;
    rdfs:comment "Links a maturity level to a challenge associated with that level." ;
    rdfs:domain ns1:MLOpsMaturityLevel ;
    rdfs:range ns1:MLOpsMaturityChallenge .

ns1:hasMLOpsMaturityDimension a owl:ObjectProperty ;
    rdfs:label "has MLOps maturity dimension" ;
    rdfs:comment "Links a maturity level to a dimension considered in the maturity model." ;
    rdfs:domain ns1:MLOpsMaturityLevel ;
    rdfs:range ns1:MLOpsDimension .

ns1:hasMLOpsParadigm a owl:ObjectProperty ;
    rdfs:label "has MLOps paradigm"^^xsd:string ;
    rdfs:comment "Links a project or organization to the MLOps paradigm it adopts."^^xsd:string ;
    rdfs:domain ns1:MLProject ;
    rdfs:range ns1:MLOpsParadigm .

ns1:hasMLOpsPractice a owl:ObjectProperty ;
    rdfs:label "has MLOps practice"^^xsd:string ;
    rdfs:comment "Links a project or pipeline to an MLOps practice employed."^^xsd:string,
        "The paper describes a particular MLOps practice."^^xsd:string ;
    rdfs:domain ns1:ResearchPaper,
        prov:Entity ;
    rdfs:range ns1:MLOpsPractice .

ns1:hasMLOpsProcess a owl:ObjectProperty ;
    rdfs:label "has MLOps process"^^xsd:string ;
    rdfs:comment "Links the MLOps concept to a specific practice or process."^^xsd:string ;
    rdfs:domain ns1:MLOps ;
    rdfs:range ns1:MLOpsPractice .

ns1:hasMaintenanceStrategy a owl:ObjectProperty ;
    rdfs:label "has maintenance strategy"^^xsd:string ;
    rdfs:comment "Specifies the strategy applied during model maintenance."^^xsd:string ;
    rdfs:domain ns1:MaintenanceProcess ;
    rdfs:range ns1:MaintenanceStrategy .

ns1:hasMaturityLevel a owl:DatatypeProperty,
        owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has maturity level"^^xsd:string ;
    rdfs:comment "Associates a maturity framework with a specific maturity level."^^xsd:string,
        "Associates a maturity model with its levels."^^xsd:string,
        "Links a maturity model to one of its levels."^^xsd:string,
        "Numeric or categorical indicator of MLOps maturity."^^xsd:string,
        "Organization's MLOps maturity level."^^xsd:string,
        "Relates an MLOps maturity model to one of its defined maturity levels."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityFramework,
        ns1:MLOpsMaturityModel,
        ns1:MaturityModel,
        ns1:Organization ;
    rdfs:range ns1:MLOpsMaturityLevel,
        ns1:MaturityLevel,
        xsd:string .

ns1:hasMaturityModel a owl:ObjectProperty ;
    rdfs:label "has maturity model"^^xsd:string ;
    rdfs:comment "Associates an organization or context with a maturity model."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:MaturityModel .

ns1:hasMetric a owl:DatatypeProperty,
        owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has metric"^^xsd:string,
        "has metric" ;
    rdfs:comment "Associates a goal with a metric."^^xsd:string,
        "Performance metric value associated with a model version." ;
    rdfs:domain ns1:Goal,
        ns1:ModelVersion ;
    rdfs:range ns1:Metric,
        xsd:float .

ns1:hasMetricDefinition a owl:ObjectProperty ;
    rdfs:label "has metric definition"^^xsd:string ;
    rdfs:comment "Links a GQM paradigm to its metric definition."^^xsd:string ;
    rdfs:domain ns1:GoalQuestionMetricParadigm ;
    rdfs:range ns1:Metric .

ns1:hasMonitoringStrategy a owl:ObjectProperty ;
    rdfs:label "has monitoring strategy"^^xsd:string ;
    rdfs:comment "Specifies the strategy used by a monitoring job."^^xsd:string ;
    rdfs:domain ns1:MonitoringJob ;
    rdfs:range ns1:MonitoringStrategy .

ns1:hasMotivation a owl:DatatypeProperty ;
    rdfs:label "has motivation"^^xsd:string ;
    rdfs:comment "Narrative explaining why a research question is posed."^^xsd:string ;
    rdfs:domain ns1:ResearchQuestion ;
    rdfs:range xsd:string .

ns1:hasProcess a owl:ObjectProperty ;
    rdfs:label "has process"^^xsd:string ;
    rdfs:comment "Associates a project with its highâlevel processes."^^xsd:string ;
    rdfs:domain ns1:MLProject ;
    rdfs:range ns1:Process ;
    owl:sameAs ns1:performsProcess .

ns1:hasProvenanceRecord a owl:ObjectProperty ;
    rdfs:label "has provenance record" ;
    rdfs:comment "Links a model version to its provenance metadata." ;
    rdfs:domain ns1:ModelVersion ;
    rdfs:range prov:Entity .

ns1:hasPublicationVenue a owl:ObjectProperty ;
    rdfs:label "has publication venue"^^xsd:string ;
    rdfs:comment "The organization (journal, conference) where the paper was published."^^xsd:string ;
    rdfs:domain ns1:ResearchPaper ;
    rdfs:range ns1:ProfessionalOrganization .

ns1:hasQuestion a owl:ObjectProperty ;
    rdfs:label "has question"^^xsd:string ;
    rdfs:comment "Links a GQM paradigm to its question."^^xsd:string ;
    rdfs:domain ns1:GoalQuestionMetricParadigm ;
    rdfs:range ns1:Question .

ns1:hasResearchProtocol a owl:ObjectProperty ;
    rdfs:label "has research protocol"^^xsd:string ;
    rdfs:comment "Links a systematic literature review to its research protocol."^^xsd:string ;
    rdfs:domain ns1:SystematicLiteratureReview ;
    rdfs:range ns1:ResearchProtocol .

ns1:hasResearchQuestion a owl:ObjectProperty ;
    rdfs:label "has research question"^^xsd:string ;
    rdfs:comment "Associates a research protocol or review with a research question."^^xsd:string,
        "Links a study or search strategy to a research question."^^xsd:string ;
    rdfs:domain ns1:ResearchProtocol,
        ns1:SearchStrategy ;
    rdfs:range ns1:ResearchQuestion .

ns1:hasResourceManagement a owl:ObjectProperty ;
    rdfs:label "has resource management"^^xsd:string ;
    rdfs:comment "Associates a project with its resource management activities."^^xsd:string ;
    rdfs:domain prov:Entity ;
    rdfs:range ns1:ResourceManagement .

ns1:hasResponsibility a owl:DatatypeProperty ;
    rdfs:label "has responsibility"^^xsd:string ;
    rdfs:comment "Describes the responsibility of a role in textual form."^^xsd:string ;
    rdfs:domain ns1:MLOpsRole ;
    rdfs:range xsd:string .

ns1:hasReviewLevel a owl:ObjectProperty ;
    rdfs:label "has review level"^^xsd:string ;
    rdfs:comment "Specifies the review level at which a paper was evaluated."^^xsd:string ;
    rdfs:domain ns1:Paper ;
    rdfs:range ns1:ReviewLevel .

ns1:hasRobustnessScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has robustness score"^^xsd:string ;
    rdfs:comment "Numeric score indicating model robustness."^^xsd:string ;
    rdfs:domain ns1:ModelVersion ;
    rdfs:range xsd:float .

ns1:hasRole a owl:ObjectProperty ;
    rdfs:label "has role"^^xsd:string ;
    rdfs:comment "Assigns a role to an agent within a project."^^xsd:string,
        "Associates an agent with an ML role."^^xsd:string,
        "Associates an agent with an MLOps role."^^xsd:string,
        "Links an agent to a role it performs."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:MLOpsRole,
        ns1:MLRole,
        ns1:Role .

ns1:hasSearchObjective a owl:ObjectProperty ;
    rdfs:label "has search objective"^^xsd:string ;
    rdfs:comment "Links a systematic review to its search objectives."^^xsd:string ;
    rdfs:domain ns1:SystematicLiteratureReview ;
    rdfs:range ns1:SearchObjective .

ns1:hasSearchPeriod a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has search period"^^xsd:string ;
    rdfs:comment "Temporal interval during which literature search was performed."^^xsd:string ;
    rdfs:domain ns1:SearchStrategy ;
    rdfs:range xsd:string .

ns1:hasSecurityManagement a owl:ObjectProperty ;
    rdfs:label "has security management"^^xsd:string ;
    rdfs:comment "Associates an organization or system with its security management practices."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:SecurityManagement .

ns1:hasSkillGap a owl:ObjectProperty ;
    rdfs:label "has skill gap"^^xsd:string ;
    rdfs:comment "Indicates a missing skill within an organization."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:SkillGap ;
    owl:sameAs ns1:requiresSkill .

ns1:hasSoftCompetency a owl:ObjectProperty ;
    rdfs:label "has soft competency"^^xsd:string ;
    rdfs:comment "Specifies a soft competency required for a role."^^xsd:string ;
    rdfs:domain ns1:Role ;
    rdfs:range ns1:SoftCompetency ;
    rdfs:subPropertyOf ns1:hasCompetency .

ns1:hasStage a owl:ObjectProperty ;
    rdfs:label "has stage"^^xsd:string ;
    rdfs:comment "Associates an MLOps process with a particular stage."^^xsd:string ;
    rdfs:domain ns1:MLOpsProcess ;
    rdfs:range ns1:MLOpsStage .

ns1:hasTask a owl:ObjectProperty ;
    rdfs:label "has task"^^xsd:string ;
    rdfs:comment "Associates a process with its constituent tasks."^^xsd:string ;
    rdfs:domain ns1:Process ;
    rdfs:range ns1:Task .

ns1:hasTechnicalCompetency a owl:ObjectProperty ;
    rdfs:label "has technical competency"^^xsd:string ;
    rdfs:comment "Specifies a technical competency required for a role."^^xsd:string ;
    rdfs:domain ns1:Role ;
    rdfs:range ns1:TechnicalCompetency ;
    rdfs:subPropertyOf ns1:hasCompetency .

ns1:hasTool a owl:ObjectProperty ;
    rdfs:label "has tool"^^xsd:string ;
    rdfs:comment "Indicates a tool used in a process or task."^^xsd:string ;
    rdfs:domain ns1:Process ;
    rdfs:range ns1:Tool .

ns1:hasTrainingRun a owl:ObjectProperty ;
    rdfs:label "has training run" ;
    rdfs:comment "Links a model to the training run that produced it." ;
    rdfs:domain ns1:MLModel ;
    rdfs:range ns1:TrainingRun ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

ns1:hasTrustMetric a owl:ObjectProperty ;
    rdfs:label "has trust metric"^^xsd:string ;
    rdfs:comment "Connects a stakeholder or system to a quantitative trust metric."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:TrustMetric .

ns1:hasUncertaintyLevel a owl:ObjectProperty ;
    rdfs:label "has uncertainty level"^^xsd:string ;
    rdfs:comment "Indicates the level of uncertainty associated with an entity."^^xsd:string ;
    rdfs:domain ns1:SME ;
    rdfs:range ns1:UncertaintyLevel .

ns1:hasVersionIdentifier a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has version identifier" ;
    rdfs:comment "Unique identifier for a model version." ;
    rdfs:domain ns1:ModelVersion ;
    rdfs:range xsd:string .

ns1:identifiesBenefit a owl:ObjectProperty ;
    rdfs:label "identifies benefit" ;
    rdfs:comment "Relates a study to a benefit it identifies." ;
    rdfs:domain ns1:MLOpsAdoptionStudy ;
    rdfs:range ns1:MLOpsAdoptionBenefit .

ns1:identifiesChallenge a owl:ObjectProperty ;
    rdfs:label "identifies challenge"^^xsd:string ;
    rdfs:comment "Relates a study to a challenge it identifies."^^xsd:string ;
    rdfs:domain ns1:MLOpsStudy ;
    rdfs:range ns1:MLOpsChallenge .

ns1:identifiesOpportunity a owl:ObjectProperty ;
    rdfs:label "identifies opportunity"^^xsd:string ;
    rdfs:comment "Relates a study to an opportunity it identifies."^^xsd:string ;
    rdfs:domain ns1:MLOpsStudy ;
    rdfs:range ns1:MLOpsOpportunity .

ns1:includesPractice a owl:ObjectProperty ;
    rdfs:label "includes practice"^^xsd:string ;
    rdfs:comment "Associates a maturity level with the automation practices it encompasses."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityLevel ;
    rdfs:range ns1:AutomationPractice ;
    rdfs:subPropertyOf prov:used .

ns1:incursSocialDebt a owl:ObjectProperty ;
    rdfs:label "incurs social debt"^^xsd:string ;
    rdfs:comment "Activity results in social debt."^^xsd:string ;
    rdfs:domain prov:Activity ;
    rdfs:range ns1:SocialDebt ;
    owl:sameAs ns1:incursTechnicalDebt,
        ns1:mitigatesTechnicalDebt .

ns1:influencedByResearchBias a owl:ObjectProperty ;
    rdfs:label "influenced by research bias"^^xsd:string ;
    rdfs:comment "Indicates that literature bias affects the perception of challenges or benefits."^^xsd:string ;
    rdfs:domain ns1:MLOpsDiscipline ;
    rdfs:range ns1:ResearchBias .

ns1:involvesRole a owl:ObjectProperty ;
    rdfs:label "involves role"^^xsd:string ;
    rdfs:comment "An activity or phase includes participation of a specific role."^^xsd:string,
        "Specifies a role that is implicated in a given MLOps adoption challenge."^^xsd:string ;
    rdfs:domain ns1:MLOpsAdoptionChallenge,
        prov:Activity ;
    rdfs:range ns1:Role .

ns1:involvesStakeholder a owl:ObjectProperty ;
    rdfs:label "involves stakeholder"^^xsd:string ;
    rdfs:comment "Links an MLOps principle to the stakeholder roles required for its realization."^^xsd:string ;
    rdfs:domain ns1:MLOpsPrinciple ;
    rdfs:range ns1:StakeholderRole .

ns1:isGeneralPurpose a owl:DatatypeProperty ;
    rdfs:label "is general purpose"^^xsd:string ;
    rdfs:comment "Specifies whether a tool is a generalâpurpose platform."^^xsd:string ;
    rdfs:domain ns1:Tool ;
    rdfs:range xsd:boolean .

ns1:isMLSpecific a owl:DatatypeProperty ;
    rdfs:label "is ML specific"^^xsd:string ;
    rdfs:comment "Specifies whether a tool is specialized for machine learning workflows."^^xsd:string ;
    rdfs:domain ns1:Tool ;
    rdfs:range xsd:boolean .

ns1:isSimilarTo a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is similar to"^^xsd:string ;
    rdfs:comment "Indicates similarity between paradigms."^^xsd:string ;
    rdfs:domain ns1:MLOpsParadigm ;
    rdfs:range ns1:DevOpsParadigm .

ns1:levelDescription a owl:DatatypeProperty ;
    rdfs:label "level description"^^xsd:string ;
    rdfs:comment "Humanâreadable description of what the maturity level entails."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityLevel,
        ns1:MaturityLevel ;
    rdfs:range xsd:string .

ns1:levelIdentifier a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "level identifier"^^xsd:string ;
    rdfs:comment "Identifier (e.g., numeric or textual) for a maturity level."^^xsd:string ;
    rdfs:domain ns1:MaturityLevel ;
    rdfs:range xsd:string .

ns1:levelNumber a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "level number"^^xsd:string ;
    rdfs:comment "Numeric identifier of a maturity level."^^xsd:string,
        "Numeric identifier of the maturity level (e.g., 0,1,2,3,4)."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityLevel,
        ns1:MaturityLevel ;
    rdfs:range xsd:integer .

ns1:maintainsModel a owl:ObjectProperty ;
    rdfs:label "maintains model"^^xsd:string ;
    rdfs:comment "Model maintenance activity maintains a specific model version."^^xsd:string ;
    rdfs:domain ns1:ModelMaintenance ;
    rdfs:range ns1:ModelVersion ;
    owl:sameAs ns1:affectsModelPerformance .

ns1:managesComputationalResources a owl:ObjectProperty ;
    rdfs:label "manages computational resources"^^xsd:string ;
    rdfs:comment "Resource management activity handles computational resources."^^xsd:string ;
    rdfs:domain ns1:ResourceManagement ;
    rdfs:range ns1:ComputationalResource .

ns1:measuresMaturity a owl:ObjectProperty ;
    rdfs:label "measures maturity"^^xsd:string ;
    rdfs:comment "Relates a metric or assessment to a maturity model."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityModel ;
    rdfs:range prov:Entity .

ns1:memberOf a owl:ObjectProperty ;
    rdfs:label "member of"^^xsd:string ;
    rdfs:comment "Indicates membership of a person in a professional organization."^^xsd:string ;
    rdfs:domain schema1:Person ;
    rdfs:range ns1:ProfessionalOrganization .

ns1:monitors a owl:ObjectProperty ;
    rdfs:label "monitors" ;
    rdfs:comment "Monitoring job observes a model's performance." ;
    rdfs:domain ns1:MonitoringJob ;
    rdfs:range ns1:MLModel ;
    rdfs:subPropertyOf prov:used .

ns1:monitorsBias a owl:ObjectProperty ;
    rdfs:label "monitors bias"^^xsd:string ;
    rdfs:comment "Monitoring job observes bias in model predictions."^^xsd:string ;
    rdfs:domain ns1:BiasMonitoring ;
    rdfs:range ns1:ModelFairness ;
    rdfs:subPropertyOf prov:used ;
    owl:sameAs ns1:monitorsFairness .

ns1:monitorsPerformance a owl:ObjectProperty ;
    rdfs:label "monitors performance"^^xsd:string ;
    rdfs:comment "A monitoring job observes the performance of a model version."^^xsd:string ;
    rdfs:domain ns1:MonitoringJob ;
    rdfs:range ns1:ModelVersion .

ns1:monitorsPipeline a owl:ObjectProperty ;
    rdfs:label "monitors pipeline"^^xsd:string ;
    rdfs:comment "Monitoring job observes a distributed analytical pipeline."^^xsd:string ;
    rdfs:domain ns1:MonitoringJob ;
    rdfs:range ns1:DistributedAnalyticalPipeline .

ns1:numberOfBenefitCategories a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "number of benefit categories"^^xsd:string ;
    rdfs:comment "Count of distinct benefit categories identified for MLOps."^^xsd:string ;
    rdfs:domain ns1:MLOpsDiscipline ;
    rdfs:range xsd:integer .

ns1:numberOfChallengeCategories a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "number of challenge categories"^^xsd:string ;
    rdfs:comment "Count of distinct challenge categories identified for MLOps."^^xsd:string ;
    rdfs:domain ns1:MLOpsDiscipline ;
    rdfs:range xsd:integer .

ns1:orchestrates a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "orchestrates"^^xsd:string ;
    rdfs:comment "An orchestrator tool manages execution of an MLOps process."^^xsd:string,
        "Orchestrator manages execution of a data pipeline."^^xsd:string ;
    rdfs:domain ns1:Orchestrator ;
    rdfs:range ns1:DataPipeline,
        ns1:MLOpsProcess .

ns1:performsActivity a owl:ObjectProperty ;
    rdfs:label "performs activity"^^xsd:string ;
    rdfs:comment "An ML role performs a specific activity."^^xsd:string ;
    rdfs:domain ns1:MLRole ;
    rdfs:range prov:Activity .

ns1:performsInference a owl:ObjectProperty ;
    rdfs:label "performs inference"^^xsd:string ;
    rdfs:comment "Inference activity runs a model version to generate predictions."^^xsd:string ;
    rdfs:domain ns1:ModelInference ;
    rdfs:range ns1:ModelVersion .

ns1:producesModelVersion a owl:ObjectProperty ;
    rdfs:label "produces model version" ;
    rdfs:comment "Indicates that a training run produces a specific model version." ;
    rdfs:domain ns1:TrainingRun ;
    rdfs:range ns1:ModelVersion ;
    rdfs:subPropertyOf prov:generated .

ns1:producesOutput a owl:ObjectProperty ;
    rdfs:label "produces output"^^xsd:string ;
    rdfs:comment "Links a model version to the type of output it generates."^^xsd:string ;
    rdfs:domain ns1:ModelVersion ;
    rdfs:range ns1:Output .

ns1:proposesRoadmap a owl:ObjectProperty ;
    rdfs:label "proposes roadmap"^^xsd:string ;
    rdfs:comment "Links a study to a roadmap it proposes."^^xsd:string ;
    rdfs:domain ns1:MLOpsStudy ;
    rdfs:range ns1:MLOpsRoadmap .

ns1:publishedIn a owl:ObjectProperty ;
    rdfs:label "published in"^^xsd:string ;
    rdfs:comment "Relates a paper to its publication venue."^^xsd:string ;
    rdfs:domain ns1:Paper ;
    rdfs:range ns1:PublicationVenue .

ns1:reducesTimeToProduction a owl:DatatypeProperty ;
    rdfs:label "reduces time to production"^^xsd:string ;
    rdfs:comment "Quantifies reduction in time required to move a model to production, measured in days."^^xsd:string ;
    rdfs:domain prov:Activity ;
    rdfs:range xsd:float ;
    rdfs:seeAlso "Measured in days."^^xsd:string .

ns1:requiresCollaborationBetween a owl:ObjectProperty ;
    rdfs:label "requires collaboration between"^^xsd:string ;
    rdfs:comment "Specifies that a process requires collaboration among multiple agents/roles."^^xsd:string ;
    rdfs:domain prov:Activity ;
    rdfs:range prov:Agent .

ns1:requiresDataStrategy a owl:ObjectProperty ;
    rdfs:label "requires data strategy"^^xsd:string ;
    rdfs:comment "Indicates that a challenge requires a defined data strategy to be addressed."^^xsd:string ;
    rdfs:domain ns1:MLOpsAdoptionChallenge ;
    rdfs:range ns1:DataStrategy .

ns1:requiresHardware a owl:ObjectProperty ;
    rdfs:label "requires hardware"^^xsd:string ;
    rdfs:comment "Specifies hardware resources needed for a process."^^xsd:string ;
    rdfs:domain ns1:Process ;
    rdfs:range ns1:HardwareResource .

ns1:requiresQualifiedPersonnel a owl:DatatypeProperty ;
    rdfs:label "requires qualified personnel"^^xsd:string ;
    rdfs:comment "Indicates whether the process requires personnel with specialized MLOps skills."^^xsd:string ;
    rdfs:domain ns1:MLOpsProcess ;
    rdfs:range xsd:boolean .

ns1:resultsIn a owl:ObjectProperty ;
    rdfs:label "results in"^^xsd:string ;
    rdfs:comment "Indicates that a practice results in a specific outcome."^^xsd:string ;
    rdfs:domain ns1:MLOpsPractice ;
    rdfs:range prov:Entity .

ns1:searchesDatabase a owl:ObjectProperty ;
    rdfs:label "searches database"^^xsd:string ;
    rdfs:comment "A search string is applied to a bibliographic database."^^xsd:string ;
    rdfs:domain ns1:SearchString ;
    rdfs:range ns1:Database .

ns1:searchesInDatabase a owl:ObjectProperty ;
    rdfs:label "searches in database"^^xsd:string ;
    rdfs:comment "Specifies which bibliographic database is queried."^^xsd:string ;
    rdfs:domain ns1:SearchStrategy ;
    rdfs:range ns1:Database .

ns1:subscribesToEvent a owl:ObjectProperty ;
    rdfs:label "subscribes to event" ;
    rdfs:comment "An agent subscribes to events for response." ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:Event .

ns1:supportsContinuousDeployment a owl:DatatypeProperty,
        owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "supports continuous deployment"^^xsd:string ;
    rdfs:comment "Boolean flag indicating whether the maturity level includes continuous deployment (CD)."^^xsd:string,
        "MLOps paradigm includes CD practices."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityLevel,
        ns1:MLOpsParadigm ;
    rdfs:range ns1:ContinuousDeployment,
        xsd:boolean ;
    rdfs:subPropertyOf prov:hasActivity .

ns1:supportsContinuousIntegration a owl:ObjectProperty ;
    rdfs:label "supports continuous integration"^^xsd:string ;
    rdfs:comment "MLOps paradigm includes CI practices."^^xsd:string ;
    rdfs:domain ns1:MLOpsParadigm ;
    rdfs:range ns1:ContinuousIntegration ;
    rdfs:subPropertyOf prov:hasActivity .

ns1:supportsContinuousMonitoring a owl:ObjectProperty ;
    rdfs:label "supports continuous monitoring"^^xsd:string ;
    rdfs:comment "MLOps paradigm includes continuous monitoring."^^xsd:string ;
    rdfs:domain ns1:MLOpsParadigm ;
    rdfs:range ns1:ContinuousMonitoring ;
    rdfs:subPropertyOf prov:hasActivity .

ns1:supportsContinuousTraining a owl:DatatypeProperty,
        owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "supports continuous training"^^xsd:string ;
    rdfs:comment "Boolean flag indicating whether the maturity level includes continuous training (CT)."^^xsd:string,
        "MLOps paradigm includes continuous training."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityLevel,
        ns1:MLOpsParadigm ;
    rdfs:range ns1:ContinuousTraining,
        xsd:boolean ;
    rdfs:subPropertyOf prov:hasActivity .

ns1:supportsDataOps a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "supports DataOps"^^xsd:string ;
    rdfs:comment "Boolean flag indicating inclusion of DataOps practices at this maturity level."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityLevel ;
    rdfs:range xsd:boolean .

ns1:supportsMLOps a owl:ObjectProperty ;
    rdfs:label "supports MLOps"^^xsd:string ;
    rdfs:comment "Indicates that a tool is designed to support MLOps activities."^^xsd:string ;
    rdfs:domain ns1:Tool ;
    rdfs:range ns1:MLOpsProcess .

ns1:supportsProject a owl:ObjectProperty ;
    rdfs:label "supports project"^^xsd:string ;
    rdfs:comment "MLOps activities support a data science project."^^xsd:string ;
    rdfs:domain ns1:MLOps ;
    rdfs:range ns1:DataScienceProject .

ns1:targetsOrganizationSize a owl:ObjectProperty ;
    rdfs:label "targets organization size"^^xsd:string ;
    rdfs:comment "Specifies the size category of software development companies considered."^^xsd:string ;
    rdfs:domain ns1:SearchObjective ;
    rdfs:range ns1:OrganizationSizeCategory .

ns1:transitionsTo a owl:ObjectProperty ;
    rdfs:label "transitions to"^^xsd:string ;
    rdfs:comment "Indicates transition from one lifecycle stage to another."^^xsd:string ;
    rdfs:domain ns1:ExperimentalModel ;
    rdfs:range ns1:ProductionEnvironment ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

ns1:triggersMonitoringJob a owl:ObjectProperty ;
    rdfs:label "triggers monitoring job"^^xsd:string ;
    rdfs:comment "Continuous monitoring process initiates monitoring jobs."^^xsd:string ;
    rdfs:domain ns1:ContinuousMonitoring ;
    rdfs:range ns1:MonitoringJob .

ns1:triggersRetraining a owl:ObjectProperty ;
    rdfs:label "triggers retraining"^^xsd:string ;
    rdfs:comment "A monitoring job can trigger a new training run when data drift is detected."^^xsd:string ;
    rdfs:domain ns1:MonitoringJob ;
    rdfs:range ns1:TrainingRun ;
    rdfs:subPropertyOf prov:wasGeneratedBy ;
    owl:sameAs ns1:triggersTrainingRun .

ns1:triggersUpdate a owl:ObjectProperty ;
    rdfs:label "triggers update"^^xsd:string ;
    rdfs:comment "Detection of drift causes a maintenance process to start."^^xsd:string ;
    rdfs:domain ns1:Drift ;
    rdfs:range ns1:MaintenanceProcess .

ns1:usesCICDPipeline a owl:ObjectProperty ;
    rdfs:label "uses CI/CD pipeline"^^xsd:string ;
    rdfs:comment "Indicates that a maturity level relies on CI/CD pipelines for automation."^^xsd:string ;
    rdfs:domain ns1:MLOpsMaturityLevel ;
    rdfs:range ns1:CICDPipeline .

ns1:usesClassificationScheme a owl:ObjectProperty ;
    rdfs:label "uses classification scheme"^^xsd:string ;
    rdfs:comment "Indicates the classification scheme applied to categorize studies."^^xsd:string ;
    rdfs:domain ns1:SearchObjective ;
    rdfs:range ns1:ClassificationScheme .

ns1:usesCloudResources a owl:ObjectProperty ;
    rdfs:label "uses cloud resources"^^xsd:string ;
    rdfs:comment "Indicates that an activity utilizes cloud computing resources."^^xsd:string ;
    rdfs:domain prov:Activity ;
    rdfs:range ns1:CloudComputing .

ns1:usesDataSet a owl:ObjectProperty ;
    rdfs:label "uses data set" ;
    rdfs:comment "Training run consumes a data set." ;
    rdfs:domain ns1:TrainingRun ;
    rdfs:range ns1:DataSet .

ns1:usesFeatureStore a owl:ObjectProperty ;
    rdfs:label "uses feature store" ;
    rdfs:comment "Training run consumes features from a feature store." ;
    rdfs:domain ns1:TrainingRun ;
    rdfs:range ns1:FeatureStore .

ns1:usesFramework a owl:ObjectProperty ;
    rdfs:label "uses framework"^^xsd:string ;
    rdfs:comment "Indicates that an agent adopts a specific MLOps maturity framework."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:MLOpsMaturityFramework .

ns1:usesOrchestrator a owl:ObjectProperty ;
    rdfs:label "uses orchestrator"^^xsd:string ;
    rdfs:comment "Agent utilizes an orchestrator for pipeline execution."^^xsd:string ;
    rdfs:domain prov:Agent ;
    rdfs:range ns1:Orchestrator .

ns1:usesSearchString a owl:ObjectProperty ;
    rdfs:label "uses search string"^^xsd:string ;
    rdfs:comment "A search strategy employs a specific Boolean query."^^xsd:string,
        "A selection process uses a specific search string."^^xsd:string ;
    rdfs:domain ns1:SearchStrategy,
        ns1:SelectionProcess ;
    rdfs:range ns1:SearchString .

ns1:usesTool a owl:ObjectProperty ;
    rdfs:label "uses tool"^^xsd:string ;
    rdfs:comment "An activity utilizes a specific tool."^^xsd:string,
        "An agent or process uses a specific tool."^^xsd:string,
        "The paper mentions or evaluates a specific MLOps tool."^^xsd:string ;
    rdfs:domain ns1:ResearchPaper,
        prov:Activity,
        prov:Agent ;
    rdfs:range ns1:MLOpsTool,
        ns1:Tool ;
    rdfs:subPropertyOf prov:used .

