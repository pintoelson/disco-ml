    rdfs:label "Exclusion Criterion"^^xsd:string ;
    rdfs:comment "A criterion used to exclude papers from a systematic literature review."^^xsd:string ;
    rdfs:subClassOf skos:Concept ;
    owl:sameAs ns1:InclusionCriterion .

ns1:ExperimentalModel a owl:Class ;
    rdfs:label "Experimental Model"^^xsd:string ;
    rdfs:comment "A model in early development stage before production."^^xsd:string ;
    rdfs:subClassOf ns1:MLModel .

ns1:Goal a owl:Class ;
    rdfs:label "Goal"^^xsd:string ;
    rdfs:comment "A desired outcome or objective in a system or process."^^xsd:string,
        "An objective defined in the Goal-Question-Metric (GQM) approach."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork,
        prov:Entity .

ns1:Hardware a owl:Class ;
    rdfs:label "Hardware"^^xsd:string ;
    rdfs:comment "Physical computing resources used for ML workloads."^^xsd:string ;
    rdfs:subClassOf prov:Entity ;
    owl:sameAs ns1:HardwareResource .

ns1:HardwareResource a owl:Class ;
    rdfs:label "Hardware Resource"^^xsd:string ;
    rdfs:comment "Physical computing resources required for ML workloads, such as GPUs."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:MLOps a owl:Class ;
    rdfs:label "MLOps"^^xsd:string ;
    rdfs:comment "A set of practices that aim to unify ML system development (Dev) and ML system operation (Ops)."^^xsd:string,
        "Application of DevOps principles to the machine learning lifecycle."^^xsd:string,
        "Machine Learning Operations, encompassing practices, tools, and processes for managing the ML lifecycle."^^xsd:string ;
    rdfs:subClassOf ns1:DevOpsPrinciple,
        prov:Activity .

ns1:MLOpsAdoptionBenefit a owl:Class ;
    rdfs:label "MLOps Adoption Benefit" ;
    rdfs:comment "Benefit realized from adopting MLOps practices in software development companies." ;
    rdfs:subClassOf ns1:Benefit .

ns1:MLOpsBenchmark a owl:Class ;
    rdfs:label "MLOps Benchmark"^^xsd:string ;
    rdfs:comment "A benchmark or reference model (e.g., Microsoft, Google) that defines maturity levels."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork .

ns1:MLOpsBenefit a owl:Class ;
    rdfs:label "MLOps Benefit"^^xsd:string ;
    rdfs:comment "Positive outcome obtained from adopting MLOps practices."^^xsd:string ;
    rdfs:subClassOf skos:Concept .

ns1:MLOpsDimension a owl:Class ;
    rdfs:label "MLOps Dimension"^^xsd:string ;
    rdfs:comment "An aspect of MLOps (e.g., data management, model monitoring, CI/CD) used to evaluate maturity."^^xsd:string ;
    rdfs:subClassOf skos:Concept .

ns1:MaintenanceStrategy a owl:Class ;
    rdfs:label "Maintenance Strategy"^^xsd:string ;
    rdfs:comment "Plan for updating, retraining, or replacing models after drift detection."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:Metric a owl:Class ;
    rdfs:label "Metric"^^xsd:string ;
    rdfs:comment "A measurable attribute used to assess performance or quality."^^xsd:string,
        "A measurable indicator used to answer a research question."^^xsd:string ;
    rdfs:subClassOf schema1:QuantitativeValue,
        prov:Entity .

ns1:ModelDrift a owl:Class ;
    rdfs:label "Model Drift"^^xsd:string ;
    rdfs:comment "Phenomenon where a model's performance degrades over time due to changes in data distribution."^^xsd:string,
        "Shift in the relationship between inputs and outputs of a model over time."^^xsd:string ;
    rdfs:subClassOf ns1:Drift,
        prov:Entity .

ns1:ModelFairness a owl:Class ;
    rdfs:label "Model Fairness"^^xsd:string ;
    rdfs:comment "Assessment of a model's equitable behavior across different groups."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:PerformanceDegradation a owl:Class ;
    rdfs:label "Performance Degradation"^^xsd:string ;
    rdfs:comment "Decline in model predictive quality due to factors such as data drift."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ProfessionalOrganization a owl:Class ;
    rdfs:label "Professional Organization"^^xsd:string ;
    rdfs:comment "Organization such as a scientific society or conference host."^^xsd:string ;
    rdfs:subClassOf schema1:Organization .

ns1:ResearchProtocol a owl:Class ;
    rdfs:label "Research Protocol"^^xsd:string ;
    rdfs:comment "A documented set of procedures and criteria guiding the conduct of a systematic review."^^xsd:string ;
    rdfs:subClassOf prov:Plan .

ns1:ResourceManagement a owl:Class ;
    rdfs:label "Resource Management"^^xsd:string ;
    rdfs:comment "Management of computational resources (e.g., GPUs, cloud infrastructure) for ML workloads."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:SearchString a owl:Class ;
    rdfs:label "Search String"^^xsd:string ;
    rdfs:comment "A Boolean query used to retrieve relevant documents in a literature search."^^xsd:string,
        "A query string used to retrieve records from a bibliographic database."^^xsd:string ;
    rdfs:subClassOf schema1:Text,
        prov:Entity ;
    owl:sameAs ns1:SearchObjective .

ns1:SkillGap a owl:Class ;
    rdfs:label "Skill Gap"^^xsd:string ;
    rdfs:comment "Missing or insufficient skill within an organization for MLOps activities."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:SoftCompetency a owl:Class ;
    rdfs:label "Soft Competency"^^xsd:string ;
    rdfs:comment "Nonâtechnical skill such as communication or collaboration."^^xsd:string ;
    rdfs:subClassOf ns1:Competency .

ns1:SoftwareEngineerRole a owl:Class ;
    rdfs:label "Software Engineer Role"^^xsd:string ;
    rdfs:comment "Role of a software engineer, focusing on software development, deployment, and maintenance of AI systems."^^xsd:string ;
    rdfs:subClassOf ns1:Role .

ns1:SystematicLiteratureReview a owl:Class ;
    rdfs:label "Systematic Literature Review"^^xsd:string ;
    rdfs:comment "A structured method for identifying, evaluating, and synthesizing research literature."^^xsd:string,
        "A systematic literature review that aggregates and synthesizes findings from primary studies."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork,
        prov:Activity .

ns1:hasCompetency a owl:ObjectProperty ;
    rdfs:label "has competency"^^xsd:string ;
    rdfs:comment "Specifies a competency required for a role."^^xsd:string ;
    rdfs:domain ns1:Role ;
    rdfs:range ns1:Competency .

ns1:BenefitCategory a owl:Class ;
    rdfs:label "Benefit Category"^^xsd:string ;
    rdfs:comment "A high-level grouping of benefits resulting from MLOps adoption."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:CI_CD_Tool a owl:Class ;
    rdfs:label "CI/CD Tool"^^xsd:string ;
    rdfs:comment "Tool that automates integration and delivery pipelines."^^xsd:string ;
    rdfs:subClassOf ns1:Tool .

ns1:Competency a owl:Class ;
    rdfs:label "Competency"^^xsd:string ;
    rdfs:comment "A skill or knowledge area required to perform a role."^^xsd:string ;
    rdfs:subClassOf skos:Concept .

ns1:ContinuousTraining a owl:Class ;
    rdfs:label "Continuous Training"^^xsd:string ;
    rdfs:comment "Automated retraining of models as new data becomes available."^^xsd:string,
        "Automated retraining of models when data drift or performance degradation is detected."^^xsd:string,
        "Ongoing process of retraining models as new data becomes available."^^xsd:string,
        "Process of periodically retraining models with new data."^^xsd:string ;
    rdfs:subClassOf ns1:MLOpsProcess,
        ns1:Process,
        prov:Activity .

ns1:DataDrift a owl:Class ;
    rdfs:label "Data Drift"^^xsd:string ;
    rdfs:comment "Change in data distribution that may affect model performance."^^xsd:string,
        "Change in the statistical properties of input data compared to training data."^^xsd:string,
        "Change in the statistical properties of input data over time, potentially degrading model performance."^^xsd:string ;
    rdfs:subClassOf ns1:Drift,
        prov:Entity .

ns1:DataEngineerRole a owl:Class ;
    rdfs:label "Data Engineer Role"^^xsd:string ;
    rdfs:comment "Role of a data engineer, responsible for data pipelines, storage, and quality."^^xsd:string ;
    rdfs:subClassOf ns1:Role .

ns1:DataStrategy a owl:Class ;
    rdfs:label "Data Strategy"^^xsd:string ;
    rdfs:comment "A plan defining how data will be collected, cleaned, labeled, and managed for MLOps pipelines."^^xsd:string ;
    rdfs:subClassOf prov:Plan .

ns1:GoalQuestionMetricParadigm a owl:Class ;
    rdfs:label "Goal-Question-Metric Paradigm"^^xsd:string ;
    rdfs:comment "A methodology for defining goals, deriving questions, and selecting metrics to assess software processes."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork .

ns1:InclusionCriterion a owl:Class ;
    rdfs:label "Inclusion Criterion"^^xsd:string ;
    rdfs:comment "A criterion used to include papers in a systematic literature review, such as relevance to MLOps."^^xsd:string ;
    rdfs:subClassOf skos:Concept .

ns1:InfrastructureComponent a owl:Class ;
    rdfs:label "Infrastructure Component"^^xsd:string ;
    rdfs:comment "Hardware or cloud resource required to execute MLOps processes."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:MLOpsMaturityModel a owl:Class ;
    rdfs:label "MLOps Maturity Model"^^xsd:string ;
    rdfs:comment "A framework describing levels of maturity in MLOps adoption."^^xsd:string,
        "A framework for assessing the maturity level of MLOps adoption in an organization."^^xsd:string,
        "A structured model describing levels of maturity for MLOps practices within an organization."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork,
        prov:Entity .

ns1:MLOpsPhase a owl:Class ;
    rdfs:label "MLOps Phase"^^xsd:string ;
    rdfs:comment "A distinct stage in the MLOps lifecycle such as data ingestion, training, deployment, monitoring, or maintenance."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:MLProject a owl:Class ;
    rdfs:label "ML Project"^^xsd:string ;
    rdfs:comment "A machine learning project encompassing data science, model development, and deployment activities."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:MaintenanceProcess a owl:Class ;
    rdfs:label "Maintenance Process"^^xsd:string ;
    rdfs:comment "Activity that updates or retrains a model in response to detected drift."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:MaturityModel a owl:Class ;
    rdfs:label "Maturity Model"^^xsd:string ;
    rdfs:comment "A model that defines maturity levels for MLOps adoption."^^xsd:string,
        "A structured model describing maturity levels for MLOps adoption."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:Orchestrator a owl:Class ;
    rdfs:label "Orchestrator"^^xsd:string ;
    rdfs:comment "Component that manages execution of pipelines and jobs in MLOps."^^xsd:string,
        "Tool that coordinates execution of MLOps pipelines."^^xsd:string,
        "Tool that manages deployment and scaling of containerized workloads."^^xsd:string ;
    rdfs:subClassOf ns1:Tool,
        prov:Agent .

ns1:OrganizationSizeCategory a owl:Class ;
    rdfs:label "Organization Size Category"^^xsd:string ;
    rdfs:comment "Category describing size of a software development company (e.g., small, medium)."^^xsd:string ;
    rdfs:subClassOf schema1:DefinedTerm .

ns1:Output a owl:Class ;
    rdfs:label "Output"^^xsd:string ;
    rdfs:comment "Result produced by a model, can be deterministic or probabilistic."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:SelectionProcess a owl:Class ;
    rdfs:label "Selection Process"^^xsd:string ;
    rdfs:comment "The process of selecting primary papers based on inclusion and exclusion criteria, including multiâlevel review."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:Skill a owl:Class ;
    rdfs:label "Skill"^^xsd:string ;
    rdfs:comment "A competency required to perform MLOps tasks."^^xsd:string,
        "General notion of a competency; can be technical or soft."^^xsd:string ;
    rdfs:subClassOf schema1:DefinedTerm,
        prov:Entity ;
    owl:sameAs ns1:SkillGap,
        ns1:TechnicalSkill .

ns1:TechnicalDebt a owl:Class ;
    rdfs:label "Technical Debt"^^xsd:string ;
    rdfs:comment "Accumulated suboptimal code or design decisions that hinder maintainability and scalability."^^xsd:string,
        "Accumulated suboptimal technical decisions in ML code and pipelines."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:ChallengeCategory a owl:Class ;
    rdfs:label "Challenge Category"^^xsd:string ;
    rdfs:comment "A high-level grouping of challenges encountered in MLOps adoption."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:DataPipeline a owl:Class ;
    rdfs:label "Data Pipeline" ;
    rdfs:comment "A workflow that extracts, transforms, and loads data for training or inference." ;
    rdfs:subClassOf prov:Activity .

ns1:DataScientistRole a owl:Class ;
    rdfs:label "Data Scientist Role"^^xsd:string ;
    rdfs:comment "Role of a data scientist, typically responsible for model development and experimentation."^^xsd:string ;
    rdfs:subClassOf ns1:Role .

ns1:Drift a owl:Class ;
    rdfs:label "Drift"^^xsd:string ;
    rdfs:comment "Change in data distribution or model behavior that degrades performance."^^xsd:string ;
    rdfs:subClassOf prov:Entity ;
    owl:sameAs ns1:DataDrift,
        ns1:ModelDrift .

ns1:MLOpsChallenge a owl:Class ;
    rdfs:label "MLOps Challenge"^^xsd:string ;
    rdfs:comment "A difficulty or obstacle encountered in implementing MLOps practices."^^xsd:string,
        "A difficulty or obstacle identified in the practice of MLOps."^^xsd:string,
        "Challenges faced in implementing MLOps practices."^^xsd:string,
        "Difficulty or obstacle encountered when adopting MLOps."^^xsd:string ;
    rdfs:subClassOf skos:Concept,
        prov:Entity .

ns1:MLOpsPrinciple a owl:Class ;
    rdfs:label "MLOps Principle"^^xsd:string ;
    rdfs:comment "Abstract principle guiding successful MLOps implementation."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork .

ns1:Methodology a owl:Class ;
    rdfs:label "Methodology"^^xsd:string ;
    rdfs:comment "A structured set of processes and practices guiding the execution of a project."^^xsd:string ;
    rdfs:subClassOf prov:Plan .

ns1:Paper a owl:Class ;
    rdfs:label "Paper"^^xsd:string ;
    rdfs:comment "A scholarly article, conference paper, or other publication considered in the literature review."^^xsd:string ;
    rdfs:subClassOf prov:Entity ;
    owl:sameAs ns1:ResearchPaper .

ns1:ResearchQuestion a owl:Class ;
    rdfs:label "Research Question"^^xsd:string ;
    rdfs:comment "A question formulated to guide systematic investigation of MLOps topics."^^xsd:string,
        "A specific question that the systematic review aims to answer."^^xsd:string ;
    rdfs:subClassOf schema1:Question .

ns1:AutomationPractice a owl:Class ;
    rdfs:label "Automation Practice"^^xsd:string ;
    rdfs:comment "An abstract practice that can be automated within the MLOps lifecycle (e.g., training, deployment, monitoring)."^^xsd:string ;
    rdfs:subClassOf prov:Entity ;
    owl:sameAs ns1:AutomationPrinciple .

ns1:Benefit a owl:Class ;
    rdfs:label "Benefit"^^xsd:string ;
    rdfs:comment "Positive outcome or advantage resulting from adopting MLOps practices."^^xsd:string,
        "Positive outcome resulting from MLOps adoption."^^xsd:string ;
    rdfs:subClassOf skos:Concept,
        prov:Entity .

ns1:CollaborationChallenge a owl:Class ;
    rdfs:label "Collaboration Challenge"^^xsd:string ;
    rdfs:comment "Challenges related to collaboration when building ML-enabled systems, such as communication, documentation, engineering, and process issues."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:MaturityLevel a owl:Class ;
    rdfs:label "Maturity Level"^^xsd:string ;
    rdfs:comment "A specific level within a maturity model, often numbered and described."^^xsd:string,
        "A specific level within an MLOps maturity model."^^xsd:string,
        "A stage representing the development and adoption maturity of the MLOps discipline."^^xsd:string,
        "Level describing the maturity of MLOps practices within an organization."^^xsd:string ;
    rdfs:subClassOf skos:Concept,
        prov:Entity .

ns1:SearchObjective a owl:Class ;
    rdfs:label "Search Objective"^^xsd:string ;
    rdfs:comment "An objective guiding the literature search, e.g., analyzing MLOps applications in SMEs."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork .

ns1:SearchStrategy a owl:Class ;
    rdfs:label "Search Strategy"^^xsd:string ;
    rdfs:comment "The methodological plan for retrieving literature related to MLOps."^^xsd:string ;
    rdfs:subClassOf prov:Plan .

ns1:Team a owl:Class ;
    rdfs:label "Team"^^xsd:string ;
    rdfs:comment "Group of agents collaborating towards a common goal."^^xsd:string ;
    rdfs:subClassOf prov:Agent .

ns1:MLOpsAdoptionChallenge a owl:Class ;
    rdfs:label "MLOps Adoption Challenge"^^xsd:string,
        "MLOps Adoption Challenge" ;
    rdfs:comment "A challenge identified in the adoption of MLOps practices, encompassing data, organizational, and technical aspects."^^xsd:string,
        "Challenge encountered when adopting MLOps in software development companies." ;
    rdfs:subClassOf ns1:Challenge,
        skos:Concept .

ns1:MLOpsParadigm a owl:Class ;
    rdfs:label "MLOps Paradigm"^^xsd:string ;
    rdfs:comment "A set of practices and cultural principles for operationalizing machine learning models, extending DevOps."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:MLOpsStage a owl:Class ;
    rdfs:label "MLOps Stage"^^xsd:string ;
    rdfs:comment "A distinct phase within an MLOps process, such as problem definition, training, deployment, or monitoring."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:MLOpsStudy a owl:Class ;
    rdfs:label "MLOps Study"^^xsd:string ;
    rdfs:comment "A scholarly work (e.g., survey, systematic literature review) that investigates MLOps challenges, opportunities, best practices, and maturity models."^^xsd:string ;
    rdfs:subClassOf schema1:ScholarlyArticle .

ns1:StakeholderRole a owl:Class ;
    rdfs:label "Stakeholder Role"^^xsd:string ;
    rdfs:comment "Role of a person or group involved in MLOps processes."^^xsd:string ;
    rdfs:subClassOf prov:Agent .

ns1:Adoption a owl:Class ;
    rdfs:label "MLOps Adoption"^^xsd:string ;
    rdfs:comment "The act of a company adopting MLOps practices."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:Challenge a owl:Class ;
    rdfs:label "Challenge"^^xsd:string ;
    rdfs:comment "A difficulty or obstacle encountered in AI engineering."^^xsd:string,
        "Difficulty or obstacle encountered during MLOps adoption."^^xsd:string,
        "Obstacle or difficulty encountered in implementing MLOps."^^xsd:string,
        "Obstacle or difficulty encountered when implementing MLOps practices."^^xsd:string ;
    rdfs:subClassOf skos:Concept,
        prov:Entity .

ns1:MLOpsDiscipline a owl:Class ;
    rdfs:label "MLOps Discipline"^^xsd:string ;
    rdfs:comment "The interdisciplinary field encompassing practices, tools, and processes for operationalizing machine learning models."^^xsd:string ;
    rdfs:subClassOf prov:Entity .

ns1:MLOpsMaturityFramework a owl:Class ;
    rdfs:label "MLOps Maturity Framework"^^xsd:string ;
    rdfs:comment "A structured framework that defines levels and dimensions for assessing MLOps maturity in an organization."^^xsd:string ;
    rdfs:subClassOf schema1:CreativeWork .

ns1:TrainingRun a owl:Class ;
    rdfs:label "Training Run" ;
    rdfs:comment "An execution of a model training process producing a model version." ;
    rdfs:subClassOf prov:Activity .

ns1:MLRole a owl:Class ;
    rdfs:label "ML Role"^^xsd:string ;
    rdfs:comment "Abstract role involved in MLOps activities."^^xsd:string ;
    rdfs:subClassOf prov:Agent .

ns1:MLModel a owl:Class ;
    rdfs:label "ML Model" ;
    rdfs:comment "A machine learning model that can be trained, versioned, and deployed." ;
    rdfs:subClassOf prov:Entity .

ns1:ResearchPaper a owl:Class ;
    rdfs:label "Research Paper"^^xsd:string ;
    rdfs:comment "Scholarly article describing research findings."^^xsd:string ;
    rdfs:subClassOf schema1:ScholarlyArticle .

ns1:MLOpsProcess a owl:Class ;
    rdfs:label "MLOps Process"^^xsd:string ;
    rdfs:comment "A set of coordinated activities and practices for operationalizing machine learning models within software development."^^xsd:string,
        "A set of practices and activities that integrate the machine learning lifecycle with DevOps principles."^^xsd:string,
        "An end-to-end workflow that encompasses model development, deployment, monitoring, and maintenance in production."^^xsd:string ;
    rdfs:subClassOf prov:Activity .

ns1:MonitoringJob a owl:Class ;
    rdfs:label "Monitoring Job" ;
    rdfs:comment "An automated job that monitors model performance, data drift, and other metrics in production." ;
    rdfs:subClassOf prov:Activity .

ns1:MLOpsPractice a owl:Class ;
    rdfs:label "MLOps Practice"^^xsd:string ;
    rdfs:comment "A practice or technique within MLOps aimed at improving the ML product lifecycle."^^xsd:string,
        "A practice, process, or technique that is part of MLOps."^^xsd:string,
        "An activity or set of activities defined within MLOps to improve the model lifecycle."^^xsd:string,
        "Specific practice within MLOps, e.g., continuous integration, monitoring, or model registry."^^xsd:string ;
    rdfs:subClassOf prov:Activity,
        prov:Entity .

ns1:MLOpsRole a owl:Class ;
    rdfs:label "MLOps Role"^^xsd:string ;
    rdfs:comment "A role defined in an MLOps process, such as architect, data engineer, ML engineer, or DevOps engineer."^^xsd:string,
        "A role performed by a person or agent within the MLOps lifecycle."^^xsd:string ;
    rdfs:subClassOf prov:Agent .

ns1:Tool a owl:Class ;
    rdfs:label "Tool"^^xsd:string ;
    rdfs:comment "Software or hardware used to support MLOps activities."^^xsd:string,
        "Software or platform used to support MLOps activities."^^xsd:string,
        "Software or platform used to support MLOps processes."^^xsd:string ;
    rdfs:subClassOf prov:Entity,
        prov:SoftwareAgent .

ns1:ModelVersion a owl:Class ;
    rdfs:label "Model Version" ;
    rdfs:comment "A specific version of an ML model, identified by a version identifier." ;
    rdfs:subClassOf ns1:MLModel .

ns1:MLOpsMaturityLevel a owl:Class ;
    rdfs:label "MLOps Maturity Level"^^xsd:string ;
    rdfs:comment "A specific level within an MLOps maturity framework representing a degree of automation and capability."^^xsd:string,
        "A specific level within an MLOps maturity model, representing a set of capabilities and automation."^^xsd:string ;
    rdfs:subClassOf skos:Concept,
        prov:Entity .

ns1:Process a owl:Class ;
    rdfs:label "Process"^^xsd:string ;
    rdfs:comment "A defined sequence of activities within an MLOps workflow."^^xsd:string,
        "An abstract activity within the MLOps lifecycle."^^xsd:string ;
    rdfs:subClassOf prov:Activity,
        prov:Plan .

ns1:Role a owl:Class ;
    rdfs:label "Role"^^xsd:string ;
    rdfs:comment "A function or position of a person or agent in MLOps processes."^^xsd:string,
        "A function or responsibility performed by a person in the MLOps lifecycle."^^xsd:string,
        "A functional role performed by an agent in the AI engineering lifecycle."^^xsd:string,
        "A set of responsibilities performed by an agent in an MLOps context."^^xsd:string ;
    rdfs:subClassOf schema1:Role,
        prov:Agent ;
    owl:sameAs ns1:DataEngineerRole,
        ns1:DataScientistRole,
        ns1:MLOpsRole,
        ns1:MLRole,
        ns1:SoftwareEngineerRole,
        ns1:StakeholderRole .

