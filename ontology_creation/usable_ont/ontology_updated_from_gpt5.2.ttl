#################################################################

###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#wasDerivedFrom
prov:wasDerivedFrom rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://rdfs.org/sioc/argument#agrees_with
<http://rdfs.org/sioc/argument#agrees_with> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf owl:topObjectProperty ;
                                            rdfs:domain sioc_arg:Argument ;
                                            rdfs:range dd:Decision .


###  http://rdfs.org/sioc/argument#disagrees_with
<http://rdfs.org/sioc/argument#disagrees_with> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf owl:topObjectProperty ;
                                               rdfs:domain sioc_arg:Argument ;
                                               rdfs:range dd:Decision .


###  http://rdfs.org/sioc/argument#neutral_towards
<http://rdfs.org/sioc/argument#neutral_towards> rdf:type owl:ObjectProperty ;
                                                rdfs:subPropertyOf owl:topObjectProperty ;
                                                rdfs:domain sioc_arg:Argument ;
                                                rdfs:range dd:Decision .


###  http://rdfs.org/sioc/argument#supported_by
<http://rdfs.org/sioc/argument#supported_by> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf owl:topObjectProperty ;
                                             rdfs:domain dd:Decision ;
                                             rdfs:range sioc_arg:Position .


###  https://example.com/dd#constrains
dd:constrains rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf dd:isRelatedTo ;
              owl:inverseOf dd:isConstrainedBy ;
              rdf:type owl:AsymmetricProperty ,
                       owl:IrreflexiveProperty ;
              rdfs:domain dd:Decision ;
              rdfs:range dd:Decision ;
              rdfs:comment "Decision A constrains decision B: B is contingent on A (if A is dropped, B is dropped) and cannot reach a higher state than A." ;
              rdfs:label "constrains" .


###  https://example.com/dd#documentsDecision
dd:documentsDecision rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf schema:about ;
                     owl:inverseOf dd:hasArchitectureArtifact ;
                     rdfs:domain dd:ArchitectureArtifact ;
                     rdfs:range dd:Decision ;
                     rdfs:comment "Links an architecture artifact to the decision(s) it documents (often where rationale is captured)." ;
                     rdfs:label "documents decision" .


###  https://example.com/dd#enables
dd:enables rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf dd:isRelatedTo ;
           owl:inverseOf dd:isEnabledBy ;
           rdf:type owl:AsymmetricProperty ,
                    owl:IrreflexiveProperty ;
           rdfs:domain dd:Decision ;
           rdfs:range dd:Decision ;
           rdfs:comment "Decision A enables decision B: A makes B possible but does not force B; a weaker form of constraining." ;
           rdfs:label "enables" .


###  https://example.com/dd#forbids
dd:forbids rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf dd:isRelatedTo ;
           owl:inverseOf dd:isForbiddenBy ;
           rdf:type owl:AsymmetricProperty ,
                    owl:IrreflexiveProperty ;
           rdfs:domain dd:Decision ;
           rdfs:range dd:Decision ;
           rdfs:comment "Decision A forbids (excludes) decision B: B cannot be taken/promoted unless A is not taken (demoted to the null/initial state)." ;
           rdfs:label "forbids" .


###  https://example.com/dd#hasArchitectureArtifact
dd:hasArchitectureArtifact rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf schema:mentions ;
                           rdfs:domain dd:Decision ;
                           rdfs:range dd:ArchitectureArtifact ;
                           rdfs:comment "Links a decision to an architectural artifact it creates, modifies, or is documented in." ;
                           rdfs:label "has architecture artifact" .


###  https://example.com/dd#hasCostEstimate
dd:hasCostEstimate rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf schema:cost ;
                   rdfs:domain dd:Decision ;
                   rdfs:range dd:CostEstimate ;
                   rdfs:comment "Links a decision to an associated cost estimate." ;
                   rdfs:label "has cost estimate" .


###  https://example.com/dd#hasDecisionTag
dd:hasDecisionTag rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf schema:about ;
                  rdfs:domain dd:Decision ;
                  rdfs:range dd:DecisionTag ;
                  rdfs:comment "Associates a decision with one or more tags/categories for classification and retrieval." ;
                  rdfs:label "has decision tag" .


###  https://example.com/dd#hasHistoryEntry
dd:hasHistoryEntry rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf schema:subjectOf ;
                   rdfs:domain dd:Decision ;
                   rdfs:range dd:DecisionHistoryEntry ;
                   rdfs:comment "Links a decision to a history entry recording a change event." ;
                   rdfs:label "has history entry" .


###  https://example.com/dd#hasPreviousVersion
dd:hasPreviousVersion rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf dd:isRelatedTo ;
                      owl:inverseOf dd:isSupersededBy ;
                      rdfs:domain dd:Decision ;
                      rdfs:range dd:Decision .


###  https://example.com/dd#hasRiskAssessment
dd:hasRiskAssessment rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf schema:risk ;
                     rdfs:domain dd:Decision ;
                     rdfs:range dd:RiskAssessment ;
                     rdfs:comment "Links a decision to a risk assessment about taking that decision." ;
                     rdfs:label "has risk assessment" .


###  https://example.com/dd#hasRiskExposure
dd:hasRiskExposure rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf schema:additionalProperty ;
                   rdfs:domain dd:RiskAssessment ;
                   rdfs:range dd:RiskExposure ;
                   rdfs:comment "Associates a risk assessment with an exposure level." ;
                   rdfs:label "has risk exposure" .


###  https://example.com/dd#historyActor
dd:historyActor rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf schema:agent ;
                rdfs:domain dd:DecisionHistoryEntry ;
                rdfs:range schema:Person ;
                rdfs:comment "Agent responsible for the change recorded in a history entry." ;
                rdfs:label "history actor" .


###  https://example.com/dd#isAddressedBy
dd:isAddressedBy rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain sioc_arg:Issue ;
                 rdfs:range dd:Decision .


###  https://example.com/dd#isConstrainedBy
dd:isConstrainedBy rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf dd:isRelatedTo ;
                   rdfs:domain dd:Decision ;
                   rdfs:range dd:Decision ;
                   rdfs:comment "Inverse of constrains: indicates a decision is contingent on another decision." ;
                   rdfs:label "is constrained by" .


###  https://example.com/dd#isEnabledBy
dd:isEnabledBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf dd:isRelatedTo ;
               rdfs:domain dd:Decision ;
               rdfs:range dd:Decision ;
               rdfs:comment "Inverse of enables: indicates a decision is made possible by another decision." ;
               rdfs:label "is enabled by" .


###  https://example.com/dd#isForbiddenBy
dd:isForbiddenBy rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf dd:isRelatedTo ;
                 rdfs:domain dd:Decision ;
                 rdfs:range dd:Decision ;
                 rdfs:comment "Inverse of forbids: indicates a decision is excluded by another decision." ;
                 rdfs:label "is forbidden by" .


###  https://example.com/dd#isRelatedTo
dd:isRelatedTo rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf schema:relatedTo ;
               rdf:type owl:SymmetricProperty ;
               rdfs:domain dd:Decision ;
               rdfs:range dd:Decision ;
               rdfs:comment "Indicates a general relationship between two decisions without committing to a specific dependency type." ;
               rdfs:label "is related to" .


###  https://example.com/dd#isSubsumedBy
dd:isSubsumedBy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf dd:isRelatedTo ;
                owl:inverseOf dd:subsumes ;
                rdfs:domain dd:Decision ;
                rdfs:range dd:Decision ;
                rdfs:comment "Inverse of subsumes: indicates a decision is a narrower part within a broader decision." ;
                rdfs:label "is subsumed by" .


###  https://example.com/dd#isSupersededBy
dd:isSupersededBy rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf dd:isRelatedTo ;
                  rdfs:domain dd:Decision .


###  https://example.com/dd#subsumes
dd:subsumes rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf dd:isRelatedTo ;
            rdf:type owl:AsymmetricProperty ,
                     owl:IrreflexiveProperty ;
            rdfs:domain dd:Decision ;
            rdfs:range dd:Decision ;
            rdfs:comment "Decision A subsumes decision B: A is broader/more encompassing and B is a narrower part or refinement within A." ;
            rdfs:label "subsumes" .


###  https://schema.org/about
schema:about rdf:type owl:ObjectProperty .


###  https://schema.org/additionalProperty
schema:additionalProperty rdf:type owl:ObjectProperty .


###  https://schema.org/agent
schema:agent rdf:type owl:ObjectProperty .


###  https://schema.org/cost
schema:cost rdf:type owl:ObjectProperty .


###  https://schema.org/mentions
schema:mentions rdf:type owl:ObjectProperty .


###  https://schema.org/relatedTo
schema:relatedTo rdf:type owl:ObjectProperty .


###  https://schema.org/risk
schema:risk rdf:type owl:ObjectProperty .


###  https://schema.org/subjectOf
schema:subjectOf rdf:type owl:ObjectProperty .


