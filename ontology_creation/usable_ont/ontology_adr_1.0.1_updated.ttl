#################################################################
#    Data properties
#################################################################

###  http://schema.org/name
<http://schema.org/name> rdf:type owl:DatatypeProperty ;
                         rdfs:range xsd:string .


###  http://schema.org/text
<http://schema.org/text> rdf:type owl:DatatypeProperty ;
                         rdfs:domain :Alternative ,
                                     :Constraint ,
                                     :Cost ,
                                     :Rationale ,
                                     :Risk ,
                                     sioc_arg:Argument ,
                                     sioc_arg:Issue ,
                                     schema:Decision ;
                         rdfs:range xsd:string .


###  https://example.com/adr#hasEpitome
:hasEpitome rdf:type owl:DatatypeProperty ;
            rdfs:domain :ArchitecturalDesignDecision .


###  https://example.com/adr#hasScope
:hasScope rdf:type owl:DatatypeProperty ;
          rdfs:domain :ArchitecturalDesignDecision .


###  https://example.com/adr#hasTimeStamp
:hasTimeStamp rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain sioc_arg:Argument ,
                          sioc_arg:Issue ,
                          schema:Decision ;
              rdfs:range xsd:dateTime .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class .


###  https://example.com/adr#Alternative
:Alternative rdf:type owl:Class ;
             rdfs:subClassOf schema:Thing ;
             rdfs:comment "A potential solution or option considered during the decision-making process for an architectural design decision."@en ;
             rdfs:label "Alternative"@en .


###  https://example.com/adr#Anticrisis
:Anticrisis rdf:type owl:Class ;
            rdfs:subClassOf :ExistenceDecision ;
            rdfs:comment "A decision that explicitly forbids the existence of a system element, representing a ban or non-existence constraint."@en ;
            rdfs:label "Anticrisis"@en .


###  https://example.com/adr#ArchitecturalDesignDecision
:ArchitecturalDesignDecision rdf:type owl:Class ;
                             rdfs:subClassOf schema:Decision ;
                             rdfs:comment "A significant decision made during the architectural design process of a software-intensive system, representing a first-class entity in software architecture representation."@en ;
                             rdfs:label "ArchitecturalDesignDecision"@en .


###  https://example.com/adr#Constraint
:Constraint rdf:type owl:Class ;
            rdfs:subClassOf schema:Thing ;
            rdfs:comment "A restriction or condition that limits the design space for architectural decisions, often derived from requirements, standards, or organizational policies."@en ;
            rdfs:label "Constraint"@en .


###  https://example.com/adr#Cost
:Cost rdf:type owl:Class ;
      rdfs:subClassOf schema:Thing ;
      rdfs:comment "The resource expenditure associated with implementing an architectural design decision, including development, acquisition, or operational costs."@en ;
      rdfs:label "Cost"@en .


###  https://example.com/adr#DecisionHistory
:DecisionHistory rdf:type owl:Class ;
                 rdfs:subClassOf schema:Thing ;
                 rdfs:comment "A record of changes to an architectural design decision over time, including timestamps, authors, and modifications."@en ;
                 rdfs:label "DecisionHistory"@en .


###  https://example.com/adr#DecisionState
:DecisionState rdf:type owl:Class ;
               rdfs:subClassOf skos:Concept ;
               rdfs:comment "The state or status of an architectural design decision, such as proposed, accepted, rejected, or deprecated."@en ;
               rdfs:label "DecisionState"@en .


###  https://example.com/adr#ExecutiveDecision
:ExecutiveDecision rdf:type owl:Class ;
                   rdfs:subClassOf :ArchitecturalDesignDecision ;
                   rdfs:comment "A decision that governs the process, technology, or organizational aspects of the system, often involving high-level policy or strategic choices."@en ;
                   rdfs:label "ExecutiveDecision"@en .


###  https://example.com/adr#ExistenceDecision
:ExistenceDecision rdf:type owl:Class ;
                   rdfs:subClassOf :ArchitecturalDesignDecision ;
                   rdfs:comment "A decision that asserts the presence or absence of a system element, such as a component, layer, or connector."@en ;
                   rdfs:label "ExistenceDecision"@en .


###  https://example.com/adr#IssueDescription
:IssueDescription rdf:type owl:Class ;
                  rdfs:subClassOf skos:Concept .


###  https://example.com/adr#PropertyDecision
:PropertyDecision rdf:type owl:Class ;
                  rdfs:subClassOf :ArchitecturalDesignDecision ;
                  rdfs:comment "A decision that defines or constrains a property or quality attribute of the system, such as performance, security, or usability."@en ;
                  rdfs:label "PropertyDecision"@en .


###  https://example.com/adr#Rationale
:Rationale rdf:type owl:Class ;
           rdfs:subClassOf schema:Thing ;
           rdfs:comment "The justification or reasoning behind an architectural design decision, including trade-offs, constraints, and alternatives considered."@en ;
           rdfs:label "Rationale"@en .


###  https://example.com/adr#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf schema:Thing ;
      rdfs:comment "The potential for negative consequences associated with an architectural design decision, often quantified by exposure (impact and likelihood)."@en ;
      rdfs:label "Risk"@en .


###  https://example.com/adr#Stakeholder
:Stakeholder rdf:type owl:Class ;
             rdfs:subClassOf schema:Person ;
             rdfs:comment "An individual or group with an interest in the outcome of architectural design decisions, such as developers, architects, or end-users."@en ;
             rdfs:label "Stakeholder"@en .


###  https://example.com/adr#TimeStamp
:TimeStamp rdf:type owl:Class ;
           rdfs:subClassOf skos:Concept .


###  https://example.com/adr#TradeOff
:TradeOff rdf:type owl:Class ;
          rdfs:subClassOf schema:Thing ;
          rdfs:comment "A balancing of competing factors or concerns in architectural design decisions, such as cost, performance, or usability."@en ;
          rdfs:label "TradeOff"@en .


###  https://rdfs.org/sioc/argument#Argument
sioc_arg:Argument rdf:type owl:Class .


###  https://rdfs.org/sioc/argument#Issue
sioc_arg:Issue rdf:type owl:Class .


###  https://schema.org/Decision
schema:Decision rdf:type owl:Class .


###  https://schema.org/Person
schema:Person rdf:type owl:Class .


###  https://schema.org/Thing
schema:Thing rdf:type owl:Class .


#################################################################
#    Annotations
#################################################################

:addresses rdfs:comment "Relates an architectural design decision to a constraint it addresses or satisfies."@en ;
           rdfs:label "addresses"@en .


:constrains rdfs:comment "Indicates that one architectural design decision imposes constraints on another, making the latter contingent upon the former."@en ;
            rdfs:label "constrains"@en .


:enables rdfs:comment "Indicates that one architectural design decision makes another possible, though not mandatory."@en ;
         rdfs:label "enables"@en .


:forbids rdfs:comment "Indicates that one architectural design decision explicitly forbids or excludes another."@en ;
         rdfs:label "forbids"@en .


:hasAlternative rdfs:comment "Relates an architectural design decision to an alternative option considered during its formulation."@en ;
                rdfs:label "hasAlternative"@en .


:hasConstraint rdfs:comment "Relates an architectural design decision to a constraint it must satisfy."@en ;
               rdfs:label "hasConstraint"@en .


:hasCost rdfs:comment "Relates an architectural design decision to its associated cost."@en ;
         rdfs:label "hasCost"@en .


:hasEpitome rdfs:comment "Relates an architectural design decision to a concise summary or epitome of its content."@en ;
            rdfs:label "hasEpitome"@en .


:hasHistory rdfs:comment "Relates an architectural design decision to its history of changes over time."@en ;
            rdfs:label "hasHistory"@en .


:hasRationale rdfs:comment "Relates an architectural design decision to its rationale or justification."@en ;
              rdfs:label "hasRationale"@en .


:hasRisk rdfs:comment "Relates an architectural design decision to its associated risk."@en ;
         rdfs:label "hasRisk"@en .


:hasScope rdfs:comment "Relates an architectural design decision to its scope or domain of applicability."@en ;
          rdfs:label "hasScope"@en .


:hasState rdfs:comment "Relates an architectural design decision to its current state or status."@en ;
          rdfs:label "hasState"@en .


:hasTradeOff rdfs:comment "Relates an architectural design decision to a trade-off it must balance or consider."@en ;
             rdfs:label "hasTradeOff"@en .


:implies rdfs:comment "Indicates that one architectural design decision logically implies or necessitates another."@en ;
         rdfs:label "implies"@en .


:subsumes rdfs:comment "Indicates that one architectural design decision is broader or more encompassing than another."@en ;
          rdfs:label "subsumes"@en .


