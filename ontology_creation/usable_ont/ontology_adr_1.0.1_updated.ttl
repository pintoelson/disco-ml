skos:broader rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#wasDerivedFrom
prov:wasDerivedFrom rdf:type owl:AnnotationProperty .


###  https://example.com/adr#addresses
:addresses rdf:type owl:AnnotationProperty ;
           rdfs:subPropertyOf schema:about ;
           rdfs:range :Constraint ,
                      schema:Decision .


###  https://example.com/adr#constrains
:constrains rdf:type owl:AnnotationProperty ;
            rdfs:subPropertyOf schema:constrains ;
            rdfs:range :ArchitecturalDesignDecision ,
                       schema:Decision .


###  https://example.com/adr#enables
:enables rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf schema:enables ;
         rdfs:range :ArchitecturalDesignDecision ,
                    schema:Decision .


###  https://example.com/adr#forbids
:forbids rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf schema:excludes ;
         rdfs:range :ArchitecturalDesignDecision ,
                    schema:Decision .


###  https://example.com/adr#hasAlternative
:hasAlternative rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf schema:alternate ;
                rdfs:range :Alternative ,
                           schema:Decision .


###  https://example.com/adr#hasConstraint
:hasConstraint rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf schema:subjectOf ;
               rdfs:range :Constraint .


###  https://example.com/adr#hasCost
:hasCost rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf schema:cost ;
         rdfs:range :Cost .


###  https://example.com/adr#hasEpitome
:hasEpitome rdf:type owl:AnnotationProperty ;
            rdfs:range xsd:string .


###  https://example.com/adr#hasHistory
:hasHistory rdf:type owl:AnnotationProperty ;
            rdfs:subPropertyOf schema:hasPart ;
            rdfs:range :DecisionHistory .


###  https://example.com/adr#hasRationale
:hasRationale rdf:type owl:AnnotationProperty ;
              rdfs:subPropertyOf schema:description ;
              rdfs:range :Rationale .


###  https://example.com/adr#hasRisk
:hasRisk rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf schema:risk ;
         rdfs:range :Risk .


###  https://example.com/adr#hasScope
:hasScope rdf:type owl:AnnotationProperty ;
          rdfs:subPropertyOf schema:scope ;
          rdfs:range xsd:string .


###  https://example.com/adr#hasStakeholder
:hasStakeholder rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf schema:contributor ;
                rdfs:range :Stakeholder .


###  https://example.com/adr#hasState
:hasState rdf:type owl:AnnotationProperty ;
          rdfs:subPropertyOf schema:additionalProperty ;
          rdfs:range :DecisionState .


###  https://example.com/adr#hasTradeOff
:hasTradeOff rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf schema:subjectOf ;
             rdfs:range :TradeOff .


###  https://example.com/adr#implies
:implies rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf schema:implies ;
         rdfs:range :ArchitecturalDesignDecision ,
                    schema:Decision .


###  https://example.com/adr#subsumes
:subsumes rdf:type owl:AnnotationProperty ;
          rdfs:subPropertyOf skos:broader ;
          rdfs:range :ArchitecturalDesignDecision ,
                     schema:Decision .


###  https://example.com/adr#tradeOffWith
:tradeOffWith rdf:type owl:AnnotationProperty ;
              rdfs:subPropertyOf schema:relatedTo ;
              rdfs:range :TradeOff .


