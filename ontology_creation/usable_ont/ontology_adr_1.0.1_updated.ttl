@base <https://example.com/adr#> .

<https://example.com/adr> rdf:type owl:Ontology ;
                           dcterms:created "2026-05-04T10:45:31.340367+00:00"^^xsd:dateTime ;
                           dcterms:description "An ontology representing the rationale, trade-offs, and lineage of Architectural Design Decisions (ADD) and records (ADR). It models abstract concepts such as decisions, rationales, constraints, stakeholders, and their interrelationships to capture the decision-making process in software and system architecture." ;
                           dcterms:identifier "hash:275b02d3464b2d38bc8ed17b0d9a957237508a01fc33b46a121cbb6a76e1d795" ;
                           dcterms:title "adr" ;
                           rdfs:comment "An ontology representing the rationale, trade-offs, and lineage of Architectural Design Decisions (ADD) and records (ADR). It models abstract concepts such as decisions, rationales, constraints, stakeholders, and their interrelationships to capture the decision-making process in software and system architecture." ;
                           rdfs:label "Architectural Design Rationale Ontology" ;
                           owl:versionInfo "1.0.1" ;
                           prov:wasDerivedFrom <urn:hash:253d54c61deeda22c9a90270e838294597ad326400a6c64b188deff4c0654198> .

