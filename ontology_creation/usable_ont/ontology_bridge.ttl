@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dd: <https://example.com/dd#> .
@prefix mlops: <https://example.com/mops#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix sioc_arg: <https://rdfs.org/sioc/argument#> .
@prefix schema: <https://schema.org/> .
@prefix bridge: <https://example.com/decision-bridge#> .

<https://example.com/decision-bridge> a owl:Ontology ;
    rdfs:label "MLOps-Decision Bridge Ontology" ;
    rdfs:comment "A mediation layer connecting decision-making entities to MLOps lifecycle artifacts and phases." ;
    owl:imports <https://example.com/dd> , 
                <https://example.com/mlops> .

#################################################################
#    Object Properties
#################################################################

# Entity - Decision, Issue, Arguments(Pro/Con/Neutral), MLAsset(model, dataset)
# Activity - MLLifeCycleActivity
# Agent - Person, SE, DS



###  Issue was generated by Model development activity
###  Model was generated by Model development activity
###  Dataset was generated by Data preparation activity
prov:wasGeneratedBy a owl:ObjectProperty ;
    rdfs:domain prov:Entity ;
    rdfs:range prov:Activity ;
    rdfs:label "was generated by" ;
    rdfs:comment "Formalizes the link between an operational event (e.g., Data Drift) and the start of a decision-making process." .

### Issue was attributed to a Agent(person)
prov:wasAttributedTo a owl:ObjectProperty ;
    rdfs:domain prov:Entity ;
    rdfs:range prov:Agent ;
    rdfs:label "attributed to" ;
    rdfs:comment "Formalizes the link between an operational event (e.g., Data Drift) and the start of a decision-making process." .

# Model development activity used Dataset (Entity)
prov:used a owl:ObjectProperty ;
    rdfs:domain prov:Activity ;
    rdfs:range prov:Entity ;
    rdfs:label "used" ;
    rdfs:comment "Formalizes the link between an operational event (e.g., Data Drift) and the start of a decision-making process." .

# Model Development Activity was associated with a Data Scientist (Agent)
prov:wasAssociatedWith a owl:ObjectProperty ;
    rdfs:domain prov:Activity ;
    rdfs:range prov:Agent ;
    rdfs:label "associated with" ;
    rdfs:comment "Formalizes the link between an operational event (e.g., Data Drift) and the start of a decision-making process." .

###  person is a scientist in a project
bridge:hasRole a owl:ObjectProperty ;
    rdfs:domain schema:Person ;
    rdfs:range mlops:Role ;
    rdfs:label "hasRole" ;
    rdfs:comment "Role of the Author." .