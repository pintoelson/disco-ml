@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dd: <https://example.com/dd#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

dd:DecisionTicketShape
    a sh:NodeShape ;
    sh:targetClass dd:DecisionTicket ; # Targets all instances of this class
    sh:property [
        sh:path dd:ticketID ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Each ticket must have exactly one unique String ID." ;
    ] ;
    sh:property [
        sh:path dd:hasAccountableAgent ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:message "Accountability Error: At least one Agent must be linked." ;
    ] .