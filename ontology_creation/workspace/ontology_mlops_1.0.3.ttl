    rdfs:comment "Relates a process or methodology to the reduction or elimination of research bias."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range mlops:ResearchBias ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:monitorsDeployment rdfs:label "monitorsDeployment"@en ;
    rdfs:comment "Relates a monitoring system to a deployment process it observes."@en ;
