mlops:reliesOnHPC rdfs:label "reliesOnHPC"@en ;
    rdfs:comment "Relates an MLOps process or system to High Performance Computing infrastructure it depends on."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:HPCInfrastructure ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:reliesOnMLOpsCrucialFactor rdfs:label "reliesOnMLOpsCrucialFactor"@en ;
    rdfs:comment "Relates an MLOps process or system to a crucial factor it depends on for successful adoption or implementation."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsCrucialFactor ;
