    rdfs:range mlops:PrivacyConstraint ;
    rdfs:subPropertyOf mlops:hasDeploymentConstraint .

mlops:hasPrivacyManagement rdfs:label "hasPrivacyManagement"@en ;
    rdfs:comment "Relates an MLOps process or system to the privacy management activities it performs or manages."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataPrivacyManagement ;
