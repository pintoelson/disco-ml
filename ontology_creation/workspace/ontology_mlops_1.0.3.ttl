mlops:hasParadigm rdfs:label "hasParadigm"@en ;
    rdfs:comment "Relates an MLOps system or process to the paradigm it follows or implements."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsParadigm ;
