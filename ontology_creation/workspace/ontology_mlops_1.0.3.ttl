    rdfs:range mlops:EdgeModel ;
    rdfs:subPropertyOf mlops:monitors .

mlops:monitorsMetric rdfs:label "monitorsMetric"@en ;
    rdfs:comment "Relates a monitoring process to a metric it tracks."@en ;
    rdfs:domain mlops:ModelMonitoring ;
    rdfs:range mlops:MLMonitoringMetric ;
    rdfs:subPropertyOf mlops:monitors .

mlops:monitorsProductionEnvironment rdfs:label "monitorsProductionEnvironment"@en ;
    rdfs:comment "Relates a monitoring system to the production environment it observes."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:ProductionEnvironment ;
    rdfs:subPropertyOf mlops:monitors .

mlops:optimizedForEdge rdfs:label "optimizedForEdge"@en ;
    rdfs:comment "Relates a model or pipeline to the edge deployment context it is optimized for."@en ;
    rdfs:domain mlops:EdgeModel ;
    rdfs:range mlops:EdgeInfrastructure ;
    rdfs:subPropertyOf schema:subjectOf .

mlops:optimizes rdfs:label "optimizes"@en ;
    rdfs:comment "Relates an AIOps or MLOps system to the objective it aims to optimize."@en ;
    rdfs:domain mlops:AIOpsSolution ;
    rdfs:range mlops:OptimizationObjective ;
    rdfs:subPropertyOf prov:used .

mlops:optimizesFor rdfs:label "optimizesFor"@en ;
    rdfs:comment "Relates a deployment strategy or infrastructure to the optimization goals it addresses, such as latency, cost, or accuracy."@en,
        "Relates a process or artifact to the optimization goal it targets, such as performance, latency, or energy efficiency."@en ;
    rdfs:domain mlops:DeploymentStrategy,
        mlops:MLProcess ;
    rdfs:range mlops:OptimizationGoal,
        schema:Thing ;
    rdfs:subPropertyOf schema:object,
        schema:objective .

mlops:optimizesForQoE a owl:ObjectProperty ;
    rdfs:label "optimizesForQoE"@en ;
    rdfs:comment "Relates an MLOps process or deployment to its focus on improving Quality of Experience for end-users."@en ;
    rdfs:domain mlops:MLPipeline ;
    rdfs:range mlops:QualityOfExperience ;
    rdfs:subPropertyOf schema:potentialAction .

mlops:optimizesMLProductLifecycle a owl:ObjectProperty ;
