    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:Collaboration ;
    rdfs:subPropertyOf prov:wasAssociatedWith .

mlops:supportsContinuousTraining a owl:ObjectProperty ;
    rdfs:label "supportsContinuousTraining"@en ;
    rdfs:comment "Relates an MLOps process or infrastructure to its capability to support continuous training of models."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:ContinuousTraining ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:supportsDeploymentOn rdfs:label "supportsDeploymentOn"@en ;
    rdfs:comment "Relates a deployment process or strategy to the hardware or platform it targets."@en ;
    rdfs:domain mlops:MLPipeline ;
    rdfs:range mlops:DeploymentEnvironment ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:supportsDynamicOrchestration a owl:ObjectProperty ;
    rdfs:label "supportsDynamicOrchestration"@en ;
    rdfs:comment "Relates an infrastructure or platform to its capability to dynamically orchestrate ML workflows or services based on changing requirements."@en ;
    rdfs:domain mlops:MLInfrastructure ;
    rdfs:range mlops:MLPipeline ;
    rdfs:subPropertyOf schema:potentialAction ;
