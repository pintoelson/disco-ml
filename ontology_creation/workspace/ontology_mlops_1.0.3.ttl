mlops:identifiesAdoptionBenefit rdfs:label "identifiesAdoptionBenefit"@en ;
    rdfs:comment "Relates an MLOps process or system to a benefit it identifies or enables during the adoption of MLOps practices."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsAdoptionBenefit ;
