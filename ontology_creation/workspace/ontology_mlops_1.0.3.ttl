<https://example.com/mlops> a owl:Ontology ;
    rdfs:label "Machine Learning Operations (MLOps) Ontology" ;
    dcterms:created "2026-05-03T10:37:35.227192+00:00"^^xsd:dateTime ;
    dcterms:description "An ontology modeling abstract concepts and relationships in Machine Learning Operations (MLOps), covering the ML lifecycle including data engineering, model development, orchestration, infrastructure, and validation. This ontology provides a high-level framework for representing MLOps processes, artifacts, and roles without including specific instances or facts." ;
    dcterms:identifier "hash:bfb417a5ea4cffb8533bebcc07cfb5031986512e1dc304c8fac266de66afd004" ;
    dcterms:title "mlops" ;
    rdfs:comment "An ontology modeling abstract concepts and relationships in Machine Learning Operations (MLOps), covering the ML lifecycle including data engineering, model development, orchestration, infrastructure, and validation. This ontology provides a high-level framework for representing MLOps processes, artifacts, and roles without including specific instances or facts." ;
    owl:versionInfo "1.0.3" ;
    prov:wasDerivedFrom <urn:hash:cd42aab512342583e45024ccd917378b961372cd7c23b019b5c910ccf9664a20> .

mlops:ABStrategy rdfs:label "ABStrategy"@en ;
    rdfs:comment "A deployment strategy where multiple model versions are compared in production using live traffic."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:AIModelDeployment rdfs:label "AIModelDeployment"@en ;
    rdfs:comment "The process of deploying and commissioning AI models into production environments, considering both software and model-specific requirements."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:AIops rdfs:label "AIops"@en ;
    rdfs:comment "The application of artificial intelligence and machine learning techniques to automate and improve IT operations, including monitoring, event correlation, and anomaly detection."@en ;
    rdfs:subClassOf mlops:MLOps .

mlops:AutomatedAction rdfs:label "AutomatedAction"@en ;
    rdfs:comment "An automated response or remediation taken by a system in response to detected anomalies, failures, or other events, often as part of AIOps workflows."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:AutomotiveSector rdfs:label "AutomotiveSector"@en ;
    rdfs:comment "The industry sector focused on the design, manufacturing, and deployment of vehicles, including autonomous driving systems."@en ;
    rdfs:subClassOf mlops:IndustryDomain .

mlops:AutonomousDrivingApplication rdfs:label "AutonomousDrivingApplication"@en ;
    rdfs:comment "A system or process that applies AI/ML to enable vehicles to operate autonomously, often requiring elastic deployment across cloud and edge resources."@en ;
    rdfs:subClassOf schema:Thing .

mlops:BandwidthConstraint rdfs:label "BandwidthConstraint"@en ;
    rdfs:comment "A limitation on data transfer rates between nodes or systems, impacting performance in distributed ML deployments."@en ;
    rdfs:subClassOf schema:Thing .

mlops:BatchProcessing rdfs:label "BatchProcessing"@en ;
    rdfs:comment "The execution of data processing tasks in discrete batches rather than continuously, often used for large-scale data transformations."@en ;
    rdfs:subClassOf mlops:DataMovement .

mlops:BigDataEcosystem a owl:Class ;
    rdfs:label "BigDataEcosystem"@en ;
    rdfs:comment "A complex environment integrating big data technologies, ML, and IoT, characterized by high volume, variety, and velocity of data."@en,
        "An infrastructure ecosystem designed to handle big data workloads, often leveraging HPC technologies."@en ;
    rdfs:subClassOf mlops:MLInfrastructure,
        schema:Thing .

mlops:BlueGreenStrategy rdfs:label "BlueGreenStrategy"@en ;
    rdfs:comment "A deployment strategy where two identical production environments (blue and green) are maintained, with traffic switching between them."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:CanaryStrategy rdfs:label "CanaryStrategy"@en ;
    rdfs:comment "A deployment strategy where a new model version is gradually rolled out to a subset of users."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:ClassificationScheme rdfs:label "ClassificationScheme"@en ;
    rdfs:comment "A structured framework or taxonomy used to categorize and evaluate research studies or artifacts based on predefined criteria or dimensions."@en ;
    rdfs:subClassOf schema:Thing .

mlops:CloudComputing rdfs:label "CloudComputing"@en ;
    rdfs:comment "A computing paradigm where on-demand computing resources are provided over the internet by cloud providers."@en,
        "A model of computing where shared resources, software, and information are provided to devices on-demand over the internet."@en ;
    rdfs:subClassOf mlops:MLInfrastructure,
        schema:Thing ;
    owl:sameAs mlops:CloudDeployment .

mlops:CloudContinuum rdfs:label "CloudContinuum"@en ;
    rdfs:comment "A continuum of cloud and edge computing environments that support MLOps workflows, enabling flexible and scalable deployment of ML models."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:CloudInfrastructure a owl:Class ;
    rdfs:label "CloudInfrastructure"@en ;
    rdfs:comment "A type of ML infrastructure leveraging cloud computing resources for deployment and orchestration of ML workloads."@en,
        "Scalable and elastic infrastructure provided by cloud providers, supporting distributed ML training and inference."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:ClusteringTechnique rdfs:label "ClusteringTechnique"@en ;
    rdfs:comment "A method for grouping data points into clusters based on similarity, often used to reduce communication load or improve energy efficiency."@en ;
    rdfs:subClassOf schema:Thing .

mlops:CollaborationImprovement rdfs:label "CollaborationImprovement"@en ;
    rdfs:comment "A benefit of MLOps adoption characterized by enhanced collaboration between data science, software engineering, and operations teams."@en ;
    rdfs:subClassOf mlops:MLOpsAdoptionBenefit .

mlops:CollaborativeKnowledgeSharing a owl:Class ;
    rdfs:label "CollaborativeKnowledgeSharing"@en ;
    rdfs:comment "A process or environment that facilitates the sharing of knowledge, best practices, and innovations among stakeholders in MLOps, contributing to improved model quality and robustness."@en ;
    rdfs:subClassOf mlops:Collaboration .

mlops:ComputeInfrastructure rdfs:label "ComputeInfrastructure"@en ;
    rdfs:comment "Hardware resources such as CPUs, GPUs, or TPUs used for training and inference in MLOps."@en,
        "Hardware resources such as CPUs, GPUs, or TPUs used for training and inference."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:ComputingResourceCost rdfs:label "ComputingResourceCost"@en ;
    rdfs:comment "A challenge in MLOps projects where the cost of computing resources infrastructure is a significant barrier, particularly for small and medium software development companies."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:ConstructionIndustry rdfs:label "ConstructionIndustry"@en ;
    rdfs:comment "The sector focused on the design, construction, and maintenance of buildings and infrastructure, where AI and MLOps methodologies are applied."@en ;
    rdfs:subClassOf mlops:IndustryDomain .

mlops:Containerization rdfs:label "Containerization"@en ;
    rdfs:comment "A method for packaging ML models and their dependencies into isolated, portable containers to ensure consistent execution across different environments."@en,
        "A technique for packaging ML applications and their dependencies into isolated, portable containers to ensure consistency across environments."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:ContainerizationTool a owl:Class ;
    rdfs:label "ContainerizationTool"@en ;
    rdfs:comment "A tool or platform that enables containerization of ML workloads for deployment and orchestration."@en ;
    rdfs:subClassOf mlops:MLTool .

mlops:ContainerizedInfrastructure a owl:Class ;
    rdfs:label "ContainerizedInfrastructure"@en ;
    rdfs:comment "A type of ML infrastructure leveraging containerization technologies for deployment and orchestration of ML workloads."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:ContinuousDelivery rdfs:label "ContinuousDelivery"@en ;
    rdfs:comment "A deployment strategy focused on the continuous delivery of ML models to production, enabling rapid and reliable updates."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:ContinuousLearning rdfs:label "ContinuousLearning"@en ;
    rdfs:comment "A process of periodically retraining machine learning models based on continuous streams of data to maintain or improve performance over time."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ContinuousMonitoring rdfs:label "ContinuousMonitoring"@en ;
    rdfs:comment "The ongoing process of observing and evaluating machine learning systems in production to detect performance degradation, drift, or failures."@en ;
    rdfs:subClassOf mlops:MLPrinciple .

mlops:ContinuousMonitoringTrainingChallenge a owl:Class ;
    rdfs:label "ContinuousMonitoringTrainingChallenge"@en ;
    rdfs:comment "A challenge in MLOps related to the continuous monitoring and retraining of ML models to address data drift and performance degradation, requiring significant computational resources and organizational support."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:ContinuousValidation a owl:Class ;
    rdfs:label "ContinuousValidation"@en ;
    rdfs:comment "A practice of continuously validating models and processes to identify and correct errors, ensuring high quality, accuracy, and relevance over time."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:CrossDisciplinaryCollaboration rdfs:label "CrossDisciplinaryCollaboration"@en ;
    rdfs:comment "A collaborative effort between data scientists, software engineers, operations experts, and other stakeholders to ensure alignment of ML models with business objectives and proper integration into existing systems."@en ;
    rdfs:subClassOf mlops:Collaboration .

mlops:CrossTeamCollaboration rdfs:label "CrossTeamCollaboration"@en ;
    rdfs:comment "A benefit of MLOps where teams such as data science, software engineering, and operations collaborate effectively to achieve common goals."@en ;
    rdfs:subClassOf mlops:MLOpsBenefit .

mlops:CyberPhysicalProductionSystem rdfs:label "CyberPhysicalProductionSystem"@en ;
    rdfs:comment "A system integrating computational and physical processes in industrial environments, such as those in Industry 4.0, where reaction times, communications, and computation power constraints are critical."@en ;
    rdfs:subClassOf mlops:IndustryDomain .

mlops:DataAccess rdfs:label "DataAccess"@en ;
    rdfs:comment "The ability to retrieve, modify, or utilize data for ML tasks, including permissions, authentication, and authorization mechanisms."@en ;
    rdfs:subClassOf mlops:DataCharacteristic .

mlops:DataAcquisition rdfs:label "DataAcquisition"@en ;
    rdfs:comment "The process of collecting and preparing data for use in AI solutions, including sourcing, cleaning, and labeling."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataCleaning rdfs:label "DataCleaning"@en ;
    rdfs:comment "The process of identifying and correcting or removing errors, inconsistencies, and inaccuracies in datasets to improve data quality."@en ;
    rdfs:subClassOf mlops:DataPreparation .

mlops:DataCollection rdfs:label "DataCollection"@en ;
    rdfs:comment "A process of gathering data from various sources for use in ML systems."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataDiscovery rdfs:label "DataDiscovery"@en ;
    rdfs:comment "The process of identifying, locating, and understanding datasets relevant to ML tasks, including metadata exploration and cataloging."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataDrift rdfs:label "DataDrift"@en ;
    rdfs:comment "A change in the distribution of data over time, which can impact model performance and requires monitoring and mitigation."@en,
        "A type of concept drift where the statistical properties of input data change over time, affecting model performance."@en ;
    rdfs:subClassOf mlops:ConceptDrift ;
    owl:sameAs mlops:ModelDrift .

mlops:DataEngineer rdfs:label "DataEngineer"@en ;
    rdfs:comment "A role responsible for obtaining, preparing, and managing data for AI solutions."@en ;
    rdfs:subClassOf mlops:MLRole ;
    owl:sameAs mlops:DataScientist .

mlops:DataGovernance rdfs:label "DataGovernance"@en ;
    rdfs:comment "A compliance requirement related to the management and protection of data used in ML systems, including cataloging and versioning."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:DataGovernanceRequirement rdfs:label "DataGovernanceRequirement"@en ;
    rdfs:comment "A requirement related to the management, versioning, and traceability of data and models in MLOps, including metadata definition and compliance."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:DataIntegration rdfs:label "DataIntegration"@en ;
    rdfs:comment "The process of combining data from multiple sources into a unified view or dataset for ML tasks."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataLabeling rdfs:label "DataLabeling"@en ;
    rdfs:comment "The process of annotating data with meaningful tags or labels to enable supervised learning tasks."@en ;
    rdfs:subClassOf mlops:DataPreparation .

mlops:DataLakehouse rdfs:label "DataLakehouse"@en ;
    rdfs:comment "A data management architecture that combines the features of data lakes and data warehouses, facilitating scalable and flexible data access for ML systems."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:DataLifecycleChallenge rdfs:label "DataLifecycleChallenge"@en ;
    rdfs:comment "A challenge or issue arising during the data lifecycle in production machine learning, such as data drift, quality degradation, or versioning conflicts."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:DataManagementChallenge rdfs:label "DataManagementChallenge"@en ;
    rdfs:comment "A challenge related to managing data throughout its lifecycle in MLOps, including quality, versioning, and accessibility."@en ;
    rdfs:subClassOf mlops:MLOpsChallenge .

mlops:DataOps a owl:Class ;
    rdfs:label "DataOps"@en ;
    rdfs:comment "A methodology and set of practices for automating and managing data workflows, emphasizing data quality, integration, and continuous delivery, often integrated with MLOps."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:DataPreparationStage a owl:Class ;
    rdfs:label "DataPreparationStage"@en ;
    rdfs:comment "A lifecycle stage involving the preparation, transformation, and validation of data for ML tasks."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:DataPreprocessing rdfs:label "DataPreprocessing"@en ;
    rdfs:comment "The process of cleaning, transforming, and preparing raw data for machine learning tasks."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataProcessing rdfs:label "DataProcessing"@en ;
    rdfs:comment "A process of transforming and preparing data for use in ML systems."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataQuality rdfs:label "DataQuality"@en ;
    rdfs:comment "The degree to which data meets specified requirements for accuracy, completeness, consistency, timeliness, and validity in the context of ML tasks."@en ;
    rdfs:subClassOf mlops:DataCharacteristic .

mlops:DataQualityChallenge a owl:Class ;
    rdfs:label "DataQualityChallenge"@en ;
    rdfs:comment "A challenge related to the quality, quantity, or availability of data required for MLOps processes, including issues like data labeling, cleaning, and preparation."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:DataScientistRole a owl:Class ;
    rdfs:label "DataScientistRole"@en ;
    rdfs:comment "A role focused on designing, training, and evaluating machine learning models, often requiring collaboration with software engineering teams for operationalization."@en ;
    rdfs:subClassOf mlops:MLRole .

mlops:Dataset rdfs:label "Dataset"@en ;
    rdfs:comment "A collection of data used for training, validation, or testing in ML systems."@en ;
    rdfs:subClassOf mlops:MLArtifact ;
    owl:sameAs mlops:usesDataset .

mlops:Deployment rdfs:label "Deployment"@en ;
    rdfs:comment "The process of deploying ML models to production environments for inference or decision-making."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:DeploymentStage a owl:Class ;
    rdfs:label "DeploymentStage"@en ;
    rdfs:comment "A lifecycle stage involving the operationalization of ML models into production environments."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:DeploymentTask rdfs:label "DeploymentTask"@en ;
    rdfs:comment "A specific task or job responsible for deploying a trained model to a production environment."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DistributedDeployment rdfs:label "DistributedDeployment"@en ;
    rdfs:comment "The deployment of ML models or pipelines across multiple computational nodes or geographic locations to achieve scalability and fault tolerance."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:DistributedPipeline a owl:Class ;
    rdfs:label "DistributedPipeline"@en ;
    rdfs:comment "A data pipeline designed to operate across distributed computing environments, such as cloud or edge."@en ;
    rdfs:subClassOf mlops:DataPipeline .

mlops:DistributedTraining rdfs:label "DistributedTraining"@en ;
    rdfs:comment "A machine learning training process that leverages multiple compute nodes to parallelize workloads, improving scalability and performance."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:EdgeArtifact rdfs:label "EdgeArtifact"@en ;
    rdfs:comment "An artifact produced or consumed in edge MLOps, such as quantized models, edge-optimized pipelines, or edge-specific datasets."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:EdgeCollaboration rdfs:label "EdgeCollaboration"@en ;
    rdfs:comment "A collaboration between teams or roles to achieve a common goal in edge MLOps, such as data scientists, edge engineers, and DevOps."@en ;
    rdfs:subClassOf mlops:Collaboration .

mlops:EdgeCompliance rdfs:label "EdgeCompliance"@en ;
    rdfs:comment "A compliance requirement or standard specific to edge deployments, such as data locality, privacy, or resource constraints."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:EdgeDeploymentStrategy rdfs:label "EdgeDeploymentStrategy"@en ;
    rdfs:comment "A deployment strategy tailored for edge environments, such as federated learning, model quantization, or pruning."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:EdgeDevice rdfs:label "EdgeDevice"@en ;
    rdfs:comment "A computing device located at the edge of a network, capable of processing data locally and interacting with cloud or centralized systems."@en,
        "A computing device located at the edge of the network, capable of executing machine learning tasks with constrained resources such as microcontrollers or IoT devices."@en,
        "A hardware device capable of executing ML models at the edge, such as microcontrollers or embedded systems."@en ;
    rdfs:subClassOf mlops:MLInfrastructure,
        schema:Thing ;
    owl:sameAs mlops:EdgeComputing .

mlops:EdgeExperiment rdfs:label "EdgeExperiment"@en ;
    rdfs:comment "An experiment conducted in or for edge environments, often involving constraints such as limited data, compute, or connectivity."@en ;
    rdfs:subClassOf mlops:Experiment .

mlops:EndToEndAutomation rdfs:label "EndToEndAutomation"@en ;
    rdfs:comment "A comprehensive automation approach covering all stages of the ML lifecycle, from data preparation to deployment and monitoring."@en ;
    rdfs:subClassOf mlops:MLPipeline .

mlops:ExpectationManagementChallenge rdfs:label "ExpectationManagementChallenge"@en ;
    rdfs:comment "A challenge related to aligning stakeholder expectations with the realities of MLOps adoption and ML system capabilities."@en ;
    rdfs:subClassOf mlops:MLOpsChallenge .

mlops:ExperimentTracker rdfs:label "ExperimentTracker"@en ;
    rdfs:comment "A tool or platform for tracking experiments, including parameters, metrics, and outcomes."@en ;
    rdfs:subClassOf mlops:MLTool ;
    owl:sameAs mlops:ExperimentTrackingTool .

mlops:ExperimentalNatureChallenge rdfs:label "ExperimentalNatureChallenge"@en ;
    rdfs:comment "A challenge arising from the experimental and iterative nature of ML, which complicates standardization and automation in MLOps."@en ;
    rdfs:subClassOf mlops:MLOpsChallenge .

mlops:FaaS rdfs:label "FaaS"@en ;
    rdfs:comment "Function as a Service, a cloud computing model enabling execution of individual functions in response to events without managing underlying infrastructure."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:FailurePrediction rdfs:label "FailurePrediction"@en ;
    rdfs:comment "A process or system that uses historical data and ML techniques to predict potential failures in IT infrastructure or ML systems before they occur."@en ;
    rdfs:subClassOf mlops:MLProcess ;
    owl:sameAs mlops:FailureManagement .

mlops:FeatureEngineering rdfs:label "FeatureEngineering"@en ;
    rdfs:comment "The process of creating, transforming, and selecting features from raw data to improve model performance."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:FederatedLearning rdfs:label "FederatedLearning"@en ;
    rdfs:comment "A collaborative machine learning approach where models are trained across multiple decentralized devices or servers holding local data samples, without exchanging the data."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:GeneticAlgorithm rdfs:label "GeneticAlgorithm"@en ;
    rdfs:comment "An optimization technique inspired by natural selection, used to solve complex problems by evolving solutions over generations."@en ;
    rdfs:subClassOf schema:Thing .

mlops:GoalQuestionMetricApproach rdfs:label "GoalQuestionMetricApproach"@en ;
    rdfs:comment "A structured methodology for defining research objectives, deriving questions, and establishing metrics to evaluate outcomes, often used in systematic reviews or evaluations."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:HeterogeneousHardware rdfs:label "HeterogeneousHardware"@en ;
    rdfs:comment "Hardware platforms with diverse architectures or capabilities, such as CPUs, GPUs, TPUs, or edge devices, used for deploying ML models."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:HeterogeneousInfrastructure rdfs:label "HeterogeneousInfrastructure"@en ;
    rdfs:comment "A computing infrastructure composed of diverse devices and systems with varying characteristics and requirements, supporting MLOps workflows."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:HighPerformanceComputing rdfs:label "HighPerformanceComputing"@en ;
    rdfs:comment "A computing environment designed to deliver significantly higher performance than standard computing, often used for complex ML workloads like deep learning."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:HybridDeployment rdfs:label "HybridDeployment"@en ;
    rdfs:comment "A deployment strategy combining cloud and edge resources to optimize performance, cost, and scalability for ML workflows."@en,
        "A deployment strategy combining cloud and edge resources to optimize performance, latency, and resource utilization for machine learning models."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:HyperparameterTuning rdfs:label "HyperparameterTuning"@en ;
    rdfs:comment "The process of optimizing model hyperparameters through systematic experimentation to improve performance."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:IdentificationStage a owl:Class ;
    rdfs:label "IdentificationStage"@en ;
    rdfs:comment "A lifecycle stage focused on the initial discovery and selection of manuscripts, datasets, or artifacts based on search terms or criteria."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:Industry40 rdfs:label "Industry40"@en ;
    rdfs:comment "The fourth industrial revolution, characterized by the integration of cyber-physical systems, IoT, and AI in manufacturing and production environments."@en ;
    rdfs:subClassOf mlops:IndustryDomain .

mlops:IntellectualPropertyProtection rdfs:label "IntellectualPropertyProtection"@en ;
    rdfs:comment "The practice of safeguarding proprietary models, algorithms, or data from unauthorized use or reproduction."@en ;
    rdfs:subClassOf schema:Thing .

mlops:IoTEnvironment rdfs:label "IoTEnvironment"@en ;
    rdfs:comment "A challenging ecosystem of interconnected devices and sensors, often with limited resources, requiring specialized ML deployment strategies."@en ;
    rdfs:subClassOf schema:Thing .

mlops:KPIInference rdfs:label "KPIInference"@en ;
    rdfs:comment "The process of deriving Key Performance Indicators (KPIs) from monitoring data to assess the health and performance of ML systems."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:KaizenMLOps a owl:Class ;
    rdfs:label "KaizenMLOps"@en ;
    rdfs:comment "A mature MLOps implementation emphasizing continuous improvement, automation, and cross-functional collaboration, as described in the Kaisen framework."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:LLMIntegration rdfs:label "LLMIntegration"@en ;
    rdfs:comment "The incorporation of Large Language Models (LLMs) into the MLOps lifecycle for tasks such as data processing, model training, or deployment."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:LatencyConstraint rdfs:label "LatencyConstraint"@en ;
    rdfs:comment "A limitation on the delay between request and response in distributed systems, critical for real-time ML applications."@en ;
    rdfs:subClassOf schema:Thing .

mlops:LowPowerDevice rdfs:label "LowPowerDevice"@en ;
    rdfs:comment "A device with limited computational resources, requiring specialized ML frameworks and optimizations for deployment."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLBenchmarking rdfs:label "MLBenchmarking"@en ;
    rdfs:comment "A process or system that evaluates and compares the performance of ML models or configurations against standardized datasets or metrics."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLDeployment rdfs:label "MLDeployment"@en ;
    rdfs:comment "The act or process of deploying an ML model to a production environment for inference or decision-making."@en ;
    rdfs:subClassOf prov:Activity .

mlops:MLDeploymentArtifact rdfs:label "MLDeploymentArtifact"@en ;
    rdfs:comment "An artifact produced or consumed during the deployment of ML models, such as deployment configurations, rollout plans, or monitoring dashboards."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:MLDeploymentComplexity rdfs:label "MLDeploymentComplexity"@en ;
    rdfs:comment "The complexity associated with deploying ML models into production environments, including integration, monitoring, and maintenance."@en ;
    rdfs:subClassOf mlops:MLWorkflowComplexity .

mlops:MLEngineerRole rdfs:label "MLEngineerRole"@en ;
    rdfs:comment "A role responsible for ensuring the quality of ML code through refactoring and application of robust programming standards, facilitating deployment and maintenance of ML models in production environments."@en ;
    rdfs:subClassOf mlops:MLEngineer .

mlops:MLFrameworkArchitecture rdfs:label "MLFrameworkArchitecture"@en ;
    rdfs:comment "The architectural design and implementation of an ML framework, including its resource requirements and dependencies."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLLibraryIncompatibility rdfs:label "MLLibraryIncompatibility"@en ;
    rdfs:comment "A situation where incompatibilities between ML libraries or frameworks hinder the MLOps process."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLObservability rdfs:label "MLObservability"@en ;
    rdfs:comment "The capability to measure, monitor, and understand the internal states and behaviors of ML systems and models in production environments."@en ;
    rdfs:subClassOf mlops:MLMonitoring ;
    owl:sameAs mlops:MLObservabilityIssue .

mlops:MLOpsAdoptionInSDC rdfs:label "MLOpsAdoptionInSDC"@en ;
    rdfs:comment "The process and practices of adopting MLOps methodologies and principles within software development companies to bridge the gap between development, operations, and data science teams."@en ;
    rdfs:subClassOf mlops:MLOpsProcess .

mlops:MLOpsArchitecture rdfs:label "MLOpsArchitecture"@en ;
    rdfs:comment "A high-level design or blueprint for organizing and integrating components within an MLOps system, such as microservices, pipelines, or infrastructure layers."@en ;
    rdfs:subClassOf schema:SoftwareSourceCode .

mlops:MLOpsArtifactCost a owl:Class ;
    rdfs:label "MLOpsArtifactCost"@en ;
    rdfs:comment "The cost associated with producing, storing, or maintaining MLOps artifacts such as datasets, models, or pipelines, particularly relevant for SMEs."@en ;
    rdfs:subClassOf mlops:MLLifecycleConstraint .

mlops:MLOpsArtifactInSDC rdfs:label "MLOpsArtifactInSDC"@en ;
    rdfs:comment "An artifact produced or consumed within the MLOps lifecycle in software development companies, such as model configurations, pipeline definitions, or compliance reports."@en ;
    rdfs:subClassOf mlops:MLOpsArtifact .

mlops:MLOpsCollaboration rdfs:label "MLOpsCollaboration"@en ;
    rdfs:comment "A collaboration focused on MLOps practices, involving teams such as data science, DevOps, and software engineering."@en,
        "A coordinated effort between data engineers, data scientists, and operations professionals to achieve common goals in MLOps."@en,
        "A coordinated effort between teams or roles specifically focused on MLOps activities, such as data scientists and DevOps engineers collaborating on model deployment."@en ;
    rdfs:subClassOf mlops:Collaboration .

mlops:MLOpsInfrastructure rdfs:label "MLOpsInfrastructure"@en ;
    rdfs:comment "The infrastructure components specifically designed to support MLOps workflows, such as Kubernetes clusters or GPU-enabled compute nodes."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:MLOpsMaturityLevel0 rdfs:label "MLOpsMaturityLevel0"@en ;
    rdfs:comment "The initial stage of MLOps maturity where no DevOps or MLOps practices have been adopted. Teams are disparate, releases are complicated, and processes are ad hoc."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:MLOpsMaturityLevel1 rdfs:label "MLOpsMaturityLevel1"@en ;
    rdfs:comment "A stage of MLOps maturity where DevOps practices are implemented for non-ML components, but not extended to ML workflows. Training environments may be managed, but deployment is manual."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:MLOpsMaturityLevel2 rdfs:label "MLOpsMaturityLevel2"@en ;
    rdfs:comment "A stage of MLOps maturity where automated training environments are in place, models are easy to replicate, and ML pipelines are automated. However, deployment is not yet fully automated."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:MLOpsMaturityLevel3 rdfs:label "MLOpsMaturityLevel3"@en ;
    rdfs:comment "A stage of MLOps maturity where automated training and deployment processes are in place, enabling faster and more efficient deployment of models into production. CI/CD practices are implemented for ML models."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:MLOpsMaturityLevel4 rdfs:label "MLOpsMaturityLevel4"@en ;
    rdfs:comment "The highest stage of MLOps maturity where full automation of MLOps operations is achieved. This includes automated training, deployment, continuous monitoring, and automated retraining of models in production."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:MLOpsOrchestrator rdfs:label "MLOpsOrchestrator"@en ;
    rdfs:comment "A system or tool responsible for coordinating and managing MLOps workflows, including scheduling, dependency resolution, and error handling."@en ;
    rdfs:subClassOf mlops:MLTool .

mlops:MLOpsRoadmap rdfs:label "MLOpsRoadmap"@en ;
    rdfs:comment "A structured plan or framework outlining the evolution and adoption of MLOps practices over time, including milestones, technologies, and organizational changes."@en ;
    rdfs:subClassOf schema:CreativeWork .

mlops:MLOpsRole rdfs:label "MLOpsRole"@en ;
    rdfs:comment "A role specifically focused on MLOps practices, such as MLOps Engineer or DataOps Engineer."@en,
        "A role within the MLOps framework, such as Data Engineer, Data Scientist, or DevOps Engineer."@en ;
    rdfs:subClassOf mlops:MLRole .

mlops:MLOpsRoleInSDC rdfs:label "MLOpsRoleInSDC"@en ;
    rdfs:comment "A role or responsibility within software development companies specifically focused on MLOps practices, such as MLOps Engineer, DataOps Engineer, or ML Engineer."@en ;
    rdfs:subClassOf mlops:MLRole .

mlops:MLOpsSurvey rdfs:label "MLOpsSurvey"@en ;
    rdfs:comment "A systematic survey or review of MLOps practices, challenges, and opportunities, providing structured insights and recommendations for the domain."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLOpsTeam rdfs:label "MLOpsTeam"@en ;
    rdfs:comment "A team or group responsible for implementing and maintaining MLOps practices and processes."@en ;
    rdfs:subClassOf prov:Agent .

mlops:MLResourceConstraint rdfs:label "MLResourceConstraint"@en ;
    rdfs:comment "A limitation on the computational, memory, or storage resources available for MLOps processes."@en ;
    rdfs:subClassOf mlops:MLLifecycleConstraint ;
    owl:sameAs mlops:MLEnvironmentalConstraint,
        mlops:MLRegulatoryConstraint .

mlops:MLRoleAlignmentArtifact rdfs:label "MLRoleAlignmentArtifact"@en ;
    rdfs:comment "An artifact documenting the alignment of roles within MLOps with organizational goals and each other's responsibilities."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:MLRoleAlignmentProcess rdfs:label "MLRoleAlignmentProcess"@en ;
    rdfs:comment "A process for aligning roles within MLOps with organizational goals and each other's responsibilities."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleAlignmentRequirement rdfs:label "MLRoleAlignmentRequirement"@en ;
    rdfs:comment "A requirement or standard related to the alignment of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLComplianceRequirement .

mlops:MLRoleBoundary rdfs:label "MLRoleBoundary"@en ;
    rdfs:comment "The defined limits and responsibilities of a role within MLOps, ensuring clarity and reducing ambiguity in task execution."@en ;
    rdfs:subClassOf mlops:MLRoleDefinition .

mlops:MLRoleClarityArtifact rdfs:label "MLRoleClarityArtifact"@en ;
    rdfs:comment "An artifact documenting the clarity of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:MLRoleClarityProcess rdfs:label "MLRoleClarityProcess"@en ;
    rdfs:comment "A process for ensuring the clarity of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleClarityRequirement rdfs:label "MLRoleClarityRequirement"@en ;
    rdfs:comment "A requirement or standard related to the clarity of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLComplianceRequirement .

mlops:MLRoleCollaborationArtifact rdfs:label "MLRoleCollaborationArtifact"@en ;
    rdfs:comment "An artifact documenting the collaboration between roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:MLRoleCollaborationProcess rdfs:label "MLRoleCollaborationProcess"@en ;
    rdfs:comment "A process for fostering collaboration between roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleCollaborationRequirement rdfs:label "MLRoleCollaborationRequirement"@en ;
    rdfs:comment "A requirement or standard related to the collaboration of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLComplianceRequirement .

mlops:MLRoleCompliance rdfs:label "MLRoleCompliance"@en ;
    rdfs:comment "A requirement or standard related to the clarity, collaboration, and alignment of roles within MLOps."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:MLRoleConflict rdfs:label "MLRoleConflict"@en ;
    rdfs:comment "A situation where the responsibilities or goals of roles within MLOps conflict, leading to inefficiencies or delays."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLRoleDevelopment rdfs:label "MLRoleDevelopment"@en ;
    rdfs:comment "The process of developing and refining roles within MLOps to improve clarity, collaboration, and alignment with organizational goals."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleEffectiveness rdfs:label "MLRoleEffectiveness"@en ;
    rdfs:comment "A measure of how well roles within MLOps achieve their intended outcomes and contribute to organizational goals."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLRoleEfficiency rdfs:label "MLRoleEfficiency"@en ;
    rdfs:comment "A measure of how effectively roles within MLOps perform their responsibilities without redundancy or conflict."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLRoleFramework rdfs:label "MLRoleFramework"@en ;
    rdfs:comment "A framework for defining and managing roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:MLRoleGovernance rdfs:label "MLRoleGovernance"@en ;
    rdfs:comment "The framework and processes for managing roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:MLRoleGovernanceArtifact rdfs:label "MLRoleGovernanceArtifact"@en ;
    rdfs:comment "An artifact documenting the governance of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:MLRoleGovernanceProcess rdfs:label "MLRoleGovernanceProcess"@en ;
    rdfs:comment "A process for governing roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleGovernanceRequirement rdfs:label "MLRoleGovernanceRequirement"@en ;
    rdfs:comment "A requirement or standard related to the governance of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLComplianceRequirement .

mlops:MLRoleIntegrationArtifact rdfs:label "MLRoleIntegrationArtifact"@en ;
    rdfs:comment "An artifact documenting the integration of roles within MLOps to ensure seamless collaboration and alignment of goals."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:MLRoleIntegrationProcess rdfs:label "MLRoleIntegrationProcess"@en ;
    rdfs:comment "A process for integrating roles within MLOps to ensure seamless collaboration and alignment of goals."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleIntegrationRequirement rdfs:label "MLRoleIntegrationRequirement"@en ;
    rdfs:comment "A requirement or standard related to the integration of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLComplianceRequirement .

mlops:MLRoleManagement rdfs:label "MLRoleManagement"@en ;
    rdfs:comment "The process of managing roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleManagementArtifact rdfs:label "MLRoleManagementArtifact"@en ;
    rdfs:comment "An artifact documenting the management of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:MLRoleManagementProcess rdfs:label "MLRoleManagementProcess"@en ;
    rdfs:comment "A process for managing roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleOptimizationArtifact rdfs:label "MLRoleOptimizationArtifact"@en ;
    rdfs:comment "An artifact documenting the optimization of roles within MLOps to reduce redundancy, clarify boundaries, and improve collaboration and alignment."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:MLRoleOptimizationProcess rdfs:label "MLRoleOptimizationProcess"@en ;
    rdfs:comment "A process for optimizing roles within MLOps to reduce redundancy, clarify boundaries, and improve collaboration and alignment."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleOptimizationRequirement rdfs:label "MLRoleOptimizationRequirement"@en ;
    rdfs:comment "A requirement or standard related to the optimization of roles within MLOps, including role definitions, responsibilities, and collaboration."@en ;
    rdfs:subClassOf mlops:MLComplianceRequirement .

mlops:MLRoleProductivity rdfs:label "MLRoleProductivity"@en ;
    rdfs:comment "A measure of the productivity of roles within MLOps, influenced by role clarity, collaboration, and alignment with goals."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLRoleRedundancy rdfs:label "MLRoleRedundancy"@en ;
    rdfs:comment "A situation where the responsibilities of roles within MLOps overlap or duplicate, leading to inefficiencies or wasted effort."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLRoleResponsibility rdfs:label "MLRoleResponsibility"@en ;
    rdfs:comment "A specific responsibility assigned to a role within MLOps, such as model training, deployment, or monitoring."@en ;
    rdfs:subClassOf mlops:MLRoleDefinition .

mlops:MLRoleSatisfaction rdfs:label "MLRoleSatisfaction"@en ;
    rdfs:comment "A measure of the satisfaction of individuals performing roles within MLOps, influenced by role clarity, collaboration, and alignment with goals."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLRoleSkillset rdfs:label "MLRoleSkillset"@en ;
    rdfs:comment "The set of skills required for a role within MLOps, such as software engineering, data science, or DevOps expertise."@en ;
    rdfs:subClassOf mlops:MLRoleDefinition .

mlops:MLRoleStandardization rdfs:label "MLRoleStandardization"@en ;
    rdfs:comment "A structured approach to standardizing roles within MLOps, including role definitions, responsibilities, and collaboration frameworks."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:MLRoleTraining rdfs:label "MLRoleTraining"@en ;
    rdfs:comment "The process of providing training and development opportunities to individuals performing roles within MLOps to enhance their skills and effectiveness."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLSystemOperation rdfs:label "MLSystemOperation"@en ;
    rdfs:comment "The operational phase of an ML system, including deployment, monitoring, maintenance, and lifecycle management in production environments."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:MLValidationIssue rdfs:label "MLValidationIssue"@en ;
    rdfs:comment "A problem or gap in the validation of an ML model or artifact, such as incorrect performance metrics or missing compliance checks."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:MLValidationProcess rdfs:label "MLValidationProcess"@en ;
    rdfs:comment "A process that validates the correctness, performance, and compliance of ML models or artifacts before deployment or release."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLVersionControl rdfs:label "MLVersionControl"@en ;
    rdfs:comment "A system or process for versioning machine learning-specific components such as models and datasets, distinct from traditional software version control."@en ;
    rdfs:subClassOf mlops:MLTool .

mlops:ManualMLOps a owl:Class ;
    rdfs:label "ManualMLOps"@en ;
    rdfs:comment "An initial maturity stage where MLOps processes are performed manually with minimal automation, often relying on ad-hoc scripts and manual intervention."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel ;
    owl:sameAs mlops:AutomatedMLOps,
        mlops:MLOpsImplementationChallenge .

mlops:MetaheuristicTechnique rdfs:label "MetaheuristicTechnique"@en ;
    rdfs:comment "An optimization approach that uses heuristic methods to find approximate solutions to complex problems, often used in cloud deployments."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MobileDevice rdfs:label "MobileDevice"@en ;
    rdfs:comment "A portable device, such as a smartphone or tablet, capable of running ML models locally or via cloud services."@en ;
    rdfs:subClassOf schema:Thing .

mlops:Model rdfs:label "Model"@en ;
    rdfs:comment "A machine learning model, including its architecture, parameters, and metadata."@en ;
    rdfs:subClassOf mlops:MLArtifact ;
    owl:sameAs mlops:ModelServing,
        mlops:ModelServingTool,
        mlops:ModelVersioning .

mlops:ModelDriftMitigation rdfs:label "ModelDriftMitigation"@en ;
    rdfs:comment "A process or system for detecting and addressing model drift to maintain model performance over time, including retraining, adjustment, or rollback strategies."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ModelExplainabilityCompliance rdfs:label "ModelExplainabilityCompliance"@en ;
    rdfs:comment "A compliance requirement ensuring that models are interpretable and their decisions can be explained."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:ModelLifecycleEfficiency rdfs:label "ModelLifecycleEfficiency"@en ;
    rdfs:comment "A benefit of MLOps adoption characterized by improved efficiency in the machine learning model lifecycle, including faster development, deployment, and maintenance."@en ;
    rdfs:subClassOf mlops:MLOpsAdoptionBenefit .

mlops:ModelMaintenance rdfs:label "ModelMaintenance"@en ;
    rdfs:comment "A lifecycle stage focused on the ongoing maintenance, updates, and optimization of deployed models to ensure sustained performance and reliability."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage ;
    owl:sameAs mlops:MLModelMaintenance .

mlops:ModelOptimization rdfs:label "ModelOptimization"@en ;
    rdfs:comment "The process of improving a model's performance through techniques such as quantization, pruning, or architecture search."@en ;
    rdfs:subClassOf mlops:MLProcess ;
    owl:sameAs mlops:InferenceOptimization .

mlops:ModelPerformanceMonitoring rdfs:label "ModelPerformanceMonitoring"@en ;
    rdfs:comment "A process or system dedicated to observing and evaluating the performance of ML models in production, including detection of performance degradation, drift, and anomalies."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ModelPruning rdfs:label "ModelPruning"@en ;
    rdfs:comment "A technique for reducing the size and computational requirements of machine learning models by removing unnecessary parameters or layers."@en,
        "The process of removing unnecessary parameters or neurons from a model to reduce its size and computational requirements for edge deployment."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ModelQuantization rdfs:label "ModelQuantization"@en ;
    rdfs:comment "A technique for reducing the computational and memory footprint of machine learning models by quantizing model parameters to lower precision."@en,
        "The process of reducing the precision of a model's parameters to optimize for edge deployment, often involving techniques like quantization-aware training."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ModelRelevance a owl:Class ;
    rdfs:label "ModelRelevance"@en ;
    rdfs:comment "The ability of a machine learning model to remain effective and applicable over time, maintained through continuous monitoring, validation, and adaptation to changing conditions."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ModelTraining rdfs:label "ModelTraining"@en ;
    rdfs:comment "A lifecycle stage where ML models are trained on prepared data using specified algorithms and hyperparameters."@en,
        "A lifecycle stage where machine learning models are trained using prepared datasets and specified configurations."@en,
        "The lifecycle stage where machine learning models are trained using prepared data and configured parameters."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:ModelValidation rdfs:label "ModelValidation"@en ;
    rdfs:comment "A lifecycle stage where trained models are evaluated for performance, bias, and compliance before deployment."@en,
        "A lifecycle stage where trained models are evaluated for performance, fairness, and compliance before deployment."@en,
        "The lifecycle stage where trained models are evaluated for performance, fairness, and compliance before deployment."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:ModularizationChallenge rdfs:label "ModularizationChallenge"@en ;
    rdfs:comment "The difficulty in decomposing AI/ML systems into modular components due to their complex, interconnected nature."@en ;
    rdfs:subClassOf mlops:MLWorkflowComplexity .

mlops:Monitoring rdfs:label "Monitoring"@en ;
    rdfs:comment "The continuous observation and evaluation of ML models and systems to detect performance degradation, drift, or failures."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:MonitoringPipeline rdfs:label "MonitoringPipeline"@en ;
    rdfs:comment "An automated workflow that continuously observes deployed models for performance and drift."@en ;
    rdfs:subClassOf mlops:MLPipeline .

mlops:MonitoringTask rdfs:label "MonitoringTask"@en ;
    rdfs:comment "A specific task or job responsible for observing and evaluating the performance and behavior of deployed models or systems."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MultiObjectiveOptimization rdfs:label "MultiObjectiveOptimization"@en ;
    rdfs:comment "An optimization approach that considers multiple, often conflicting objectives simultaneously, such as cost, performance, and resilience."@en ;
    rdfs:subClassOf schema:Thing .

mlops:NeuralNetworkModel a owl:Class ;
    rdfs:label "NeuralNetworkModel"@en ;
    rdfs:comment "A machine learning model based on neural network architectures."@en ;
    rdfs:subClassOf mlops:DeepLearningModel .

mlops:OperationalEfficiency rdfs:label "OperationalEfficiency"@en ;
    rdfs:comment "A benefit of MLOps characterized by streamlined processes, reduced manual effort, and improved resource utilization in ML lifecycle management."@en ;
    rdfs:subClassOf mlops:MLOpsBenefit .

mlops:Orchestration rdfs:label "Orchestration"@en ;
    rdfs:comment "The automated arrangement, coordination, and management of workflows and processes in MLOps to ensure efficient execution of machine learning pipelines."@en,
        "The coordination and management of ML workflows, including task scheduling, dependency resolution, and resource allocation."@en,
        "The coordination and management of multiple processes or systems to achieve a unified workflow, such as training and inference."@en ;
    rdfs:subClassOf mlops:MLPrinciple,
        mlops:MLProcess ;
    owl:sameAs mlops:OrchestrationInfrastructure .

mlops:PRISMAStatement rdfs:label "PRISMAStatement"@en ;
    rdfs:comment "A methodological framework for reporting systematic reviews and meta-analyses, emphasizing transparency and completeness in study selection and reporting."@en ;
    rdfs:subClassOf schema:CreativeWork .

mlops:Packaging rdfs:label "Packaging"@en ;
    rdfs:comment "The process of preparing ML models and artifacts for deployment, including containerization and artifact versioning."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:Parallelization rdfs:label "Parallelization"@en ;
    rdfs:comment "The technique of dividing a computational task into smaller subtasks that can be executed simultaneously to improve performance."@en ;
    rdfs:subClassOf mlops:TaskDistribution .

mlops:PipelineOrchestrationTool rdfs:label "PipelineOrchestrationTool"@en ;
    rdfs:comment "A tool for orchestrating and managing MLOps pipelines."@en ;
    rdfs:subClassOf mlops:MLTool .

mlops:PredictiveMaintenance rdfs:label "PredictiveMaintenance"@en ;
    rdfs:comment "A specialized domain within failure management that uses predictive models to anticipate equipment failures and schedule maintenance proactively."@en ;
    rdfs:subClassOf mlops:FailureManagement .

mlops:QualityCriteria rdfs:label "QualityCriteria"@en ;
    rdfs:comment "A set of predefined standards or benchmarks used to evaluate the relevance, rigor, or impact of research studies or artifacts in a systematic review."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:DataQualityAssessment .

mlops:Redeployment rdfs:label "Redeployment"@en ;
    rdfs:comment "The process of deploying a new or updated model version into production, replacing or augmenting existing deployments."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:Reproducibility rdfs:label "Reproducibility"@en ;
    rdfs:comment "The ability to recreate the same results from a machine learning process, including data, model, and code versioning, ensuring consistency and reliability."@en ;
    rdfs:subClassOf mlops:MLPrinciple .

mlops:ResearchProtocol rdfs:label "ResearchProtocol"@en ;
    rdfs:comment "A predefined methodology or framework guiding the execution of research activities, including stages such as planning, execution, analysis, and reporting."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ResearchQuestion rdfs:label "ResearchQuestion"@en ;
    rdfs:comment "A specific inquiry formulated to guide the investigation or evaluation of a topic, often derived from research objectives or goals."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ResourceConstrainedEnvironment rdfs:label "ResourceConstrainedEnvironment"@en ;
    rdfs:comment "An environment with limited computational, memory, or energy resources, such as microcontrollers or embedded systems, requiring specialized optimization for ML model deployment."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:ResourceManagement rdfs:label "ResourceManagement"@en ;
    rdfs:comment "A process or system that optimizes the allocation and utilization of computational resources, such as compute, storage, and network, for ML and IT operations."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:Retraining rdfs:label "Retraining"@en ;
    rdfs:comment "A process of updating a machine learning model with new data to adapt to changing conditions or improve performance."@en,
        "The process of updating a model with new data to adapt to changing patterns or drifts in the production environment."@en,
        "The process of updating or retraining ML models with new data to maintain or improve performance over time."@en ;
    rdfs:subClassOf mlops:MLProcess ;
    owl:sameAs mlops:ModelRetraining .

mlops:RiskPrediction rdfs:label "RiskPrediction"@en ;
    rdfs:comment "A process or system that predicts risks associated with ML systems, such as model failure, data drift, or compliance violations."@en ;
    rdfs:subClassOf mlops:MLProcess ;
    owl:sameAs mlops:ITRiskPrediction .

mlops:ScopusAPI rdfs:label "ScopusAPI"@en ;
    rdfs:comment "A specific API provided by Scopus for accessing metadata and search capabilities in academic databases."@en ;
    rdfs:subClassOf mlops:MLTool .

mlops:ScreeningStage a owl:Class ;
    rdfs:label "ScreeningStage"@en ;
    rdfs:comment "A lifecycle stage focused on evaluating and filtering manuscripts or artifacts based on predefined criteria during the screening phase of research or model development."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage,
        mlops:SelectionStage ;
    owl:sameAs mlops:MonitoringStage .

mlops:Serverless rdfs:label "Serverless"@en ;
    rdfs:comment "A cloud computing execution model where the cloud provider dynamically manages infrastructure, allowing developers to focus on code without server management."@en ;
    rdfs:subClassOf mlops:MLInfrastructure ;
    owl:sameAs mlops:ServerlessArchitecture,
        mlops:ServerlessExecution .

mlops:ServerlessTool a owl:Class ;
    rdfs:label "ServerlessTool"@en ;
    rdfs:comment "A tool or platform that enables serverless deployment of ML workloads."@en ;
    rdfs:subClassOf mlops:MLTool ;
    owl:sameAs mlops:ServerlessInfrastructure .

mlops:SliceDeployment rdfs:label "SliceDeployment"@en ;
    rdfs:comment "A deployment strategy for network slicing in 5G/6G architectures, often involving ML-based optimization."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:SoftwareDefinedNetwork rdfs:label "SoftwareDefinedNetwork"@en ;
    rdfs:comment "A network architecture where network control is decoupled from forwarding and is directly programmable, enabling dynamic and centralized management."@en ;
    rdfs:subClassOf schema:Thing .

mlops:SoftwareDevelopmentCompany rdfs:label "SoftwareDevelopmentCompany"@en ;
    rdfs:comment "An organization focused on the development of software products or services, which may adopt MLOps practices to integrate machine learning into their workflows."@en ;
    rdfs:subClassOf schema:Organization .

mlops:SoftwareEngineerRole a owl:Class ;
    rdfs:label "SoftwareEngineerRole"@en ;
    rdfs:comment "A role responsible for the maintenance, evolution, and operationalization of AI solutions, bridging the gap between data science and software engineering."@en ;
    rdfs:subClassOf mlops:MLRole .

mlops:SoftwareEngineeringMLIntegration rdfs:label "SoftwareEngineeringMLIntegration"@en ;
    rdfs:comment "The intersection and integration challenges between software engineering practices and machine learning workflows, including version control, modularization, and deployment strategies."@en ;
    rdfs:subClassOf mlops:MLWorkflowComplexity .

mlops:SoftwareEngineeringMLIntegrationChallenge a owl:Class ;
    rdfs:label "SoftwareEngineeringMLIntegrationChallenge"@en ;
    rdfs:comment "A challenge arising from the integration of data science and software engineering practices in MLOps, including maintenance, evolution, and operationalization of AI solutions."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:StandardizedDevelopmentProcess a owl:Class ;
    rdfs:label "StandardizedDevelopmentProcess"@en ;
    rdfs:comment "A structured and standardized approach to developing machine learning models, ensuring consistency, reliability, and adherence to best practices throughout the MLOps lifecycle."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:StorageInfrastructure rdfs:label "StorageInfrastructure"@en ;
    rdfs:comment "Systems for storing datasets, models, and artifacts, such as databases or object storage."@en,
        "Systems for storing datasets, models, and other artifacts, such as databases or object storage."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:TalentShortageChallenge rdfs:label "TalentShortageChallenge"@en ;
    rdfs:comment "A challenge related to the scarcity of specialized talent required for MLOps implementation and maintenance."@en ;
    rdfs:subClassOf mlops:MLOpsChallenge ;
    owl:sameAs mlops:QualifiedPersonnelShortage .

mlops:TeamIntegrationChallenge rdfs:label "TeamIntegrationChallenge"@en ;
    rdfs:comment "A challenge related to integrating cross-functional teams (e.g., data scientists, DevOps, software engineers) in MLOps initiatives."@en ;
    rdfs:subClassOf mlops:MLOpsChallenge .

mlops:TrainingPipeline rdfs:label "TrainingPipeline"@en ;
    rdfs:comment "An automated workflow that orchestrates the training of machine learning models."@en ;
    rdfs:subClassOf mlops:MLPipeline ;
    owl:sameAs mlops:DeploymentPipeline .

mlops:TrainingStage a owl:Class ;
    rdfs:label "TrainingStage"@en ;
    rdfs:comment "A lifecycle stage focused on the training and evaluation of ML models."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:TrainingTask rdfs:label "TrainingTask"@en ;
    rdfs:comment "A specific task or job responsible for training a machine learning model using a dataset and computational resources."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:VersionControlManagement rdfs:label "VersionControlManagement"@en ;
    rdfs:comment "The process of managing versions of data, models, and code in MLOps, including tracking changes and maintaining lineage."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:WindPowerIndustry rdfs:label "WindPowerIndustry"@en ;
    rdfs:comment "The sector focused on the generation of electricity from wind energy, where monitoring systems and AI/ML models are critical."@en ;
    rdfs:subClassOf mlops:IndustryDomain .

mlops:WirelessSensorNetwork rdfs:label "WirelessSensorNetwork"@en ;
    rdfs:comment "A network of distributed sensors that communicate wirelessly to monitor physical or environmental conditions, often used in industrial or environmental monitoring."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:addressesEducationGap a owl:ObjectProperty ;
    rdfs:label "addressesEducationGap"@en ;
    rdfs:comment "Relates an MLOps process or system to the challenge of the MLOps education gap, emphasizing the need for academic programs to include MLOps training."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsEducationGap ;
    rdfs:subPropertyOf mlops:addressesChallenge .

mlops:addressesInfrastructureOptimization a owl:ObjectProperty ;
    rdfs:label "addressesInfrastructureOptimization"@en ;
    rdfs:comment "Relates an MLOps process or system to the optimization of infrastructure to better support MLOps workflows."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLInfrastructureOptimization ;
    rdfs:subPropertyOf mlops:addressesChallenge .

mlops:addressesMLOpsChallengeInSDC rdfs:label "addressesMLOpsChallengeInSDC"@en ;
    rdfs:comment "Relates an MLOps process or system to a specific challenge it addresses within software development companies."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsChallengeInSDC ;
    rdfs:subPropertyOf prov:used .

mlops:addressesPersonnelShortage a owl:ObjectProperty ;
    rdfs:label "addressesPersonnelShortage"@en ;
    rdfs:comment "Relates an MLOps process or system to the challenge of qualified personnel shortage, highlighting the need for training and role clarity."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:QualifiedPersonnelShortage ;
    rdfs:subPropertyOf mlops:addressesChallenge .

mlops:addressesRoleAmbiguity a owl:ObjectProperty ;
    rdfs:label "addressesRoleAmbiguity"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the role ambiguity it addresses or reduces."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleAmbiguity ;
    rdfs:subPropertyOf mlops:addressesChallenge .

mlops:addressesRoleOverlap a owl:ObjectProperty ;
    rdfs:label "addressesRoleOverlap"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the role overlap it addresses or reduces."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleOverlap ;
    rdfs:subPropertyOf mlops:addressesChallenge .

mlops:affectsProductivity a owl:ObjectProperty ;
    rdfs:label "affectsProductivity"@en ;
    rdfs:comment "Relates an MLOps challenge or process to the productivity of stakeholders, such as role ambiguity or lack of qualified personnel."@en,
        "Relates an MLOps challenge or process to the productivity of stakeholders."@en ;
    rdfs:domain mlops:MLChallenge,
        mlops:MLInterdisciplinaryChallenge ;
    rdfs:range mlops:MLProductivity ;
    rdfs:subPropertyOf schema:impactScore .

mlops:allocatesResources rdfs:label "allocatesResources"@en ;
    rdfs:comment "Relates a process or system to the allocation of resources for ML tasks."@en ;
    rdfs:domain mlops:ResourceAllocation ;
    rdfs:range mlops:MLInfrastructure ;
    rdfs:subPropertyOf prov:used .

mlops:analyzesLogs rdfs:label "analyzesLogs"@en ;
    rdfs:comment "Relates a process or system to the analysis of system logs for root cause analysis."@en ;
    rdfs:domain mlops:RootCauseAnalysis ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf prov:used .

mlops:appliesToSMEs a owl:ObjectProperty ;
    rdfs:label "appliesToSMEs"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to its applicability or relevance for small and medium-sized enterprises (SMEs)."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:SMEsOrientedMLOps ;
    rdfs:subPropertyOf mlops:appliesToIndustry .

mlops:appliesToSoftwareDevelopmentCompany rdfs:label "appliesToSoftwareDevelopmentCompany"@en ;
    rdfs:comment "Relates an MLOps process, artifact, or system to the context of software development companies where it is applied."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range schema:Organization ;
    rdfs:subPropertyOf mlops:hasIndustryDomain .

mlops:assessesMaturity a owl:ObjectProperty ;
    rdfs:label "assessesMaturity"@en ;
    rdfs:comment "Relates a maturity assessment process to the MLOps process or system it evaluates."@en,
        "Relates an MLOps process or system to the maturity assessment it performs or supports."@en ;
    rdfs:domain mlops:MLOpsCapabilityAssessment,
        mlops:MaturityAssessment ;
    rdfs:range mlops:MLOps,
        mlops:MLOpsMaturityModel ;
    rdfs:subPropertyOf prov:used ;
    owl:sameAs mlops:hasMaturityChallenge,
        mlops:hasMaturityCriteria,
        mlops:hasMaturityDimension,
        mlops:hasMaturityFramework,
        mlops:hasProcessMaturity .

mlops:collaboratesWith a owl:ObjectProperty ;
    rdfs:label "collaboratesWith"@en ;
    rdfs:comment "Relates a role or process to another role or process it collaborates with in MLOps workflows."@en ;
    rdfs:domain mlops:MLRole ;
    rdfs:range mlops:MLRole ;
    rdfs:subPropertyOf prov:wasAssociatedWith .

mlops:deploysToEnvironment rdfs:label "deploysToEnvironment"@en ;
    rdfs:comment "Relates a deployment process to the environment it targets."@en ;
    rdfs:domain mlops:ModelDeployment ;
    rdfs:range mlops:MLDeploymentEnvironment ;
    rdfs:subPropertyOf schema:object .

mlops:detectsAnomalies rdfs:label "detectsAnomalies"@en ;
    rdfs:comment "Relates a monitoring system to the anomalies it detects in data or system behavior."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:AnomalyDetection ;
    rdfs:subPropertyOf mlops:monitors .

mlops:detectsDrift a owl:ObjectProperty ;
    rdfs:label "detectsDrift"@en ;
    rdfs:comment "Relates a monitoring system to the detection of concept drift in a model or dataset, enabling timely interventions to maintain model performance."@en,
        "Relates a monitoring system to the detection of concept drift in a model or dataset."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:ConceptDrift ;
    rdfs:subPropertyOf mlops:monitors .

mlops:ensuresDataPrivacy rdfs:label "ensuresDataPrivacy"@en ;
    rdfs:comment "Relates a process or artifact to the data privacy requirement it satisfies."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataPrivacy ;
    rdfs:subPropertyOf mlops:ensuresCompliance .

mlops:ensuresExplainability rdfs:label "ensuresExplainability"@en ;
    rdfs:comment "Relates a process or artifact to the model explainability requirement it satisfies."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:ModelExplainability ;
    rdfs:subPropertyOf mlops:ensuresCompliance .

mlops:ensuresModelFairness rdfs:label "ensuresModelFairness"@en ;
    rdfs:comment "Relates a process or artifact to the fairness requirements it satisfies, ensuring that ML models and processes do not discriminate unfairly."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:ModelFairnessRequirement ;
    rdfs:subPropertyOf mlops:ensuresCompliance .

mlops:facilitatesPredictiveAnalytics rdfs:label "facilitatesPredictiveAnalytics"@en ;
    rdfs:comment "Relates a system or process to the enabling of predictive analytics over data streams."@en ;
    rdfs:domain mlops:DataSummarization ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf schema:enables .

mlops:handlesDistributedExecution a owl:ObjectProperty ;
    rdfs:label "handlesDistributedExecution"@en ;
    rdfs:comment "Relates an MLOps process or system to its capability to handle distributed execution."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range xsd:boolean .

mlops:hasAdoptionBarrier a owl:ObjectProperty ;
    rdfs:label "hasAdoptionBarrier"@en ;
    rdfs:comment "Relates an MLOps process, system, or organization to the barriers it faces in adopting MLOps practices, such as cost or complexity."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsAdoptionBarrier ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasAdoptionBenefit a owl:ObjectProperty ;
    rdfs:label "hasAdoptionBenefit"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to an adoption benefit it provides or is associated with."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsAdoptionBenefit ;
    rdfs:subPropertyOf schema:subjectOf .

mlops:hasAgility a owl:ObjectProperty ;
    rdfs:label "hasAgility"@en ;
    rdfs:comment "Relates an MLOps process or system to its ability to enable rapid adaptation and responsiveness to changing requirements or market demands."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range schema:Boolean ;
    rdfs:subPropertyOf schema:additionalProperty .

mlops:hasAutomationLevel a owl:ObjectProperty ;
    rdfs:label "hasAutomationLevel"@en ;
    rdfs:comment "Relates a process or system to the degree of automation it employs, such as fully automated, semi-automated, or manual."@en,
        "Relates an MLOps process or system to the degree of automation it employs, such as manual, semi-automated, or fully automated."@en ;
    rdfs:domain mlops:MLOps,
        mlops:MLProcess ;
    rdfs:range schema:DefinedTerm ;
    rdfs:subPropertyOf mlops:hasMaturityLevel,
        schema:additionalProperty ;
    owl:sameAs mlops:IntelligentAutomation,
        mlops:hasAutomationCapability,
        mlops:providesIntelligentAutomation .

mlops:hasBenefit rdfs:label "hasBenefit"@en ;
    rdfs:comment "Relates an MLOps process, system, or adoption effort to the benefits it achieves or contributes to."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsBenefit ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasBusinessAlignment a owl:ObjectProperty ;
    rdfs:label "hasBusinessAlignment"@en ;
    rdfs:comment "Relates an MLOps process or system to the alignment with business goals or objectives, ensuring technical solutions meet organizational needs."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:BusinessGoal ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasChallengeCategory rdfs:label "hasChallengeCategory"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to a category of challenges it addresses or faces."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsChallengeCategory ;
    rdfs:subPropertyOf schema:subjectOf ;
    owl:sameAs mlops:hasOpportunityCategory .

mlops:hasCodeQualityRequirement rdfs:label "hasCodeQualityRequirement"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the code quality requirements it must satisfy to ensure maintainability and scalability."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range mlops:MLCodeQuality ;
    rdfs:subPropertyOf mlops:ensuresCompliance .

mlops:hasCollaboration a owl:ObjectProperty ;
    rdfs:label "hasCollaboration"@en ;
    rdfs:comment "Relates a process or artifact to the collaboration that produced or used it, highlighting the teamwork aspect of MLOps."@en,
        "Relates a process or artifact to the collaboration that produced or used it."@en,
        "Relates an MLOps process or artifact to the collaboration that produced or used it."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:Collaboration,
        mlops:MLCollaboration ;
    rdfs:subPropertyOf prov:wasAssociatedWith .

mlops:hasComplianceReport rdfs:label "hasComplianceReport"@en ;
    rdfs:comment "Relates a process or artifact to its compliance report."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLComplianceReport ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasComplianceRequirement a owl:ObjectProperty ;
    rdfs:label "hasComplianceRequirement"@en ;
    rdfs:comment "Relates an MLOps artifact or process to a compliance requirement it must satisfy, such as data privacy, model explainability, or fairness."@en,
        "Relates an MLOps artifact or process to a compliance requirement it must satisfy."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:MLCompliance,
        mlops:MLComplianceRequirement ;
    rdfs:subPropertyOf prov:wasGeneratedBy,
        mlops:ensuresCompliance .

mlops:hasComponentWear rdfs:label "hasComponentWear"@en ;
    rdfs:comment "Relates a monitoring system to the wear or aging of components it observes."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLComponentWear ;
    rdfs:subPropertyOf mlops:monitors .

mlops:hasComputationalResourceRequirement a owl:ObjectProperty ;
    rdfs:label "hasComputationalResourceRequirement"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the computational resources required for its execution, such as training or deployment."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range mlops:MLInfrastructure ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:hasCostConstraint a owl:ObjectProperty ;
    rdfs:label "hasCostConstraint"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to the cost constraints it must operate under, particularly relevant for SMEs."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsCostConstraint ;
    rdfs:subPropertyOf mlops:hasLifecycleConstraint .

mlops:hasCustomerInvolvement a owl:ObjectProperty ;
    rdfs:label "hasCustomerInvolvement"@en ;
    rdfs:comment "Relates an MLOps process or system to the level or type of customer involvement it requires or facilitates."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:CustomerInvolvement ;
    rdfs:subPropertyOf prov:wasAssociatedWith .

mlops:hasDataBias rdfs:label "hasDataBias"@en ;
    rdfs:comment "Relates a dataset or process to the bias present in the data."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:MLDataBias ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasDataCharacteristic rdfs:label "hasDataCharacteristic"@en ;
    rdfs:comment "Relates a dataset to a characteristic that describes its quality or suitability for ML tasks."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:DataCharacteristic ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasDataIngestion rdfs:label "hasDataIngestion"@en ;
    rdfs:comment "Relates an MLOps system or process to a data ingestion process it performs or manages."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataIngestion ;
    rdfs:subPropertyOf mlops:hasProcess .

mlops:hasDataLineage rdfs:label "hasDataLineage"@en ;
    rdfs:comment "Relates a process or artifact to its data lineage."@en,
        "Relates an MLOps artifact or process to the data lineage it tracks or generates."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:DataLineage ;
    rdfs:subPropertyOf prov:wasDerivedFrom,
        mlops:hasArtifact .

mlops:hasDataManagement rdfs:label "hasDataManagement"@en ;
    rdfs:comment "Relates an MLOps process or system to its data management practices."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataManagement ;
    rdfs:subPropertyOf mlops:hasProcess .

mlops:hasDataPreparation rdfs:label "hasDataPreparation"@en ;
    rdfs:comment "Relates an MLOps system or process to a data preparation process it performs or manages."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataPreparation ;
    rdfs:subPropertyOf mlops:hasProcess .

mlops:hasDataPrivacyManagement a owl:ObjectProperty ;
    rdfs:label "hasDataPrivacyManagement"@en ;
    rdfs:comment "Relates an MLOps process or system to the data privacy management practices it involves or requires, such as protecting confidential customer information."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataPrivacyManagement ;
    rdfs:subPropertyOf mlops:hasProcess .

mlops:hasDataStrategy a owl:ObjectProperty ;
    rdfs:label "hasDataStrategy"@en ;
    rdfs:comment "Relates an MLOps process or system to the data strategy it employs or requires."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataStrategy ;
    rdfs:subPropertyOf mlops:hasProcess ;
    owl:sameAs mlops:hasProactiveMonitoringStrategy .

mlops:hasDataSubset rdfs:label "hasDataSubset"@en ;
    rdfs:comment "Relates a dataset or pipeline to a subset of data used for training or evaluation."@en ;
    rdfs:domain mlops:DataPipeline ;
    rdfs:range mlops:DataSubset ;
    rdfs:subPropertyOf prov:used .

mlops:hasDataValidation rdfs:label "hasDataValidation"@en ;
    rdfs:comment "Relates a process or system to the data validation it performs or manages."@en,
        "Relates an MLOps system or process to a data validation process it performs or manages."@en ;
    rdfs:domain mlops:MLOps,
        mlops:MLPipeline ;
    rdfs:range mlops:DataValidation ;
    rdfs:subPropertyOf mlops:hasProcess .

mlops:hasDatabaseSource rdfs:label "hasDatabaseSource"@en ;
    rdfs:comment "Relates a metadata retrieval process to the database or API it queries, such as Scopus or other academic databases."@en ;
    rdfs:domain mlops:MetadataRetrieval ;
    rdfs:range mlops:DatabaseSource ;
    rdfs:subPropertyOf prov:used .

mlops:hasDeployment rdfs:label "hasDeployment"@en ;
    rdfs:comment "Relates a model or artifact to its deployment process."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:MLDeploymentProcess,
        mlops:ModelDeployment ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasDeploymentEnvironment rdfs:label "hasDeploymentEnvironment"@en ;
    rdfs:comment "Relates a deployment process to the environment where the model is deployed, such as cloud, edge, or hybrid."@en,
        "Relates a deployment process to the environment where the model is deployed, such as edge, cloud, or hybrid."@en,
        "Relates a deployment process to the environment where the model is deployed."@en ;
    rdfs:domain mlops:MLDeploymentProcess,
        mlops:MLPipeline ;
    rdfs:range mlops:DeploymentStrategy,
        mlops:MLDeploymentEnvironment,
        mlops:MLInfrastructure ;
    rdfs:subPropertyOf mlops:hasDeploymentStrategy,
        mlops:reliesOn .

mlops:hasDeploymentTarget rdfs:label "hasDeploymentTarget"@en ;
    rdfs:comment "Relates a deployment process to the hardware or software target it deploys to, such as edge devices or cloud platforms."@en ;
    rdfs:domain mlops:MLPipeline ;
    rdfs:range mlops:MLInfrastructure ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasDriftDetection rdfs:label "hasDriftDetection"@en ;
    rdfs:comment "Relates an MLOps process or system to the drift detection process it performs or manages."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataDriftDetection ;
    rdfs:subPropertyOf mlops:hasProcess .

mlops:hasEdgeDeployment rdfs:label "hasEdgeDeployment"@en ;
    rdfs:comment "Relates an MLOps process or artifact to its edge deployment."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:EdgeDeployment ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasEdgeInfrastructure a owl:ObjectProperty ;
    rdfs:label "hasEdgeInfrastructure"@en ;
    rdfs:comment "Relates an MLOps process or system to the edge infrastructure it depends on."@en,
        "Relates an MLOps process or system to the edge infrastructure it relies on for deployment or execution."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:EdgeInfrastructure ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:hasEnabler rdfs:label "hasEnabler"@en ;
    rdfs:comment "Relates an MLOps process or system to an entity that enables or facilitates its operation."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsEnabler ;
    rdfs:subPropertyOf prov:used .

mlops:hasEnergyConstraint rdfs:label "hasEnergyConstraint"@en ;
    rdfs:comment "Relates a deployment strategy to an energy consumption constraint it must satisfy."@en ;
    rdfs:domain mlops:DeploymentStrategy ;
    rdfs:range mlops:EnergyConsumption ;
    rdfs:subPropertyOf mlops:hasResourceConstraint .

mlops:hasExclusionCriteria a owl:ObjectProperty ;
    rdfs:label "hasExclusionCriteria"@en ;
    rdfs:comment "Relates a systematic literature review to its exclusion criteria for selecting studies."@en,
        "Relates a systematic review process to the exclusion criteria used to filter out irrelevant studies or artifacts."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:ExclusionCriteria ;
    rdfs:subPropertyOf mlops:hasSelectionCriteria .

mlops:hasExperiment a owl:ObjectProperty ;
    rdfs:label "hasExperiment"@en ;
    rdfs:comment "Relates an MLOps artifact or outcome to the experiment that produced it."@en,
        "Relates an artifact or outcome to the experiment that produced it, enabling traceability and reproducibility in model development."@en,
        "Relates an artifact or outcome to the experiment that produced it."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:Experiment ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasExperimentalProcess a owl:ObjectProperty ;
    rdfs:label "hasExperimentalProcess"@en ;
    rdfs:comment "Relates an MLOps process or system to the experimental nature of the machine learning development process it involves or supports."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLExperimentalProcess ;
    rdfs:subPropertyOf mlops:hasProcess .

mlops:hasExplainability rdfs:label "hasExplainability"@en ;
    rdfs:comment "Relates a model or system to its explainability characteristics or requirements."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:ModelExplainability ;
    rdfs:subPropertyOf schema:description .

mlops:hasExplainabilityRequirement rdfs:label "hasExplainabilityRequirement"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the explainability requirements it must satisfy."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLExplainability ;
    rdfs:subPropertyOf mlops:ensuresCompliance .

mlops:hasFairnessRequirement rdfs:label "hasFairnessRequirement"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the fairness requirements it must satisfy."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLFairness ;
    rdfs:subPropertyOf mlops:ensuresCompliance .

mlops:hasFeatureStore rdfs:label "hasFeatureStore"@en ;
    rdfs:comment "Relates a process or system to the feature store it uses or manages."@en,
        "Relates a process or system to the feature store it uses."@en,
        "Relates an MLOps system or process to the feature store it uses or manages."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:FeatureStore ;
    rdfs:subPropertyOf mlops:hasArtifact,
        mlops:reliesOn ;
    owl:sameAs mlops:usesFeatureStore .

mlops:hasField rdfs:label "hasField"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to the field or domain it is applied in."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLField ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasFramework rdfs:range mlops:MLOpsFramework .

mlops:hasGeographicalDistribution a owl:ObjectProperty ;
    rdfs:label "hasGeographicalDistribution"@en ;
    rdfs:comment "Relates a collection of studies or artifacts to their geographic distribution."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:GeographicalDistribution ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasHardwareArchitecture rdfs:label "hasHardwareArchitecture"@en ;
    rdfs:comment "Relates an MLOps process or system to the hardware architecture it relies on."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLHardwareArchitecture ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:hasHardwareConstraint a owl:ObjectProperty ;
    rdfs:label "hasHardwareConstraint"@en ;
    rdfs:comment "Relates an MLOps process or system to the hardware constraints it must operate under, particularly relevant for SMEs."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsHardwareConstraint ;
    rdfs:subPropertyOf mlops:hasLifecycleConstraint .

mlops:hasITOperationsFocus rdfs:label "hasITOperationsFocus"@en ;
    rdfs:comment "Relates an MLOps or AIOps process to the IT operations domain it targets or supports."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:ITOperations ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasImplementationAttribute rdfs:label "hasImplementationAttribute"@en ;
    rdfs:comment "Relates an MLOps process or system to an attribute or principle that contributes to its successful implementation."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsImplementationAttribute ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasImprovementPath a owl:ObjectProperty ;
    rdfs:label "hasImprovementPath"@en ;
    rdfs:comment "Relates a maturity level to a recommended path or strategy for improving to the next level."@en ;
    rdfs:domain mlops:MLOpsMaturityLevel ;
    rdfs:range mlops:MLOpsMaturityLevel ;
    rdfs:subPropertyOf schema:subjectOf .

mlops:hasInclusionCriteria a owl:ObjectProperty ;
    rdfs:label "hasInclusionCriteria"@en ;
    rdfs:comment "Relates a systematic literature review to its inclusion criteria for selecting studies."@en,
        "Relates a systematic review process to the inclusion criteria used to select relevant studies or artifacts."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:InclusionCriteria ;
    rdfs:subPropertyOf mlops:hasSelectionCriteria .

mlops:hasInclusionExclusionCriteria rdfs:label "hasInclusionExclusionCriteria"@en ;
    rdfs:comment "Relates a screening phase to the criteria used to include or exclude records, such as title or abstract evaluation."@en ;
    rdfs:domain mlops:ScreeningPhase ;
    rdfs:range mlops:InclusionExclusionCriteria ;
    rdfs:subPropertyOf prov:used .

mlops:hasInfrastructure a owl:ObjectProperty ;
    rdfs:label "hasInfrastructure"@en ;
    rdfs:comment "Relates an MLOps process or system to the infrastructure it depends on."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLInfrastructure ;
    rdfs:subPropertyOf prov:used ;
    owl:sameAs mlops:reliesOnInfrastructure .

mlops:hasInteractionType rdfs:label "hasInteractionType"@en ;
    rdfs:comment "Relates an interaction to its specific type or focus within MLOps."@en ;
    rdfs:domain mlops:HumanAIInteraction ;
    rdfs:range schema:Text ;
    rdfs:subPropertyOf schema:description ;
    owl:sameAs mlops:hasCollaborationType .

mlops:hasInterdisciplinaryComplexityChallenge a owl:ObjectProperty ;
    rdfs:label "hasInterdisciplinaryComplexityChallenge"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to an interdisciplinary complexity challenge it faces or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:InterdisciplinaryComplexityChallenge ;
    rdfs:subPropertyOf mlops:hasChallenge .

mlops:hasIsolation rdfs:label "hasIsolation"@en ;
    rdfs:comment "Relates an MLOps process or system to the isolation measures applied to its components."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLIsolation ;
    rdfs:subPropertyOf prov:used .

mlops:hasKPI rdfs:label "hasKPI"@en ;
    rdfs:comment "Relates a monitoring system or process to the Key Performance Indicators (KPIs) it tracks or infers."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf mlops:monitors .

mlops:hasKnowledgeGap a owl:ObjectProperty ;
    rdfs:label "hasKnowledgeGap"@en ;
    rdfs:comment "Relates an MLOps process or system to the knowledge gap it addresses or is affected by, such as communication challenges between data science and other teams."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLKnowledgeGap ;
    rdfs:subPropertyOf mlops:hasInterdisciplinaryChallenge .

mlops:hasLifecycleStageDefinition a owl:ObjectProperty ;
    rdfs:label "hasLifecycleStageDefinition"@en ;
    rdfs:comment "Relates an MLOps process or system to the formal definition of lifecycle stages to ensure effectiveness and sustainability of ML models in production."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLLifecycleStageDefinition ;
    rdfs:subPropertyOf mlops:hasPrinciple .

mlops:hasMLOpsBenefit rdfs:label "hasMLOpsBenefit"@en ;
    rdfs:comment "Relates an MLOps process or system to the benefits it provides or aims to achieve."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsBenefit ;
    rdfs:subPropertyOf schema:potentialAction .

mlops:hasMLOpsBenefitInSDC a owl:ObjectProperty ;
    rdfs:label "hasMLOpsBenefitInSDC"@en ;
    rdfs:comment "Relates an MLOps process or system to a benefit it provides or is associated with specifically within software development companies."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsAdoptionBenefitInSDC ;
    rdfs:subPropertyOf schema:potentialAction .

mlops:hasMLOpsChallengeInSDC a owl:ObjectProperty ;
    rdfs:label "hasMLOpsChallengeInSDC"@en ;
    rdfs:comment "Relates an MLOps process or system to a specific challenge it addresses or faces within software development companies."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsChallengeInSDC ;
    rdfs:subPropertyOf prov:used .

mlops:hasMLOpsMaturity rdfs:label "hasMLOpsMaturity"@en ;
    rdfs:comment "Relates an MLOps process or system to the maturity level it has achieved or is assessed against."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsMaturity ;
    rdfs:subPropertyOf schema:additionalProperty .

mlops:hasMaturityModel rdfs:label "hasMaturityModel"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to a maturity model it adheres to or is assessed against."@en,
        "Relates an organization or process to the maturity model it adheres to or is assessed against."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLMaturityModel,
        mlops:MLOpsMaturityModel ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasMetadata rdfs:label "hasMetadata"@en ;
    rdfs:comment "Relates a record or artifact to its associated metadata, such as title, abstract, or citation count."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:Metadata ;
    rdfs:subPropertyOf prov:hadPrimarySource .

mlops:hasMethodology rdfs:label "hasMethodology"@en ;
