mlops:hasModelRegistry rdfs:label "hasModelRegistry"@en ;
    rdfs:comment "Relates a process or system to the model registry it uses or manages."@en,
        "Relates a process or system to the model registry it uses."@en,
        "Relates an MLOps system or process to the model registry it uses or manages."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:ModelRegistry ;
    rdfs:subPropertyOf mlops:hasArtifact,
