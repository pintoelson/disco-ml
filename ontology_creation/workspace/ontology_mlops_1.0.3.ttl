    rdfs:comment "Relates an MLOps process or system to its support for Continuous Integration and Continuous Deployment (CI/CD) practices, enabling faster model deployment."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:CI_CD ;
