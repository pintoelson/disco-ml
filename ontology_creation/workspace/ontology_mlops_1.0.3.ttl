mlops:hasTechnicalCompetency a owl:ObjectProperty ;
    rdfs:label "hasTechnicalCompetency"@en ;
    rdfs:comment "Relates an MLOps process, role, or system to the technical competencies required for its execution or success."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsTechnicalCompetency ;
