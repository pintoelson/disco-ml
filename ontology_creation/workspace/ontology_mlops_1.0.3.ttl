mlops:hasProductionEnvironment rdfs:label "hasProductionEnvironment"@en ;
    rdfs:comment "Relates a deployment or serving process to the production environment it targets."@en ;
    rdfs:domain mlops:MLPipeline ;
    rdfs:range mlops:ProductionEnvironment ;
    rdfs:subPropertyOf prov:used .

mlops:hasQualityOfService a owl:ObjectProperty ;
