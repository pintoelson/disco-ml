mlops:hasModelServingEngine rdfs:label "hasModelServingEngine"@en ;
    rdfs:comment "Relates a deployment process to the serving engine it uses."@en ;
    rdfs:domain mlops:ModelDeployment ;
    rdfs:range mlops:ModelServingEngine ;
    rdfs:subPropertyOf mlops:usesTool .

mlops:hasMultidisciplinaryFocus rdfs:label "hasMultidisciplinaryFocus"@en ;
