mlops:hasTrainingRun rdfs:label "hasTrainingRun"@en ;
    rdfs:comment "Relates an MLOps system or process to a training run it performs or manages."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:TrainingRun ;
    rdfs:subPropertyOf mlops:hasProcess .

mlops:hasTrend rdfs:label "hasTrend"@en ;
