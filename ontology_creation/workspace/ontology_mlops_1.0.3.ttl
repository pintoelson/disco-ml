mlops:improvesRoleClarity rdfs:label "improvesRoleClarity"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the improvement of role clarity it provides."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleClarity ;
    rdfs:subPropertyOf schema:improves ;
    owl:sameAs mlops:improvesRoleAlignment,
        mlops:improvesRoleCollaboration,
        mlops:improvesRoleIntegration,
        mlops:improvesRoleOptimization,
        mlops:requiresRoleAlignment,
        mlops:requiresRoleClarity,
        mlops:requiresRoleCollaboration,
        mlops:requiresRoleDefinition,
        mlops:requiresRoleIntegration,
        mlops:requiresRoleOptimization .

mlops:isCollaborativeProcess rdfs:label "isCollaborativeProcess"@en ;
