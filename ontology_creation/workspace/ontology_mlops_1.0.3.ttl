mlops:hasOptimizationTechnique rdfs:label "hasOptimizationTechnique"@en ;
    rdfs:comment "Relates a model or process to the optimization technique applied to it, such as quantization or pruning."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:MLProcess ;
    rdfs:subPropertyOf prov:used .

mlops:hasOrganizationalCulture a owl:ObjectProperty ;
    rdfs:label "hasOrganizationalCulture"@en ;
    rdfs:comment "Relates an MLOps process or system to the organizational culture it requires or benefits from."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:OrganizationalCulture ;
