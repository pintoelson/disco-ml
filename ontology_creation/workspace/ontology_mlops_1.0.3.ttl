mlops:hasSector rdfs:label "hasSector"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to the sector in which it is applied."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsSector ;
