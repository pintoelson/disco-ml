    rdfs:comment "Relates an MLOps tool or system to the task offloading process it performs."@en ;
    rdfs:domain mlops:MLTool ;
    rdfs:range mlops:TaskOffloading ;
    rdfs:subPropertyOf schema:potentialAction .

mlops:performsTrafficAnalysis a owl:ObjectProperty ;
