mlops:identifiesAdoptionChallenge rdfs:label "identifiesAdoptionChallenge"@en ;
    rdfs:comment "Relates an MLOps process or system to a challenge it identifies or addresses during the adoption of MLOps practices."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsAdoptionChallenge ;
