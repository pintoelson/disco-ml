mlops:supportsExperimentation a owl:ObjectProperty ;
    rdfs:label "supportsExperimentation"@en ;
    rdfs:comment "Relates an MLOps process or system to its capability to support experimentation and iterative development."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf schema:potentialAction .

mlops:supportsITSM a owl:ObjectProperty ;
    rdfs:label "supportsITSM"@en ;
    rdfs:comment "Relates an MLOps tool or infrastructure to its role in supporting IT service management processes."@en ;
    rdfs:domain mlops:MLTool ;
    rdfs:range mlops:ITServiceManagement ;
    rdfs:subPropertyOf schema:potentialAction .

mlops:triggersRetraining rdfs:label "triggersRetraining"@en ;
    rdfs:comment "Relates a monitoring process or event to the retraining of a model."@en ;
    rdfs:domain mlops:ConceptDriftDetection ;
    rdfs:range mlops:ModelRetraining ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:usesAPIResource a owl:ObjectProperty ;
    rdfs:label "usesAPIResource"@en ;
    rdfs:comment "Relates an MLOps process or system to an API resource it employs."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:APIResource ;
    rdfs:subPropertyOf mlops:usesTool .

mlops:usesArchitecture rdfs:label "usesArchitecture"@en ;
    rdfs:comment "Relates an MLOps or AIOps system to the architectural pattern it employs, such as serverless or SDN."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:usesDataCharacteristic rdfs:label "usesDataCharacteristic"@en ;
    rdfs:comment "Relates an MLOps process to a data characteristic it relies on or evaluates."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range mlops:DataCharacteristic ;
    rdfs:subPropertyOf prov:used .

mlops:usesDataStream rdfs:label "usesDataStream"@en ;
    rdfs:comment "Relates a process or system to the data streams it utilizes."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataStream ;
    rdfs:subPropertyOf prov:used .

mlops:usesEdgeTool rdfs:label "usesEdgeTool"@en ;
    rdfs:comment "Relates an edge MLOps process or system to the tool it employs, which may be optimized for edge environments."@en ;
    rdfs:domain mlops:EdgeMLOps ;
    rdfs:range mlops:MLTool ;
    rdfs:subPropertyOf mlops:usesTool .

mlops:usesFaaS rdfs:label "usesFaaS"@en ;
    rdfs:comment "Relates an MLOps process or system to a serverless computing platform it utilizes."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:FaaSPlatform ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:usesInfrastructure rdfs:label "usesInfrastructure"@en ;
    rdfs:comment "Relates a process or system to the infrastructure it utilizes, such as cloud, edge, or serverless."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLInfrastructure ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:usesMLLibrary rdfs:label "usesMLLibrary"@en ;
    rdfs:comment "Relates an MLOps process or system to the ML library or framework it employs."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLLibraryFramework ;
    rdfs:subPropertyOf mlops:usesTool .

mlops:usesModelRegistry rdfs:label "usesModelRegistry"@en ;
    rdfs:comment "Relates a process or system to the model registry it uses or consumes."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range mlops:ModelRegistry ;
    rdfs:subPropertyOf prov:used .

mlops:usesModelVersion rdfs:label "usesModelVersion"@en ;
    rdfs:comment "Relates a process or system to the model version it uses or consumes."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range mlops:ModelVersion ;
    rdfs:subPropertyOf prov:used .

mlops:usesNetworking rdfs:label "usesNetworking"@en ;
    rdfs:comment "Relates an MLOps process or system to networking components it utilizes."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:NetworkingComponent ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:usesSource rdfs:label "usesSource"@en ;
    rdfs:comment "Relates an MLOps process to the data source it utilizes, such as an API or database."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:usesSystematicLiteratureReviewTool a owl:ObjectProperty ;
    rdfs:label "usesSystematicLiteratureReviewTool"@en ;
    rdfs:comment "Relates a systematic literature review process to the tool it employs for conducting the review."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:SystematicLiteratureReviewTool ;
    rdfs:subPropertyOf mlops:usesTool ;
    owl:sameAs mlops:addressesSystematicLiteratureReviewChallenge,
        mlops:facilitatedBySystematicLiteratureReviewEnabler,
        mlops:hasSystematicLiteratureReviewCriteria,
        mlops:hasSystematicLiteratureReviewReport,
        mlops:hasSystematicLiteratureReviewStage .

mlops:utilizesCloudResources a owl:ObjectProperty ;
    rdfs:label "utilizesCloudResources"@en ;
    rdfs:comment "Relates an MLOps process or system to the utilization of cloud resources, including serverless architectures, to provide scalable and cost-effective computational resources for ML tasks."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:CloudResourceUtilization ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:AIChallenge rdfs:label "AIChallenge"@en ;
    rdfs:comment "A challenge or problem in AI/ML systems that requires operational solutions, such as data quality, model explainability, or scalability."@en ;
    rdfs:subClassOf schema:Thing .

mlops:AIOps a owl:Class ;
    rdfs:label "AIOps"@en ;
    rdfs:comment "A methodology and set of practices that apply artificial intelligence and machine learning to automate and enhance IT operations, including anomaly detection, root-cause analysis, failure prediction, and automated actions."@en,
        "The application of artificial intelligence to automate and enhance IT operations, including incident remediation, log analysis, and performance monitoring."@en ;
    rdfs:subClassOf mlops:MLOps,
        mlops:MLTool .

mlops:AIOpsSolution rdfs:label "AIOpsSolution"@en ;
    rdfs:comment "An AI-driven operations solution that automates and optimizes IT and ML operations, including anomaly detection, performance optimization, and predictive maintenance."@en ;
    rdfs:subClassOf mlops:MLOps .

mlops:APIResource a owl:Class ;
    rdfs:label "APIResource"@en ;
    rdfs:comment "A resource exposed via API for simplified interaction with ML models or services."@en ;
    rdfs:subClassOf schema:Thing .

mlops:AnomalyDetection rdfs:label "AnomalyDetection"@en ;
    rdfs:comment "A process or system that identifies unusual patterns or outliers in data or system behavior, often using ML techniques."@en,
        "A process or system that identifies unusual patterns or outliers in data, often as part of AIOps or monitoring workflows."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:AutomatedFiltering rdfs:label "AutomatedFiltering"@en ;
    rdfs:comment "A process of applying automated criteria to exclude or prioritize records based on metadata or other attributes, such as citation count or publication date."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:AutomatedMLOps a owl:Class ;
    rdfs:label "AutomatedMLOps"@en ;
    rdfs:comment "A maturity stage where MLOps processes are partially automated, leveraging CI/CD and basic orchestration tools to reduce manual effort."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:BusinessImpact rdfs:label "BusinessImpact"@en ;
    rdfs:comment "The measurable effect of AI/ML solutions on business outcomes, such as efficiency gains, cost reduction, or revenue growth."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:measuresBusinessImpact .

mlops:CI_CD rdfs:label "CI/CD"@en ;
    rdfs:comment "A set of principles and practices for automating the integration and delivery of software, including machine learning systems, to ensure rapid, reliable, and consistent deployment."@en ;
    rdfs:subClassOf mlops:MLPrinciple .

mlops:CloudDeployment rdfs:label "CloudDeployment"@en ;
    rdfs:comment "A deployment strategy where machine learning models are deployed on cloud-based infrastructure, leveraging scalable compute and storage resources."@en,
        "A deployment strategy where machine learning models are executed on cloud infrastructure, leveraging scalable resources and managed services."@en,
        "The deployment of ML models or pipelines on cloud infrastructure, leveraging scalable compute and storage resources."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:CloudResourceUtilization a owl:Class ;
    rdfs:label "CloudResourceUtilization"@en ;
    rdfs:comment "The practice of leveraging cloud resources, including serverless architectures, to provide scalable and cost-effective computational resources for training and deploying ML models, addressing challenges related to physical infrastructure costs and resource constraints."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:CollaborativeCulture rdfs:label "CollaborativeCulture"@en ;
    rdfs:comment "A shared organizational culture that emphasizes teamwork, communication, and coordination among stakeholders involved in MLOps processes."@en,
        "An organizational culture that fosters collaboration between cross-functional teams, such as data scientists, software engineers, and operations experts."@en ;
    rdfs:subClassOf mlops:MLOpsEnabler,
        schema:Intangible,
        schema:Thing ;
    owl:sameAs mlops:requiresCollaborativeCulture .

mlops:ConceptDriftDetection rdfs:label "ConceptDriftDetection"@en ;
    rdfs:comment "A specialized monitoring process that identifies and alerts on concept drift in ML models or datasets."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ConceptualLevel rdfs:label "ConceptualLevel"@en ;
    rdfs:comment "The highest level of abstraction in a measurement model, where objectives are defined to establish the purpose and scope of a systematic review."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasConceptualLevel .

mlops:ContinuousTraining a owl:Class ;
    rdfs:label "ContinuousTraining"@en ;
    rdfs:comment "A maturity stage where ML models are continuously retrained and updated based on new data or performance feedback, often enabled by automated pipelines."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:CrossDomainSkillset rdfs:label "CrossDomainSkillset"@en ;
    rdfs:comment "A set of skills spanning software engineering, data science, and IT operations required for effective MLOps adoption and implementation."@en ;
    rdfs:subClassOf schema:Thing .

mlops:CustomerInvolvement rdfs:label "CustomerInvolvement"@en ;
    rdfs:comment "A collaborative practice where customers are actively engaged throughout the MLOps lifecycle to align expectations, validate progress, and ensure the delivered solution meets business needs."@en ;
    rdfs:subClassOf mlops:Collaboration .

mlops:DataDriftDetection rdfs:label "DataDriftDetection"@en ;
    rdfs:comment "A specialized monitoring process that identifies and alerts on changes in the statistical properties of input data over time, enabling timely interventions to maintain model performance."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataIngestion rdfs:label "DataIngestion"@en ;
    rdfs:comment "A process for collecting and ingesting data from various sources into the ML pipeline."@en,
        "The process of collecting and importing data from various sources into a system for further processing."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataLineage rdfs:label "DataLineage"@en ;
    rdfs:comment "A record of the origin, transformations, and dependencies of a dataset used in ML."@en,
        "The tracking and documentation of data origins, transformations, and usage throughout its lifecycle."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:DataMovement rdfs:label "DataMovement"@en ;
    rdfs:comment "The transfer of data between storage systems, compute nodes, or geographic locations, often involving batch or streaming processes."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataObservability rdfs:label "DataObservability"@en ;
    rdfs:comment "The ability to monitor and ensure the quality, availability, and reliability of data in ML systems, often facilitated by continuous access to data streams."@en ;
    rdfs:subClassOf schema:Thing .

mlops:DataPrivacy rdfs:label "DataPrivacy"@en ;
    rdfs:comment "A compliance requirement or constraint related to the protection of sensitive or personal data in machine learning systems."@en,
        "The practices and measures to protect sensitive data and ensure compliance with privacy regulations."@en ;
    rdfs:subClassOf mlops:MLCompliance ;
    owl:sameAs mlops:DataPrivacyCompliance,
        mlops:DataPrivacyRequirement .

mlops:DataPrivacyCompliance rdfs:label "DataPrivacyCompliance"@en ;
    rdfs:comment "A compliance requirement ensuring that data handling practices adhere to privacy regulations and policies."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:DataPrivacyRequirement rdfs:label "DataPrivacyRequirement"@en ;
    rdfs:comment "A compliance requirement ensuring that data handling practices adhere to privacy regulations and policies, protecting sensitive or personal data in ML systems."@en,
        "A compliance requirement related to the protection and privacy of data used in ML systems."@en ;
    rdfs:subClassOf mlops:MLComplianceRequirement .

mlops:DataQualityAssessment rdfs:label "DataQualityAssessment"@en ;
    rdfs:comment "A process or system for evaluating the quality of datasets used in ML tasks, including checks for completeness, consistency, accuracy, and timeliness."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataScientist rdfs:label "DataScientist"@en ;
    rdfs:comment "A role responsible for designing, training, and evaluating machine learning models."@en ;
    rdfs:subClassOf mlops:MLRole .

mlops:DataStrategy a owl:Class ;
    rdfs:label "DataStrategy"@en ;
    rdfs:comment "A structured approach to managing data throughout its lifecycle in MLOps, including sourcing, cleaning, labeling, and governance to ensure quality and relevance."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataStream rdfs:label "DataStream"@en ;
    rdfs:comment "A continuous flow of data, often used in big data systems for real-time processing and monitoring."@en ;
    rdfs:subClassOf schema:Thing .

mlops:DataSubset rdfs:label "DataSubset"@en ;
    rdfs:comment "A partitioned portion of a larger dataset, often used to simplify training or evaluation tasks."@en ;
    rdfs:subClassOf schema:Thing .

mlops:DataSummarization rdfs:label "DataSummarization"@en ;
    rdfs:comment "A process of aggregating and summarizing data to facilitate analysis or monitoring."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataValidation rdfs:label "DataValidation"@en ;
    rdfs:comment "A process for validating the quality, consistency, and integrity of datasets used in ML."@en,
        "A process or system responsible for validating the quality, consistency, and integrity of data used in MLOps workflows."@en,
        "The process of validating data quality, consistency, and suitability for machine learning tasks before use."@en,
        "The process of verifying data integrity, consistency, and suitability for ML tasks, including checks for missing values, outliers, and schema compliance."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:DataVersioning rdfs:label "DataVersioning"@en ;
    rdfs:comment "A process or system for managing and tracking versions of datasets used in ML workflows to ensure reproducibility and traceability."@en,
        "A process or system for tracking and managing versions of datasets used in ML workflows, ensuring reproducibility and traceability."@en,
        "The practice of tracking and managing changes to datasets over time, enabling reproducibility and rollback capabilities."@en ;
    rdfs:subClassOf mlops:MLArtifact,
        mlops:MLProcess .

mlops:DatabaseSource rdfs:label "DatabaseSource"@en ;
    rdfs:comment "A database or API used for retrieving metadata or records, such as Scopus, PubMed, or arXiv."@en ;
    rdfs:subClassOf schema:Thing .

mlops:DeepLearningModel a owl:Class ;
    rdfs:label "DeepLearningModel"@en ;
    rdfs:comment "A machine learning model based on deep learning techniques, such as neural networks."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:DeploymentEnvironment rdfs:label "DeploymentEnvironment"@en ;
    rdfs:comment "An environment where machine learning models are deployed and executed, such as cloud platforms, edge devices, or on-premises systems."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:DeploymentPipeline rdfs:label "DeploymentPipeline"@en ;
    rdfs:comment "An automated workflow that orchestrates the deployment of models to production environments."@en ;
    rdfs:subClassOf mlops:MLPipeline .

mlops:DevOpsEngineer rdfs:label "DevOpsEngineer"@en ;
    rdfs:comment "A role responsible for deploying, monitoring, and maintaining AI solutions in production environments."@en,
        "A role responsible for managing infrastructure and orchestration platforms supporting MLOps."@en,
        "A role responsible for managing infrastructure, CI/CD pipelines, and deployment strategies."@en ;
    rdfs:subClassOf mlops:MLRole .

mlops:EdgeComputing rdfs:label "EdgeComputing"@en ;
    rdfs:comment "A computing paradigm where data processing occurs near the source of data generation, reducing latency and bandwidth usage."@en,
        "A distributed computing paradigm that brings computation and data storage closer to the sources of data, such as IoT devices or local edge servers."@en ;
    rdfs:subClassOf mlops:MLInfrastructure,
        schema:Thing .

mlops:EdgeDataPipeline rdfs:label "EdgeDataPipeline"@en ;
    rdfs:comment "A data pipeline designed to operate in edge environments, often with constraints on bandwidth, latency, and reliability."@en ;
    rdfs:subClassOf mlops:EdgePipeline .

mlops:EdgeDeployment a owl:Class ;
    rdfs:label "EdgeDeployment"@en ;
    rdfs:comment "A deployment strategy specifically designed for edge devices or environments with limited resources and unreliable connectivity."@en,
        "A deployment strategy where ML models are deployed on edge devices or edge servers to enable real-time inference and reduce latency."@en,
        "A deployment strategy where machine learning models are deployed on edge devices with limited resources, such as microcontrollers or embedded systems."@en,
        "A deployment strategy where machine learning models are executed on edge devices, optimizing for latency, bandwidth, and resource constraints."@en,
        "The deployment of ML models on edge devices or IoT nodes to enable low-latency inference and reduce bandwidth usage."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:EdgeModelVersion rdfs:label "EdgeModelVersion"@en ;
    rdfs:comment "A specific version of a machine learning model optimized for edge deployment, including its parameters, metadata, and lineage."@en ;
    rdfs:subClassOf mlops:EdgeModel .

mlops:EdgeMonitoring rdfs:label "EdgeMonitoring"@en ;
    rdfs:comment "A monitoring system tailored for edge deployments, tracking performance, drift, and operational metrics in constrained environments."@en ;
    rdfs:subClassOf schema:Thing .

mlops:EdgePipeline rdfs:label "EdgePipeline"@en ;
    rdfs:comment "A data or ML pipeline designed to operate in edge environments, often with constraints on bandwidth, latency, and reliability."@en ;
    rdfs:subClassOf mlops:DataPipeline ;
    owl:sameAs mlops:EdgeDataPipeline .

mlops:EnergyConsumption rdfs:label "EnergyConsumption"@en ;
    rdfs:comment "The amount of energy consumed by computational resources during ML operations, particularly relevant for GPU-dependent applications."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ExclusionCriteria rdfs:label "ExclusionCriteria"@en ;
    rdfs:comment "A specific condition or rule used to exclude studies in a systematic literature review."@en ;
    rdfs:subClassOf mlops:SelectionCriteria ;
    owl:sameAs mlops:InclusionCriteria .

mlops:ExperimentTrackingTool rdfs:label "ExperimentTrackingTool"@en ;
    rdfs:comment "A tool for tracking experiments, parameters, and outcomes during model development."@en ;
    rdfs:subClassOf mlops:MLTool .

mlops:FaaSPlatform rdfs:label "FaaSPlatform"@en ;
    rdfs:comment "A serverless computing platform that enables event-driven execution of functions, often used for deploying machine learning models as services."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:FailureMode rdfs:label "FailureMode"@en ;
    rdfs:comment "A category of failure or anomaly that can occur in machine learning systems, such as concept drift, data corruption, or infrastructure overload."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasFailureMode .

mlops:FilterCriterion rdfs:label "FilterCriterion"@en ;
    rdfs:comment "A condition or rule used to include or exclude records during automated filtering, such as exclusion of retracted articles or prioritization by citation count."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasFilterCriterion .

mlops:GeographicalDistribution a owl:Class ;
    rdfs:label "GeographicalDistribution"@en ;
    rdfs:comment "A classification or analysis of the geographic origin or distribution of studies, manuscripts, or artifacts."@en ;
    rdfs:subClassOf schema:Thing .

mlops:HPCInfrastructure rdfs:label "HPCInfrastructure"@en ;
    rdfs:comment "High Performance Computing infrastructure providing scalable and cost-effective computational resources for training and deploying machine learning models."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:HumanAIInteraction rdfs:label "HumanAIInteraction"@en ;
    rdfs:comment "A process or system that facilitates interaction and collaboration between humans and AI systems in MLOps contexts."@en ;
    rdfs:subClassOf schema:Interaction .

mlops:ITOperations rdfs:label "ITOperations"@en ;
    rdfs:comment "The domain of Information Technology operations, focusing on managing and optimizing IT infrastructure and services."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ITRiskPrediction rdfs:label "ITRiskPrediction"@en ;
    rdfs:comment "A process or system that uses machine learning techniques to predict, assess, and mitigate risks in IT infrastructure and operations."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ITServiceManagement a owl:Class ;
    rdfs:label "ITServiceManagement"@en ;
    rdfs:comment "A framework or process for managing IT services, including incident resolution, service requests, and operational workflows."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:InclusionExclusionCriteria rdfs:label "InclusionExclusionCriteria"@en ;
    rdfs:comment "A set of rules or conditions used to determine whether a record should be included or excluded during screening, such as title or abstract evaluation."@en ;
    rdfs:subClassOf schema:Thing .

mlops:InferenceOptimization rdfs:label "InferenceOptimization"@en ;
    rdfs:comment "Techniques and processes to improve the efficiency and performance of ML model inference, such as quantization or pruning."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:InformationExtraction rdfs:label "InformationExtraction"@en ;
    rdfs:comment "A process of collecting and synthesizing data from selected studies or artifacts to answer research questions or objectives."@en ;
    rdfs:subClassOf mlops:MLProcess ;
    owl:sameAs mlops:hasInformationExtraction .

mlops:LeadershipEngagement rdfs:label "LeadershipEngagement"@en ;
    rdfs:comment "The involvement and support of organizational leaders in MLOps initiatives, including strategy alignment and resource allocation."@en ;
    rdfs:subClassOf prov:Activity,
        mlops:MLOpsEnabler ;
    owl:sameAs mlops:requiresLeadershipEngagement .

mlops:LogAnalysis a owl:Class ;
    rdfs:label "LogAnalysis"@en ;
    rdfs:comment "A process for analyzing structured or unstructured logs to extract insights, detect anomalies, or diagnose issues in machine learning systems."@en,
        "A process or system that analyzes logs to extract insights, detect anomalies, or monitor ML systems."@en,
        "The process of analyzing log data to detect patterns, anomalies, or incidents, often used in monitoring and incident remediation."@en ;
    rdfs:subClassOf mlops:MLProcess ;
    owl:sameAs mlops:LogProcessing .

mlops:LogProcessing rdfs:label "LogProcessing"@en ;
    rdfs:comment "An automated workflow for collecting, parsing, enhancing, and analyzing log data to extract insights or detect anomalies."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLCodeQuality rdfs:label "MLCodeQuality"@en ;
    rdfs:comment "The adherence to software engineering best practices in machine learning model development to ensure maintainability, scalability, and integration in production environments, addressing technical debt and facilitating deployment."@en ;
    rdfs:subClassOf mlops:MLPrinciple ;
    owl:sameAs mlops:MLProductQuality .

mlops:MLComplianceReport rdfs:label "MLComplianceReport"@en ;
    rdfs:comment "An artifact documenting compliance with ML-related standards or regulations."@en ;
    rdfs:subClassOf prov:Entity,
        mlops:MLArtifact .

mlops:MLComponentWear rdfs:label "MLComponentWear"@en ;
    rdfs:comment "The degradation of hardware or software components over time due to usage, environmental factors, or aging, affecting MLOps processes."@en ;
    rdfs:subClassOf schema:Event .

mlops:MLDataBias rdfs:label "MLDataBias"@en ;
    rdfs:comment "A systematic error in the data used for training or evaluation that can lead to unfair or inaccurate models."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLDeploymentStrategy rdfs:label "MLDeploymentStrategy"@en ;
    rdfs:comment "A method or approach for deploying ML models to production, such as A/B testing, canary, or blue-green deployment."@en ;
    rdfs:subClassOf mlops:DeploymentStrategy .

mlops:MLEngineer rdfs:label "MLEngineer"@en ;
    rdfs:comment "A role responsible for deploying, monitoring, and maintaining ML models in production."@en,
        "A role responsible for deploying, monitoring, and maintaining machine learning models in production."@en ;
    rdfs:subClassOf mlops:MLRole .

mlops:MLEnvironmentalConstraint rdfs:label "MLEnvironmentalConstraint"@en ;
    rdfs:comment "A constraint imposed by the operational environment, such as unreliable connectivity or harsh conditions."@en ;
    rdfs:subClassOf mlops:MLLifecycleConstraint .

mlops:MLExperimentalProcess a owl:Class ;
    rdfs:label "MLExperimentalProcess"@en ;
    rdfs:comment "A process characterized by iterative experimentation, hypothesis testing, and uncertainty management, reflecting the exploratory nature of machine learning model development compared to traditional software development."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLExplainability rdfs:label "MLExplainability"@en ;
    rdfs:comment "The degree to which the decisions and outputs of ML models can be understood and interpreted by humans, including transparency and interpretability."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:MLFairness rdfs:label "MLFairness"@en ;
    rdfs:comment "The principle of ensuring that ML models and processes do not discriminate unfairly against individuals or groups, considering ethical and societal impacts."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:MLField rdfs:label "MLField"@en ;
    rdfs:comment "A specific domain or industry sector where MLOps is applied, such as telecommunications, healthcare, or finance."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLHardwareArchitecture rdfs:label "MLHardwareArchitecture"@en ;
    rdfs:comment "The hardware configuration and architecture used to support MLOps processes, including devices like edge nodes, GPUs, TPUs, or cloud-based resources."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:MLInfrastructureOptimization a owl:Class ;
    rdfs:label "MLInfrastructureOptimization"@en ;
    rdfs:comment "The process of optimizing infrastructure components, such as Kubernetes or serverless platforms, to better support MLOps workflows, including model training, deployment, and monitoring."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLIsolation rdfs:label "MLIsolation"@en ;
    rdfs:comment "The separation of components or processes in MLOps to prevent interference, ensure security, or manage resource constraints."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLKnowledgeGap a owl:Class ;
    rdfs:label "MLKnowledgeGap"@en ;
    rdfs:comment "A disparity in understanding between data science teams and other stakeholders regarding the capabilities, limitations, and lifecycle requirements of machine learning systems, leading to misaligned expectations and project challenges."@en ;
    rdfs:subClassOf mlops:MLInterdisciplinaryChallenge .

mlops:MLLibraryFramework rdfs:label "MLLibraryFramework"@en ;
    rdfs:comment "A software library or framework used in machine learning workflows, such as TensorFlow, PyTorch, or scikit-learn."@en ;
    rdfs:subClassOf mlops:MLTool .

mlops:MLLifecycle rdfs:label "MLLifecycle"@en ;
    rdfs:comment "The complete lifecycle of machine learning solutions from development through deployment and maintenance."@en,
        "The entire process from data preparation to model deployment and monitoring in machine learning operations."@en,
        "The overarching process encompassing all stages from data preparation to model monitoring in MLOps."@en ;
    rdfs:subClassOf prov:Activity,
        mlops:MLOps,
        mlops:MLProcess ;
    owl:sameAs mlops:MLLifecycleConstraint,
        mlops:MLLifecycleManagement,
        mlops:MLLifecycleStage,
        mlops:MLOpsLifecycleStage,
        mlops:hasEdgeLifecycleStage,
        mlops:hasLifecycle,
        mlops:hasLifecycleConstraint,
        mlops:supportsLifecycleStage .

mlops:MLLifecycleManagement rdfs:label "MLLifecycleManagement"@en ;
    rdfs:comment "A coordinated effort to manage and oversee the entire machine learning lifecycle, ensuring alignment with business goals and software engineering principles."@en ;
    rdfs:subClassOf mlops:Collaboration .

mlops:MLLifecycleStageDefinition a owl:Class ;
    rdfs:label "MLLifecycleStageDefinition"@en ;
    rdfs:comment "The formal definition of essential stages in the MLOps lifecycle, such as problem definition, data preparation, model training, deployment, and continuous monitoring, to ensure effectiveness and sustainability of ML models in production."@en ;
    rdfs:subClassOf mlops:MLPrinciple .

mlops:MLMaturityModel rdfs:label "MLMaturityModel"@en ;
    rdfs:comment "A framework or model that assesses the maturity of an organization's MLOps practices across dimensions such as processes, tools, roles, and collaboration."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLModelRetraining rdfs:label "MLModelRetraining"@en ;
    rdfs:comment "A process of periodically retraining ML models with recent data to mitigate obsolescence and counteract performance degradation caused by data drift or changing conditions."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLMonitoringMetric rdfs:label "MLMonitoringMetric"@en ;
    rdfs:comment "A metric used to monitor the performance or behavior of a machine learning model in production."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLObservabilityIssue rdfs:label "MLObservabilityIssue"@en ;
    rdfs:comment "A problem or gap in the observability of an ML system, such as lack of logging, missing metrics, or unclear model behavior."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:MLOpportunity rdfs:label "MLOpportunity"@en ;
    rdfs:comment "A potential area for improvement, innovation, or advancement in MLOps practices, tools, or methodologies."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsAdoptionBarrier a owl:Class ;
    rdfs:label "MLOpsAdoptionBarrier"@en ;
    rdfs:comment "A barrier or obstacle to the adoption of MLOps practices, such as cost, complexity, or lack of expertise, particularly relevant for SMEs."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:MLOpsAdoptionBenefitInSDC a owl:Class ;
    rdfs:label "MLOpsAdoptionBenefitInSDC"@en ;
    rdfs:comment "A benefit identified in the adoption of MLOps practices specifically within software development companies, such as improved collaboration, faster implementation, or enhanced model lifecycle efficiency."@en ;
    rdfs:subClassOf mlops:MLOpsAdoptionBenefit .

mlops:MLOpsAdoptionChallenge rdfs:label "MLOpsAdoptionChallenge"@en ;
    rdfs:comment "A challenge or obstacle encountered during the adoption and implementation of MLOps practices in an organization, such as cultural resistance, tool integration, or skill gaps."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:MLOpsApplicationField rdfs:label "MLOpsApplicationField"@en ;
    rdfs:comment "A domain or sector where MLOps methodologies and practices are applied, such as healthcare, finance, or autonomous systems."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsChallengeCategory rdfs:label "MLOpsChallengeCategory"@en ;
    rdfs:comment "A category or classification of challenges encountered in MLOps, such as technical, organizational, or operational challenges, used to structure analysis and solutions."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsCompliance rdfs:label "MLOpsCompliance"@en ;
    rdfs:comment "The compliance requirements specific to MLOps practices, such as auditability, reproducibility, and security."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:MLOpsCostConstraint a owl:Class ;
    rdfs:label "MLOpsCostConstraint"@en ;
    rdfs:comment "A constraint related to the financial costs associated with implementing, deploying, and maintaining MLOps practices, particularly impactful for SMEs."@en ;
    rdfs:subClassOf mlops:MLLifecycleConstraint ;
    owl:sameAs mlops:MLOpsHardwareConstraint .

mlops:MLOpsCrucialFactor rdfs:label "MLOpsCrucialFactor"@en ;
    rdfs:comment "A key element or condition that significantly influences the successful adoption and implementation of MLOps in software development companies, such as leadership support, cross-functional collaboration, or toolchain integration."@en ;
    rdfs:subClassOf mlops:MLOpsEnabler .

mlops:MLOpsEducationGap a owl:Class ;
    rdfs:label "MLOpsEducationGap"@en ;
    rdfs:comment "The gap between traditional data science education and the practical requirements of MLOps, including the need for continuous monitoring, deployment, and collaboration with DevOps, which is often not covered in academic programs."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:MLOpsImplementationAttribute rdfs:label "MLOpsImplementationAttribute"@en ;
    rdfs:comment "A fundamental characteristic or principle that contributes to the successful implementation of MLOps, such as automation, collaboration, or reproducibility."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsImplementationChallenge a owl:Class ;
    rdfs:label "MLOpsImplementationChallenge"@en ;
    rdfs:comment "A challenge related to the practical implementation of MLOps practices, particularly in resource-constrained environments such as SMEs, including cost, scalability, and process maturity."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:MLOpsLifecycleStage rdfs:label "MLOpsLifecycleStage"@en ;
    rdfs:comment "A distinct phase within the MLOps lifecycle, such as model deployment or monitoring."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:MLOpsMaturity rdfs:label "MLOpsMaturity"@en ;
    rdfs:comment "A measure of the maturity level of MLOps practices within an organization, including the adoption of principles, roles, artifacts, and processes."@en ;
    rdfs:subClassOf mlops:MLOpsEnabler .

mlops:MLOpsMaturityChallenge rdfs:label "MLOpsMaturityChallenge"@en ;
    rdfs:comment "A challenge related to the maturity of the MLOps discipline, including the lack of holistic conceptual frameworks and evolving practices."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:MLOpsMethodology rdfs:label "MLOpsMethodology"@en ;
    rdfs:comment "A systematic approach or set of principles for conducting MLOps activities, such as systematic literature review or iterative experimentation."@en ;
    rdfs:subClassOf prov:Activity .

mlops:MLOpsOpportunity rdfs:label "MLOpsOpportunity"@en ;
    rdfs:comment "A potential area for advancement or innovation within the MLOps domain, such as new automation techniques, tooling, or methodological improvements."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsOpportunityCategory rdfs:label "MLOpsOpportunityCategory"@en ;
    rdfs:comment "A category or classification of opportunities for improvement or innovation in MLOps practices, tools, or methodologies, used to guide strategic planning."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsParadigm rdfs:label "MLOpsParadigm"@en ;
    rdfs:comment "A conceptual framework or approach to MLOps, such as the paradigms described in the survey (e.g., MLOps, AIOps, LAOps, RLOps)."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsPipeline rdfs:label "MLOpsPipeline"@en ;
    rdfs:comment "A specialized pipeline that orchestrates MLOps workflows, including data, model, and infrastructure management."@en ;
    rdfs:subClassOf mlops:MLPipeline .

mlops:MLOpsPlatform rdfs:label "MLOpsPlatform"@en ;
    rdfs:comment "A comprehensive platform that integrates tools and processes for end-to-end MLOps, including development, deployment, and monitoring."@en,
        "A platform that integrates tools and processes to support MLOps workflows."@en ;
    rdfs:subClassOf mlops:MLOps,
        schema:SoftwareApplication .

mlops:MLOpsProcessMaturity a owl:Class ;
    rdfs:label "MLOpsProcessMaturity"@en ;
    rdfs:comment "The degree to which MLOps processes are defined, controlled, and predictable within an organization, particularly relevant for SMEs adopting MLOps practices."@en ;
    rdfs:subClassOf mlops:MLLifecycleConstraint .

mlops:MLOpsSector rdfs:label "MLOpsSector"@en ;
    rdfs:comment "A domain or industry sector where MLOps practices and solutions are applied, such as communications, networking, physics, autonomous vehicles, or traditional factories."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsSoftCompetency a owl:Class ;
    rdfs:label "MLOpsSoftCompetency"@en ;
    rdfs:comment "Non-technical skills required for effective MLOps adoption, such as collaboration, communication, and cross-functional teamwork, particularly relevant for SMEs."@en ;
    rdfs:subClassOf schema:DefinedTerm ;
    owl:sameAs mlops:MLOpsTechnicalCompetency .

mlops:MLOpsStandardization rdfs:label "MLOpsStandardization"@en ;
    rdfs:comment "A structured approach or framework for standardizing MLOps practices, processes, and artifacts to ensure consistency, reproducibility, and compliance across the ML lifecycle."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsToolchain rdfs:label "MLOpsToolchain"@en ;
    rdfs:comment "A collection of tools integrated to support MLOps workflows, such as version control, CI/CD, and monitoring."@en ;
    rdfs:subClassOf schema:SoftwareSourceCode .

mlops:MLOpsTrend rdfs:label "MLOpsTrend"@en ;
    rdfs:comment "A direction or pattern of development in MLOps practices, technologies, or methodologies that is gaining prominence or adoption."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLPipelineStage rdfs:label "MLPipelineStage"@en ;
    rdfs:comment "A distinct stage within an ML pipeline, such as data ingestion, training, or deployment."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:MLProduct rdfs:label "MLProduct"@en ;
    rdfs:comment "A machine learning system deployed as a product, designed to deliver specific functionality or value to end-users."@en ;
    rdfs:subClassOf mlops:MLSystem .

mlops:MLProductLifecycleComplexity a owl:Class ;
    rdfs:label "MLProductLifecycleComplexity"@en ;
    rdfs:comment "The complexity arising from the unique lifecycle requirements of machine learning products, including data management, model drift, and continuous improvement needs, which may not align with traditional software engineering patterns."@en ;
    rdfs:subClassOf mlops:MLWorkflowComplexity .

mlops:MLProductQuality rdfs:label "MLProductQuality"@en ;
    rdfs:comment "A benefit of MLOps where the quality of deployed ML products is improved through automation, monitoring, and continuous improvement practices."@en ;
    rdfs:subClassOf mlops:MLOpsBenefit .

mlops:MLProductivity a owl:Class ;
    rdfs:label "MLProductivity"@en ;
    rdfs:comment "The efficiency and effectiveness of stakeholders in MLOps projects, influenced by organizational, process, and technical challenges such as role ambiguity, lack of qualified personnel, and unrealistic customer expectations."@en,
        "The efficiency and effectiveness of stakeholders in MLOps projects, influenced by organizational, process, and technical challenges."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLRegulatoryConstraint rdfs:label "MLRegulatoryConstraint"@en ;
    rdfs:comment "A constraint imposed by regulatory or legal requirements, such as data privacy or model explainability laws."@en ;
    rdfs:subClassOf mlops:MLLifecycleConstraint .

mlops:MLReliability rdfs:label "MLReliability"@en ;
    rdfs:comment "The degree to which MLOps processes and artifacts perform consistently and correctly under specified conditions, including fault tolerance and robustness."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLResourceManagement a owl:Class ;
    rdfs:label "MLResourceManagement"@en ;
    rdfs:comment "The practice of optimizing the allocation and utilization of computational resources, such as GPUs, for machine learning tasks to balance performance, cost, and scalability, particularly in resource-constrained environments."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleAmbiguity a owl:Class ;
    rdfs:label "MLRoleAmbiguity"@en ;
    rdfs:comment "A challenge in MLOps projects where unclear definitions of roles and responsibilities lead to confusion, overloading of personnel, and inefficiencies in ML development and deployment."@en,
        "A situation where the responsibilities and boundaries of MLOps roles are unclear, leading to inefficiencies, conflicts, or tasks being performed outside the intended remit."@en ;
    rdfs:subClassOf mlops:MLChallenge,
        mlops:MLRoleClarity .

mlops:MLRoleOverlap a owl:Class ;
    rdfs:label "MLRoleOverlap"@en ;
    rdfs:comment "A situation where the responsibilities of MLOps roles overlap, leading to redundancy, inefficiencies, or conflicts in task execution."@en ;
    rdfs:subClassOf mlops:MLRoleClarity .

mlops:MLSecurity rdfs:label "MLSecurity"@en ;
    rdfs:comment "The security measures and considerations applied to MLOps processes, artifacts, and infrastructure to ensure trustworthiness and reliability."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLTrend rdfs:label "MLTrend"@en ;
    rdfs:comment "A prevailing direction or pattern in the evolution of MLOps practices, technologies, or applications over time."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLTrustworthiness rdfs:label "MLTrustworthiness"@en ;
    rdfs:comment "The confidence in the correctness, reliability, and ethical alignment of ML models and processes, including aspects like robustness and fairness."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MaturityCriteria a owl:Class ;
    rdfs:label "MaturityCriteria"@en ;
    rdfs:comment "A specific criterion or requirement used to evaluate a maturity dimension in an MLOps assessment."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:MaturityAssessment,
        mlops:MaturityDimension,
        mlops:MaturityFramework .

mlops:Metadata rdfs:label "Metadata"@en ;
    rdfs:comment "Descriptive information associated with a record or artifact, such as title, abstract, citation count, or publication date."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MetadataRetrieval rdfs:label "MetadataRetrieval"@en ;
    rdfs:comment "A process of programmatically collecting and storing metadata associated with studies or artifacts, often from databases or APIs."@en ;
    rdfs:subClassOf mlops:MLProcess ;
    owl:sameAs mlops:MetadataHarvesting .

mlops:ModelDrift rdfs:label "ModelDrift"@en ;
    rdfs:comment "A type of concept drift where the relationship between input data and output predictions changes, degrading model accuracy."@en ;
    rdfs:subClassOf mlops:ConceptDrift .

mlops:ModelEvaluation rdfs:label "ModelEvaluation"@en ;
    rdfs:comment "A process for evaluating the performance of a machine learning model using metrics and benchmarks."@en,
        "An artifact representing the results of evaluating a model's performance, fairness, or compliance."@en,
        "The process of assessing a model's performance using metrics and validation datasets to ensure it meets required standards."@en ;
    rdfs:subClassOf mlops:MLArtifact,
        mlops:MLProcess .

mlops:ModelExplainabilityRequirement rdfs:label "ModelExplainabilityRequirement"@en ;
    rdfs:comment "A compliance requirement related to the interpretability and explainability of ML models."@en,
        "A compliance requirement related to the interpretability and transparency of machine learning models, ensuring that model decisions can be understood and explained."@en ;
    rdfs:subClassOf mlops:MLComplianceRequirement .

mlops:ModelFairnessRequirement rdfs:label "ModelFairnessRequirement"@en ;
    rdfs:comment "A compliance requirement ensuring that ML models and processes do not discriminate unfairly against individuals or groups, considering ethical and societal impacts."@en ;
    rdfs:subClassOf mlops:MLComplianceRequirement .

mlops:ModelGovernance rdfs:label "ModelGovernance"@en ;
    rdfs:comment "A compliance requirement related to the management and validation of models, including versioning and explainability."@en,
        "The framework and processes for managing the lifecycle of models, including approval, monitoring, and retirement."@en ;
    rdfs:subClassOf mlops:MLCompliance,
        schema:Thing .

mlops:ModelInterpretability rdfs:label "ModelInterpretability"@en ;
    rdfs:comment "The ability to understand and interpret the decisions made by a machine learning model, often through techniques like SHAP or LIME, ensuring transparency and trust in model outputs."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:ensuresModelInterpretability .

mlops:ModelLineage rdfs:label "ModelLineage"@en ;
    rdfs:comment "A record of the origin, evolution, and dependencies of a machine learning model across versions and experiments."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:ModelPackaging rdfs:label "ModelPackaging"@en ;
    rdfs:comment "A process of preparing a trained ML model for deployment, including serialization, containerization, and metadata attachment."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ModelServingEngine rdfs:label "ModelServingEngine"@en ;
    rdfs:comment "A software component responsible for serving model predictions in real-time or batch mode."@en ;
    rdfs:subClassOf mlops:MLTool .

mlops:ModelServingTool rdfs:label "ModelServingTool"@en ;
    rdfs:comment "A tool for serving models in production environments for inference."@en ;
    rdfs:subClassOf mlops:MLTool .

mlops:ModelVersioning rdfs:label "ModelVersioning"@en ;
    rdfs:comment "A process or system for managing and tracking versions of machine learning models to ensure reproducibility, rollback capabilities, and compliance with deployment requirements."@en,
        "A process or system for tracking and managing versions of ML models, including parameters, metadata, and lineage for reproducibility."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MonitoringStage a owl:Class ;
    rdfs:label "MonitoringStage"@en ;
    rdfs:comment "A lifecycle stage focused on observing and evaluating the performance and behavior of ML systems during runtime."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:MultidisciplinaryDomain rdfs:label "MultidisciplinaryDomain"@en ;
    rdfs:comment "A domain that integrates multiple disciplines or fields, such as MLOps which combines ML, software engineering, and operations."@en ;
    rdfs:subClassOf schema:Thing .

mlops:NetworkOrchestration a owl:Class ;
    rdfs:label "NetworkOrchestration"@en ;
    rdfs:comment "The process of dynamically managing and orchestrating network resources, services, or slices, often in 5G/6G contexts."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:NetworkTopology rdfs:label "NetworkTopology"@en ;
    rdfs:comment "The structural arrangement of nodes and connections in a network, which can be optimized for robustness or performance."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasNetworkTopology .

mlops:NetworkingComponent rdfs:label "NetworkingComponent"@en ;
    rdfs:comment "A component or system involved in network communication, such as lightweight networks used for reliability estimation or event-driven AI solutions."@en ;
    rdfs:subClassOf schema:Thing .

mlops:OperationalLevel rdfs:label "OperationalLevel"@en ;
    rdfs:comment "The middle level of abstraction in a measurement model, where questions are developed to focus, characterize, and structure the evaluation of research papers."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasOperationalLevel .

mlops:OperationalProblemChallenge rdfs:label "OperationalProblemChallenge"@en ;
    rdfs:comment "A challenge related to immediate operational problems in MLOps, such as faulty pipelines, data inconsistencies, or lack of specialized personnel."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:Operationalization rdfs:label "Operationalization"@en ;
    rdfs:comment "The process of converting AI insights into tangible business value through deployment and integration."@en ;
    rdfs:subClassOf prov:Activity .

mlops:OptimizationGoal rdfs:label "OptimizationGoal"@en ;
    rdfs:comment "A specific objective targeted during the optimization of machine learning models or processes, such as minimizing latency, maximizing accuracy, or reducing energy consumption."@en ;
    rdfs:subClassOf schema:Thing .

mlops:OrchestrationInfrastructure rdfs:label "OrchestrationInfrastructure"@en ;
    rdfs:comment "Platforms for coordinating and managing MLOps workflows, such as Kubernetes or Airflow."@en,
        "Platforms that coordinate and manage MLOps workflows, such as Kubernetes or Airflow."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:OrganizationalCulture rdfs:label "OrganizationalCulture"@en ;
    rdfs:comment "A set of shared values, practices, and behaviors within an organization that influence the adoption and effectiveness of MLOps, including collaboration, experimentation, and continuous learning."@en ;
    rdfs:subClassOf mlops:MLOpsEnabler .

mlops:PrivacyConstraint rdfs:label "PrivacyConstraint"@en ;
    rdfs:comment "A requirement or limitation related to protecting sensitive data and ensuring compliance with privacy regulations."@en ;
    rdfs:subClassOf schema:Thing .

mlops:QualityOfExperience a owl:Class ;
    rdfs:label "QualityOfExperience"@en ;
    rdfs:comment "A metric or framework for evaluating the end-user experience in applications, particularly in edge or IoT deployments."@en ;
    rdfs:subClassOf schema:Thing .

mlops:QualityOfService a owl:Class ;
    rdfs:label "QualityOfService"@en ;
    rdfs:comment "A metric or framework for evaluating the quality of service provided by ML systems, including reliability, performance, and user satisfaction."@en ;
    rdfs:subClassOf schema:Thing .

mlops:QuantitativeLevel rdfs:label "QuantitativeLevel"@en ;
    rdfs:comment "The lowest level of abstraction in a measurement model, where specific metrics are created to provide quantifiable answers to research questions."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasQuantitativeLevel .

mlops:ResearchBias a owl:Class ;
    rdfs:label "ResearchBias"@en ;
    rdfs:comment "A systematic error or deviation in research that affects the validity or reliability of findings, such as selection bias or confirmation bias."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:ResearchTrend .

mlops:ResearchBiasChallenge rdfs:label "ResearchBiasChallenge"@en ;
    rdfs:comment "A challenge arising from research bias in MLOps literature, where problems and solutions are overemphasized compared to benefits."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:ResourceAllocation rdfs:label "ResourceAllocation"@en ;
    rdfs:comment "A process of assigning computational resources to ML tasks, such as training or inference, based on system state and requirements."@en,
        "The process of assigning and managing computational resources to ML workflows to optimize performance, cost, and scalability."@en ;
    rdfs:subClassOf mlops:MLProcess ;
    owl:sameAs mlops:ResourceProvisioning .

mlops:ResourceProvisioning rdfs:label "ResourceProvisioning"@en ;
    rdfs:comment "A domain focused on the allocation and management of computational resources, including consolidation, scheduling, power management, service composition, and workload estimation."@en ;
    rdfs:subClassOf mlops:IndustryDomain .

mlops:ResourceScalability rdfs:label "ResourceScalability"@en ;
    rdfs:comment "The ability of a system to dynamically adjust computational resources (e.g., CPU, GPU, memory) to meet demand."@en ;
    rdfs:subClassOf schema:Thing .

mlops:RootCauseAnalysis rdfs:label "RootCauseAnalysis"@en ;
    rdfs:comment "A process for identifying the underlying causes of failures or anomalies in machine learning systems or infrastructure."@en,
        "A process of identifying the underlying causes of system failures or anomalies, often using logs or other data sources."@en,
        "A process or system that investigates and identifies the underlying causes of failures or anomalies in IT infrastructure or ML systems."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:SMEsOrientedMLOps a owl:Class ;
    rdfs:label "SMEsOrientedMLOps"@en ;
    rdfs:comment "A specialized MLOps approach tailored to the needs and constraints of small and medium-sized enterprises (SMEs), focusing on cost-effectiveness, process maturity, and accessibility."@en ;
    rdfs:subClassOf mlops:MLOps .

mlops:ScalabilityRequirement rdfs:label "ScalabilityRequirement"@en ;
    rdfs:comment "A requirement related to the ability of an ML system to handle increasing workloads or data volumes efficiently."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ScreeningPhase rdfs:label "ScreeningPhase"@en ;
    rdfs:comment "A phase in a systematic review or MLOps process where records are evaluated against inclusion/exclusion criteria based on metadata such as title or abstract."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:SearchQuery rdfs:label "SearchQuery"@en ;
    rdfs:comment "A structured query used to retrieve relevant documents or metadata from databases or APIs, such as Scopus or other academic search services."@en ;
    rdfs:subClassOf mlops:MLProcess ;
    owl:sameAs mlops:hasSearchQuery .

mlops:SecurityConstraint rdfs:label "SecurityConstraint"@en ;
    rdfs:comment "A requirement or limitation related to protecting data, models, and infrastructure from unauthorized access or attacks."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ServerlessArchitecture rdfs:label "ServerlessArchitecture"@en ;
    rdfs:comment "A cloud computing execution model where the cloud provider dynamically manages server infrastructure, allowing developers to focus on code rather than infrastructure management."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ServerlessExecution rdfs:label "ServerlessExecution"@en ;
    rdfs:comment "The execution of ML tasks using serverless computing platforms, which abstract away infrastructure management and scale automatically."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ServerlessInfrastructure a owl:Class ;
    rdfs:label "ServerlessInfrastructure"@en ;
    rdfs:comment "A cloud infrastructure paradigm where resource management is abstracted from the user, enabling automatic scaling and cost optimization for ML workloads."@en,
        "A type of ML infrastructure leveraging serverless technologies for deployment and orchestration of ML workloads."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:SmallMediumSDC a owl:Class ;
    rdfs:label "SmallMediumSDC"@en ;
    rdfs:comment "A software development company categorized as small (11 to 50 employees) or medium (51 to 200 employees) based on employee count."@en ;
    rdfs:subClassOf schema:Organization ;
    owl:sameAs mlops:appliesToSmallMediumSDC .

mlops:SocialDebt rdfs:label "SocialDebt"@en ;
    rdfs:comment "A challenge in MLOps projects where ambiguity in defining roles and artifacts leads to overloading of personnel, resulting in inefficiencies and reduced productivity."@en,
        "A form of debt arising from social or organizational factors in MLOps, such as unclear role definitions, lack of collaboration, or misaligned incentives that impede effective teamwork and process efficiency."@en ;
    rdfs:subClassOf mlops:MLChallenge,
        schema:Thing ;
    owl:sameAs mlops:MLTechnicalDebt,
        mlops:TechnicalDebt,
        mlops:addressesTechnicalDebt,
        mlops:hasSocialDebt,
        mlops:hasTechnicalDebt .

mlops:SoftSkillsRequirement rdfs:label "SoftSkillsRequirement"@en ;
    rdfs:comment "The non-technical skills required for effective MLOps, such as communication, collaboration, and adaptability, particularly for roles like data scientists interacting with stakeholders."@en ;
    rdfs:subClassOf mlops:MLRole .

mlops:SoftwareEngineeringPrinciples rdfs:label "SoftwareEngineeringPrinciples"@en ;
    rdfs:comment "The application of software engineering best practices, such as version control, testing, and CI/CD, to the ML workflow."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:appliesSoftwareEngineeringPrinciples .

mlops:SystematicLiteratureReviewCollaboration rdfs:label "SystematicLiteratureReviewCollaboration"@en ;
    rdfs:comment "A collaborative effort between researchers or practitioners to conduct systematic literature reviews, emphasizing cross-domain skills and coordinated workflows."@en ;
    rdfs:subClassOf mlops:Collaboration .

mlops:SystematicLiteratureReviewProcess rdfs:label "SystematicLiteratureReviewProcess"@en ;
    rdfs:comment "A structured and comprehensive process for conducting systematic literature reviews in MLOps contexts, including identification, screening, eligibility, and inclusion stages."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:SystematicLiteratureReviewTool rdfs:label "SystematicLiteratureReviewTool"@en ;
    rdfs:comment "A tool or platform used to support systematic literature review processes, such as metadata harvesting, screening, or quality assessment."@en ;
    rdfs:subClassOf mlops:MLTool ;
    owl:sameAs mlops:SystematicLiteratureReviewChallenge,
        mlops:SystematicLiteratureReviewCollaboration,
        mlops:SystematicLiteratureReviewCriteria,
        mlops:SystematicLiteratureReviewEnabler,
        mlops:SystematicLiteratureReviewProcess,
        mlops:SystematicLiteratureReviewReport,
        mlops:SystematicLiteratureReviewStage .

mlops:TaskDistribution rdfs:label "TaskDistribution"@en ;
    rdfs:comment "The allocation and execution of computational tasks across distributed systems or nodes to optimize performance and resource utilization."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:TaskOffloading a owl:Class ;
    rdfs:label "TaskOffloading"@en ;
    rdfs:comment "The process of delegating computational tasks from resource-constrained devices to more capable edge or cloud infrastructure."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:TrafficAnalysis a owl:Class ;
    rdfs:label "TrafficAnalysis"@en ;
    rdfs:comment "A process or system that analyzes network traffic patterns, often in the context of 5G/6G architectures, to optimize ML-based solutions."@en,
        "The process of analyzing network traffic to classify patterns, detect anomalies, or optimize performance, often used in 5G/6G networks."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:TrainingRun rdfs:label "TrainingRun"@en ;
    rdfs:comment "An instance of a model training process, including configuration, data, and outcomes."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ValidationJob rdfs:label "ValidationJob"@en ;
    rdfs:comment "A discrete execution of a validation process that evaluates the performance or compliance of a model or artifact."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ValidationProcess rdfs:label "ValidationProcess"@en ;
    rdfs:comment "A process for validating the performance, fairness, and compliance of a machine learning model."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:addressesSystematicLiteratureReviewChallenge a owl:ObjectProperty ;
    rdfs:label "addressesSystematicLiteratureReviewChallenge"@en ;
    rdfs:comment "Relates a systematic literature review process to the challenge it addresses or mitigates."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:SystematicLiteratureReviewChallenge ;
    rdfs:subPropertyOf mlops:addressesChallenge .

mlops:addressesTechnicalDebt rdfs:label "addressesTechnicalDebt"@en ;
    rdfs:comment "Relates an MLOps process or system to the reduction or mitigation of technical debt in ML model development."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range mlops:MLTechnicalDebt ;
    rdfs:subPropertyOf mlops:addressesChallenge .

mlops:appliesSoftwareEngineeringPrinciples rdfs:label "appliesSoftwareEngineeringPrinciples"@en ;
    rdfs:comment "Relates an MLOps process or system to the software engineering principles it applies."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:SoftwareEngineeringPrinciples ;
    rdfs:subPropertyOf prov:used .

mlops:appliesToIndustry rdfs:label "appliesToIndustry"@en ;
    rdfs:comment "Relates an MLOps process, artifact, or system to the industry domain it is applied in."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:IndustryDomain ;
    rdfs:subPropertyOf mlops:hasIndustryDomain .

mlops:appliesToSmallMediumSDC a owl:ObjectProperty ;
    rdfs:label "appliesToSmallMediumSDC"@en ;
    rdfs:comment "Relates a research process or artifact to its application in small and medium software development companies."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range mlops:SmallMediumSDC ;
    rdfs:subPropertyOf mlops:hasApplicationField .

mlops:assessesQuality rdfs:label "assessesQuality"@en ;
    rdfs:comment "Relates a quality assessment process to the artifact, study, or process it evaluates."@en ;
    rdfs:domain mlops:QualityAssessment ;
    rdfs:range mlops:MLArtifact ;
    rdfs:subPropertyOf prov:used .

mlops:ensuresModelInterpretability rdfs:label "ensuresModelInterpretability"@en ;
    rdfs:comment "Relates a process or artifact to the interpretability requirements it satisfies, ensuring that model decisions can be understood and explained."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:ModelInterpretability ;
    rdfs:subPropertyOf mlops:ensuresCompliance .

mlops:facilitatedBy rdfs:label "facilitatedBy"@en ;
    rdfs:comment "Relates an MLOps process or system to a framework or architecture that enables or supports it."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsFramework ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:facilitatedBySystematicLiteratureReviewEnabler a owl:ObjectProperty ;
    rdfs:label "facilitatedBySystematicLiteratureReviewEnabler"@en ;
    rdfs:comment "Relates a systematic literature review process to the enabler that facilitates its execution."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:SystematicLiteratureReviewEnabler ;
    rdfs:subPropertyOf mlops:facilitatedBy .

mlops:facilitates rdfs:label "facilitates"@en ;
    rdfs:comment "Relates an MLOps process or system to the creation or improvement of machine learning products or systems."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLProduct ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasAIOpsTool a owl:ObjectProperty ;
    rdfs:label "hasAIOpsTool"@en ;
    rdfs:comment "Relates an MLOps process or system to an AIOps tool it employs for operations management."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:AIOps ;
    rdfs:subPropertyOf mlops:usesTool .

mlops:hasApplicationField rdfs:label "hasApplicationField"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to the field in which it is applied."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsApplicationField ;
    rdfs:subPropertyOf schema:subjectOf .

mlops:hasAutomationCapability rdfs:label "hasAutomationCapability"@en ;
    rdfs:comment "Relates a process or system to the types of automation it supports, such as anomaly detection, root-cause analysis, or automated actions."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range schema:DefinedTerm ;
    rdfs:subPropertyOf schema:additionalProperty .

mlops:hasBigDataParadigm rdfs:label "hasBigDataParadigm"@en ;
    rdfs:comment "Relates an MLOps process or system to the Big Data paradigm it employs or is constrained by."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:BigDataParadigm ;
    rdfs:subPropertyOf prov:used .

mlops:hasBusinessGoal rdfs:label "hasBusinessGoal"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the business goal it supports."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:BusinessGoal ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasConceptualLevel rdfs:label "hasConceptualLevel"@en ;
    rdfs:comment "Relates a measurement model to its conceptual level, where objectives are defined to establish the purpose of a systematic review."@en ;
    rdfs:domain mlops:MeasurementModel ;
    rdfs:range mlops:ConceptualLevel ;
    rdfs:subPropertyOf prov:used .

mlops:hasDeploymentStrategy a owl:ObjectProperty ;
    rdfs:label "hasDeploymentStrategy"@en ;
    rdfs:comment "Relates a deployment process to the strategy it employs, such as canary or blue-green deployment, to ensure safe and reliable model rollout."@en,
        "Relates a deployment process to the strategy it employs."@en ;
    rdfs:domain mlops:MLDeploymentProcess,
        mlops:MLPipeline ;
    rdfs:range mlops:DeploymentStrategy,
        mlops:MLDeploymentStrategy ;
    rdfs:subPropertyOf prov:used,
        schema:hasOccupation .

mlops:hasEdgeLifecycleStage rdfs:label "hasEdgeLifecycleStage"@en ;
    rdfs:comment "Relates an edge MLOps process or system to a lifecycle stage it involves or affects in edge environments."@en ;
    rdfs:domain mlops:EdgeMLOps ;
    rdfs:range mlops:MLLifecycleStage ;
    rdfs:subPropertyOf mlops:hasLifecycleStage .

mlops:hasFailureMode rdfs:label "hasFailureMode"@en ;
    rdfs:comment "Relates a monitoring or analysis process to the type of failure or anomaly it addresses, such as drift, performance degradation, or infrastructure failure."@en ;
    rdfs:domain mlops:MLMonitoring ;
    rdfs:range mlops:FailureMode ;
    rdfs:subPropertyOf schema:object .

mlops:hasFilterCriterion rdfs:label "hasFilterCriterion"@en ;
    rdfs:comment "Relates a filtering process to the criteria it applies, such as exclusion of retracted articles or prioritization by citation count."@en ;
    rdfs:domain mlops:AutomatedFiltering ;
    rdfs:range mlops:FilterCriterion ;
    rdfs:subPropertyOf prov:used .

mlops:hasInformationExtraction rdfs:label "hasInformationExtraction"@en ;
    rdfs:comment "Relates a systematic review process to the extraction of information from selected studies or artifacts."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:InformationExtraction ;
    rdfs:subPropertyOf prov:used .

mlops:hasLifecycle rdfs:label "hasLifecycle"@en ;
    rdfs:comment "Relates an MLOps system or process to its lifecycle."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLLifecycle ;
    rdfs:subPropertyOf prov:used .

mlops:hasMaturityChallenge a owl:ObjectProperty ;
    rdfs:label "hasMaturityChallenge"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to a maturity-related challenge it faces or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsMaturityChallenge ;
    rdfs:subPropertyOf mlops:hasChallenge .

mlops:hasMaturityCriteria a owl:ObjectProperty ;
    rdfs:label "hasMaturityCriteria"@en ;
    rdfs:comment "Relates a maturity dimension to the criteria used to evaluate it."@en ;
    rdfs:domain mlops:MaturityDimension ;
    rdfs:range mlops:MaturityCriteria ;
    rdfs:subPropertyOf prov:used .

mlops:hasMaturityDimension a owl:ObjectProperty ;
    rdfs:label "hasMaturityDimension"@en ;
    rdfs:comment "Relates an MLOps maturity model or assessment to a specific dimension it evaluates."@en ;
    rdfs:domain mlops:MLOpsMaturityModel ;
    rdfs:range mlops:MaturityDimension ;
    rdfs:subPropertyOf prov:used .

mlops:hasMaturityFramework a owl:ObjectProperty ;
    rdfs:label "hasMaturityFramework"@en ;
    rdfs:comment "Relates an organization or process to the maturity framework it uses for assessment and improvement."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MaturityFramework ;
    rdfs:subPropertyOf prov:used .

mlops:hasMaturityLevel a owl:ObjectProperty ;
    rdfs:label "hasMaturityLevel"@en ;
    rdfs:comment "Relates an MLOps process, system, or organization to the maturity level it has achieved or is assessed against."@en,
        "Relates an organization or process to its MLOps maturity level."@en,
        "Relates an organization or process to the maturity level it has achieved in MLOps practices, based on a maturity model."@en ;
    rdfs:domain mlops:MLOps,
        mlops:MLOpsCapabilityAssessment ;
    rdfs:range mlops:MLOpsMaturityLevel,
        mlops:MLOpsMaturityModel ;
    rdfs:subPropertyOf prov:wasGeneratedBy,
        schema:additionalProperty,
        schema:hasOccupation .

mlops:hasMeasurementModel rdfs:label "hasMeasurementModel"@en ;
    rdfs:comment "Relates a research process to the measurement model it employs, such as the Goal-Question-Metric (GQM) approach."@en ;
    rdfs:domain mlops:ResearchObjective ;
    rdfs:range mlops:MeasurementModel ;
    rdfs:subPropertyOf prov:used .

mlops:hasNetworkTopology rdfs:label "hasNetworkTopology"@en ;
    rdfs:comment "Relates a system or process to the network topology it operates within or optimizes."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:NetworkTopology ;
    rdfs:subPropertyOf schema:subjectOf .

mlops:hasOperationalLevel rdfs:label "hasOperationalLevel"@en ;
    rdfs:comment "Relates a measurement model to its operational level, where questions are derived to focus and characterize the evaluation of research papers."@en ;
    rdfs:domain mlops:MeasurementModel ;
    rdfs:range mlops:OperationalLevel ;
    rdfs:subPropertyOf prov:used .

mlops:hasOpportunity rdfs:label "hasOpportunity"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to an opportunity it leverages or creates."@en,
        "Relates an MLOps process, system, or artifact to an opportunity it presents or leverages."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpportunity,
        mlops:MLOpsOpportunity ;
    rdfs:subPropertyOf schema:hasOccupation,
        schema:subjectOf .

mlops:hasOpportunityCategory rdfs:label "hasOpportunityCategory"@en ;
    rdfs:comment "Relates an MLOps process, system, or artifact to a category of opportunities it leverages or creates."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsOpportunityCategory ;
    rdfs:subPropertyOf schema:subjectOf .

mlops:hasPrinciple rdfs:label "hasPrinciple"@en ;
    rdfs:comment "Relates an MLOps process or system to a guiding principle it adheres to."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLPrinciple ;
    rdfs:subPropertyOf prov:used .

mlops:hasProactiveMonitoringStrategy a owl:ObjectProperty ;
    rdfs:label "hasProactiveMonitoringStrategy"@en ;
    rdfs:comment "Relates an MLOps process or system to the presence of a proactive monitoring strategy for detecting model drift, performance degradation, or data changes."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range xsd:boolean ;
    rdfs:subPropertyOf schema:potentialAction .

mlops:hasProcessMaturity a owl:ObjectProperty ;
    rdfs:label "hasProcessMaturity"@en ;
    rdfs:comment "Relates an MLOps process or system to its level of maturity, defined by how well-defined, controlled, and predictable it is."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLOpsProcessMaturity ;
    rdfs:subPropertyOf prov:used .

mlops:hasQualityMetric rdfs:label "hasQualityMetric"@en ;
    rdfs:comment "Relates an MLOps artifact, process, or study to a quality metric used to evaluate it."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:QualityMetric ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasQuantitativeLevel rdfs:label "hasQuantitativeLevel"@en ;
    rdfs:comment "Relates a measurement model to its quantitative level, where specific metrics are created to provide quantifiable answers to research questions."@en ;
    rdfs:domain mlops:MeasurementModel ;
    rdfs:range mlops:QuantitativeLevel ;
    rdfs:subPropertyOf prov:used .

mlops:hasResearchObjective rdfs:label "hasResearchObjective"@en ;
    rdfs:comment "Relates a systematic review or research process to the objectives or goals it aims to achieve."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:ResearchObjective ;
    rdfs:subPropertyOf prov:used .

mlops:hasRole a owl:ObjectProperty ;
    rdfs:label "hasRole"@en ;
    rdfs:comment "Relates an agent or team to a role they perform within MLOps, such as Data Scientist or ML Engineer."@en,
        "Relates an agent or team to a role they perform within MLOps."@en ;
    rdfs:domain schema:Person ;
    rdfs:range mlops:MLRole ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasSearchQuery rdfs:label "hasSearchQuery"@en ;
    rdfs:comment "Relates a metadata harvesting process to the search query it employs to retrieve relevant documents or metadata."@en ;
    rdfs:domain mlops:MetadataHarvesting ;
    rdfs:range mlops:SearchQuery ;
    rdfs:subPropertyOf mlops:hasProcess .

mlops:hasSelectionStage rdfs:label "hasSelectionStage"@en ;
    rdfs:comment "Relates a systematic review process to a specific stage in the selection process, such as identification, screening, or full reading."@en ;
    rdfs:domain mlops:SystematicReview ;
    rdfs:range mlops:SelectionStage ;
    rdfs:subPropertyOf prov:used .

mlops:hasSocialDebt rdfs:label "hasSocialDebt"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the social debt it incurs or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:SocialDebt ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasSystematicLiteratureReviewCriteria a owl:ObjectProperty ;
    rdfs:label "hasSystematicLiteratureReviewCriteria"@en ;
    rdfs:comment "Relates a systematic literature review process to the criteria it employs for inclusion or exclusion of studies."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:SystematicLiteratureReviewCriteria ;
    rdfs:subPropertyOf mlops:hasSelectionCriteria .

mlops:hasSystematicLiteratureReviewReport a owl:ObjectProperty ;
    rdfs:label "hasSystematicLiteratureReviewReport"@en ;
    rdfs:comment "Relates a systematic literature review process to the report it produces documenting findings and conclusions."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:SystematicLiteratureReviewReport ;
    rdfs:subPropertyOf mlops:hasArtifact .

mlops:hasSystematicLiteratureReviewStage a owl:ObjectProperty ;
    rdfs:label "hasSystematicLiteratureReviewStage"@en ;
    rdfs:comment "Relates a systematic literature review process to a specific stage it involves or affects, such as identification or screening."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:SystematicLiteratureReviewStage ;
    rdfs:subPropertyOf mlops:hasLifecycleStage .

mlops:hasTechnicalDebt rdfs:label "hasTechnicalDebt"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the technical debt it incurs or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:TechnicalDebt ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasWorkflowComplexity rdfs:label "hasWorkflowComplexity"@en ;
    rdfs:comment "Relates an MLOps process or system to the complexity of the ML workflow it involves."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLWorkflowComplexity ;
    rdfs:subPropertyOf schema:description .

mlops:improvesRoleAlignment rdfs:label "improvesRoleAlignment"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the improvement of role alignment it provides."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleAlignment ;
    rdfs:subPropertyOf schema:improves .

mlops:improvesRoleCollaboration rdfs:label "improvesRoleCollaboration"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the improvement of role collaboration it provides."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleCollaboration ;
    rdfs:subPropertyOf schema:improves .

mlops:improvesRoleIntegration rdfs:label "improvesRoleIntegration"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the improvement of role integration it provides."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleIntegration ;
    rdfs:subPropertyOf schema:improves .

mlops:improvesRoleOptimization rdfs:label "improvesRoleOptimization"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the improvement of role optimization it provides."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleOptimization ;
    rdfs:subPropertyOf schema:improves .

mlops:measuresBusinessImpact rdfs:label "measuresBusinessImpact"@en ;
    rdfs:comment "Relates a process or system to the business impact it measures or aims to achieve."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:BusinessImpact ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:monitorsDataQuality rdfs:label "monitorsDataQuality"@en ;
    rdfs:comment "Relates a monitoring system to the quality of data it observes."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:DataObservability ;
    rdfs:subPropertyOf mlops:monitors .

mlops:performsNetworkOrchestration a owl:ObjectProperty ;
    rdfs:label "performsNetworkOrchestration"@en ;
    rdfs:comment "Relates an MLOps tool or system to the network orchestration process it performs."@en ;
    rdfs:domain mlops:MLTool ;
    rdfs:range mlops:NetworkOrchestration ;
    rdfs:subPropertyOf schema:potentialAction .

mlops:providesIntelligentAutomation rdfs:label "providesIntelligentAutomation"@en ;
    rdfs:comment "Relates an MLOps system or tool to the intelligent automation capabilities it offers or enables."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:IntelligentAutomation ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:reliesOnInfrastructure a owl:ObjectProperty ;
    rdfs:label "reliesOnInfrastructure"@en ;
    rdfs:comment "Relates an MLOps process or system to the specific infrastructure it depends on."@en,
        "Relates an MLOps process or system to the specific type of infrastructure it depends on, such as HPC, cloud, or edge computing."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLInfrastructure ;
    rdfs:subPropertyOf mlops:reliesOn .

mlops:requiresLeadershipEngagement rdfs:label "requiresLeadershipEngagement"@en ;
    rdfs:comment "Relates an MLOps process or system to the leadership engagement it requires."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:LeadershipEngagement ;
    rdfs:subPropertyOf prov:wasAssociatedWith .

mlops:requiresRoleAlignment rdfs:label "requiresRoleAlignment"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the role alignment it requires or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleAlignment ;
    rdfs:subPropertyOf prov:used .

mlops:requiresRoleClarity rdfs:label "requiresRoleClarity"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the role clarity it requires or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleClarity ;
    rdfs:subPropertyOf prov:used .

mlops:requiresRoleCollaboration rdfs:label "requiresRoleCollaboration"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the role collaboration it requires or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleCollaboration ;
    rdfs:subPropertyOf prov:used .

mlops:requiresRoleDefinition rdfs:label "requiresRoleDefinition"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the role definition it requires or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleDefinition ;
    rdfs:subPropertyOf prov:used .

mlops:requiresRoleIntegration rdfs:label "requiresRoleIntegration"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the role integration it requires or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleIntegration ;
    rdfs:subPropertyOf prov:used .

mlops:requiresRoleOptimization rdfs:label "requiresRoleOptimization"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the role optimization it requires or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLRoleOptimization ;
    rdfs:subPropertyOf prov:used .

mlops:supportsLifecycleStage rdfs:label "supportsLifecycleStage"@en ;
    rdfs:comment "Relates an MLOps tool or framework to the lifecycle stages it supports, such as training, deployment, or monitoring."@en ;
    rdfs:domain mlops:MLTool ;
    rdfs:range mlops:MLLifecycleStage ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:usesDataset rdfs:label "usesDataset"@en ;
    rdfs:comment "Relates a process or system to the dataset it uses or consumes."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range schema:Dataset ;
    rdfs:subPropertyOf prov:used .

mlops:usesFeatureStore rdfs:label "usesFeatureStore"@en ;
    rdfs:comment "Relates a process or system to the feature store it uses or consumes."@en ;
    rdfs:domain mlops:MLProcess ;
    rdfs:range mlops:FeatureStore ;
    rdfs:subPropertyOf prov:used .

mlops:usesParadigm rdfs:label "usesParadigm"@en ;
    rdfs:comment "Relates an MLOps process or system to the computing paradigm it employs, such as cloud or edge computing."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf mlops:reliesOn .

schema:Boolean owl:sameAs xsd:boolean .

schema:monitors owl:sameAs mlops:monitors .

mlops:AIServiceDevelopment rdfs:label "AIServiceDevelopment"@en ;
    rdfs:comment "The process of developing artificial intelligence solutions as software projects, including requirements analysis, design, implementation, and testing."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:BigDataParadigm rdfs:label "BigDataParadigm"@en ;
    rdfs:comment "A computational approach for processing large-scale datasets that exceed the capacity of traditional data processing systems, often involving distributed storage and processing."@en ;
    rdfs:subClassOf schema:Thing .

mlops:BusinessGoal a owl:Class ;
    rdfs:label "BusinessGoal"@en ;
    rdfs:comment "A business objective or requirement that guides the development and deployment of AI solutions, ensuring alignment with organizational needs."@en,
        "A business objective or requirement that guides the development and deployment of AI solutions."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasBusinessGoal .

mlops:DataManagement rdfs:label "DataManagement"@en ;
    rdfs:comment "A structured approach to handling data throughout its lifecycle in MLOps, including collection, cleaning, standardization, integration, and sharing."@en,
        "The practice of managing data throughout its lifecycle, ensuring quality, accessibility, and compliance for machine learning projects."@en,
        "The practice of overseeing the lifecycle of data, including ingestion, storage, processing, and governance, to ensure its quality, accessibility, and compliance for ML tasks."@en,
        "The process of collecting, storing, processing, and governing data to ensure its quality, accessibility, and usability for ML tasks."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage,
        mlops:MLProcess .

mlops:DataPrivacyManagement a owl:Class ;
    rdfs:label "DataPrivacyManagement"@en ;
    rdfs:comment "A process or system responsible for managing and enforcing data privacy policies, ensuring compliance with regulations and building trust in ML systems through responsible data handling."@en,
        "The process of establishing and enforcing policies for protecting confidential and sensitive data throughout the machine learning lifecycle, from project conception to deployment."@en ;
    rdfs:subClassOf mlops:DataManagement,
        mlops:MLProcess .

mlops:EdgeInfrastructure a owl:Class ;
    rdfs:label "EdgeInfrastructure"@en ;
    rdfs:comment "A distributed computing infrastructure located at the edge of the network, enabling low-latency processing and deployment of ML models in proximity to data sources or end-users."@en,
        "A type of ML infrastructure leveraging edge computing resources for deployment and orchestration of ML workloads."@en,
        "Hardware and software resources located at the edge of the network, enabling low-latency ML inference and processing for IoT and mobile devices."@en,
        "The hardware and software infrastructure supporting MLOps at the edge, including edge devices, gateways, and local compute resources."@en ;
    rdfs:subClassOf mlops:MLInfrastructure .

mlops:EdgeMLOps rdfs:label "EdgeMLOps"@en ;
    rdfs:comment "A specialized MLOps framework for managing the lifecycle of machine learning models deployed in edge environments."@en ;
    rdfs:subClassOf mlops:MLOps .

mlops:Experiment rdfs:label "Experiment"@en ;
    rdfs:comment "A structured process of testing and evaluating ML models or configurations, including data, parameters, and outcomes."@en,
        "A structured process of testing and evaluating ML models or configurations, including data, parameters, metrics, and outcomes, often tracked for reproducibility and comparison."@en ;
    rdfs:subClassOf prov:Activity .

mlops:FailureManagement rdfs:label "FailureManagement"@en ;
    rdfs:comment "A domain focused on proactive and reactive measures to prevent, predict, detect, analyze, and remediate failures in systems or processes."@en,
        "A process or system focused on detecting, analyzing, and mitigating failures in ML systems or infrastructure."@en ;
    rdfs:subClassOf mlops:IndustryDomain,
        mlops:MLProcess .

mlops:FeatureStore rdfs:label "FeatureStore"@en ;
    rdfs:comment "A centralized repository for storing, managing, and serving features for machine learning models to ensure consistency and reusability."@en,
        "A centralized repository for storing, managing, and serving features used in machine learning models to ensure consistency and reusability."@en,
        "A centralized storage system for managing and serving features used in machine learning models."@en,
        "A tool or platform for storing, managing, and serving features for ML models."@en ;
    rdfs:subClassOf mlops:MLArtifact,
        mlops:MLTool .

mlops:InclusionCriteria rdfs:label "InclusionCriteria"@en ;
    rdfs:comment "A specific condition or rule used to include studies in a systematic literature review."@en ;
    rdfs:subClassOf mlops:SelectionCriteria .

mlops:IntelligentAutomation rdfs:label "IntelligentAutomation"@en ;
    rdfs:comment "The application of AI techniques to automate and optimize MLOps processes, such as automated model tuning, anomaly detection, or pipeline orchestration."@en ;
    rdfs:subClassOf schema:Thing .

mlops:InterdisciplinaryComplexityChallenge rdfs:label "InterdisciplinaryComplexityChallenge"@en ;
    rdfs:comment "A challenge arising from the integration of multiple disciplines in MLOps, such as data science, software engineering, operations, and ethics, which introduces friction points."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:MLCollaboration rdfs:label "MLCollaboration"@en ;
    rdfs:comment "A collaborative effort between teams or roles to achieve MLOps goals, such as data scientists, ML engineers, and DevOps engineers."@en,
        "A coordinated effort between teams or roles to achieve a common goal in MLOps, such as data scientists, ML engineers, and DevOps engineers, emphasizing cross-domain skills and collaborative culture."@en,
        "A coordinated effort between teams or roles to achieve a common goal in MLOps, such as data scientists, ML engineers, and DevOps engineers, focusing on machine learning-specific challenges and solutions."@en ;
    rdfs:subClassOf mlops:Collaboration .

mlops:MLDeploymentEnvironment rdfs:label "MLDeploymentEnvironment"@en ;
    rdfs:comment "An environment where machine learning models are deployed, such as cloud, on-premise, or edge."@en,
        "The environment where ML models are deployed, such as cloud, edge, or on-premise infrastructure."@en ;
    rdfs:subClassOf mlops:MLInfrastructure,
        schema:Thing .

mlops:MLModelMaintenance rdfs:label "MLModelMaintenance"@en ;
    rdfs:comment "A lifecycle stage focused on the continuous monitoring, updating, and maintenance of ML models to ensure long-term performance, reliability, and compliance with evolving data and regulatory requirements."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:MLOpsArtifact rdfs:label "MLOpsArtifact"@en ;
    rdfs:comment "An artifact specifically produced or consumed in MLOps workflows, such as model configurations or pipeline definitions."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:MLOpsCapabilityAssessment rdfs:label "MLOpsCapabilityAssessment"@en ;
    rdfs:comment "A process or system for evaluating and classifying the maturity level of MLOps processes in a software company based on predefined criteria and attributes."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLOpsChallengeInSDC a owl:Class ;
    rdfs:label "MLOpsChallengeInSDC"@en ;
    rdfs:comment "A specific difficulty or obstacle encountered in the adoption of MLOps within software development companies, such as integration complexity, role ambiguity, or infrastructure limitations."@en ;
    rdfs:subClassOf mlops:MLChallenge,
        mlops:MLOpsChallenge .

mlops:MLOpsFramework rdfs:label "MLOpsFramework"@en ;
    rdfs:comment "A framework that provides a structured approach to automating and managing the ML lifecycle."@en,
        "A structured set of guidelines, tools, and practices designed to facilitate the implementation of MLOps processes."@en ;
    rdfs:subClassOf mlops:MLOps,
        schema:SoftwareSourceCode .

mlops:MLOpsHardwareConstraint a owl:Class ;
    rdfs:label "MLOpsHardwareConstraint"@en ;
    rdfs:comment "A constraint related to the availability or cost of specialized hardware required for MLOps, such as GPUs or TPUs, impacting SMEs disproportionately."@en ;
    rdfs:subClassOf mlops:MLLifecycleConstraint .

mlops:MLOpsProcess rdfs:label "MLOpsProcess"@en ;
    rdfs:comment "A process specifically designed to support MLOps workflows, such as model deployment or data validation."@en,
        "A specific process or workflow within the MLOps framework, such as deployment or monitoring."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLOpsTechnicalCompetency a owl:Class ;
    rdfs:label "MLOpsTechnicalCompetency"@en ;
    rdfs:comment "Technical skills required for effective MLOps adoption, such as data engineering, model deployment, and infrastructure management, particularly relevant for SMEs."@en ;
    rdfs:subClassOf schema:DefinedTerm .

mlops:MLRoleAlignment rdfs:label "MLRoleAlignment"@en ;
    rdfs:comment "The degree to which roles within MLOps are aligned with organizational goals and each other's responsibilities."@en ;
    rdfs:subClassOf mlops:MLRoleIntegration .

mlops:MLRoleOptimization rdfs:label "MLRoleOptimization"@en ;
    rdfs:comment "The process of optimizing roles within MLOps to reduce redundancy, clarify boundaries, and improve collaboration and alignment."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLSystem rdfs:label "MLSystem"@en ;
    rdfs:comment "A software system that incorporates machine learning components to perform tasks such as prediction, classification, or decision-making."@en ;
    rdfs:subClassOf schema:SoftwareSourceCode .

mlops:MLTechnicalDebt rdfs:label "MLTechnicalDebt"@en ;
    rdfs:comment "The accumulation of suboptimal practices or shortcuts in ML model development that compromise long-term maintainability, scalability, and integration in production environments due to lack of robust code structures and software engineering principles."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:MaturityAssessment a owl:Class ;
    rdfs:label "MaturityAssessment"@en ;
    rdfs:comment "A process or activity that evaluates the current maturity level of MLOps practices within an organization or project."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MaturityFramework a owl:Class ;
    rdfs:label "MaturityFramework"@en ;
    rdfs:comment "A structured methodology or set of guidelines for evaluating and improving MLOps maturity, such as those from Microsoft, Google, or Kaisen."@en ;
    rdfs:subClassOf mlops:MLOpsEnabler .

mlops:ModelExplainability rdfs:label "ModelExplainability"@en ;
    rdfs:comment "A compliance requirement or constraint related to the interpretability and transparency of machine learning models."@en,
        "The ability to understand and interpret the decisions made by a machine learning model, often through techniques like SHAP or LIME."@en,
        "The degree to which a machine learning model's decisions and behavior can be explained and understood, often a critical factor in trust and compliance."@en ;
    rdfs:subClassOf mlops:MLCompliance,
        schema:Thing ;
    owl:sameAs mlops:ModelExplainabilityRequirement .

mlops:ModelMonitoring rdfs:label "ModelMonitoring"@en ;
    rdfs:comment "A lifecycle stage where deployed models are continuously observed for performance degradation, drift, or failures."@en,
        "A lifecycle stage where deployed models are continuously observed for performance, drift, and anomalies."@en,
        "A process or system responsible for monitoring the performance and behavior of deployed machine learning models over time."@en,
        "A process or system responsible for monitoring the performance and behavior of deployed models."@en,
        "The continuous observation and evaluation of deployed models to detect performance degradation, data drift, or other issues."@en,
        "The lifecycle stage where deployed models are continuously observed for performance, drift, and anomalies."@en,
        "The process of continuously observing and evaluating model performance in production."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage,
        mlops:MLProcess .

mlops:ModelRegistry rdfs:label "ModelRegistry"@en ;
    rdfs:comment "A centralized repository for storing, versioning, and managing machine learning models and their metadata."@en,
        "A system for storing, versioning, and managing machine learning models and their metadata for governance and reproducibility."@en,
        "A system for storing, versioning, and managing machine learning models and their metadata to enable reproducibility and governance."@en,
        "A tool or platform for cataloging, versioning, and managing ML models."@en ;
    rdfs:subClassOf mlops:MLArtifact,
        mlops:MLTool .

mlops:ModelRetraining rdfs:label "ModelRetraining"@en ;
    rdfs:comment "A process of retraining a machine learning model to adapt to new data or changing conditions, often triggered by concept drift detection."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:ModelServing rdfs:label "ModelServing"@en ;
    rdfs:comment "A process or system responsible for serving machine learning models in production environments to provide predictions or decisions."@en,
        "A process or system responsible for serving machine learning models in production environments."@en,
        "The infrastructure and processes for serving model predictions to end-users or systems."@en,
        "The process of deploying and serving machine learning models in production environments to provide predictions or decisions."@en ;
    rdfs:subClassOf mlops:MLInfrastructure,
        mlops:MLProcess .

mlops:OptimizationObjective rdfs:label "OptimizationObjective"@en ;
    rdfs:comment "A specific goal or metric that an AIOps or MLOps system aims to optimize, such as performance, energy efficiency, cost, or resilience."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ProductionEnvironment rdfs:label "ProductionEnvironment"@en ;
    rdfs:comment "A production environment where AI models are deployed and serve predictions."@en,
        "The operational environment where ML models are deployed and monitored in production settings."@en ;
    rdfs:subClassOf mlops:MLInfrastructure,
        schema:Thing .

mlops:QualifiedPersonnelShortage a owl:Class ;
    rdfs:label "QualifiedPersonnelShortage"@en ;
    rdfs:comment "A challenge in MLOps characterized by the lack of qualified personnel, such as data scientists and ML engineers, who possess both ML expertise and MLOps knowledge, leading to difficulties in sustaining ML models over time."@en,
        "A challenge in MLOps projects where there is a shortage of personnel with the necessary skills and training in data science and MLOps, particularly in small and medium software development companies."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:QualityAssessment rdfs:label "QualityAssessment"@en ;
    rdfs:comment "A process or activity that evaluates the quality of artifacts, studies, or processes using defined quality metrics."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:QualityMetric rdfs:label "QualityMetric"@en ;
    rdfs:comment "A measurable criterion used to evaluate the quality, relevance, or compliance of an MLOps artifact, process, or study within a systematic review or operational context."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:QualityAssessment,
        mlops:assessesQuality,
        mlops:hasQualityMetric,
        mlops:monitorsDataQuality .

mlops:ResearchObjective rdfs:label "ResearchObjective"@en ;
    rdfs:comment "A specific goal or aim guiding the conduct of a systematic review or research study, such as analyzing the application of MLOps in small and medium software development companies."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasResearchObjective .

mlops:ResearchTrend a owl:Class ;
    rdfs:label "ResearchTrend"@en ;
    rdfs:comment "A pattern or direction in research that indicates emerging topics, methodologies, or challenges in a field."@en ;
    rdfs:subClassOf schema:Thing .

mlops:SelectionStage rdfs:label "SelectionStage"@en ;
    rdfs:comment "A distinct stage in the selection process of a systematic review or MLOps process, such as identification, screening, or full reading."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage ;
    owl:sameAs mlops:hasSelectionStage .

mlops:SystematicLiteratureReviewChallenge rdfs:label "SystematicLiteratureReviewChallenge"@en ;
    rdfs:comment "A challenge or obstacle encountered in conducting systematic literature reviews, such as bias, reproducibility, or scalability of review processes."@en ;
    rdfs:subClassOf mlops:MLChallenge .

mlops:SystematicLiteratureReviewCriteria rdfs:label "SystematicLiteratureReviewCriteria"@en ;
    rdfs:comment "A set of predefined rules or conditions used to include or exclude studies in a systematic literature review, such as inclusion/exclusion criteria or quality assessment metrics."@en ;
    rdfs:subClassOf mlops:SelectionCriteria .

mlops:SystematicLiteratureReviewEnabler rdfs:label "SystematicLiteratureReviewEnabler"@en ;
    rdfs:comment "An entity that facilitates or enhances the effectiveness of systematic literature reviews, such as methodological frameworks or automation tools."@en ;
    rdfs:subClassOf mlops:MLOpsEnabler .

mlops:SystematicLiteratureReviewReport rdfs:label "SystematicLiteratureReviewReport"@en ;
    rdfs:comment "An artifact documenting the results and findings of a systematic literature review, including synthesized insights and conclusions."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:SystematicLiteratureReviewStage rdfs:label "SystematicLiteratureReviewStage"@en ;
    rdfs:comment "A distinct stage within a systematic literature review process, such as identification, screening, eligibility, or inclusion."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:SystematicReview rdfs:label "SystematicReview"@en ;
    rdfs:comment "A structured and comprehensive review of literature or artifacts following a predefined methodology to identify, evaluate, and synthesize relevant information, often used in research or MLOps contexts to assess quality and relevance."@en,
        "A structured process of identifying, screening, and selecting studies or artifacts for analysis, often used in research synthesis or MLOps validation contexts."@en ;
    rdfs:subClassOf prov:Activity,
        mlops:MLProcess .

mlops:TechnicalDebt rdfs:label "TechnicalDebt"@en ;
    rdfs:comment "A challenge in MLOps projects where poor development practices, such as lack of software engineering principles in ML model creation, lead to long-term maintenance issues and increased costs."@en,
        "A form of debt incurred during the development and deployment of ML systems, including issues like code complexity, poor documentation, or suboptimal architecture choices that hinder maintainability and scalability."@en ;
    rdfs:subClassOf mlops:MLChallenge,
        schema:Thing .

mlops:TrainingJob rdfs:label "TrainingJob"@en ;
    rdfs:comment "A discrete execution of a training process that produces a model or model version from a dataset and configuration."@en,
        "A discrete unit of work that executes the training process for a machine learning model, including data ingestion, preprocessing, and model optimization."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:hasCollaborationType a owl:ObjectProperty ;
    rdfs:label "hasCollaborationType"@en ;
    rdfs:comment "Relates a collaboration to its specific type or focus within MLOps, such as cross-disciplinary collaboration."@en,
        "Relates a collaboration to its specific type or focus within MLOps, such as cross-functional teamwork or DevOps integration."@en,
        "Relates a collaboration to its specific type or focus within MLOps."@en ;
    rdfs:domain mlops:Collaboration ;
    rdfs:range schema:Text ;
    rdfs:subPropertyOf mlops:hasCollaborationType,
        schema:description .

mlops:hasDeploymentConstraint rdfs:label "hasDeploymentConstraint"@en ;
    rdfs:comment "Relates a deployment process to a constraint that must be satisfied, such as bandwidth or latency."@en ;
    rdfs:domain mlops:DeploymentStrategy ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:hasIndustryDomain rdfs:label "hasIndustryDomain"@en ;
    rdfs:comment "Relates an MLOps process, artifact, or system to the industry domain it is applied in."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:IndustryDomain ;
    rdfs:subPropertyOf schema:subjectOf .

mlops:hasInterdisciplinaryChallenge rdfs:label "hasInterdisciplinaryChallenge"@en ;
    rdfs:comment "Relates an MLOps project or process to the interdisciplinary challenges it faces, such as integrating data science and software development."@en,
        "Relates an MLOps project or process to the interdisciplinary challenges it faces."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLInterdisciplinaryChallenge ;
    rdfs:subPropertyOf schema:subjectOf .

mlops:hasResourceConstraint rdfs:label "hasResourceConstraint"@en ;
    rdfs:comment "Relates a deployment strategy to a resource constraint it must address, such as compute, storage, or memory."@en ;
    rdfs:domain mlops:DeploymentStrategy ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf schema:hasOccupation .

mlops:requiresCollaborativeCulture rdfs:label "requiresCollaborativeCulture"@en ;
    rdfs:comment "Relates an MLOps process or system to the collaborative culture it requires."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:CollaborativeCulture ;
    rdfs:subPropertyOf prov:wasAssociatedWith .

mlops:ConceptDrift rdfs:label "ConceptDrift"@en ;
    rdfs:comment "A phenomenon where the statistical properties of the target variable change over time, leading to degraded model performance, requiring detection and mitigation strategies."@en,
        "A phenomenon where the statistical properties of the target variable change over time, leading to degraded model performance."@en ;
    rdfs:subClassOf schema:Event .

mlops:DataPipeline rdfs:label "DataPipeline"@en ;
    rdfs:comment "An automated workflow for preparing, transforming, and validating data for ML tasks, including ingestion, cleaning, feature engineering, and validation."@en,
        "An automated workflow for preparing, transforming, and validating data for ML tasks."@en ;
    rdfs:subClassOf mlops:MLPipeline .

mlops:DataPreparation rdfs:label "DataPreparation"@en ;
    rdfs:comment "A lifecycle stage focused on cleaning, transforming, and preparing raw data for ML tasks."@en,
        "A lifecycle stage focused on collecting, cleaning, transforming, and validating data for machine learning tasks."@en,
        "A process for preparing and transforming raw data into a format suitable for ML tasks."@en,
        "The lifecycle stage focused on collecting, cleaning, transforming, and validating data for machine learning tasks."@en,
        "The process of cleaning, transforming, and structuring raw data into a format suitable for ML model training or inference."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage,
        mlops:MLProcess .

mlops:EdgeModel rdfs:label "EdgeModel"@en ;
    rdfs:comment "A machine learning model optimized for deployment and execution on edge devices with constraints such as limited memory, compute, and power."@en ;
    rdfs:subClassOf mlops:ModelVersion ;
    owl:sameAs mlops:EdgeModelVersion .

mlops:MLInterdisciplinaryChallenge rdfs:label "MLInterdisciplinaryChallenge"@en ;
    rdfs:comment "A challenge arising from the need to integrate multiple disciplines (e.g., data science, software engineering, operations) in MLOps projects, leading to complexity in management and coordination."@en,
        "A challenge arising from the need to integrate multiple disciplines (e.g., data science, software engineering, operations) in MLOps projects, leading to complexity in management, coordination, and role definition."@en ;
    rdfs:subClassOf mlops:MLChallenge,
        schema:Thing ;
    owl:sameAs mlops:InterdisciplinaryComplexityChallenge,
        mlops:hasInterdisciplinaryChallenge .

mlops:MLMonitoring rdfs:label "MLMonitoring"@en ;
    rdfs:comment "A process or system dedicated to observing and evaluating the performance and behavior of machine learning models in production."@en,
        "The practice of observing and evaluating ML systems and artifacts to ensure performance, reliability, and compliance throughout their lifecycle."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLRoleCollaboration a owl:Class ;
    rdfs:label "MLRoleCollaboration"@en ;
    rdfs:comment "A collaborative effort between defined roles in MLOps, such as data scientists, data engineers, and DevOps, to ensure effective communication, shared understanding, and alignment with business goals throughout the ML lifecycle."@en,
        "A collaborative effort between roles within MLOps to achieve common goals, such as data scientists and DevOps engineers working together on model deployment."@en ;
    rdfs:subClassOf mlops:Collaboration .

mlops:MLRoleIntegration rdfs:label "MLRoleIntegration"@en ;
    rdfs:comment "The process of integrating roles within MLOps to ensure seamless collaboration and alignment of goals."@en ;
    rdfs:subClassOf mlops:MLRoleCollaboration .

mlops:MaturityDimension a owl:Class ;
    rdfs:label "MaturityDimension"@en ;
    rdfs:comment "A specific aspect or dimension of MLOps maturity, such as data management, model quality, process automation, or organizational culture."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MetadataHarvesting rdfs:label "MetadataHarvesting"@en ;
    rdfs:comment "A process of collecting and aggregating metadata from various sources, such as academic databases or APIs, to support MLOps workflows."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:hasLifecycleConstraint rdfs:label "hasLifecycleConstraint"@en ;
    rdfs:comment "Relates an MLOps process or system to the constraints it must operate under."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLLifecycleConstraint ;
    rdfs:subPropertyOf prov:used .

mlops:hasSelectionCriteria a owl:ObjectProperty ;
    rdfs:label "hasSelectionCriteria"@en ;
    rdfs:comment "Relates a lifecycle stage or process to the selection criteria it employs, such as inclusion or exclusion criteria."@en,
        "Relates a lifecycle stage or process to the selection criteria it employs."@en,
        "Relates a systematic literature review to the criteria used for selecting studies, such as inclusion or exclusion criteria."@en,
        "Relates a systematic review or selection process to the criteria used to include or exclude artifacts, studies, or publications."@en,
        "Relates a systematic review process to the criteria used for selecting studies or artifacts, including inclusion and exclusion criteria."@en ;
    rdfs:domain mlops:MLLifecycleStage,
        mlops:SystematicLiteratureReview,
        mlops:SystematicReview ;
    rdfs:range mlops:SelectionCriteria ;
    rdfs:subPropertyOf prov:used .

mlops:DataCharacteristic rdfs:label "DataCharacteristic"@en ;
    rdfs:comment "An abstract class representing qualities or attributes of data relevant to ML tasks, such as quality, access, or integration."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLDeploymentProcess rdfs:label "MLDeploymentProcess"@en ;
    rdfs:comment "A process responsible for deploying ML models to production environments, including validation, rollout, and rollback strategies."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLOpsMaturityModel a owl:Class ;
    rdfs:label "MLOpsMaturityModel"@en ;
    rdfs:comment "A framework or model that assesses the maturity of an organization's MLOps practices, including stages, capabilities, and best practices for continuous improvement."@en,
        "A structured framework for assessing the maturity and capability of MLOps processes in an organization, including levels, criteria, and improvement paths."@en,
        "A structured framework for assessing the maturity and capability of MLOps processes within an organization, including levels, criteria, and evaluation methods."@en ;
    rdfs:subClassOf mlops:MLCompliance,
        mlops:MLOpsEnabler .

mlops:MLRoleClarity rdfs:label "MLRoleClarity"@en ;
    rdfs:comment "A measure of the clarity and specificity of role definitions within MLOps, addressing issues like role ambiguity or overlap that can lead to inefficiencies or conflicts."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MeasurementModel rdfs:label "MeasurementModel"@en ;
    rdfs:comment "A structured framework for defining objectives, questions, and metrics to evaluate research outcomes or processes, such as the Goal-Question-Metric (GQM) approach."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasMeasurementModel .

mlops:ModelDeployment rdfs:label "ModelDeployment"@en ;
    rdfs:comment "A lifecycle stage where validated models are deployed to production environments for inference."@en,
        "A process for deploying machine learning models to production environments."@en,
        "The lifecycle stage where validated models are deployed to production environments for inference."@en,
        "The process of deploying a trained model into a production environment for inference."@en,
        "The process of deploying a trained model to a production environment for inference or decision-making."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage,
        mlops:MLProcess .

mlops:ModelVersion rdfs:label "ModelVersion"@en ;
    rdfs:comment "A specific version of a machine learning model, including its parameters, metadata, and lineage."@en,
        "A specific version of a machine learning model, including its parameters, metadata, lineage, and associated artifacts like training configuration and evaluation metrics."@en ;
    rdfs:subClassOf mlops:MLArtifact .

mlops:SelectionCriteria a owl:Class ;
    rdfs:label "SelectionCriteria"@en ;
    rdfs:comment "A set of predefined rules or conditions used to include or exclude artifacts, studies, or publications in a systematic review or selection process."@en,
        "A set of predefined rules or conditions used to include or exclude studies in a systematic literature review."@en,
        "A set of predefined rules or conditions used to include or exclude studies or artifacts in a systematic review or selection process."@en,
        "A set of rules or conditions used to evaluate and filter manuscripts, datasets, or artifacts during the identification or screening stages."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsAdoptionBenefit rdfs:label "MLOpsAdoptionBenefit"@en ;
    rdfs:comment "A benefit identified in the adoption of MLOps practices, such as improved collaboration, faster implementation, or enhanced model lifecycle efficiency."@en,
        "A measurable advantage or positive outcome resulting from the adoption of MLOps practices in an organization, such as improved efficiency, reliability, or scalability."@en ;
    rdfs:subClassOf mlops:MLChallenge,
        schema:Thing .

mlops:MLOpsBenefit rdfs:label "MLOpsBenefit"@en ;
    rdfs:comment "A measurable advantage or improvement gained from the adoption of MLOps practices, such as reduced time-to-market, improved model reliability, or enhanced collaboration."@en,
        "A positive outcome or advantage gained from adopting MLOps practices, such as improved operational efficiency, enhanced collaboration, or higher quality of deployed ML products."@en ;
    rdfs:subClassOf mlops:MLOpsEnabler,
        schema:Thing .

mlops:MLRoleDefinition a owl:Class ;
    rdfs:label "MLRoleDefinition"@en ;
    rdfs:comment "A formal definition of roles and responsibilities within MLOps, including data scientists, ML engineers, DevOps engineers, and MLOps engineers, to clarify boundaries and reduce ambiguity."@en,
        "The formal definition and assignment of roles and responsibilities within an MLOps process to ensure clarity, collaboration, and efficiency among team members such as data scientists, data engineers, and DevOps engineers."@en ;
    rdfs:subClassOf mlops:MLPrinciple,
        schema:Thing .

mlops:MLWorkflowComplexity rdfs:label "MLWorkflowComplexity"@en ;
    rdfs:comment "The inherent complexity arising from the interdisciplinary nature of ML workflows, including integration of business value, data, system, process, and infrastructure considerations, as well as challenges like technical debt and role ambiguity."@en,
        "The inherent complexity arising from the interdisciplinary nature of ML workflows, including integration of business value, data, system, process, and infrastructure considerations."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:hasWorkflowComplexity .

mlops:hasArtifact a owl:ObjectProperty ;
    rdfs:label "hasArtifact"@en ;
    rdfs:comment "Relates a process or system to an artifact it uses or produces during the MLOps lifecycle."@en,
        "Relates a process or system to an artifact it uses or produces."@en,
        "Relates an MLOps process or system to an artifact it uses or produces."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLArtifact ;
    rdfs:subPropertyOf prov:used .

mlops:hasChallenge rdfs:label "hasChallenge"@en ;
    rdfs:comment "Relates an MLOps process, system, or adoption effort to the challenges it faces or addresses."@en,
        "Relates an MLOps process, system, or artifact to a challenge it faces or addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLChallenge,
        mlops:MLOpsChallenge ;
    rdfs:subPropertyOf schema:hasOccupation,
        schema:subjectOf ;
    owl:sameAs mlops:addressesChallenge .

mlops:hasLifecycleStage a owl:ObjectProperty ;
    rdfs:label "hasLifecycleStage"@en ;
    rdfs:comment "Relates a process or system to a lifecycle stage it involves or affects, such as training, deployment, or monitoring."@en,
        "Relates a process or system to a lifecycle stage it involves or affects, with the stage being generated by the process."@en,
        "Relates a process or system to a lifecycle stage it involves or affects."@en,
        "Relates an MLOps process or system to a lifecycle stage it involves or affects."@en,
        "Relates an MLOps process or system to a specific lifecycle stage it involves or affects."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLLifecycleStage ;
    rdfs:subPropertyOf prov:used,
        prov:wasGeneratedBy,
        mlops:hasLifecycleStage .

mlops:usesTool a owl:ObjectProperty ;
    rdfs:label "usesTool"@en ;
    rdfs:comment "Relates a process or system to the tool it employs, such as an ML framework or orchestration tool."@en,
        "Relates a process or system to the tool it employs."@en,
        "Relates an MLOps process or system to the tool it employs."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLTool ;
    rdfs:subPropertyOf prov:used .

mlops:MLOpsChallenge rdfs:label "MLOpsChallenge"@en ;
    rdfs:comment "A difficulty or obstacle encountered in the adoption or implementation of MLOps practices, including technical, organizational, or cultural barriers."@en,
        "A problem or obstacle encountered in the implementation or operation of MLOps systems, such as scalability, interpretability, deployment complexity, or organizational challenges like role ambiguity and technical debt."@en,
        "A specific difficulty or obstacle encountered in the implementation or operation of MLOps practices, such as scalability, reproducibility, or integration complexity."@en ;
    rdfs:subClassOf schema:Thing .

mlops:addressesChallenge rdfs:label "addressesChallenge"@en ;
    rdfs:comment "Relates an MLOps process, tool, or strategy to the AI challenge it addresses."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:AIChallenge ;
    rdfs:subPropertyOf prov:used .

mlops:IndustryDomain rdfs:label "IndustryDomain"@en ;
    rdfs:comment "A specific industry or sector where MLOps methodologies are applied, such as automotive, healthcare, energy, or manufacturing."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLLifecycleConstraint rdfs:label "MLLifecycleConstraint"@en ;
    rdfs:comment "A constraint or limitation imposed on an MLOps lifecycle stage, such as resource constraints, environmental conditions, or regulatory limits."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLPrinciple rdfs:label "MLPrinciple"@en ;
    rdfs:comment "A foundational concept or practice guiding the design and implementation of MLOps processes and systems."@en ;
    rdfs:subClassOf owl:Thing .

mlops:ensuresCompliance a owl:ObjectProperty ;
    rdfs:label "ensuresCompliance"@en ;
    rdfs:comment "Relates a process or artifact to the compliance requirement it satisfies, ensuring adherence to legal, ethical, or operational standards."@en,
        "Relates a process or artifact to the compliance requirement it satisfies."@en ;
    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:MLCompliance ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:MLComplianceRequirement rdfs:label "MLComplianceRequirement"@en ;
    rdfs:comment "A specific requirement or standard that must be met for legal, ethical, or operational compliance in ML systems, such as data privacy, model explainability, or regulatory adherence."@en,
        "A specific requirement or standard that must be met for legal, ethical, or operational compliance in ML systems."@en,
        "A specific requirement or standard that must be satisfied for compliance in ML systems."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:MLOpsEnabler rdfs:label "MLOpsEnabler"@en ;
    rdfs:comment "An abstract entity that facilitates or enhances the implementation and effectiveness of MLOps practices, such as tools, culture, or infrastructure."@en ;
    rdfs:subClassOf schema:Thing .

mlops:monitors a owl:ObjectProperty ;
    rdfs:label "monitors"@en ;
    rdfs:comment "Relates a monitoring system or process to the entity it observes, such as a model or pipeline."@en,
        "Relates a monitoring system or process to the entity it observes, such as a model, pipeline, or dataset, to track performance and detect issues."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf prov:wasGeneratedBy,
        schema:monitors .

mlops:SystematicLiteratureReview a owl:Class ;
    rdfs:label "SystematicLiteratureReview"@en ;
    rdfs:comment "A structured and comprehensive review of literature following predefined criteria to identify, evaluate, and synthesize relevant studies in a field, often used in research or MLOps contexts to assess quality and relevance."@en,
        "A structured and comprehensive review of literature following predefined criteria to identify, evaluate, and synthesize relevant studies in a field."@en,
        "A structured and comprehensive review of literature following predefined criteria to identify, evaluate, and synthesize research findings."@en ;
    rdfs:subClassOf mlops:Collaboration,
        mlops:MLProcess .

mlops:MLOpsMaturityLevel a owl:Class ;
    rdfs:label "MLOpsMaturityLevel"@en ;
    rdfs:comment "A classification of the maturity of MLOps practices within an organization, ranging from no automation to fully automated operations."@en,
        "A discrete level within an MLOps maturity model, representing a stage of process capability and automation."@en ;
    rdfs:subClassOf schema:DefinedTerm .

mlops:MLRole a owl:Class ;
    rdfs:label "MLRole"@en ;
    rdfs:comment "A role or responsibility within MLOps, such as Data Scientist, ML Engineer, DevOps Engineer, MLOps Engineer, or Data Engineer."@en,
        "A role or responsibility within MLOps, such as Data Scientist, ML Engineer, or DevOps Engineer."@en ;
    rdfs:subClassOf schema:DefinedTerm,
        schema:Role .

mlops:Collaboration rdfs:label "Collaboration"@en ;
    rdfs:comment "A coordinated effort between teams or roles to achieve a common goal in MLOps, such as data scientists and DevOps engineers."@en,
        "A coordinated effort between teams or roles to achieve a common goal in MLOps, such as data scientists, ML engineers, and DevOps engineers collaborating on model development and deployment."@en ;
    rdfs:subClassOf prov:Activity,
        mlops:MLPrinciple ;
    owl:sameAs mlops:MLCollaboration .

mlops:reliesOn a owl:ObjectProperty ;
    rdfs:label "reliesOn"@en ;
    rdfs:comment "Relates an MLOps process or system to the infrastructure it depends on, such as compute resources or storage systems."@en,
        "Relates an MLOps process or system to the infrastructure it depends on."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLInfrastructure ;
    rdfs:subPropertyOf prov:used .

mlops:MLCompliance a owl:Class ;
    rdfs:label "MLCompliance"@en ;
    rdfs:comment "A requirement or standard related to the legal, ethical, or operational compliance of ML systems, such as data privacy or model explainability."@en,
        "A requirement or standard related to the legal, ethical, or operational compliance of ML systems, such as data privacy, model explainability, or regulatory adherence."@en ;
    rdfs:subClassOf prov:Entity,
        schema:CreativeWork,
        schema:DefinedTerm,
        schema:Thing ;
    owl:sameAs mlops:MLOpsCompliance .

mlops:MLPipeline rdfs:label "MLPipeline"@en ;
    rdfs:comment "An automated workflow that orchestrates activities in the ML lifecycle, such as data ingestion, training, and deployment."@en,
        "An automated workflow that orchestrates activities in the ML lifecycle, such as data ingestion, training, evaluation, deployment, and monitoring."@en ;
    rdfs:subClassOf prov:Activity,
        prov:Plan,
        schema:DefinedTerm,
        schema:SoftwareSourceCode ;
    owl:sameAs mlops:MLOpsPipeline .

mlops:DeploymentStrategy a owl:Class ;
    rdfs:label "DeploymentStrategy"@en ;
    rdfs:comment "A method or approach for deploying ML models to production, such as A/B testing, canary deployment, blue-green deployment, shadow deployment, or rolling updates."@en,
        "A method or approach for deploying ML models to production, such as A/B testing, canary, or blue-green deployment."@en ;
    rdfs:subClassOf schema:Action,
        schema:DefinedTerm,
        schema:Thing .

mlops:hasProcess a owl:ObjectProperty ;
    rdfs:label "hasProcess"@en ;
    rdfs:comment "Relates a system or role to a process it performs or involves, such as a data scientist performing model training."@en,
        "Relates a system or role to a process it performs or involves."@en,
        "Relates an MLOps system or role to a process it performs or involves."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLProcess ;
    rdfs:subPropertyOf prov:used .

mlops:MLTool a owl:Class ;
    rdfs:label "MLTool"@en ;
    rdfs:comment "A software tool or platform used in MLOps, such as ML frameworks (TensorFlow, PyTorch), experiment trackers (MLflow, Weights & Biases), orchestration tools (Airflow, Kubeflow), or monitoring systems (Prometheus, Evidently)."@en,
        "A software tool or platform used in MLOps, such as MLFlow, TensorFlow, or Kubeflow."@en ;
    rdfs:subClassOf mlops:MLTool,
        schema:DefinedTerm,
        schema:SoftwareApplication .

mlops:MLChallenge rdfs:label "MLChallenge"@en ;
    rdfs:comment "A problem or obstacle encountered in the MLOps lifecycle, such as data drift, model degradation, or infrastructure failures."@en,
        "A specific problem, issue, or obstacle encountered in the implementation or operation of MLOps systems, such as scalability, interpretability, or deployment complexity."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLLifecycleStage a owl:Class ;
    rdfs:label "MLLifecycleStage"@en ;
    rdfs:comment "A distinct phase within the machine learning lifecycle, such as data preparation, model training, deployment, monitoring, or maintenance."@en,
        "A distinct phase within the machine learning lifecycle, such as data preparation, model training, deployment, or monitoring, that is also considered a process."@en,
        "A distinct phase within the machine learning lifecycle, such as data preparation, model training, deployment, or monitoring."@en ;
    rdfs:subClassOf owl:Thing,
        mlops:MLLifecycleStage,
        mlops:MLProcess,
        schema:DefinedTerm,
        schema:Enumeration,
        schema:Event,
        schema:Thing ;
    owl:sameAs mlops:hasLifecycleStage .

mlops:MLInfrastructure a owl:Class ;
    rdfs:label "MLInfrastructure"@en ;
    rdfs:comment "The underlying hardware and software infrastructure supporting MLOps, including compute resources, storage systems, networking, and orchestration platforms."@en,
        "The underlying hardware and software infrastructure supporting MLOps, such as compute resources, storage, and orchestration platforms."@en ;
    rdfs:subClassOf prov:Entity,
        mlops:MLInfrastructure,
        schema:DefinedTerm,
        schema:Infrastructure,
        schema:Thing .

mlops:MLArtifact rdfs:label "MLArtifact"@en ;
    rdfs:comment "An artifact produced or consumed during the MLOps lifecycle, such as datasets, models, or pipelines."@en,
        "An artifact produced or consumed during the MLOps lifecycle, such as datasets, models, pipelines, configurations, or evaluation reports."@en ;
    rdfs:subClassOf prov:Entity,
        schema:DefinedTerm ;
    owl:sameAs mlops:MLOpsArtifact .

mlops:MLProcess rdfs:label "MLProcess"@en ;
    rdfs:comment "A discrete activity within the MLOps lifecycle, such as data preprocessing, model training, hyperparameter tuning, validation, deployment, or monitoring."@en,
        "A discrete activity within the MLOps lifecycle, such as training, validation, or deployment."@en ;
    rdfs:subClassOf prov:Activity,
        prov:Plan,
        prov:Process,
        schema:DefinedTerm,
        schema:Event ;
    owl:sameAs mlops:MLOpsProcess .

schema:Thing owl:sameAs owl:Thing .

mlops:MLOps rdfs:label "MLOps"@en ;
    rdfs:comment "A framework and set of practices for automating and managing the machine learning lifecycle, including development, deployment, monitoring, and maintenance of ML models in production environments, emphasizing collaborative culture and cross-functional teamwork among stakeholders."@en,
        "A framework and set of practices for automating and managing the machine learning lifecycle, including development, deployment, monitoring, and maintenance of ML models in production environments."@en ;
    rdfs:subClassOf prov:Activity,
        prov:Plan,
        schema:DefinedTerm,
        schema:SoftwareSourceCode .

