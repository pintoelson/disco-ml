mlops:producesModelVersion rdfs:label "producesModelVersion"@en ;
    rdfs:comment "Relates a training job to the model version it produces."@en ;
    rdfs:domain mlops:TrainingJob ;
    rdfs:range mlops:ModelVersion ;
    rdfs:subPropertyOf prov:generated .

mlops:productionizes rdfs:label "productionizes"@en ;
    rdfs:comment "Relates an MLOps process or system to the act of bringing a machine learning model or system into production."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:MLSystem ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:reliesOnDevOps rdfs:label "reliesOnDevOps"@en ;
    rdfs:comment "Relates an AI development process to DevOps practices or infrastructure it depends on."@en ;
    rdfs:domain mlops:AIServiceDevelopment ;
    rdfs:range mlops:DevOpsEngineer ;
