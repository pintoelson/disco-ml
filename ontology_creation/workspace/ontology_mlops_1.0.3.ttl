    rdfs:domain mlops:MLArtifact ;
    rdfs:range mlops:Operationalization ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasOptimizationObjective rdfs:label "hasOptimizationObjective"@en ;
    rdfs:comment "Relates an MLOps or AIOps process to the objective it aims to optimize."@en ;
    rdfs:domain mlops:MLOps ;
    rdfs:range mlops:OptimizationObjective ;
