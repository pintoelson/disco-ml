schema:DataEngineering a owl:Class ;
    rdfs:label "Data Engineering"^^xsd:string ;
    rdfs:comment "The discipline of preparing, transforming, integrating, and managing data used in AI and ML workflows."^^xsd:string ;
    rdfs:subClassOf schema:Action ;
    owl:sameAs aicd:DataCollection,
        aicd:DataEngineer,
        aicd:DataEngineerRole,
        aicd:DataEngineeringTeam,
        aicd:DataLabeling,
        aicd:DataManagement,
        aicd:DataManagementChallenge,
        aicd:DataManagementMaturity,
        aicd:DataOps,
        aicd:DataOpsPrinciple,
        aicd:DataPreparation,
        aicd:DataScienceProject,
        aicd:DataScienceTeam,
        aicd:DataScientist,
        aicd:DataScientistInvolvement,
        aicd:DataScientistRole,
        aicd:DataStorage,
        aicd:DataStrategy,
        aicd:MLEngineeringTeam,
        aicd:TrainingDataQuality,
        aicd:integratesDataScienceAndSoftwareEngineering .

schema:duration rdfs:comment "Duration of a process or activity; when used for lifecycle stages, it should be interpreted using standard time units such as days."^^xsd:string .

aicd:Accuracy a owl:Class ;
    rdfs:label "Accuracy"^^xsd:string ;
    rdfs:comment "A quality dimension indicating how correctly a model produces expected outputs relative to a reference or target."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:Adjustment a owl:Class ;
    rdfs:label "Adjustment"^^xsd:string ;
    rdfs:comment "An iterative corrective activity used to adapt models or related processes in response to validation or monitoring feedback."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:ArtifactDefinition a owl:Class ;
    rdfs:label "Artifact Definition"^^xsd:string ;
    rdfs:comment "The activity of specifying and clarifying the artifacts used in ML development and MLOps workflows."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:Assessment a owl:Class ;
    rdfs:label "Assessment"^^xsd:string ;
    rdfs:comment "An evaluative activity used to examine MLOps-related practices, processes, or capabilities against defined criteria."^^xsd:string ;
    rdfs:subClassOf schema:Action ;
    owl:sameAs aicd:QualityAssessment .

aicd:AutomatedMLOps a owl:Class ;
    rdfs:label "Automated MLOps"^^xsd:string ;
    rdfs:comment "A higher-maturity MLOps mode characterized by automated lifecycle activities and integrated pipelines."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess ;
    aicd:hasLifecycleStage aicd:ModelDeployment,
        aicd:ModelMonitoring,
        aicd:ModelRetraining,
        aicd:ModelValidation .

aicd:AutomatedModelDeployment a owl:Class ;
    rdfs:label "Automated Model Deployment"^^xsd:string ;
    rdfs:comment "The automated release of trained AI models into production as part of an MLOps lifecycle."^^xsd:string ;
    rdfs:subClassOf aicd:ModelDeployment,
        aicd:ProductionOperations .

aicd:AutomatedTraining a owl:Class ;
    rdfs:label "Automated Training"^^xsd:string ;
    rdfs:comment "A maturity level emphasizing automation of model training within ML workflows."^^xsd:string ;
    rdfs:subClassOf aicd:MLOpsMaturityLevel .

aicd:CI_CDWorkflow a owl:Class ;
    rdfs:label "CI/CD Workflow"^^xsd:string ;
    rdfs:comment "A recurring software delivery workflow that automates integration and deployment activities for AI and ML systems within the lifecycle."^^xsd:string ;
    rdfs:subClassOf aicd:RecurringPipeline .

aicd:CloudResource a owl:Class ;
    rdfs:label "Cloud Resource"^^xsd:string ;
    rdfs:comment "A computational resource provided through cloud infrastructure to support scalable and cost-aware ML development or operations."^^xsd:string,
        "Computational resources provided by a cloud environment to support training or deployment workloads."^^xsd:string ;
    rdfs:subClassOf aicd:ComputationalResource,
        schema:Thing .

aicd:CrossTeamCollaboration a owl:Class ;
    rdfs:label "Cross-Team Collaboration"^^xsd:string ;
    rdfs:comment "A collaborative capability involving coordination across multiple teams in MLOps-oriented work."^^xsd:string ;
    rdfs:subClassOf aicd:Benefit ;
    aicd:supportsCrossTeamCollaboration aicd:DataScienceTeam,
        aicd:DevelopmentTeam,
        aicd:OperationsTeam .

aicd:CustomerInvolvement a owl:Class ;
    rdfs:label "Customer Involvement"^^xsd:string ;
    rdfs:comment "The participation of customers across MLOps phases to improve alignment, expectations, and delivery coordination."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:DataCollection a owl:Class ;
    rdfs:label "Data Collection"^^xsd:string ;
    rdfs:comment "The activity of acquiring data for use in ML model development, validation, or operation."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:DataDrifting a owl:Class ;
    rdfs:label "Data Drifting"^^xsd:string ;
    rdfs:comment "A change in the properties or distribution of input data over time that can affect model behavior and lifecycle decisions."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:DataEngineer a owl:Class ;
    rdfs:label "Data Engineer"^^xsd:string ;
    rdfs:comment "A professional role responsible for data cleaning, preparation, and pipeline support in MLOps workflows."^^xsd:string ;
    rdfs:subClassOf schema:Person .

aicd:DataEngineeringTeam a owl:Class ;
    rdfs:label "Data Engineering Team"^^xsd:string ;
    rdfs:comment "A team responsible for data engineering capabilities in MLOps-oriented AI development workflows."^^xsd:string ;
    rdfs:subClassOf schema:Organization .

aicd:DataGovernance a owl:Class ;
    rdfs:label "Data Governance"^^xsd:string ;
    rdfs:comment "Governance activity covering policies, controls, and accountability for data used in ML lifecycle processes."^^xsd:string ;
    rdfs:subClassOf aicd:DataManagement ;
    aicd:addressesConcern aicd:FairnessConcern,
        aicd:SecurityConcern .

aicd:DataLabeling a owl:Class ;
    rdfs:label "Data Labeling"^^xsd:string ;
    rdfs:comment "An activity for assigning labels or annotations to data so it can be used for model training and evaluation."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:DataManagementMaturity a owl:Class ;
    rdfs:label "Data Management Maturity"^^xsd:string ;
    rdfs:comment "The maturity of data management practices within an MLOps lifecycle, ranging from ad hoc to standardized and automated approaches."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:DataOps a owl:Class ;
    rdfs:label "DataOps"^^xsd:string ;
    rdfs:comment "A stage in which data management processes are standardized and automated to support model development and operations."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess .

aicd:DataPipeline a owl:Class ;
    rdfs:label "Data Pipeline"^^xsd:string ;
    rdfs:comment "A pipeline that moves, transforms, and prepares data for use in ML development and operational workflows."^^xsd:string ;
    rdfs:subClassOf aicd:RecurringPipeline .

aicd:DataPreparation a owl:Class ;
    rdfs:label "Data Preparation"^^xsd:string ;
    rdfs:comment "An activity for transforming raw data into a form suitable for model training, validation, or operational use."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:DataScientist a owl:Class ;
    rdfs:label "Data Scientist"^^xsd:string ;
    rdfs:comment "A professional role responsible for model development and experimentation, often collaborating with software engineering and data engineering teams."^^xsd:string ;
    rdfs:subClassOf schema:Person .

aicd:DataScientistInvolvement a owl:Class ;
    rdfs:label "Data Scientist Involvement"^^xsd:string ;
    rdfs:comment "The participation of data scientists throughout the project lifecycle, including early-stage development and iteration."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:DataStorage a owl:Class ;
    rdfs:label "Data Storage"^^xsd:string ;
    rdfs:comment "The activity or capability of persisting data in a form that supports access and use in ML workflows."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:DeployedMLProductQuality a owl:Class ;
    rdfs:label "Deployed ML Product Quality"^^xsd:string ;
    rdfs:comment "A benefit concerned with the quality of deployed machine learning products."^^xsd:string ;
    rdfs:subClassOf aicd:Benefit ;
    aicd:improvesQualityOf aicd:MLModel .

aicd:Deployment a owl:Class ;
    rdfs:label "Deployment"^^xsd:string ;
    rdfs:comment "An activity in which a trained machine learning model is released into an operational environment for use."^^xsd:string ;
    rdfs:subClassOf aicd:ModelDeployment ;
    owl:sameAs aicd:AutomatedModelDeployment,
        aicd:ContinuousDeployment,
        aicd:DeploymentMaintenanceChallenge,
        aicd:DeploymentPhase .

aicd:DevOpsPrinciple a owl:Class ;
    rdfs:label "DevOps Principle"^^xsd:string ;
    rdfs:comment "A principle from DevOps that can be applied to the ML lifecycle to improve automation, collaboration, and delivery speed."^^xsd:string,
        "A principle of integrating development and operations practices to improve delivery speed, reliability, and feedback loops."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:DevOpsTeam a owl:Class ;
    rdfs:label "DevOps Team"^^xsd:string ;
    rdfs:comment "A team responsible for operational automation, delivery, and infrastructure practices supporting AI model lifecycles."^^xsd:string ;
    rdfs:subClassOf schema:Organization .

aicd:DevelopmentPractice a owl:Class ;
    rdfs:label "Development Practice"^^xsd:string ;
    rdfs:comment "A software development practice that supports MLOps adoption, integration, or recurring delivery of ML functionality."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:EndToEndMLOpsLifecycle a owl:Class ;
    rdfs:label "End-to-End MLOps Lifecycle"^^xsd:string ;
    rdfs:comment "The complete lifecycle spanning data, experimentation, training, deployment, monitoring, and retraining activities for ML systems."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        aicd:RecurringPipeline .

aicd:Experimentation a owl:Class ;
    rdfs:label "Experimentation"^^xsd:string ;
    rdfs:comment "An exploratory activity that allocates time for trying alternatives and learning during MLOps-oriented development."^^xsd:string,
        "An iterative exploratory activity in ML development that supports testing hypotheses, comparing alternatives, and managing uncertainty."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:GeneralPurposeFramework a owl:Class ;
    rdfs:label "General-Purpose Framework"^^xsd:string ;
    rdfs:comment "A framework that can support ML projects but is not specialized specifically for ML workflows."^^xsd:string ;
    rdfs:subClassOf schema:SoftwareApplication .

aicd:GovernanceConcern a owl:Class ;
    rdfs:label "Governance Concern"^^xsd:string ;
    rdfs:comment "A cross-silo concern related to oversight, accountability, and controlled operation across the AI lifecycle."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern .

aicd:InclusionCriteria a owl:Class ;
    rdfs:label "Inclusion Criteria"^^xsd:string ;
    rdfs:comment "A set of conditions used to determine whether a publication or study is eligible for consideration in an MLOps-related review or selection process."^^xsd:string ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs aicd:ExclusionCriteria .

aicd:InterdisciplinaryCollaboration a owl:Class ;
    rdfs:label "Interdisciplinary Collaboration"^^xsd:string ;
    rdfs:comment "Collaboration across disciplines involved in ML lifecycle activities, including development, data, and operations functions."^^xsd:string ;
    rdfs:subClassOf schema:Action ;
    aicd:supportsScaling aicd:Productionalization .

aicd:MLEngineeringTeam a owl:Class ;
    rdfs:label "ML Engineering Team"^^xsd:string ;
    rdfs:comment "A team responsible for machine learning engineering activities such as model development, validation, and operationalization."^^xsd:string ;
    rdfs:subClassOf schema:Organization .

aicd:MLOpsCapabilityMaturityAssessment a owl:Class ;
    rdfs:label "MLOps Capability Maturity Assessment"^^xsd:string ;
    rdfs:comment "An assessment activity focused on determining the maturity or capability level of MLOps processes in an organization."^^xsd:string ;
    rdfs:subClassOf aicd:Assessment .

aicd:MLProjectLifecycle a owl:Class ;
    rdfs:label "ML Project Lifecycle"^^xsd:string ;
    rdfs:comment "The lifecycle of an ML project spanning analysis, development, validation, operationalization, and ongoing improvement activities."^^xsd:string ;
    rdfs:subClassOf aicd:ModelLifecycle .

aicd:ModelDrift a owl:Class ;
    rdfs:label "Model Drift"^^xsd:string ;
    rdfs:comment "A change in deployed model behavior or performance over time that can indicate the need for update or retraining."^^xsd:string ;
    rdfs:subClassOf aicd:conceptDrift,
        schema:Thing .

aicd:ModelGovernance a owl:Class ;
    rdfs:label "Model Governance"^^xsd:string ;
    rdfs:comment "Governance activity covering oversight, controls, and decision-making for AI model development, validation, deployment, and updates."^^xsd:string ;
    rdfs:subClassOf schema:Action ;
    aicd:addressesConcern aicd:ExplainabilityConcern,
        aicd:FairnessConcern,
        aicd:SecurityConcern .

aicd:ModelObsolescence a owl:Class ;
    rdfs:label "Model Obsolescence"^^xsd:string ;
    rdfs:comment "A lifecycle condition in which a deployed ML model becomes outdated because the underlying data or operating context changes."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:ModelPerformanceMonitoring a owl:Class ;
    rdfs:label "Model Performance Monitoring"^^xsd:string ;
    rdfs:comment "Monitoring activity focused on tracking performance metrics of deployed ML models over time."^^xsd:string ;
    rdfs:subClassOf aicd:ModelMonitoring .

aicd:ModelQualityMonitoring a owl:Class ;
    rdfs:label "Model Quality Monitoring"^^xsd:string ;
    rdfs:comment "Monitoring activity focused on assessing model quality over time, including performance degradation and related quality signals."^^xsd:string ;
    rdfs:subClassOf aicd:ModelMonitoring ;
    owl:sameAs aicd:ModelPerformanceMonitoring ;
    aicd:monitorsFor aicd:conceptDrift,
        aicd:safetyConstraintViolation .

aicd:MonitoringConcern a owl:Class ;
    rdfs:label "Monitoring Concern"^^xsd:string ;
    rdfs:comment "A cross-silo concern related to observing model behavior and operational health over time."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern .

aicd:OperationalEfficiency a owl:Class ;
    rdfs:label "Operational Efficiency"^^xsd:string ;
    rdfs:comment "A benefit concerned with improved efficiency in AI model development, deployment, and operations."^^xsd:string ;
    rdfs:subClassOf aicd:Benefit ;
    aicd:enhancesOperationalEfficiencyOf aicd:MLOpsPipeline .

aicd:OrganizationalCulture a owl:Class ;
    rdfs:label "Organizational Culture"^^xsd:string ;
    rdfs:comment "The shared norms and practices that influence how MLOps processes are adopted, coordinated, and sustained in an organization."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:ProcessIntegration a owl:Class ;
    rdfs:label "Process Integration"^^xsd:string ;
    rdfs:comment "The coordination and coupling of ML lifecycle activities into an integrated development and operations workflow."^^xsd:string ;
    rdfs:subClassOf schema:Action ;
    aicd:usesDataOpsPrinciple aicd:DataOpsPrinciple ;
    aicd:usesDevOpsPrinciple aicd:DevOpsPrinciple .

aicd:PublicationScreening a owl:Class ;
    rdfs:label "Publication Screening"^^xsd:string ;
    rdfs:comment "The activity of checking candidate publications against inclusion and exclusion criteria during a review workflow."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        schema:Action .

aicd:QualifiedPersonnelShortage a owl:Class ;
    rdfs:label "Qualified Personnel Shortage"^^xsd:string ;
    rdfs:comment "A lack of sufficiently qualified personnel, especially in data science areas, affecting MLOps implementation."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:ResearchImpactAssessment a owl:Class ;
    rdfs:label "Research Impact Assessment"^^xsd:string ;
    rdfs:comment "The activity of evaluating studies with respect to publication venue standing, peer review, or related research impact considerations."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:ResearchPerspective a owl:Class ;
    rdfs:label "Research Perspective"^^xsd:string ;
    rdfs:comment "A perspective oriented toward scholarly investigation, evidence synthesis, and research-driven understanding of MLOps."^^xsd:string,
        "A perspective oriented toward systematic study, surveys, and synthesis of MLOps challenges, opportunities, practices, and maturity models."^^xsd:string ;
    rdfs:subClassOf aicd:LifecyclePerspective,
        schema:Thing .

aicd:ResearchProtocol a owl:Class ;
    rdfs:label "Research Protocol"^^xsd:string ;
    rdfs:comment "A structured plan or methodology used to conduct a systematic literature review or similar evidence-gathering study within MLOps research."^^xsd:string ;
    rdfs:subClassOf schema:CreativeWork .

aicd:RoleAmbiguityConcern a owl:Class ;
    rdfs:label "Role Ambiguity Concern"^^xsd:string ;
    rdfs:comment "A concern related to unclear role definitions and overlapping responsibilities in an MLOps process."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern ;
    aicd:hasRoleDefinition aicd:RoleDefinition .

aicd:SmallAndMediumSizedSoftwareDevelopmentCompany a owl:Class ;
    rdfs:label "Small and Medium-Sized Software Development Company"^^xsd:string ;
    rdfs:comment "A software development organization of small or medium size considered as a context for MLOps adoption and evaluation."^^xsd:string ;
    rdfs:subClassOf aicd:SoftwareDevelopmentCompany .

aicd:SocialDebt a owl:Class ;
    rdfs:label "Social Debt"^^xsd:string ;
    rdfs:comment "A form of organizational or role-definition debt that can arise when MLOps responsibilities are unclear or misaligned."^^xsd:string,
        "Coordination and workload problems that arise when roles and artifacts are ambiguous in ML development work."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:SoftwareDeveloperRole a owl:Class ;
    rdfs:label "Software Developer Role"^^xsd:string ;
    rdfs:comment "A role contributing software engineering work to the MLOps process, often in coordination with other lifecycle roles."^^xsd:string ;
    rdfs:subClassOf aicd:MLOpsRole ;
    aicd:collaboratesWith aicd:DevOpsRole,
        aicd:MLEngineerRole .

aicd:SoftwareDevelopmentContext a owl:Class ;
    rdfs:label "Software Development Context"^^xsd:string ;
    rdfs:comment "A software development setting in which MLOps concepts, practices, and adoption challenges are considered."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:SoftwareDevelopmentIndustry a owl:Class ;
    rdfs:label "Software Development Industry"^^xsd:string ;
    rdfs:comment "The industrial context in which MLOps practices, activities, and approaches are applied."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:Standardization a owl:Class ;
    rdfs:label "Standardization"^^xsd:string ;
    rdfs:comment "The practice of defining and applying common development and operational processes to improve consistency across AI lifecycle activities."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        schema:Action ;
    aicd:hasQualityOutcome aicd:ModelQuality ;
    aicd:supportsScaling aicd:ContinuousDevelopmentProcess .

aicd:TechnicalDebtConcern a owl:Class ;
    rdfs:label "Technical Debt Concern"^^xsd:string ;
    rdfs:comment "A cross-silo concern related to accumulated implementation or process debt that can hinder scaling and lifecycle automation."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern .

aicd:ThreeLevelReview a owl:Class ;
    rdfs:label "Three-Level Review"^^xsd:string ;
    rdfs:comment "A staged review procedure that screens publications across title, abstract and introductory material, and full text."^^xsd:string ;
    rdfs:subClassOf aicd:LiteratureSearchProcess .

aicd:TrainingAutomation a owl:Class ;
    rdfs:label "Training Automation"^^xsd:string ;
    rdfs:comment "Automation of the model training activity within a recurring ML pipeline."^^xsd:string ;
    rdfs:subClassOf aicd:DevelopmentAutomation,
        aicd:RecurringPipeline .

aicd:TrainingDataQuality a owl:Class ;
    rdfs:label "Training Data Quality"^^xsd:string ;
    rdfs:comment "The quality characteristics of data used to train ML models, which influence model performance."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:addressesDataDrift a owl:ObjectProperty ;
    rdfs:label "addresses data drift"^^xsd:string ;
    rdfs:comment "Relates a monitoring or retraining activity to data drift conditions it is intended to address."^^xsd:string ;
    rdfs:subPropertyOf aicd:monitorsFor .

aicd:addressesModelDrift a owl:ObjectProperty ;
    rdfs:label "addresses model drift"^^xsd:string ;
    rdfs:comment "Relates a monitoring, maintenance, or retraining activity to model drift conditions it is intended to address."^^xsd:string ;
    rdfs:subPropertyOf aicd:monitorsFor .

aicd:automates a owl:ObjectProperty ;
    rdfs:label "automates"^^xsd:string ;
    rdfs:comment "Relates a process, pipeline, or maturity stage to the activity it automates."^^xsd:string ;
    rdfs:subPropertyOf schema:relatedTo .

aicd:causesSocialDebt a owl:ObjectProperty ;
    rdfs:label "causes social debt"^^xsd:string ;
    rdfs:comment "Relates a process, practice, or condition to social debt that it contributes to or creates."^^xsd:string ;
    rdfs:subPropertyOf schema:causes .

aicd:causesTechnicalDebt a owl:ObjectProperty ;
    rdfs:label "causes technical debt"^^xsd:string ;
    rdfs:comment "Relates a development practice or omission to technical debt that accumulates in an ML codebase."^^xsd:string,
        "Relates a process, practice, or condition to technical debt that it contributes to or creates."^^xsd:string ;
    rdfs:subPropertyOf schema:causes .

aicd:consumesArtifact a owl:ObjectProperty ;
    rdfs:label "consumes artifact"^^xsd:string ;
    rdfs:comment "Relates a lifecycle activity to an artifact it consumes as input."^^xsd:string ;
    rdfs:subPropertyOf schema:uses .

aicd:continuousMonitoring a owl:ObjectProperty ;
    rdfs:label "continuous monitoring"^^xsd:string ;
    rdfs:comment "Relates a lifecycle process to ongoing monitoring activities performed repeatedly over time."^^xsd:string ;
    rdfs:subPropertyOf aicd:hasMonitoringPhase .

aicd:continuousTraining a owl:ObjectProperty ;
    rdfs:label "continuous training"^^xsd:string ;
    rdfs:comment "Relates a lifecycle process to repeated or ongoing retraining activities performed over time."^^xsd:string ;
    rdfs:subPropertyOf aicd:hasRetrainingPhase .

aicd:detectsModelDrift a owl:ObjectProperty ;
    rdfs:label "detects model drift"^^xsd:string ;
    rdfs:comment "Relates monitoring activity to model drift conditions it is intended to detect."^^xsd:string ;
    rdfs:subPropertyOf aicd:monitorsFor .

aicd:diagnosesOperationalAnomaly a owl:ObjectProperty ;
    rdfs:label "diagnoses operational anomaly"^^xsd:string ;
    rdfs:comment "Relates an interpretability or validation activity to the operational anomaly it helps diagnose."^^xsd:string ;
    rdfs:subPropertyOf schema:relatedTo .

aicd:enablesRecurringExecution a owl:ObjectProperty ;
    rdfs:label "enables recurring execution"^^xsd:string ;
    rdfs:comment "Relates a workflow, process, or organizational capability to the repeated execution characteristic of continuous development."^^xsd:string ;
    rdfs:subPropertyOf schema:supports .

aicd:evaluatesModel a owl:ObjectProperty ;
    rdfs:label "evaluates model"^^xsd:string ;
    rdfs:comment "Relates an evaluation activity to the model being assessed."^^xsd:string ;
    rdfs:subPropertyOf schema:about .

aicd:hasChallenge a owl:ObjectProperty ;
    rdfs:label "has challenge"^^xsd:string ;
    rdfs:comment "Relates an MLOps adoption effort, practice, or process to a challenge associated with it."^^xsd:string,
        "Relates an MLOps context or process to a challenge affecting its implementation or operation."^^xsd:string,
        "Relates an adoption assessment or MLOps practice to a challenge associated with it."^^xsd:string ;
    rdfs:domain aicd:AdoptionAssessment,
        aicd:MLOpsAdoption ;
    rdfs:range aicd:Challenge ;
    rdfs:subPropertyOf schema:hasPart .

aicd:hasEvaluationPhase a owl:ObjectProperty ;
    rdfs:label "has evaluation phase"^^xsd:string ;
    rdfs:comment "Relates a lifecycle process or pipeline to an evaluation phase included within it."^^xsd:string ;
    rdfs:subPropertyOf aicd:hasValidationPhase,
        schema:hasPart .

aicd:hasInclusionCriterion a owl:ObjectProperty ;
    rdfs:label "has inclusion criterion"^^xsd:string ;
    rdfs:comment "Relates a review or screening process to an inclusion criterion used for candidate selection."^^xsd:string,
        "Relates a selection process to a criterion used to include primary studies."^^xsd:string ;
    rdfs:domain aicd:LiteratureSearchProcess ;
    rdfs:range aicd:InclusionCriteria ;
    rdfs:subPropertyOf schema:hasPart .

aicd:hasLifecycleAutomation a owl:ObjectProperty ;
    rdfs:label "has lifecycle automation"^^xsd:string ;
    rdfs:comment "Relates a lifecycle process or pipeline to automation spanning multiple lifecycle stages."^^xsd:string ;
    rdfs:subPropertyOf aicd:hasAutomationPhase .

aicd:hasMetric a owl:ObjectProperty ;
    rdfs:label "has metric"^^xsd:string ;
    rdfs:comment "Relates a research question or evaluation framework to a metric used to answer or quantify it."^^xsd:string ;
    rdfs:subPropertyOf schema:hasPart .

aicd:hasProblemDefinition a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has problem definition"^^xsd:string ;
    rdfs:comment "Relates a lifecycle process to its problem definition stage."^^xsd:string ;
    rdfs:subPropertyOf schema:hasPart .

aicd:hasRole a owl:ObjectProperty ;
    rdfs:label "has role"^^xsd:string ;
    rdfs:comment "Relates an MLOps activity, process, or organizational context to an involved role."^^xsd:string ;
    rdfs:subPropertyOf schema:hasPart .

aicd:hasTrainingPhase a owl:ObjectProperty ;
    rdfs:label "has training phase"^^xsd:string ;
    rdfs:comment "Relates a lifecycle process or pipeline to a phase centered on model training or retraining."^^xsd:string,
        "Relates a lifecycle process or pipeline to a training phase included within it."^^xsd:string ;
    rdfs:subPropertyOf aicd:hasLifecycleStage,
        schema:hasPart .

aicd:includesStage a owl:ObjectProperty ;
    rdfs:label "includes stage"^^xsd:string ;
    rdfs:comment "Relates a continuous development process or pipeline to a constituent stage such as training, evaluation, deployment, or monitoring."^^xsd:string ;
    rdfs:subPropertyOf schema:hasPart .

aicd:integratesDataScienceAndSoftwareEngineering a owl:Class ;
    rdfs:label "Integrating Data Science and Software Engineering Work"^^xsd:string ;
    rdfs:comment "A challenge in MLOps arising from the need to coordinate data science and software engineering practices for sustaining AI solutions."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern .

aicd:integratesDiscipline a owl:ObjectProperty ;
    rdfs:label "integrates discipline"^^xsd:string ;
    rdfs:comment "Relates the MLOps lifecycle perspective to a discipline that it integrates across the development and operational workflow."^^xsd:string ;
    rdfs:subPropertyOf schema:relatedTo .

aicd:involvesArtifact a owl:ObjectProperty ;
    rdfs:label "involves artifact"^^xsd:string ;
    rdfs:comment "Relates a process or project to an artifact produced or used during its execution."^^xsd:string ;
    rdfs:subPropertyOf schema:hasPart .

aicd:managesData a owl:ObjectProperty ;
    rdfs:label "manages data"^^xsd:string ;
    rdfs:comment "Relates an activity or process to data that it manages, governs, or prepares for ML lifecycle use."^^xsd:string ;
    rdfs:subPropertyOf schema:uses .

aicd:mitigatesDataDrift a owl:ObjectProperty ;
    rdfs:label "mitigates data drift"^^xsd:string ;
    rdfs:comment "Relates a retraining or maintenance activity to the data drift it is intended to mitigate."^^xsd:string ;
    rdfs:subPropertyOf schema:relatedTo .

aicd:operatesInfrastructure a owl:ObjectProperty ;
    rdfs:label "operates infrastructure"^^xsd:string ;
    rdfs:comment "Relates a DevOps or operations role to infrastructure operation and support."^^xsd:string ;
    rdfs:subPropertyOf schema:operatesOn .

aicd:performsOutsideUsualRemit a owl:ObjectProperty ;
    rdfs:label "performs outside usual remit"^^xsd:string ;
    rdfs:comment "Relates an agent or role to activities undertaken beyond its typical responsibilities."^^xsd:string ;
    rdfs:subPropertyOf schema:relatedTo .

aicd:producesArtifact a owl:ObjectProperty ;
    rdfs:label "produces artifact"^^xsd:string ;
    rdfs:comment "Relates a lifecycle activity to an artifact it creates, such as a trained model, configuration, or packaged output."^^xsd:string ;
    rdfs:subPropertyOf schema:produces .

aicd:requiresArtifactDefinition a owl:ObjectProperty ;
    rdfs:label "requires artifact definition"^^xsd:string ;
    rdfs:comment "Relates an MLOps context to the need to define involved artifacts clearly."^^xsd:string ;
    rdfs:subPropertyOf schema:requiresActivity .

aicd:requiresDataTransformation a owl:ObjectProperty ;
    rdfs:label "requires data transformation" ;
    rdfs:comment "Relates an integration or deployment activity to the data transformation logic needed to align source data with model expectations." ;
    rdfs:subPropertyOf aicd:requiresActivity,
        schema:requiresActivity .

aicd:requiresExperimentationTime a owl:ObjectProperty ;
    rdfs:label "requires experimentation time"^^xsd:string ;
    rdfs:comment "Relates a project or development phase to additional time allocated for experimentation."^^xsd:string ;
    rdfs:subPropertyOf schema:requiresActivity .

aicd:retrainedUsing a owl:ObjectProperty ;
    rdfs:label "retrained using" ;
    rdfs:comment "Relates a retraining activity to the data used for the update." ;
    rdfs:subPropertyOf schema:object,
        schema:uses .

aicd:supportsModelUpdates a owl:ObjectProperty ;
    rdfs:label "supports model updates"^^xsd:string ;
    rdfs:comment "Relates a process, workflow, or maturity stage to recurring model updates in production."^^xsd:string ;
    rdfs:subPropertyOf schema:supports .

aicd:usesComputationalResource a owl:ObjectProperty ;
    rdfs:label "uses computational resource"^^xsd:string ;
    rdfs:comment "Relates an ML activity to the computational resource it consumes."^^xsd:string ;
    rdfs:subPropertyOf schema:uses .

aicd:usesExperimentalActivity a owl:ObjectProperty ;
    rdfs:label "uses experimental activity"^^xsd:string ;
    rdfs:comment "Relates a development process or pipeline to experimentation activities used in model development."^^xsd:string ;
    rdfs:subPropertyOf schema:uses .

aicd:usesModelPipeline a owl:ObjectProperty ;
    rdfs:label "uses model pipeline"^^xsd:string ;
    rdfs:comment "Relates a maturity stage or lifecycle process to the machine learning pipeline it relies on."^^xsd:string ;
    rdfs:subPropertyOf schema:uses .

aicd:usesProductionData a owl:ObjectProperty ;
    rdfs:label "uses production data" ;
    rdfs:comment "Relates retraining activity to data sourced from the production environment." ;
    rdfs:subPropertyOf aicd:retrainedUsing,
        schema:uses .

aicd:usesRecentData a owl:ObjectProperty ;
    rdfs:label "uses recent data"^^xsd:string ;
    rdfs:comment "Relates a retraining or maintenance activity to the recent data used to update a model."^^xsd:string ;
    rdfs:subPropertyOf schema:uses .

aicd:validationBeforeTraining a owl:ObjectProperty ;
    rdfs:label "validation before training" ;
    rdfs:comment "Relates a lifecycle process to validation performed before model training." ;
    rdfs:subPropertyOf aicd:hasValidationPhase .

aicd:validationDuringTraining a owl:ObjectProperty ;
    rdfs:label "validation during training" ;
    rdfs:comment "Relates a lifecycle process to validation performed during model training." ;
    rdfs:subPropertyOf aicd:hasValidationPhase .

aicd:Automation a owl:Class ;
    rdfs:label "Automation"^^xsd:string ;
    rdfs:comment "The use of automated execution in MLOps processes, including continuous integration, continuous delivery, and continuous training."^^xsd:string ;
    rdfs:subClassOf schema:Action ;
    aicd:supportsScaling aicd:Productionalization .

aicd:ComputationalResourceConstraint a owl:Class ;
    rdfs:label "Computational Resource Constraint"^^xsd:string ;
    rdfs:comment "A constraint arising from the high computational cost of training, deployment, or retraining workflows."^^xsd:string ;
    rdfs:subClassOf schema:Thing ;
    aicd:requiresCapability aicd:ComputationalResource .

aicd:ContinuousIntegration a owl:Class ;
    rdfs:label "Continuous Integration"^^xsd:string ;
    rdfs:comment "A practice of frequently integrating changes and verifying them through automated checks."^^xsd:string,
        "An integration practice in which code and model-related changes are frequently merged and validated as part of an MLOps lifecycle."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        schema:Action .

aicd:ContinuousTesting a owl:Class ;
    rdfs:label "Continuous Testing"^^xsd:string ;
    rdfs:comment "Repeated testing activity carried out throughout the AI lifecycle to detect errors and preserve model quality over time."^^xsd:string ;
    rdfs:subClassOf schema:Action ;
    aicd:hasQualityOutcome aicd:ModelQuality .

aicd:ContinuousTraining a owl:Class ;
    rdfs:label "Continuous Training"^^xsd:string ;
    rdfs:comment "A recurring training practice in which a model is repeatedly updated as new data becomes available."^^xsd:string,
        "An ongoing retraining-oriented activity in which deployed models are updated with newly available data to sustain performance in production."^^xsd:string,
        "An ongoing training activity in which model updates are repeatedly performed to keep an ML model aligned with changing data or requirements."^^xsd:string,
        "An ongoing training activity in which models are retrained repeatedly as new data or conditions become available."^^xsd:string ;
    rdfs:subClassOf aicd:ModelRetraining ;
    aicd:addressesConcern aicd:ConceptDrift,
        aicd:SustainabilityConcern ;
    aicd:hasContinuousTrainingPhase aicd:ModelRetraining ;
    aicd:usesTrainingData aicd:Dataset .

aicd:CostConcern a owl:Class ;
    rdfs:label "Cost Concern"^^xsd:string ;
    rdfs:comment "A cross-silo concern related to financial cost generated by training, deployment, retraining, or infrastructure use."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern .

aicd:DataEngineerRole a owl:Class ;
    rdfs:label "Data Engineer Role"^^xsd:string ;
    rdfs:comment "A role responsible for data engineering work supporting ML pipelines and MLOps operations."^^xsd:string,
        "A role responsible for data preparation, transformation, and data pipeline support in the MLOps lifecycle."^^xsd:string ;
    rdfs:subClassOf aicd:MLOpsRole,
        aicd:MLRole ;
    aicd:hasResponsibility aicd:requiresDataTransformation ;
    aicd:preparesData aicd:ModelRetraining .

aicd:DataOpsPrinciple a owl:Class ;
    rdfs:label "DataOps Principle"^^xsd:string ;
    rdfs:comment "A principle focused on operationalizing data management workflows with collaboration, automation, and quality controls."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:DataQualityAndQuantityChallenge a owl:Class ;
    rdfs:label "Data Quality and Quantity Challenge"^^xsd:string ;
    rdfs:comment "A challenge in MLOps related to insufficient, low-quality, or poorly prepared data for training AI models."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern ;
    aicd:requiresDataStrategy aicd:DataStrategy .

aicd:DataScienceProject a owl:Class ;
    rdfs:label "Data Science Project"^^xsd:string ;
    rdfs:comment "A project that applies data science methods to extract value from data and develop analytical or machine learning solutions."^^xsd:string ;
    rdfs:subClassOf schema:Project .

aicd:DataScientistRole a owl:Class ;
    rdfs:label "Data Scientist Role"^^xsd:string ;
    rdfs:comment "A professional role concerned with developing ML solutions and often participating in model creation and experimentation."^^xsd:string,
        "A role responsible for data science and model development activities in MLOps settings."^^xsd:string,
        "A role responsible for problem framing, experimentation, and model development within the MLOps lifecycle."^^xsd:string ;
    rdfs:subClassOf aicd:MLOpsRole,
        aicd:MLRole,
        schema:Role ;
    aicd:definesRequirements aicd:ProblemDefinition ;
    aicd:developsModel aicd:ModelValidation ;
    aicd:hasProfessionalDevelopment aicd:ProfessionalDevelopment .

aicd:DataStrategy a owl:Class ;
    rdfs:label "Data Strategy"^^xsd:string ;
    rdfs:comment "A planned approach for governing, collecting, cleaning, labeling, and preparing data to support MLOps and model development."^^xsd:string ;
    rdfs:subClassOf schema:CreativeWork .

aicd:Dataset a owl:Class ;
    rdfs:label "Dataset"^^xsd:string ;
    rdfs:comment "A collection of data used as input to machine learning development, training, validation, or retraining activities."^^xsd:string,
        "A collection of data used for training, validation, retraining, or evaluation of machine learning models."^^xsd:string ;
    rdfs:subClassOf schema:Dataset .

aicd:DevOpsRole a owl:Class ;
    rdfs:label "DevOps Role"^^xsd:string ;
    rdfs:comment "A role responsible for infrastructure, automation, integration, and deployment support in an MLOps process."^^xsd:string ;
    rdfs:subClassOf aicd:MLOpsRole ;
    aicd:hasResponsibility aicd:ModelDeployment ;
    aicd:operatesInfrastructure aicd:MLOpsInfrastructure .

aicd:DevelopmentAutomation a owl:Class ;
    rdfs:label "Development Automation"^^xsd:string ;
    rdfs:comment "Automation of experimentation and model development activities within an ML pipeline."^^xsd:string ;
    rdfs:subClassOf aicd:RecurringPipeline .

aicd:ExclusionCriteria a owl:Class ;
    rdfs:label "Exclusion Criteria"^^xsd:string ;
    rdfs:comment "A set of conditions used to discard publications or studies that do not meet the requirements of an MLOps-related review or selection process."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:JenkinsTool a owl:Class ;
    rdfs:label "Jenkins Tool"^^xsd:string ;
    rdfs:comment "A workflow automation tool used to support integration and deployment activities in MLOps."^^xsd:string ;
    rdfs:subClassOf aicd:WorkflowOrchestrationTool .

aicd:KubernetesPlatform a owl:Class ;
    rdfs:label "Kubernetes Platform"^^xsd:string ;
    rdfs:comment "A general-purpose container orchestration platform used as infrastructure for ML project execution."^^xsd:string ;
    rdfs:subClassOf aicd:GeneralPurposeFramework .

aicd:MLEngineerRole a owl:Class ;
    rdfs:label "ML Engineer Role"^^xsd:string ;
    rdfs:comment "A role focused on engineering ML systems, operationalizing models, and supporting production lifecycle workflows."^^xsd:string,
        "A role responsible for ML engineering work, including implementation and operationalization of models."^^xsd:string ;
    rdfs:subClassOf aicd:MLOpsRole,
        aicd:MLRole ;
    aicd:developsModel aicd:ModelDeployment ;
    aicd:hasResponsibility aicd:ModelMaintenance,
        aicd:ModelMonitoring .

aicd:MLLifecycle a owl:Class ;
    rdfs:label "ML Lifecycle"^^xsd:string ;
    rdfs:comment "The lifecycle of machine learning systems from experimentation and development through production operation and ongoing improvement."^^xsd:string ;
    rdfs:subClassOf schema:CreativeWork ;
    owl:sameAs aicd:EndToEndMLOpsLifecycle,
        aicd:LifecycleConcern,
        aicd:LifecyclePerspective,
        aicd:LifecycleStage,
        aicd:MLProjectLifecycle,
        aicd:ModelLifecycle .

aicd:MLOpsMaturityModel a owl:Class ;
    rdfs:label "MLOps Maturity Model"^^xsd:string ;
    rdfs:comment "A maturity framework used to describe progressive levels of MLOps capability in an organization."^^xsd:string ;
    rdfs:subClassOf schema:CreativeWork .

aicd:MLOpsPipeline a owl:Class ;
    rdfs:label "MLOps Pipeline"^^xsd:string ;
    rdfs:comment "An integrated pipeline that supports machine learning lifecycle automation, including training, deployment, and continuous updating."^^xsd:string,
        "An integrated recurring pipeline that supports model development, training, validation, deployment, monitoring, and retraining in production-oriented ML workflows."^^xsd:string ;
    rdfs:subClassOf aicd:RecurringPipeline ;
    aicd:hasLifecycleAutomation aicd:Automation ;
    aicd:hasLifecycleStage aicd:ModelDeployment,
        aicd:ModelMonitoring,
        aicd:ModelRetraining,
        aicd:ModelValidation ;
    aicd:includesStage aicd:DataManagement,
        aicd:DeploymentPhase,
        aicd:MonitoringPhase,
        aicd:ProblemDefinition,
        aicd:RetrainingPhase,
        aicd:TrainingPhase,
        aicd:ValidationPhase .

aicd:MaintenancePhase a owl:Class ;
    rdfs:label "Maintenance Phase"^^xsd:string ;
    rdfs:comment "A phase in which a deployed model is sustained through fixes, updates, and operational support."^^xsd:string ;
    rdfs:subClassOf aicd:LifecycleStage .

aicd:ModelEvaluation a owl:Class ;
    rdfs:label "Model Evaluation"^^xsd:string ;
    rdfs:comment "The activity of assessing model quality, behavior, or performance against criteria during the AI lifecycle."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:ModelLifecycle a owl:Class ;
    rdfs:label "Model Lifecycle"^^xsd:string ;
    rdfs:comment "A recurring lifecycle framing that encompasses development, validation, deployment, monitoring, maintenance, and retraining of AI models."^^xsd:string,
        "The end-to-end lifecycle of an AI model spanning development, validation, deployment, monitoring, maintenance, and retraining activities."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        schema:Process ;
    aicd:hasLifecycleStage aicd:DataManagement,
        aicd:DeploymentPhase,
        aicd:MaintenancePhase,
        aicd:MonitoringPhase,
        aicd:ProblemDefinition,
        aicd:RetrainingPhase,
        aicd:TrainingPhase,
        aicd:ValidationPhase .

aicd:OperationalAnomaly a owl:Class ;
    rdfs:label "Operational Anomaly"^^xsd:string ;
    rdfs:comment "An irregular condition detected during operation of an AI system or model in production."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:OperationsTeam a owl:Class ;
    rdfs:label "Operations Team"^^xsd:string ;
    rdfs:comment "A team responsible for deploying, operating, and maintaining machine learning systems in production environments."^^xsd:string ;
    rdfs:subClassOf schema:Organization ;
    aicd:collaboratesWith aicd:DataScienceTeam,
        aicd:DevelopmentTeam .

aicd:PerformanceDegradation a owl:Class ;
    rdfs:label "Performance Degradation"^^xsd:string ;
    rdfs:comment "A deterioration in the effectiveness of an AI model during its operational lifecycle."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:PerformanceMetric a owl:Class ;
    rdfs:label "Performance Metric"^^xsd:string ;
    rdfs:comment "A measurable criterion used to evaluate model effectiveness or operational behavior in context."^^xsd:string ;
    rdfs:subClassOf schema:PropertyValue .

aicd:ProductionOperations a owl:Class ;
    rdfs:label "Production Operations"^^xsd:string ;
    rdfs:comment "Operational activities that keep AI models running effectively in production, including monitoring and retraining."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        schema:Action .

aicd:ProfessionalDevelopment a owl:Class ;
    rdfs:label "Professional Development"^^xsd:string ;
    rdfs:comment "Preparation or training that builds professional competence in software engineering, computer science, or related MLOps capabilities."^^xsd:string ;
    rdfs:subClassOf schema:Action ;
    aicd:hasRoleDefinition aicd:RoleDefinition .

aicd:ProgrammingPractice a owl:Class ;
    rdfs:label "Programming Practice"^^xsd:string ;
    rdfs:comment "A software engineering practice applied during model development to improve code quality, maintainability, and deployability."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:QualityAssessment a owl:Class ;
    rdfs:label "Quality Assessment"^^xsd:string ;
    rdfs:comment "The activity of assessing the quality or relevance of studies using a set of evaluation criteria."^^xsd:string ;
    rdfs:subClassOf aicd:ModelValidation,
        schema:Action .

aicd:SoftwareDevelopmentCompany a owl:Class ;
    rdfs:label "Software Development Company"^^xsd:string ;
    rdfs:comment "An organization context in which MLOps adoption and continuous model development practices are evaluated or applied."^^xsd:string,
        "An organization context used for evaluating MLOps maturity and capability in software engineering practice."^^xsd:string ;
    rdfs:subClassOf schema:Organization ;
    owl:sameAs aicd:SmallAndMediumSizedSoftwareDevelopmentCompany,
        aicd:SoftwareDevelopmentIndustry ;
    aicd:hasChallenge aicd:CostConcern,
        aicd:DeploymentMaintenanceChallenge,
        aicd:SpecializedTalentShortage ;
    aicd:usesCICD aicd:CI_CDWorkflow .

aicd:SpecializedTalentShortage a owl:Class ;
    rdfs:label "Specialized Talent Shortage"^^xsd:string ;
    rdfs:comment "A challenge related to insufficient availability of specialized skills and expertise for MLOps adoption."^^xsd:string,
        "A shortage of specialized personnel and skills required to support MLOps adoption and lifecycle execution."^^xsd:string ;
    rdfs:subClassOf aicd:Challenge .

aicd:TechnicalDebt a owl:Class ;
    rdfs:label "Technical Debt"^^xsd:string ;
    rdfs:comment "A condition in which expedient implementation choices create future maintenance, scalability, or integration costs in ML software."^^xsd:string,
        "A form of accumulated implementation or design debt that can arise during the creation and operationalization of ML models."^^xsd:string,
        "Accumulated implementation and code-quality shortcomings that increase future maintenance and rewriting effort in ML development."^^xsd:string ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs aicd:TechnicalDebtConcern .

aicd:WorkflowOrchestrationTool a owl:Class ;
    rdfs:label "Workflow Orchestration Tool"^^xsd:string ;
    rdfs:comment "A tool used to orchestrate and automate MLOps workflows across lifecycle stages."^^xsd:string ;
    rdfs:subClassOf schema:SoftwareApplication .

aicd:hasAutomationPhase a owl:ObjectProperty ;
    rdfs:label "has automation phase"^^xsd:string ;
    rdfs:comment "Relates a lifecycle process or maturity progression to a phase in which automation is introduced or increased."^^xsd:string ;
    rdfs:subPropertyOf schema:hasPart .

aicd:hasPerspective a owl:ObjectProperty ;
    rdfs:label "has perspective"^^xsd:string ;
    rdfs:comment "Relates an ontology, process, or knowledge artifact to a perspective used to frame it."^^xsd:string ;
    rdfs:subPropertyOf schema:about .

schema:Question rdfs:subClassOf schema:Thing .

aicd:AbstractionLevel a owl:Class ;
    rdfs:label "Abstraction Level"^^xsd:string ;
    rdfs:comment "A level in a structured evaluation framework, such as conceptual, operational, or quantitative abstraction."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:ComputationalResource a owl:Class ;
    rdfs:label "Computational Resource"^^xsd:string ;
    rdfs:comment "A computational asset used to build, train, validate, or operate ML systems, including specialized hardware and cloud resources."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:ContinuousMonitoring a owl:Class ;
    rdfs:label "Continuous Monitoring"^^xsd:string ;
    rdfs:comment "A recurring monitoring practice used to observe model behavior, performance, and operational conditions over time."^^xsd:string,
        "An ongoing monitoring activity for observing ML models in production and detecting drift, degradation, or other operational issues."^^xsd:string ;
    rdfs:subClassOf aicd:ModelMonitoring ;
    aicd:monitorsFor aicd:conceptDrift,
        aicd:safetyConstraintViolation .

aicd:DataScienceTeam a owl:Class ;
    rdfs:label "Data Science Team"^^xsd:string ;
    rdfs:comment "A team responsible for data analysis, model experimentation, and scientific aspects of machine learning development within an MLOps setting."^^xsd:string ;
    rdfs:subClassOf schema:Organization ;
    aicd:collaboratesWith aicd:DevOpsTeam,
        aicd:DevelopmentTeam,
        aicd:OperationsTeam .

aicd:DevelopmentTeam a owl:Class ;
    rdfs:label "Development Team"^^xsd:string ;
    rdfs:comment "A software development team involved in integrating machine learning capabilities into products and services."^^xsd:string ;
    rdfs:subClassOf schema:Organization .

aicd:ExplainabilityConcern a owl:Class ;
    rdfs:label "Explainability Concern" ;
    rdfs:comment "A cross-silo concern related to making AI model behavior understandable across the lifecycle." ;
    rdfs:subClassOf aicd:CrossSiloConcern,
        aicd:LifecycleConcern .

aicd:LifecyclePerspective a owl:Class ;
    rdfs:label "Lifecycle Perspective"^^xsd:string ;
    rdfs:comment "A viewpoint used to characterize AI model development and operations as a recurring lifecycle rather than a single isolated pipeline."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:LiteratureSearchProcess a owl:Class ;
    rdfs:label "Literature Search Process"^^xsd:string ;
    rdfs:comment "An abstract process for identifying, screening, and evaluating studies related to MLOps in a research synthesis workflow."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        schema:Process .

aicd:ModelMaintenance a owl:Class ;
    rdfs:label "Model Maintenance" ;
    rdfs:comment "The activity of sustaining deployed AI models through updates, fixes, and operational support." ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        aicd:MLOpsCapability,
        aicd:MaintenancePhase,
        schema:Action ;
    aicd:mitigatesConcern aicd:OperationalConcern .

aicd:ModelQuality a owl:Class ;
    rdfs:label "Model Quality"^^xsd:string ;
    rdfs:comment "A high-level quality concept capturing robustness, reliability, correctness, and related desirable model properties across the lifecycle."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:OperationalConcern a owl:Class ;
    rdfs:label "Operational Concern"^^xsd:string ;
    rdfs:comment "A concern related to operational execution of AI systems, including reliability, pipeline failures, data quality issues, and specialized personnel needs."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern .

aicd:RetrainingPhase a owl:Class ;
    rdfs:label "Retraining Phase"^^xsd:string ;
    rdfs:comment "A phase in which an existing model is updated with new or refreshed data to restore or improve performance."^^xsd:string ;
    rdfs:subClassOf aicd:LifecycleStage .

aicd:RoleDefinition a owl:Class ;
    rdfs:label "Role Definition"^^xsd:string ;
    rdfs:comment "An abstract specification of responsibilities and remit associated with a role in an MLOps-oriented organization."^^xsd:string,
        "The activity of specifying responsibilities and roles involved in MLOps work and ML development."^^xsd:string ;
    rdfs:subClassOf schema:Action,
        schema:Thing .

aicd:SustainabilityConcern a owl:Class ;
    rdfs:label "Sustainability Concern"^^xsd:string ;
    rdfs:comment "A concern related to sustaining model usefulness over time through monitoring, retraining, and operational support."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern .

aicd:TrainingPhase a owl:Class ;
    rdfs:label "Training Phase"^^xsd:string ;
    rdfs:comment "A phase in which a model is fitted or optimized using training data."^^xsd:string ;
    rdfs:subClassOf aicd:LifecycleStage .

aicd:ValidationPhase a owl:Class ;
    rdfs:label "Validation Phase"^^xsd:string ;
    rdfs:comment "A phase in which a model, data, or pipeline is checked against requirements, constraints, or quality criteria."^^xsd:string ;
    rdfs:subClassOf aicd:LifecycleStage .

aicd:hasMonitoringPhase a owl:ObjectProperty ;
    rdfs:label "has monitoring phase"^^xsd:string,
        "has monitoring phase" ;
    rdfs:comment "Relates a lifecycle process or pipeline to a monitoring phase included within it.",
        "Relates a lifecycle process or pipeline to a monitoring phase included within it."^^xsd:string ;
    rdfs:subPropertyOf aicd:hasLifecycleStage,
        schema:hasPart .

aicd:hasRetrainingPhase a owl:ObjectProperty ;
    rdfs:label "has retraining phase" ;
    rdfs:comment "Relates a lifecycle process or pipeline to a retraining phase included within it." ;
    rdfs:subPropertyOf aicd:hasLifecycleStage,
        schema:hasPart .

aicd:safetyConstraintViolation a owl:Class ;
    rdfs:label "Safety Constraint Violation" ;
    rdfs:comment "A condition in which a deployed AI model violates expected safety constraints." ;
    rdfs:subClassOf aicd:OperationalConcern,
        schema:Thing .

aicd:AdoptionAssessment a owl:Class ;
    rdfs:label "Adoption Assessment"^^xsd:string ;
    rdfs:comment "An abstract analysis of the benefits and challenges involved in adopting MLOps in software development organizations."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:Benefit a owl:Class ;
    rdfs:label "Benefit"^^xsd:string ;
    rdfs:comment "A positive outcome or advantage associated with adopting MLOps practices."^^xsd:string,
        "A positive outcome or advantage associated with adopting or applying MLOps in software development."^^xsd:string,
        "A positive outcome or advantage associated with the adoption and implementation of MLOps practices."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:ContinuousDeployment a owl:Class ;
    rdfs:label "Continuous Deployment"^^xsd:string ;
    rdfs:comment "A deployment practice in which validated ML changes are automatically or repeatedly released to production as part of an MLOps lifecycle."^^xsd:string,
        "A practice of automatically releasing validated changes into an operational environment."^^xsd:string,
        "An MLOps activity for repeatedly integrating and deploying an ML model into production through automated or semi-automated workflows."^^xsd:string,
        "An automated deployment activity that releases updated models into operational environments as part of an MLOps pipeline."^^xsd:string ;
    rdfs:subClassOf aicd:ModelDeployment,
        schema:Action ;
    aicd:hasDeploymentPhase aicd:ModelDeployment .

aicd:DataManagementChallenge a owl:Class ;
    rdfs:label "Data Management Challenge"^^xsd:string ;
    rdfs:comment "A challenge related to handling, organizing, and governing data in MLOps workflows."^^xsd:string,
        "A challenge related to handling, organizing, governing, and maintaining data used in MLOps workflows."^^xsd:string ;
    rdfs:subClassOf aicd:Challenge .

aicd:DeploymentMaintenanceChallenge a owl:Class ;
    rdfs:label "Deployment and Maintenance Challenge"^^xsd:string ;
    rdfs:comment "A challenge related to deploying machine learning models to production and sustaining them through maintenance."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern ;
    aicd:relatedToImplementation aicd:Productionalization .

aicd:DeploymentPhase a owl:Class ;
    rdfs:label "Deployment Phase"^^xsd:string ;
    rdfs:comment "A phase in which a validated AI model is packaged, released, and made available for operational use."^^xsd:string ;
    rdfs:subClassOf aicd:LifecycleStage .

aicd:FairnessConcern a owl:Class ;
    rdfs:label "Fairness Concern" ;
    rdfs:comment "A cross-silo concern related to bias and fairness assessment across the lifecycle of AI model development and deployment." ;
    rdfs:subClassOf aicd:CrossSiloConcern,
        aicd:LifecycleConcern .

aicd:MLOpsAdoption a owl:Class ;
    rdfs:label "MLOps Adoption"^^xsd:string ;
    rdfs:comment "The organizational adoption and implementation of MLOps practices in software development contexts."^^xsd:string,
        "The organizational adoption and implementation of MLOps practices."^^xsd:string,
        "The process of taking up and integrating MLOps in a software development context."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        aicd:Productionalization ;
    owl:sameAs aicd:AdoptionAssessment ;
    aicd:hasBenefit aicd:CrossTeamCollaboration,
        aicd:DeployedMLProductQuality,
        aicd:OperationalEfficiency ;
    aicd:hasChallenge aicd:ComputationalResourceConstraint,
        aicd:DataManagementChallenge,
        aicd:DeploymentMaintenanceChallenge,
        aicd:RoleAmbiguityConcern,
        aicd:SpecializedTalentShortage ;
    aicd:involvesRole aicd:DataEngineerRole,
        aicd:DataScientistRole,
        aicd:DevOpsRole,
        aicd:MLEngineerRole .

aicd:MLOpsInfrastructure a owl:Class ;
    rdfs:label "MLOps Infrastructure"^^xsd:string ;
    rdfs:comment "Infrastructure supporting integration, continuous deployment, monitoring, and training of ML models."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:MLOpsMaturityLevel a owl:Class ;
    rdfs:label "MLOps Maturity Level"^^xsd:string ;
    rdfs:comment "A level within an MLOps maturity model representing a degree of practice adoption or capability."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:MLRole a owl:Class ;
    rdfs:label "ML Role"^^xsd:string ;
    rdfs:comment "A role involved in MLOps or ML development work."^^xsd:string ;
    rdfs:subClassOf schema:Role .

aicd:hasDeploymentPhase a owl:ObjectProperty ;
    rdfs:label "has deployment phase",
        "has deployment phase"^^xsd:string ;
    rdfs:comment "Relates a lifecycle process or pipeline to a deployment phase included within it."^^xsd:string,
        "Relates a lifecycle process or pipeline to a deployment phase included within it." ;
    rdfs:subPropertyOf aicd:hasLifecycleStage,
        schema:hasPart .

aicd:DataManagement a owl:Class ;
    rdfs:label "Data Management"^^xsd:string ;
    rdfs:comment "The coordinated handling of data collection, cleaning, storage, and accessibility within MLOps practices."^^xsd:string,
        "The governance, preparation, storage, and handling of data used across the ML product lifecycle, including concerns about data quality, availability, and access."^^xsd:string,
        "The management of data assets, including acquisition, preparation, quality, and lifecycle handling for MLOps workflows."^^xsd:string,
        "The management of data assets, including organization, governance, access, and handling, within MLOps workflows."^^xsd:string,
        "The set of activities concerned with acquiring, preparing, governing, and maintaining training and operational data for ML systems."^^xsd:string ;
    rdfs:subClassOf aicd:ContinuousDevelopmentProcess,
        schema:Action,
        schema:Process,
        schema:Thing .

aicd:LifecycleConcern a owl:Class ;
    rdfs:label "Lifecycle Concern"^^xsd:string ;
    rdfs:comment "A concern that arises across stages of the AI model continuous development lifecycle, including development, validation, deployment, monitoring, maintenance, and retraining."^^xsd:string ;
    rdfs:subClassOf aicd:CrossSiloConcern .

aicd:MLModel a owl:Class ;
    rdfs:label "ML Model"^^xsd:string ;
    rdfs:comment "An abstract machine learning artifact that is developed, validated, deployed, monitored, and updated within the continuous development lifecycle."^^xsd:string ;
    rdfs:subClassOf schema:SoftwareSourceCode .

aicd:MonitoringPhase a owl:Class ;
    rdfs:label "Monitoring Phase"^^xsd:string ;
    rdfs:comment "A phase in which deployed models are observed for drift, degradation, safety issues, and operational anomalies."^^xsd:string ;
    rdfs:subClassOf aicd:LifecycleStage .

aicd:ProblemDefinition a owl:Class ;
    rdfs:label "Problem Definition"^^xsd:string ;
    rdfs:comment "The initial lifecycle stage in which the AI problem, objectives, and business requirements are defined before model development begins."^^xsd:string ;
    rdfs:subClassOf schema:Action .

aicd:addressesConcern a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "addresses concern" ;
    rdfs:comment "Relates a lifecycle activity, practice, or process to a cross-silo concern it addresses." ;
    rdfs:subPropertyOf schema:about .

aicd:hasValidationPhase a owl:ObjectProperty ;
    rdfs:label "has validation phase" ;
    rdfs:comment "Relates a lifecycle process or pipeline to a validation phase included within it." ;
    rdfs:subPropertyOf aicd:hasEvaluationPhase,
        aicd:hasLifecycleStage,
        schema:hasPart .

aicd:Challenge a owl:Class ;
    rdfs:label "Challenge"^^xsd:string ;
    rdfs:comment "A difficulty or obstacle associated with the adoption and implementation of MLOps practices."^^xsd:string,
        "A difficulty, limitation, or obstacle associated with adopting MLOps practices."^^xsd:string,
        "A difficulty, obstacle, or limiting factor encountered when adopting or implementing MLOps."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:MLOpsRole a owl:Class ;
    rdfs:label "MLOps Role"^^xsd:string ;
    rdfs:comment "A role concerned with the operational lifecycle of machine learning systems, including deployment, monitoring, maintenance, and related coordination tasks."^^xsd:string,
        "A role participating in an MLOps process with defined responsibilities across development, operations, and collaboration."^^xsd:string ;
    rdfs:subClassOf schema:Role ;
    aicd:causesSocialDebt aicd:SocialDebt ;
    aicd:hasRoleDefinition aicd:RoleDefinition .

aicd:SecurityConcern a owl:Class ;
    rdfs:label "Security Concern" ;
    rdfs:comment "A cross-silo concern related to protecting AI models, data, infrastructure, and operations throughout the lifecycle." ;
    rdfs:subClassOf aicd:CrossSiloConcern,
        aicd:LifecycleConcern .

aicd:ModelRetraining a owl:Class ;
    rdfs:label "Model Retraining" ;
    rdfs:comment "The activity of training an existing AI model again using new or refreshed data to address drift or change." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty aicd:usesRecentData ;
            owl:someValuesFrom schema:Dataset ],
        aicd:ContinuousDevelopmentProcess,
        aicd:ContinuousTraining,
        aicd:MLOpsCapability,
        aicd:RetrainingPhase,
        aicd:continuousTraining,
        schema:Action ;
    aicd:addressesConcern aicd:CostConcern,
        aicd:SustainabilityConcern ;
    aicd:mitigatesConcern aicd:conceptDrift ;
    aicd:updatesModel aicd:MLModel ;
    aicd:usesRecentData aicd:Dataset .

aicd:conceptDrift a owl:Class ;
    rdfs:label "Concept Drift" ;
    rdfs:comment "A change in the relationship between input data and target behavior that can degrade deployed model performance." ;
    rdfs:subClassOf aicd:OperationalConcern,
        schema:Thing .

aicd:monitorsFor a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "monitors for" ;
    rdfs:comment "Relates monitoring activity to a condition or issue it is intended to detect, such as drift or safety violations." ;
    rdfs:subPropertyOf schema:relatedTo .

aicd:LifecycleStage a owl:Class ;
    rdfs:label "Lifecycle Stage"^^xsd:string ;
    rdfs:comment "A stage or phase within a continuous AI development process, such as validation, deployment, monitoring, or retraining."^^xsd:string,
        "An abstract stage within a continuous AI development lifecycle, such as training, validation, deployment, monitoring, or retraining."^^xsd:string ;
    rdfs:subClassOf schema:Thing .

aicd:Productionalization a owl:Class ;
    rdfs:label "Productionalization" ;
    rdfs:comment "The broader process of transitioning an AI or ML model from a laboratory or experimental setting into production use." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty aicd:hasDeploymentPhase ;
            owl:someValuesFrom aicd:Deployment ],
        aicd:ContinuousDeployment,
        aicd:ContinuousDevelopmentProcess,
        aicd:DeploymentMaintenanceChallenge ;
    aicd:causesTechnicalDebt aicd:TechnicalDebt ;
    aicd:hasContinuousDeployment aicd:ContinuousDeployment ;
    aicd:hasContinuousMonitoring aicd:ContinuousMonitoring ;
    aicd:hasContinuousTraining aicd:ContinuousTraining ;
    aicd:hasProblemDefinition aicd:ProblemDefinition ;
    aicd:usesInfrastructure aicd:MLOpsInfrastructure ;
    aicd:usesTool aicd:JenkinsTool,
        aicd:KubernetesPlatform .

aicd:RecurringPipeline a owl:Class ;
    rdfs:label "Recurring Pipeline" ;
    rdfs:comment "A pipeline that is repeatedly executed to support continuous development and operationalization of AI models." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty aicd:includesStage ;
            owl:someValuesFrom schema:Action ],
        aicd:ContinuousDevelopmentProcess,
        aicd:LifecycleStage,
        aicd:MLLifecycle,
        schema:Action ;
    aicd:isRecurring true ;
    aicd:requiresCapability aicd:MLOpsCapability .

aicd:ModelValidation a owl:Class ;
    rdfs:label "Model Validation" ;
    rdfs:comment "The activity of evaluating an AI model, data, or pipeline behavior against requirements, constraints, or quality criteria." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty aicd:diagnosesOperationalAnomaly ;
            owl:someValuesFrom aicd:OperationalAnomaly ],
        [ a owl:Restriction ;
            owl:onProperty aicd:evaluatesModel ;
            owl:someValuesFrom aicd:MLModel ],
        aicd:ContinuousDevelopmentProcess,
        aicd:ContinuousIntegration,
        aicd:ContinuousTesting,
        aicd:MLOpsCapability,
        aicd:ModelEvaluation,
        aicd:ValidationPhase,
        schema:Action ;
    aicd:addressesConcern aicd:ExplainabilityConcern,
        aicd:FairnessConcern ;
    aicd:evaluatesModel aicd:MLModel ;
    aicd:hasQualityDimension aicd:Accuracy ;
    aicd:hasQualityOutcome aicd:ModelQuality ;
    aicd:mitigatesConcern aicd:ExplainabilityConcern,
        aicd:FairnessConcern ;
    aicd:usesPerformanceMetric aicd:PerformanceMetric .

aicd:MLOpsCapability a owl:Class ;
    rdfs:label "MLOps Capability"^^xsd:string ;
    rdfs:comment "A capability needed to support recurring AI development workflows, such as orchestration, validation, monitoring, deployment, or maintenance."^^xsd:string,
        "An organizational or process capability relevant to operating machine learning systems, such as automation, monitoring, governance, or collaboration."^^xsd:string ;
    rdfs:subClassOf schema:CreativeWork,
        schema:Thing ;
    aicd:improvesCapability aicd:ContinuousDevelopmentProcess .

aicd:ModelDeployment a owl:Class ;
    rdfs:label "Model Deployment" ;
    rdfs:comment "The activity of packaging and releasing an AI model into an operational environment for inference services." ;
    rdfs:subClassOf aicd:ContinuousDeployment,
        aicd:ContinuousDevelopmentProcess,
        aicd:DeploymentPhase,
        aicd:MLOpsCapability,
        schema:Action .

aicd:hasLifecycleStage a owl:ObjectProperty ;
    rdfs:label "has lifecycle stage",
        "has lifecycle stage"^^xsd:string ;
    rdfs:comment "Relates a continuous development process to one of its constituent lifecycle stages or activities."^^xsd:string,
        "Relates a continuous development process to one of its constituent lifecycle stages or activities." ;
    rdfs:subPropertyOf schema:hasPart .

aicd:ModelMonitoring a owl:Class ;
    rdfs:label "Model Monitoring" ;
    rdfs:comment "The activity of observing deployed AI models and their behavior in production to detect drift, safety issues, or performance degradation." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty aicd:monitorsFor ;
            owl:someValuesFrom aicd:PerformanceDegradation ],
        [ a owl:Restriction ;
            owl:onProperty aicd:monitorsFor ;
            owl:someValuesFrom schema:Thing ],
        aicd:ContinuousDevelopmentProcess,
        aicd:ContinuousMonitoring,
        aicd:MLOpsCapability,
        aicd:ModelEvaluation,
        aicd:MonitoringPhase,
        aicd:continuousMonitoring,
        schema:Action ;
    aicd:addressesConcern aicd:SecurityConcern,
        aicd:SustainabilityConcern ;
    aicd:mitigatesConcern aicd:conceptDrift ;
    aicd:monitorsFor aicd:OperationalAnomaly,
        aicd:PerformanceDegradation,
        aicd:conceptDrift,
        aicd:safetyConstraintViolation ;
    aicd:monitorsModel aicd:MLModel .

schema:CreativeWork a owl:Class .

aicd:CrossSiloConcern a owl:Class ;
    rdfs:label "Cross-Silo Concern" ;
    rdfs:comment "A concern that must be addressed across multiple phases of the AI lifecycle rather than within only a single stage." ;
    rdfs:subClassOf aicd:LifecycleConcern,
        schema:Thing .

aicd:ContinuousDevelopmentProcess a owl:Class ;
    rdfs:label "Continuous Development Process" ;
    rdfs:comment "An ongoing process for iteratively developing, validating, deploying, and updating AI models within an operational lifecycle." ;
    rdfs:subClassOf [ a owl:Class ;
            rdfs:label "MLOps Lifecycle Process"^^xsd:string ;
            rdfs:comment "An abstract lifecycle process for continuous AI model development, deployment, monitoring, and retraining."^^xsd:string ;
            rdfs:subClassOf schema:Process ],
        [ a owl:Restriction ;
            owl:onProperty aicd:hasValidationPhase ;
            owl:someValuesFrom aicd:ModelValidation ],
        [ a owl:Restriction ;
            owl:onProperty aicd:hasLifecycleStage ;
            owl:someValuesFrom schema:Action ],
        aicd:LifecycleStage,
        aicd:MLLifecycle,
        aicd:Productionalization,
        schema:Process ;
    aicd:hasLifecycleStage aicd:ModelDeployment,
        aicd:ModelMaintenance,
        aicd:ModelMonitoring,
        aicd:ModelRetraining,
        aicd:ModelValidation ;
    aicd:includesAdjustment aicd:Adjustment ;
    aicd:includesContinuousTesting aicd:ContinuousTesting ;
    aicd:isRecurring true ;
    aicd:requiresCapability aicd:MLOpsCapability ;
    aicd:requiresStandardization aicd:Standardization .

