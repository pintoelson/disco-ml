mlops: a owl:Ontology ;
    rdfs:label "MLOps Domain Ontology" ;
    dcterms:created "2026-04-20T13:00:51.850459+00:00"^^xsd:dateTime ;
    dcterms:description "An ontology modeling the abstract concepts and relationships in Machine Learning Operations (MLOps), including lifecycle stages, infrastructure, orchestration, and domain-specific applications across industries such as space exploration, healthcare, IT, and telecommunications." ;
    dcterms:identifier "hash:efcdaf09eb5a6cef9324d44875d5031c644fa0ab607f10b2eb189538920e6b0f" ;
    dcterms:title "mlops" ;
    rdfs:comment "An ontology modeling the abstract concepts and relationships in Machine Learning Operations (MLOps), including lifecycle stages, infrastructure, orchestration, and domain-specific applications across industries such as space exploration, healthcare, IT, and telecommunications." ;
    owl:versionInfo "1.0.2" ;
    prov:wasDerivedFrom <urn:hash:efcdaf09eb5a6cef9324d44875d5031c644fa0ab607f10b2eb189538920e6b0f> .

mlops:Adhoc a owl:Class ;
    rdfs:label "Ad-hoc"@en ;
    rdfs:comment "The initial maturity level where data management processes are ad hoc, with improvised processes, non-standardized practices, and documentation."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:AutomatedModelDeployment a owl:Class ;
    rdfs:label "Automated Model Deployment"@en ;
    rdfs:comment "A maturity level where, in addition to automated training, the deployment process of trained models is also automated, enabling faster and more efficient deployment into production."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:AutomatedTraining a owl:Class ;
    rdfs:label "Automated Training"@en ;
    rdfs:comment "A maturity level where the training environment is fully managed, and models are easy to replicate, indicating partial automation of MLOps workflows."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:AutomaticMLOps a owl:Class ;
    rdfs:label "Automatic MLOps"@en ;
    rdfs:comment "A maturity level where companies have full control of the end-to-end workflow and fully automate tasks related to data and models."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:CICDPipelineAutomation a owl:Class ;
    rdfs:label "CI/CD Pipeline Automation"@en ;
    rdfs:comment "The most advanced maturity level where automation of the Continuous Integration and Continuous Delivery (CI/CD) pipeline for ML models is achieved, enabling automated and continuous implementation and update of models in production."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:CIForNonML a owl:Class ;
    rdfs:label "CI for Non-ML Components"@en ;
    rdfs:comment "A maturity level where CI/CD DevOps practices are implemented for non-ML components."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:CI_CD a owl:Class ;
    rdfs:label "CI/CD"@en ;
    rdfs:comment "A set of practices that combine continuous integration and continuous deployment to automate the testing, building, and deployment of machine learning models and related artifacts."@en ;
    rdfs:subClassOf mlops:MLWorkflowOrchestration .

mlops:CloudDeployment a owl:Class ;
    rdfs:label "Cloud Deployment"@en ;
    rdfs:comment "The deployment of machine learning models on cloud-based infrastructure for scalable and distributed inference."@en ;
    rdfs:subClassOf schema:Action .

mlops:ComprehensiveMLOpsPipelines a owl:Class ;
    rdfs:label "Comprehensive MLOps Pipelines"@en ;
    rdfs:comment "A maturity level where comprehensive MLOps pipelines support frequent model updates, including DevOps practices such as CI/CD and code reviews for ML."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:DataDrift a owl:Class ;
    rdfs:label "Data Drift"@en ;
    rdfs:comment "A phenomenon where the statistical properties of the input data change over time, leading to degradation in model performance and necessitating retraining or model updates."@en ;
    rdfs:subClassOf schema:Event ;
    owl:sameAs mlops:DataDriftDetection,
        mlops:MLModelDriftDetection,
        mlops:ModelDrift,
        mlops:ModelDriftDetection .

mlops:DataGovernance a owl:Class ;
    rdfs:label "Data Governance"@en ;
    rdfs:comment "A framework or system for managing the availability, usability, integrity, and security of data used in MLOps workflows, ensuring compliance with legal and ethical standards."@en,
        "A process or framework ensuring data quality, security, and compliance within MLOps workflows."@en,
        "The policies, processes, and controls governing data quality, access, security, and lifecycle management to ensure reliable and compliant data usage in MLOps workflows."@en ;
    rdfs:subClassOf schema:Action .

mlops:DataManagement a owl:Class ;
    rdfs:label "Data Management"@en ;
    rdfs:comment "The process of acquiring, storing, processing, and governing data to ensure quality, consistency, and compliance with privacy and security requirements."@en ;
    rdfs:subClassOf schema:Action .

mlops:DataOps a owl:Class ;
    rdfs:label "DataOps"@en ;
    rdfs:comment "A maturity level where standardized and automated processes for data management are implemented."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:DataPipeline a owl:Class ;
    rdfs:label "Data Pipeline"@en ;
    rdfs:comment "An automated sequence of data processing steps, including ingestion, transformation, and feature extraction, designed to prepare data for model training."@en ;
    rdfs:subClassOf schema:Action .

mlops:DataValidation a owl:Class ;
    rdfs:label "Data Validation"@en ;
    rdfs:comment "A process within the data preparation stage focused on validating data quality, consistency, and suitability for model training."@en ;
    rdfs:subClassOf mlops:DataPreparationStage .

mlops:DataValidationStage a owl:Class ;
    rdfs:label "Data Validation Stage"@en ;
    rdfs:comment "A lifecycle stage focused on validating the quality, consistency, and integrity of datasets before they are used in model training or other MLOps processes."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:EdgeDeployment a owl:Class ;
    rdfs:label "Edge Deployment"@en ;
    rdfs:comment "The deployment of machine learning models on edge devices or edge computing environments to reduce latency and enable real-time inference."@en ;
    rdfs:subClassOf schema:Action .

mlops:FullAutomatedOperations a owl:Class ;
    rdfs:label "Full Automated Operations"@en ;
    rdfs:comment "The highest maturity level where operations of ML models are fully automated, including training, deployment, continuous monitoring, and automated retraining in production."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:HybridDeployment a owl:Class ;
    rdfs:label "Hybrid Deployment"@en ;
    rdfs:comment "The deployment of machine learning models across both cloud and edge environments to leverage complementary benefits of each."@en ;
    rdfs:subClassOf schema:Action .

mlops:IterativeDevelopment a owl:Class ;
    rdfs:label "Iterative Development"@en ;
    rdfs:comment "A maturity level where iterative development is present, but no CI/CD for ML models yet."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:MLArtefact a owl:Class ;
    rdfs:label "ML Artefact"@en ;
    rdfs:comment "A tangible output or deliverable produced during the MLOps lifecycle, such as datasets, models, code, or documentation."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLAudit a owl:Class ;
    rdfs:label "ML Audit"@en ;
    rdfs:comment "A formal review or assessment of a machine learning model, workflow, or system to verify compliance, performance, or adherence to standards."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLAuditability a owl:Class ;
    rdfs:label "ML Auditability"@en ;
    rdfs:comment "The capability to trace, log, and review decisions, data, and processes involved in the lifecycle of a machine learning model for accountability and transparency."@en ;
    rdfs:subClassOf mlops:MLGovernance .

mlops:MLChangeManagement a owl:Class ;
    rdfs:label "ML Change Management"@en ;
    rdfs:comment "The structured approach to managing changes in machine learning models, workflows, or systems to ensure stability, reliability, and compliance."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLCollaboration a owl:Class ;
    rdfs:label "ML Collaboration"@en ;
    rdfs:comment "The process of coordinating and facilitating collaboration among data scientists, ML engineers, data engineers, product owners, and DevOps engineers in MLOps workflows."@en ;
    rdfs:subClassOf schema:Action ;
    owl:sameAs mlops:CollaborationEnvironment,
        mlops:MLCollaborationEnvironment .

mlops:MLComponent a owl:Class ;
    rdfs:label "ML Component"@en ;
    rdfs:comment "A modular part of an ML-enabled system that encapsulates machine learning functionality, such as a model, feature extractor, or inference service."@en ;
    rdfs:subClassOf schema:SoftwareSourceCode .

mlops:MLContinuousDeployment a owl:Class ;
    rdfs:label "ML Continuous Deployment"@en ;
    rdfs:comment "The automated deployment of machine learning models to production environments as part of a continuous integration and delivery pipeline."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLContinuousIntegration a owl:Class ;
    rdfs:label "ML Continuous Integration"@en ;
    rdfs:comment "The practice of frequently integrating changes to machine learning models, data, or workflows into a shared repository, followed by automated testing and validation."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLContinuousTraining a owl:Class ;
    rdfs:label "ML Continuous Training"@en ;
    rdfs:comment "The automated and ongoing process of training machine learning models in response to new data or feedback, integrated into the deployment pipeline."@en ;
    rdfs:subClassOf mlops:MLProcess .

mlops:MLCostManagement a owl:Class ;
    rdfs:label "ML Cost Management"@en ;
    rdfs:comment "The monitoring and optimization of financial costs associated with MLOps workflows, including compute, storage, and tooling expenses."@en ;
    rdfs:subClassOf mlops:MLResourceManagement .

mlops:MLDataGovernance a owl:Class ;
    rdfs:label "ML Data Governance"@en ;
    rdfs:comment "The policies and processes that ensure the quality, security, privacy, and compliance of data used in machine learning workflows."@en ;
    rdfs:subClassOf mlops:MLGovernance .

mlops:MLDataLineage a owl:Class ;
    rdfs:label "ML Data Lineage"@en ;
    rdfs:comment "The traceability of data from its origin through transformations to its use in machine learning models, ensuring reproducibility and accountability."@en ;
    rdfs:subClassOf mlops:MLDocumentation .

mlops:MLDataQualityMonitoring a owl:Class ;
    rdfs:label "ML Data Quality Monitoring"@en ;
    rdfs:comment "The ongoing assessment of data quality (e.g., completeness, consistency, drift) used in machine learning workflows to ensure reliable model performance."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:MLDataValidation a owl:Class ;
    rdfs:label "ML Data Validation"@en ;
    rdfs:comment "The systematic checking of data quality, consistency, and suitability for use in machine learning workflows before training or deployment."@en ;
    rdfs:subClassOf mlops:DataPreparationStage .

mlops:MLDeploymentStrategy a owl:Class ;
    rdfs:label "ML Deployment Strategy"@en ;
    rdfs:comment "A defined approach for deploying machine learning models, such as canary, blue-green, or A/B testing, to ensure reliability and minimize risk."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLEnabledSystem a owl:Class ;
    rdfs:label "ML-Enabled System"@en ;
    rdfs:comment "A software system that integrates machine learning components to deliver functionality, often requiring specialized engineering practices for development and operation."@en ;
    rdfs:subClassOf schema:SoftwareSourceCode .

mlops:MLExperimentStage a owl:Class ;
    rdfs:label "ML Experiment Stage"@en ;
    rdfs:comment "A lifecycle stage focused on iterative experimentation, hypothesis testing, and model refinement to address uncertainty and improve performance."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:MLExperimentTracking a owl:Class ;
    rdfs:label "ML Experiment Tracking"@en ;
    rdfs:comment "The systematic recording and management of experiments, including hyperparameters, metrics, artifacts, and outcomes, to enable reproducibility and comparison."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLFeatureEngineering a owl:Class ;
    rdfs:label "ML Feature Engineering"@en ;
    rdfs:comment "The process of designing, selecting, and transforming features to improve the performance and interpretability of machine learning models."@en ;
    rdfs:subClassOf mlops:DataPreparationStage .

mlops:MLFeedbackLoop a owl:Class ;
    rdfs:label "ML Feedback Loop"@en ;
    rdfs:comment "A process that captures feedback from model predictions, user interactions, or operational metrics to inform retraining, improvements, or governance actions."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLHyperparameterTuning a owl:Class ;
    rdfs:label "ML Hyperparameter Tuning"@en ;
    rdfs:comment "The process of optimizing the hyperparameters of a machine learning model to improve its performance, often using techniques like grid search or Bayesian optimization."@en ;
    rdfs:subClassOf mlops:ModelTrainingStage .

mlops:MLIncidentManagement a owl:Class ;
    rdfs:label "ML Incident Management"@en ;
    rdfs:comment "The processes and procedures for responding to and resolving incidents related to machine learning models or systems, including rollbacks, investigations, and post-mortems."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLMetadataManagement a owl:Class ;
    rdfs:label "ML Metadata Management"@en ;
    rdfs:comment "The organization and retrieval of metadata associated with machine learning models, datasets, and workflows, including versioning, lineage, and provenance."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLModelCard a owl:Class ;
    rdfs:label "ML Model Card"@en ;
    rdfs:comment "A standardized document that provides transparency about a machine learning model, including its purpose, performance, limitations, and usage guidelines."@en ;
    rdfs:subClassOf mlops:MLDocumentation .

mlops:MLModelEvaluation a owl:Class ;
    rdfs:label "ML Model Evaluation"@en ;
    rdfs:comment "The assessment of a machine learning model's performance using metrics such as accuracy, precision, recall, or business-specific KPIs."@en ;
    rdfs:subClassOf mlops:ModelTrainingStage .

mlops:MLModelPackaging a owl:Class ;
    rdfs:label "ML Model Packaging"@en ;
    rdfs:comment "The preparation of a machine learning model for deployment, including serialization, containerization, and integration with serving infrastructure."@en ;
    rdfs:subClassOf mlops:ModelDeploymentStage .

mlops:MLModelServing a owl:Class ;
    rdfs:label "ML Model Serving"@en ;
    rdfs:comment "The infrastructure and processes that enable the real-time or batch serving of machine learning model predictions to end-users or systems."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLModelServingCompliance a owl:Class ;
    rdfs:label "ML Model Serving Compliance"@en ;
    rdfs:comment "The adherence to regulatory and organizational requirements in the serving of machine learning model predictions, including data privacy and auditability."@en ;
    rdfs:subClassOf mlops:MLCompliance .

mlops:MLModelServingEnvironment a owl:Class ;
    rdfs:label "ML Model Serving Environment"@en ;
    rdfs:comment "The environment (e.g., cloud, edge, hybrid) in which a machine learning model is served to end-users or systems."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLModelServingGovernance a owl:Class ;
    rdfs:label "ML Model Serving Governance"@en ;
    rdfs:comment "The policies and processes that govern the serving of machine learning model predictions, including access control, monitoring, and audit trails."@en ;
    rdfs:subClassOf mlops:MLGovernance .

mlops:MLModelServingInfrastructure a owl:Class ;
    rdfs:label "ML Model Serving Infrastructure"@en ;
    rdfs:comment "The infrastructure components (e.g., servers, containers, APIs) that enable the serving of machine learning model predictions in production."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLModelServingPerformance a owl:Class ;
    rdfs:label "ML Model Serving Performance"@en ;
    rdfs:comment "The metrics and characteristics (e.g., latency, throughput, availability) that define the performance of a machine learning model serving system."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLModelServingReliability a owl:Class ;
    rdfs:label "ML Model Serving Reliability"@en ;
    rdfs:comment "The ability of a model serving system to consistently deliver predictions without failure or degradation over time."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLModelServingScalability a owl:Class ;
    rdfs:label "ML Model Serving Scalability"@en ;
    rdfs:comment "The capability of a model serving system to handle increasing loads (e.g., request volume, data size) efficiently and reliably."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLModelServingSecurity a owl:Class ;
    rdfs:label "ML Model Serving Security"@en ;
    rdfs:comment "The measures and controls that protect the serving infrastructure and predictions of machine learning models from threats and unauthorized access."@en ;
    rdfs:subClassOf mlops:MLSecurity .

mlops:MLModelServingStrategy a owl:Class ;
    rdfs:label "ML Model Serving Strategy"@en ;
    rdfs:comment "A defined approach for serving machine learning model predictions, such as real-time, batch, or streaming, tailored to specific use cases and requirements."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsCurriculum a owl:Class ;
    rdfs:label "MLOps Curriculum"@en ;
    rdfs:comment "An educational program or curriculum designed to train professionals in MLOps practices, tools, and methodologies."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLPerformanceMonitoring a owl:Class ;
    rdfs:label "ML Performance Monitoring"@en ;
    rdfs:comment "The continuous tracking and analysis of machine learning model performance metrics (e.g., accuracy, latency, throughput) in production environments."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:MLPipeline a owl:Class ;
    rdfs:label "ML Pipeline"@en ;
    rdfs:comment "An automated workflow that orchestrates multiple MLOps processes, such as data ingestion, training, evaluation, and deployment, to achieve end-to-end automation."@en ;
    rdfs:subClassOf mlops:MLWorkflow ;
    owl:sameAs mlops:MLPipelineAutomation .

mlops:MLRetraining a owl:Class ;
    rdfs:label "ML Retraining"@en ;
    rdfs:comment "The periodic or event-driven process of retraining a machine learning model to adapt to new data, changing environments, or evolving requirements."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLRiskManagement a owl:Class ;
    rdfs:label "ML Risk Management"@en ;
    rdfs:comment "The identification, assessment, and mitigation of risks associated with machine learning models and systems, including performance, security, and ethical risks."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLRollback a owl:Class ;
    rdfs:label "ML Rollback"@en ;
    rdfs:comment "The process of reverting a deployed machine learning model to a previous version due to performance degradation, errors, or compliance issues."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLTraining a owl:ObjectProperty ;
    rdfs:label "performs training"@en ;
    rdfs:comment "Relates an ML role (e.g., data scientist) to the training process they perform on machine learning models."@en ;
    rdfs:domain mlops:MLRole ;
    rdfs:range schema:Action ;
    rdfs:subPropertyOf prov:performedBy ;
    owl:sameAs mlops:hasContinuousTraining .

mlops:MLValidation a owl:Class ;
    rdfs:label "ML Validation"@en ;
    rdfs:comment "The process of confirming that a machine learning model meets specified requirements and performs as expected in a given context."@en ;
    rdfs:subClassOf mlops:MLTesting .

mlops:MLVerification a owl:Class ;
    rdfs:label "ML Verification"@en ;
    rdfs:comment "The formal or systematic assessment of a machine learning model to ensure it adheres to defined properties, constraints, or specifications."@en ;
    rdfs:subClassOf mlops:MLTesting .

mlops:MLWorkflowStage a owl:Class ;
    rdfs:label "ML Workflow Stage"@en ;
    rdfs:comment "A distinct phase within an ML workflow, such as data preparation, model training, deployment, or monitoring, that represents a logical grouping of activities."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:ManualMLOps a owl:Class ;
    rdfs:label "Manual MLOps"@en ;
    rdfs:comment "A maturity level where companies manually standardize the end-to-end MLOps lifecycle."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:ManualProcesses a owl:Class ;
    rdfs:label "Manual Processes"@en ;
    rdfs:comment "The initial maturity level where MLOps processes are predominantly manual, with no automation or standardized practices."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:ModelEvaluation a owl:Class ;
    rdfs:label "Model Evaluation"@en ;
    rdfs:comment "A process within the model training stage focused on evaluating model performance using validation datasets and metrics."@en ;
    rdfs:subClassOf mlops:ModelTrainingStage .

mlops:ModelEvaluationStage a owl:Class ;
    rdfs:label "Model Evaluation Stage"@en ;
    rdfs:comment "A lifecycle stage where trained models are evaluated using metrics such as accuracy, precision, recall, and F1-score to assess their performance before deployment."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:ModelInterpretability a owl:Class ;
    rdfs:label "Model Interpretability"@en ;
    rdfs:comment "A process or system focused on making machine learning models interpretable and understandable to stakeholders for debugging, compliance, and trust."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:ModelQualityAssurance a owl:Class ;
    rdfs:label "Model Quality Assurance"@en ;
    rdfs:comment "The processes and practices ensuring that machine learning models meet quality standards, including validation, testing, and performance monitoring."@en ;
    rdfs:subClassOf schema:Action .

mlops:ModelRetraining a owl:Class ;
    rdfs:label "Model Retraining"@en ;
    rdfs:comment "A process of updating or retraining machine learning models with new data to maintain performance and mitigate obsolescence due to data drift."@en ;
    rdfs:subClassOf mlops:ModelTrainingStage .

mlops:ModelServing a owl:Class ;
    rdfs:label "Model Serving"@en ;
    rdfs:comment "A process within the model deployment stage focused on serving model predictions to end-users or systems in real-time or batch mode."@en ;
    rdfs:subClassOf mlops:ModelDeploymentStage .

mlops:ModelServingStage a owl:Class ;
    rdfs:label "Model Serving Stage"@en ;
    rdfs:comment "A lifecycle stage responsible for serving model predictions to end-users or applications through APIs, microservices, or other serving mechanisms."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:NoDevOps a owl:Class ;
    rdfs:label "No DevOps"@en ;
    rdfs:comment "A maturity level where no DevOps practices have been adopted."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:PerformanceMonitoring a owl:Class ;
    rdfs:label "Performance Monitoring"@en ;
    rdfs:comment "A process within the model monitoring stage focused on tracking model performance metrics such as accuracy, latency, and throughput."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:ProblemDefinitionStage a owl:Class ;
    rdfs:label "Problem Definition Stage"@en ;
    rdfs:comment "A lifecycle stage focused on defining the objectives, scope, and business requirements for a machine learning project to ensure alignment with stakeholder expectations."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:ProcessIntegrationAndAutomation a owl:Class ;
    rdfs:label "Process Integration and Automation"@en ;
    rdfs:comment "The integration of MLOps workflows with CI/CD/CT pipelines to enable continuous delivery, deployment, and training of machine learning models."@en ;
    rdfs:subClassOf schema:Action .

mlops:ResourceAllocation a owl:Class ;
    rdfs:label "Resource Allocation"@en ;
    rdfs:comment "The assignment and optimization of computational resources (CPU, GPU, memory) to MLOps workflows to meet performance, cost, and latency requirements."@en ;
    rdfs:subClassOf mlops:InfrastructureManagement .

mlops:ResourceOptimization a owl:Class ;
    rdfs:label "Resource Optimization"@en ;
    rdfs:comment "A process within infrastructure management focused on optimizing the allocation and utilization of computational resources to improve efficiency and reduce costs."@en ;
    rdfs:subClassOf mlops:InfrastructureManagement .

mlops:SocialDebt a owl:Class ;
    rdfs:label "Social Debt"@en ;
    rdfs:comment "The organizational and role-related challenges in MLOps, including unclear responsibilities, lack of defined processes, or misalignment between teams (e.g., data scientists, software engineers, operations) that hinder effective collaboration and workflow efficiency."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:MLSocialDebt,
        mlops:MLTechnicalDebt,
        mlops:TechnicalDebt .

mlops:addressesChallenge a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "addresses challenge"@en ;
    rdfs:comment "Relates an MLOps practice or solution to a challenge it aims to mitigate or resolve."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLOpsChallenge ;
    rdfs:subPropertyOf schema:additionalProperty .

mlops:addressesDataChallenge a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "addresses data challenge"@en ;
    rdfs:comment "Relates an MLOps process or workflow to a specific data-related challenge it addresses, such as data quality or quantity issues."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:DataQuality,
        mlops:DataQuantity ;
    rdfs:subPropertyOf prov:used .

mlops:adheresToBestPractice a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "adheres to best practice"@en ;
    rdfs:comment "Relates a machine learning process or artifact to a best practice it follows or should follow to ensure quality and reliability."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLBestPractice ;
    rdfs:subPropertyOf prov:wasInfluencedBy .

mlops:affects a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "affects"@en ;
    rdfs:comment "Relates a form of debt (e.g., technical debt, social debt) to the MLOps workflows or stages it impacts."@en ;
    rdfs:domain mlops:TechnicalDebt ;
    rdfs:range schema:Action ;
    rdfs:subPropertyOf prov:affectedBy .

mlops:appliesQualityModel a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "applies quality model"@en ;
    rdfs:comment "Relates an MLOps process or workflow to a quality model it adheres to or implements."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLQualityModel ;
    rdfs:subPropertyOf prov:used .

mlops:appliesToDomain a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "applies to domain"@en ;
    rdfs:comment "Relates a research protocol or systematic review to the specific domain or context it addresses, such as MLOps in small and medium software development companies."@en ;
    rdfs:domain mlops:ResearchProtocol ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf prov:used .

mlops:assessedBy a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "assessed by"@en ;
    rdfs:comment "Relates an MLOps process or workflow to the maturity framework used to evaluate its capability or maturity."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MaturityFramework ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:assessesDataQuality a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "assesses data quality"@en ;
    rdfs:comment "Relates a data quality assessment process to the dataset or data source it evaluates."@en ;
    rdfs:domain mlops:DataQualityAssessment ;
    rdfs:range schema:Thing .

mlops:causesMLSocialDebt a owl:ObjectProperty ;
    rdfs:label "causes social debt"@en ;
    rdfs:comment "Relates an organizational issue or ambiguity to the social debt it causes in MLOps teams."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLSocialDebt ;
    rdfs:subPropertyOf prov:causedBy ;
    owl:sameAs mlops:generatesMLTechnicalDebt,
        mlops:mitigatesTechnicalDebt .

mlops:contributesTo a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "contributes to"@en ;
    rdfs:comment "Relates an ML team member to the MLOps workflows or stages they contribute to."@en ;
    rdfs:domain schema:Person ;
    rdfs:range schema:Action ;
    rdfs:subPropertyOf prov:wasAssociatedWith .

mlops:definesMaturityLevel a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "defines maturity level"@en ;
    rdfs:comment "Relates a maturity model to the specific maturity levels it defines."@en ;
    rdfs:domain mlops:MLOpsMaturityModel ;
    rdfs:range mlops:MLOpsMaturityLevel ;
    rdfs:subPropertyOf schema:additionalProperty .

mlops:deploysTo a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "deploys to"@en ;
    rdfs:comment "Relates a deployment process to the target environment (e.g., cloud, edge, hybrid) where a model is deployed."@en ;
    rdfs:domain schema:Action ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf prov:used .

mlops:derivesFromObjective a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "derives from objective"@en ;
    rdfs:comment "Relates a research question to the research objective from which it is derived, typically within a structured framework like Goal-Question-Metric (GQM)."@en ;
    rdfs:domain mlops:ResearchQuestion ;
    rdfs:range mlops:ResearchObjective ;
    rdfs:subPropertyOf prov:wasDerivedFrom .

mlops:detectsDataDrift a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "detects data drift"@en ;
    rdfs:comment "Relates a monitoring system to the data drift it detects."@en ;
    rdfs:domain mlops:DataDriftDetection ;
    rdfs:range schema:Thing ;
    owl:sameAs mlops:detectsModelDrift,
        mlops:monitorsModelDrift .

mlops:enablesDataControl a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "enables data control"@en ;
    rdfs:comment "Relates a data control system to the data or processes it manages."@en ;
    rdfs:domain mlops:CustomerDataControl ;
    rdfs:range schema:Thing .

mlops:enablesStakeholderInvolvement a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "enables stakeholder involvement"@en ;
    rdfs:comment "Relates a collaborative environment or process to the stakeholders it involves in MLOps workflows."@en ;
    rdfs:domain mlops:CollaborativeEnvironment ;
    rdfs:range mlops:StakeholderInvolvement .

mlops:enforcesStandardization a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "enforces standardization"@en ;
    rdfs:comment "Relates a standardization process to the MLOps workflows or practices it standardizes."@en ;
    rdfs:domain mlops:StandardizationProcess ;
    rdfs:range schema:Action .

mlops:enhancesCollaboration a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "enhances collaboration"@en ;
    rdfs:comment "Relates a benefit or efficiency to the collaboration it improves between stakeholders in MLOps workflows."@en ;
    rdfs:domain mlops:CollaborationEfficiency ;
    rdfs:range schema:Organization .

mlops:ensuresPrivacy a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "ensures privacy"@en ;
    rdfs:comment "Relates a privacy management system to the data or processes it protects."@en ;
    rdfs:domain mlops:PrivacyAndSecurityManagement ;
    rdfs:range schema:Thing .

mlops:ensuresSecurity a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "ensures security"@en ;
    rdfs:comment "Relates a security management system to the data or processes it protects."@en ;
    rdfs:domain mlops:PrivacyAndSecurityManagement ;
    rdfs:range schema:Thing .

mlops:evaluatesPerformance a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "evaluates performance"@en ;
    rdfs:comment "Relates a monitoring system to the performance metrics it evaluates."@en ;
    rdfs:domain mlops:ModelPerformanceEvaluation ;
    rdfs:range schema:Thing .

mlops:exacerbatesMLQualifiedPersonnelShortage a owl:ObjectProperty ;
    rdfs:label "exacerbates qualified personnel shortage"@en ;
    rdfs:comment "Relates a challenge or issue to the shortage of qualified personnel in MLOps."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLQualifiedPersonnelShortage ;
    rdfs:subPropertyOf prov:causedBy .

mlops:fostersCollaboration a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "fosters collaboration"@en ;
    rdfs:comment "Relates an organizational culture to the collaborative practices it promotes among teams in MLOps workflows."@en ;
    rdfs:domain mlops:OrganizationalCulture ;
    rdfs:range mlops:CollaborativeEnvironment .

mlops:guidesEvaluation a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "guides evaluation"@en ;
    rdfs:comment "Relates a research objective to the systematic review process it guides, ensuring that the review aligns with the stated goals and questions."@en ;
    rdfs:domain mlops:ResearchObjective ;
    rdfs:range mlops:SystematicLiteratureReview ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasLifecycleStage a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has lifecycle stage"@en ;
    rdfs:comment "Relates an MLOps process or workflow to a specific lifecycle stage it belongs to."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLLifecycleStage ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasTool a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has tool"@en ;
    rdfs:comment "Relates an MLOps process or workflow to the tools or technologies it utilizes."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLOpsTool ;
    rdfs:subPropertyOf prov:used ;
    owl:sameAs mlops:hasAdoptionBarrier,
        mlops:hasArtifact,
        mlops:hasBenefit,
        mlops:hasChallenge,
        mlops:hasCollaborationChallenge,
        mlops:hasCollaborationContext,
        mlops:hasCommunication,
        mlops:hasComplianceFramework,
        mlops:hasDataQualityMetric,
        mlops:hasDataStrategy,
        mlops:hasDocumentation,
        mlops:hasEffectiveness,
        mlops:hasEthicsRequirement,
        mlops:hasExperiment,
        mlops:hasExplainabilityRequirement,
        mlops:hasFairnessRequirement,
        mlops:hasFramework,
        mlops:hasGovernanceRequirement,
        mlops:hasLifecycle,
        mlops:hasMLChallenge,
        mlops:hasMLRole,
        mlops:hasMaturityLevel,
        mlops:hasMetadata,
        mlops:hasModelPerformanceMetric,
        mlops:hasOrganizationalStandard,
        mlops:hasPrinciple,
        mlops:hasPrivacyRequirement,
        mlops:hasProcess,
        mlops:hasPublicationType,
        mlops:hasRegulatoryRequirement,
        mlops:hasReliability,
        mlops:hasResearchObjective,
        mlops:hasResearchQuestion,
        mlops:hasResourceConstraint,
        mlops:hasRobustness,
        mlops:hasRole,
        mlops:hasRoleDefinition,
        mlops:hasSecurityRequirement,
        mlops:hasStakeholder,
        mlops:hasTeam .

mlops:hasWorkflow a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has workflow"@en ;
    rdfs:comment "Relates an MLOps process or stage to a workflow it is part of."@en ;
    rdfs:domain mlops:MLLifecycleStage ;
    rdfs:range mlops:MLOpsWorkflow ;
    rdfs:subPropertyOf prov:wasGeneratedBy ;
    owl:sameAs mlops:integratesMLWorkflow,
        mlops:isPartOfWorkflow .

mlops:improvesLifecycleEfficiency a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "improves lifecycle efficiency"@en ;
    rdfs:comment "Relates a benefit or process to the lifecycle efficiency it enhances in MLOps workflows."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:LifecycleEfficiency .

mlops:incursMLComputingResourceCost a owl:ObjectProperty ;
    rdfs:label "incurs computing resource cost"@en ;
    rdfs:comment "Relates a process or workflow to the computing resource costs it incurs in MLOps."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLComputingResourceCost ;
    rdfs:subPropertyOf prov:used .

mlops:isMaintainedBy a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "is maintained by"@en ;
    rdfs:comment "Relates a machine learning model or its deployment to the MLOps workflow responsible for its ongoing maintenance."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLModelMaintenance ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:isProductionizedBy a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "is productionized by"@en ;
    rdfs:comment "Relates a machine learning model or its development process to the MLOps workflow that brings it into production."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLModelProductionization ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:managesData a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "manages data"@en ;
    rdfs:comment "Relates an MLOps process or workflow to the data it manages or processes."@en ;
    rdfs:domain schema:Action ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf prov:used .

mlops:managesInfrastructure a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "manages infrastructure"@en ;
    rdfs:comment "Relates an MLOps process or workflow to the infrastructure it manages or utilizes."@en ;
    rdfs:domain mlops:InfrastructureManagement ;
    rdfs:range schema:Thing .

mlops:managesMLCustomerExpectations a owl:ObjectProperty ;
    rdfs:label "manages customer expectations"@en ;
    rdfs:comment "Relates a process to the management of customer expectations regarding ML model capabilities."@en ;
    rdfs:domain mlops:MLCustomerExpectationManagement ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf prov:used .

mlops:managesMLData a owl:ObjectProperty ;
    rdfs:label "manages data"@en ;
    rdfs:comment "Relates a data management process to the data it manages in MLOps workflows."@en ;
    rdfs:domain mlops:MLDataManagement ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf prov:used .

mlops:monitorsBias a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "monitors bias"@en ;
    rdfs:comment "Relates a monitoring system to the bias aspects of a model it evaluates."@en ;
    rdfs:domain mlops:ModelFairnessMonitoring ;
    rdfs:range schema:Thing .

mlops:monitorsErrors a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "monitors errors"@en ;
    rdfs:comment "Relates a monitoring system to the error metrics of a model it evaluates."@en ;
    rdfs:domain mlops:ModelFairnessMonitoring ;
    rdfs:range schema:Thing .

mlops:monitorsModelFairness a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "monitors model fairness"@en ;
    rdfs:comment "Relates a monitoring system to the fairness aspects of a model it evaluates."@en ;
    rdfs:domain mlops:ModelFairnessMonitoring ;
    rdfs:range schema:Thing .

mlops:monitorsModelPerformance a owl:ObjectProperty ;
    rdfs:label "monitors model performance"@en ;
    rdfs:comment "Relates a monitoring process to the performance metrics of a machine learning model in production."@en ;
    rdfs:domain mlops:ModelMonitoringStage ;
    rdfs:range mlops:MLModelPerformanceMetrics ;
    rdfs:subPropertyOf prov:used .

mlops:orchestrates a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "orchestrates"@en ;
    rdfs:comment "Relates an orchestrator to the workflows or pipelines it manages and coordinates."@en ;
    rdfs:domain mlops:MLWorkflowOrchestration ;
    rdfs:range schema:Action .

mlops:performsContinuousMonitoring a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "performs continuous monitoring"@en ;
    rdfs:comment "Relates a monitoring system or process to the models or data it monitors."@en ;
    rdfs:domain mlops:ContinuousMonitoring ;
    rdfs:range schema:Thing .

mlops:performsContinuousValidation a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "performs continuous validation"@en ;
    rdfs:comment "Relates a validation process to the models or workflows it validates."@en ;
    rdfs:domain mlops:ContinuousValidation ;
    rdfs:range schema:Thing .

mlops:preventsModelObsolete a owl:ObjectProperty ;
    rdfs:label "prevents model obsolete"@en ;
    rdfs:comment "Relates a process or strategy to the prevention of model obsolescence through updates or retraining."@en ;
    rdfs:domain mlops:MLModelObsoletePrevention ;
    rdfs:range mlops:MLModelDegradation ;
    rdfs:subPropertyOf prov:preventedBy .

mlops:promotesCollaboration a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "promotes collaboration"@en ;
    rdfs:comment "Relates a collaborative environment or process to the cross-disciplinary teams or stakeholders it brings together for MLOps workflows."@en ;
    rdfs:domain mlops:CollaborativeEnvironment ;
    rdfs:range schema:Organization ;
    rdfs:subPropertyOf mlops:enablesCollaboration .

mlops:promotesContinuousLearning a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "promotes continuous learning"@en ;
    rdfs:comment "Relates an organizational culture to the practices it encourages to support ongoing learning and adaptation in MLOps workflows."@en ;
    rdfs:domain mlops:OrganizationalCulture ;
    rdfs:range schema:Thing .

mlops:protectsMLData a owl:ObjectProperty ;
    rdfs:label "protects data"@en ;
    rdfs:comment "Relates a data protection process to the data it protects in MLOps workflows."@en ;
    rdfs:domain mlops:MLDataProtection ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf prov:used .

mlops:protectsPrivacy a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "protects privacy"@en ;
    rdfs:comment "Relates a privacy management process to the sensitive data it protects or governs."@en ;
    rdfs:domain mlops:PrivacyManagement ;
    rdfs:range schema:Thing ;
    rdfs:subPropertyOf prov:used .

mlops:providesExplainability a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "provides explainability"@en ;
    rdfs:comment "Relates an explainability system to the model or process it explains."@en ;
    rdfs:domain mlops:ModelExplainability ;
    rdfs:range schema:Thing .

mlops:requiresDomainExpertise a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "requires domain expertise"@en ;
    rdfs:comment "Relates a process or workflow to the domain expertise required to execute it effectively."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:DomainExpertise .

mlops:requiresProcessElement a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "requires process element"@en ;
    rdfs:comment "Relates an MLOps process or workflow to a specific process element it requires for execution."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLProcessElement ;
    rdfs:subPropertyOf prov:used .

mlops:requiresProfessionalCompetency a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "requires professional competency"@en ;
    rdfs:comment "Relates a process or workflow to the professional competencies required to execute it effectively."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:ProfessionalCompetency .

mlops:requiresSoftwareEngineeringPractice a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "requires software engineering practice"@en ;
    rdfs:comment "Relates an AI solution or MLOps process to the software engineering practices it requires for maintenance and evolution."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:SoftwareEngineeringPractice ;
    rdfs:subPropertyOf prov:used .

mlops:supportsCollaboration a owl:AsymmetricProperty,
        owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "supports collaboration"@en ;
    rdfs:comment "Relates an MLOps framework or tool to the collaborative environments it enables or enhances."@en,
        "Relates an MLOps process or workflow to the organizational culture or collaborative practices it enables or requires."@en ;
    rdfs:domain mlops:MLOpsFramework,
        schema:Action ;
    rdfs:range mlops:CollaborativeEnvironment,
        mlops:OrganizationalCulture ;
    rdfs:subPropertyOf prov:wasInfluencedBy .

mlops:supportsModelImplementation a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "supports model implementation"@en ;
    rdfs:comment "Relates a benefit or process to the model implementation it facilitates in MLOps workflows."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:ModelImplementation .

mlops:tracksModelVersion a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "tracks model version"@en ;
    rdfs:comment "Relates a model registry or tracking system to the versions of models it manages."@en ;
    rdfs:domain mlops:ModelRegistry ;
    rdfs:range mlops:ModelVersioning .

mlops:triggersRetraining a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "triggers retraining"@en ;
    rdfs:comment "Relates a monitoring event or performance degradation to the initiation of a retraining process for a machine learning model."@en ;
    rdfs:domain mlops:ModelPerformanceDegradation ;
    rdfs:range mlops:ContinuousTraining ;
    rdfs:subPropertyOf prov:wasDerivedFrom .

mlops:usesToolchain a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "uses toolchain"@en ;
    rdfs:comment "Relates an ML workflow or process to the toolchain it utilizes for execution and management."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLToolchain .

mlops:utilizesCloudResources a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "utilizes cloud resources"@en ;
    rdfs:comment "Relates an MLOps process or workflow to the use of cloud-based computational resources for training or deployment, such as serverless computing."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:ServerlessComputing ;
    rdfs:subPropertyOf mlops:requiresInfrastructure .

mlops:utilizesFeatureStore a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "utilizes feature store"@en ;
    rdfs:comment "Relates a data pipeline or training process to a feature store it uses for feature management."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:FeatureStore .

mlops:yieldsBenefit a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "yields benefit"@en ;
    rdfs:comment "Relates an MLOps practice or adoption to a benefit it produces."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLOpsBenefit ;
    rdfs:subPropertyOf schema:additionalProperty .

mlops:CollaborationChallenge a owl:Class ;
    rdfs:label "Collaboration Challenge"@en ;
    rdfs:comment "A barrier or difficulty in coordinating and communicating among stakeholders (e.g., data scientists, engineers, operations) during MLOps workflows."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:TeamIntegrationChallenge .

mlops:CollaborationEfficiency a owl:Class ;
    rdfs:label "Collaboration Efficiency"@en ;
    rdfs:comment "The improvement in productivity and effectiveness of collaboration between data science, operations, and other stakeholders in MLOps workflows, enabling faster model implementation and deployment."@en ;
    rdfs:subClassOf schema:Thing .

mlops:CollaborationEnvironment a owl:Class ;
    rdfs:label "Collaboration Environment"@en ;
    rdfs:comment "A shared workspace or platform enabling interdisciplinary teams to collaborate effectively on MLOps workflows, including data scientists, engineers, and operations professionals."@en ;
    rdfs:subClassOf mlops:CollaborativeEnvironment .

mlops:ContinuousMonitoring a owl:Class ;
    rdfs:label "Continuous Monitoring"@en ;
    rdfs:comment "An ongoing process of evaluating and tracking the performance of deployed machine learning models in production to detect degradation, data drift, or other issues requiring retraining or intervention."@en,
        "An ongoing process of evaluating, logging, and validating model performance and data quality in production environments to ensure sustained accuracy and reliability."@en,
        "The ongoing process of tracking and evaluating the performance, behavior, and data drift of deployed ML models in production to ensure reliability and accuracy."@en ;
    rdfs:subClassOf mlops:MLOpsParadigm,
        mlops:ModelMonitoringStage .

mlops:ContinuousValidation a owl:Class ;
    rdfs:label "Continuous Validation"@en ;
    rdfs:comment "A process that continuously tests and validates models against predefined metrics and benchmarks to ensure they meet performance and quality standards throughout their lifecycle."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:CustomerDataControl a owl:Class ;
    rdfs:label "Customer Data Control"@en ;
    rdfs:comment "A system or process enabling customers to manage and control how their data is used, shared, or processed within MLOps workflows."@en ;
    rdfs:subClassOf schema:Action .

mlops:DataQuality a owl:Class ;
    rdfs:label "Data Quality"@en ;
    rdfs:comment "The degree to which data meets specified requirements for accuracy, completeness, consistency, timeliness, and relevance in the context of MLOps workflows."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:DataQuantity .

mlops:DataStrategy a owl:Class ;
    rdfs:label "Data Strategy"@en ;
    rdfs:comment "A systematic approach to defining, managing, and governing data assets and processes within MLOps to ensure quality, consistency, and availability for machine learning workflows."@en ;
    rdfs:subClassOf schema:Action ;
    owl:sameAs mlops:DataManagementChallenge .

mlops:DomainExpertise a owl:Class ;
    rdfs:label "Domain Expertise"@en ;
    rdfs:comment "Specialized knowledge in a specific application domain required to extract value from data and apply MLOps effectively."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ExpectationManagementChallenge a owl:Class ;
    rdfs:label "Expectation Management Challenge"@en ;
    rdfs:comment "Challenges in aligning stakeholder expectations with the capabilities and limitations of machine learning models and MLOps processes."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ExperimentalNatureChallenge a owl:Class ;
    rdfs:label "Experimental Nature Challenge"@en ;
    rdfs:comment "Challenges arising from the iterative and experimental nature of machine learning, including model experimentation, hyperparameter tuning, and reproducibility issues."@en ;
    rdfs:subClassOf schema:Thing .

mlops:FeatureStore a owl:Class ;
    rdfs:label "Feature Store"@en ;
    rdfs:comment "A centralized repository for storing, managing, and serving features used in machine learning models to ensure consistency and reusability."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLAdoptionBarrier a owl:Class ;
    rdfs:label "ML Adoption Barrier"@en ;
    rdfs:comment "A factor that hinders the successful implementation and deployment of ML models, such as high costs, lack of expertise, or infrastructure limitations."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLBestPractice a owl:Class ;
    rdfs:label "ML Best Practice"@en ;
    rdfs:comment "A methodological principle or technical standard that promotes quality, maintainability, scalability, and reliability in machine learning model development and deployment processes."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLChallenge a owl:Class ;
    rdfs:label "ML Challenge"@en ;
    rdfs:comment "A specific obstacle or difficulty encountered during the development, deployment, or maintenance of ML models, such as data quality issues, model drift, or resource constraints."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLCollaborationEnvironment a owl:Class ;
    rdfs:label "ML Collaboration Environment"@en ;
    rdfs:comment "A shared platform or workspace that facilitates collaboration among ML stakeholders, including tools for documentation, communication, and workflow management."@en ;
    rdfs:subClassOf mlops:CollaborativeEnvironment .

mlops:MLCommunication a owl:Class ;
    rdfs:label "ML Communication"@en ;
    rdfs:comment "The exchange of information, decisions, and feedback among stakeholders involved in MLOps workflows to ensure alignment and understanding."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLCompliance a owl:Class ;
    rdfs:label "ML Compliance"@en ;
    rdfs:comment "Adherence to regulatory, ethical, and organizational standards and requirements in the development and deployment of machine learning models."@en ;
    rdfs:subClassOf mlops:MLGovernance .

mlops:MLComplianceFramework a owl:Class ;
    rdfs:label "ML Compliance Framework"@en ;
    rdfs:comment "A structured set of policies, standards, and controls designed to ensure adherence to regulatory and organizational requirements in MLOps."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLComputingResourceCost a owl:Class ;
    rdfs:label "ML Computing Resource Cost"@en ;
    rdfs:comment "The financial and operational costs associated with the provisioning and utilization of computational resources for MLOps workflows, including cloud, edge, and hybrid environments."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLCustomerExpectationManagement a owl:Class ;
    rdfs:label "ML Customer Expectation Management"@en ;
    rdfs:comment "The process of aligning customer expectations with the capabilities and limitations of machine learning models to ensure realistic outcomes and satisfaction."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLDataManagement a owl:Class ;
    rdfs:label "ML Data Management"@en ;
    rdfs:comment "The process of managing data throughout the MLOps lifecycle, including acquisition, storage, processing, and governance to ensure quality, security, and compliance."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLDataProtection a owl:Class ;
    rdfs:label "ML Data Protection"@en ;
    rdfs:comment "The implementation of measures to protect sensitive and confidential data used in MLOps workflows, including encryption, access control, and compliance with regulations."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLDevelopmentPractice a owl:Class ;
    rdfs:label "ML Development Practice"@en ;
    rdfs:comment "The set of methodologies, tools, and processes applied during the development of machine learning models to ensure quality, reproducibility, and maintainability."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLEthics a owl:Class ;
    rdfs:label "ML Ethics"@en ;
    rdfs:comment "The principles and practices that guide the responsible development and deployment of machine learning models, ensuring alignment with societal values and norms."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLExperiment a owl:Class ;
    rdfs:label "ML Experiment"@en ;
    rdfs:comment "A structured process of testing hypotheses, iterating on model configurations, and evaluating outcomes to improve machine learning model performance and reliability."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLExplainability a owl:Class ;
    rdfs:label "ML Explainability"@en ;
    rdfs:comment "The capability to provide understandable explanations for the decisions and behaviors of machine learning models to stakeholders and end-users."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLFairness a owl:Class ;
    rdfs:label "ML Fairness"@en ;
    rdfs:comment "The assessment and mitigation of biases in machine learning models to ensure equitable outcomes across different groups and contexts."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLIntegration a owl:Class ;
    rdfs:label "ML Integration"@en ;
    rdfs:comment "The process of integrating machine learning workflows with software development and deployment pipelines to enable end-to-end automation and reliability."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLLifecycle a owl:Class ;
    rdfs:label "ML Lifecycle"@en ;
    rdfs:comment "The complete sequence of stages involved in the development, deployment, and maintenance of machine learning models, encompassing data preparation, model training, deployment, monitoring, and governance."@en ;
    rdfs:subClassOf schema:Event ;
    owl:sameAs mlops:LifecycleEfficiency,
        mlops:MLModelLifecycle,
        mlops:MLProjectLifecycle .

mlops:MLModelDegradation a owl:Class ;
    rdfs:label "ML Model Degradation"@en ;
    rdfs:comment "The phenomenon where the performance of a machine learning model deteriorates over time due to changes in data distribution, model drift, or other factors."@en ;
    rdfs:subClassOf schema:Event .

mlops:MLModelDriftDetection a owl:Class ;
    rdfs:label "ML Model Drift Detection"@en ;
    rdfs:comment "The identification of changes in the statistical properties of input data or model performance over time, indicating the need for retraining or intervention."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:MLModelMaintenance a owl:Class ;
    rdfs:label "ML Model Maintenance"@en ;
    rdfs:comment "The ongoing process of monitoring, updating, and maintaining machine learning models in production to ensure performance, reliability, and relevance over time."@en,
        "The ongoing process of monitoring, updating, and managing machine learning models in production to ensure performance, reliability, and relevance over time."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage,
        schema:Action .

mlops:MLModelObsoletePrevention a owl:Class ;
    rdfs:label "ML Model Obsolete Prevention"@en ;
    rdfs:comment "Strategies and processes to prevent machine learning models from becoming obsolete, including continuous monitoring, retraining, and updating."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:MLModelPerformanceMetrics a owl:Class ;
    rdfs:label "ML Model Performance Metrics"@en ;
    rdfs:comment "Quantitative measures used to evaluate the performance of machine learning models in production, including accuracy, precision, recall, F1-score, and other relevant metrics."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLModelProductionization a owl:Class ;
    rdfs:label "ML Model Productionization"@en ;
    rdfs:comment "The process of transitioning a machine learning model from development to production, including deployment, monitoring, and maintenance for operational use."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLOpsArtifact a owl:Class ;
    rdfs:label "MLOps Artifact"@en ;
    rdfs:comment "An abstract entity representing any artifact produced or consumed during MLOps processes, such as datasets, models, configurations, or logs."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsBenefit a owl:Class ;
    rdfs:label "MLOps Benefit"@en ;
    rdfs:comment "An advantage or positive outcome resulting from the adoption of MLOps practices, such as improved model performance, faster deployment, or reduced operational overhead."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsChallenge a owl:Class ;
    rdfs:label "MLOps Challenge"@en ;
    rdfs:comment "A common obstacle or difficulty encountered during the adoption or implementation of MLOps practices, such as scalability, data quality, or tool integration."@en,
        "A difficulty or obstacle encountered in MLOps workflows, such as role ambiguity, technical debt, or infrastructure limitations, that hinders efficiency or effectiveness."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsMaturityModel a owl:Class ;
    rdfs:label "MLOps Maturity Model"@en ;
    rdfs:comment "A structured framework or model that defines distinct levels of MLOps maturity, typically ranging from ad-hoc processes to fully automated operations."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsPrinciple a owl:Class ;
    rdfs:label "MLOps Principle"@en ;
    rdfs:comment "A foundational guideline or best practice that underpins successful MLOps implementation, such as automation, collaboration, monitoring, or reproducibility."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsRole a owl:Class ;
    rdfs:label "MLOps Role"@en ;
    rdfs:comment "An abstract role or responsibility within MLOps, such as data engineer, model developer, or operations engineer, that defines the responsibilities and activities of individuals or teams."@en ;
    rdfs:subClassOf schema:Role .

mlops:MLOpsTool a owl:Class ;
    rdfs:label "MLOps Tool"@en ;
    rdfs:comment "An abstract entity representing tools or technologies used in MLOps workflows, such as Docker, Kubernetes, TensorFlow, or MLflow."@en ;
    rdfs:subClassOf schema:SoftwareApplication .

mlops:MLOrganizationalStandard a owl:Class ;
    rdfs:label "ML Organizational Standard"@en ;
    rdfs:comment "An internal policy or standard defined by an organization to guide the development, deployment, or operation of machine learning models."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLPipelineAutomation a owl:Class ;
    rdfs:label "ML Pipeline Automation"@en ;
    rdfs:comment "A maturity level where automation of the ML pipeline is achieved, including steps involved in experimentation and model development."@en ;
    rdfs:subClassOf mlops:MLOpsMaturityLevel .

mlops:MLPrivacy a owl:Class ;
    rdfs:label "ML Privacy"@en ;
    rdfs:comment "The measures and processes that ensure the privacy of data and models, including anonymization, differential privacy, and secure multi-party computation."@en ;
    rdfs:subClassOf mlops:MLSecurity .

mlops:MLProcessElement a owl:Class ;
    rdfs:label "ML Process Element"@en ;
    rdfs:comment "A fundamental component of an MLOps workflow, including roles, competencies, tools, artifacts, activities, and tasks required for effective ML project execution."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLProductQuality a owl:Class ;
    rdfs:label "ML Product Quality"@en ;
    rdfs:comment "The overall quality attributes of deployed machine learning models, including accuracy, reliability, robustness, and adherence to domain-specific requirements."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLQualityModel a owl:Class ;
    rdfs:label "ML Quality Model"@en ;
    rdfs:comment "A framework or standard that defines criteria and processes for ensuring the quality, reliability, and maintainability of ML models and MLOps workflows."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLRegulatoryRequirement a owl:Class ;
    rdfs:label "ML Regulatory Requirement"@en ;
    rdfs:comment "A legal or regulatory obligation that must be satisfied in the development or deployment of machine learning models, such as GDPR, HIPAA, or sector-specific standards."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLResourceManagement a owl:Class ;
    rdfs:label "ML Resource Management"@en ;
    rdfs:comment "The planning, allocation, and optimization of resources (e.g., compute, storage, human) required for MLOps workflows."@en ;
    rdfs:subClassOf mlops:InfrastructureManagement .

mlops:MLStakeholder a owl:Class ;
    rdfs:label "ML Stakeholder"@en ;
    rdfs:comment "An individual or group with an interest in the development, deployment, or operation of machine learning models, such as data scientists, engineers, or business analysts."@en ;
    rdfs:subClassOf schema:Person .

mlops:MLTeam a owl:Class ;
    rdfs:label "ML Team"@en ;
    rdfs:comment "A group of professionals (e.g., data scientists, software engineers, operations) collaborating to develop, deploy, and maintain machine learning systems within an MLOps framework."@en,
        "A group of stakeholders collaborating on MLOps workflows, including data scientists, engineers, and operations professionals."@en ;
    rdfs:subClassOf schema:Organization .

mlops:MLToolchain a owl:Class ;
    rdfs:label "ML Toolchain"@en ;
    rdfs:comment "A collection of tools and technologies integrated to support MLOps workflows, including version control, CI/CD, orchestration, and monitoring."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLWorkflow a owl:Class ;
    rdfs:label "ML Workflow"@en ;
    rdfs:comment "A structured sequence of activities and processes within MLOps, including data preparation, model training, deployment, and monitoring, designed to achieve a specific goal."@en,
        "A structured sequence of tasks and processes in MLOps, including data preparation, training, evaluation, deployment, and monitoring, designed to achieve a specific goal."@en ;
    rdfs:subClassOf schema:Action .

mlops:MaturityFramework a owl:Class ;
    rdfs:label "Maturity Framework"@en ;
    rdfs:comment "A structured set of guidelines, benchmarks, or criteria used to assess and improve the maturity of MLOps processes in an organization."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ModelEffectiveness a owl:Class ;
    rdfs:label "Model Effectiveness"@en ;
    rdfs:comment "The degree to which a machine learning model achieves its intended objectives and delivers value in real-world applications."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ModelExplainability a owl:Class ;
    rdfs:label "Model Explainability"@en ;
    rdfs:comment "A process or system providing transparency into how machine learning models make decisions, enabling stakeholders to understand and trust model outputs."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:ModelImplementation a owl:Class ;
    rdfs:label "Model Implementation"@en ;
    rdfs:comment "The process of deploying and operationalizing machine learning models in production environments for real-world inference and decision-making."@en ;
    rdfs:subClassOf schema:Action .

mlops:ModelPerformanceDegradation a owl:Class ;
    rdfs:label "Model Performance Degradation"@en ;
    rdfs:comment "A reduction in the effectiveness of a deployed machine learning model over time due to factors such as data drift, concept drift, or changes in the operational environment."@en ;
    rdfs:subClassOf schema:Event .

mlops:ModelPerformanceEvaluation a owl:Class ;
    rdfs:label "Model Performance Evaluation"@en ;
    rdfs:comment "A process or system assessing the performance of deployed models in production environments to ensure they meet operational and business requirements."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:ModelRegistry a owl:Class ;
    rdfs:label "Model Registry"@en ;
    rdfs:comment "A centralized system for storing, cataloging, and managing machine learning models and their metadata for governance and deployment."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ModelReliability a owl:Class ;
    rdfs:label "Model Reliability"@en ;
    rdfs:comment "The consistency and dependability of a machine learning model's performance in production environments over time."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ModelRobustness a owl:Class ;
    rdfs:label "Model Robustness"@en ;
    rdfs:comment "The ability of a machine learning model to maintain performance and reliability under varying conditions, including data drift and adversarial inputs."@en ;
    rdfs:subClassOf schema:Thing .

mlops:OperationalEfficiency a owl:Class ;
    rdfs:label "Operational Efficiency"@en ;
    rdfs:comment "A measure of the effectiveness and productivity of MLOps processes in reducing operational overhead, minimizing manual intervention, and optimizing resource utilization."@en ;
    rdfs:subClassOf schema:Thing .

mlops:PeerReviewedPublication a owl:Class ;
    rdfs:label "Peer Reviewed Publication"@en ;
    rdfs:comment "A publication that has undergone peer review, indicating a certain level of quality and rigor in the research or findings presented."@en ;
    rdfs:subClassOf schema:CreativeWork .

mlops:PrivacyManagement a owl:Class ;
    rdfs:label "Privacy Management"@en ;
    rdfs:comment "The process of identifying, classifying, and protecting sensitive or confidential data (e.g., PII) to ensure compliance with privacy regulations and ethical standards."@en ;
    rdfs:subClassOf schema:Action ;
    owl:sameAs mlops:PrivacyAndSecurityManagement .

mlops:ProfessionalCompetency a owl:Class ;
    rdfs:label "Professional Competency"@en ;
    rdfs:comment "A set of skills, knowledge, and expertise required for roles in MLOps, including architecture, data engineering, ML, and DevOps."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ResourceConstraint a owl:Class ;
    rdfs:label "Resource Constraint"@en ;
    rdfs:comment "A limitation on computational resources (e.g., GPU availability, memory, cost) that impacts the design, training, or deployment of machine learning models."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:MLResourceConstraint .

mlops:RoleDefinition a owl:Class ;
    rdfs:label "Role Definition"@en ;
    rdfs:comment "The formal specification of responsibilities, skills, and contributions of individuals or teams involved in MLOps workflows, such as data scientists, data engineers, ML engineers, and DevOps."@en ;
    rdfs:subClassOf schema:Action .

mlops:ServerlessComputing a owl:Class ;
    rdfs:label "Serverless Computing"@en ;
    rdfs:comment "A paradigm where infrastructure management is abstracted from the user, enabling scalable and cost-efficient execution of MLOps workflows without manual provisioning."@en ;
    rdfs:subClassOf mlops:InfrastructureManagement .

mlops:SoftwareEngineeringPractice a owl:Class ;
    rdfs:label "Software Engineering Practice"@en ;
    rdfs:comment "A systematic approach or methodology in software engineering applied to the development, maintenance, and evolution of AI solutions within MLOps."@en ;
    rdfs:subClassOf schema:Action .

mlops:StakeholderInvolvement a owl:Class ;
    rdfs:label "Stakeholder Involvement"@en ;
    rdfs:comment "The systematic engagement of stakeholders, including customers, data scientists, and product teams, throughout MLOps workflows to align technical processes with business goals and ensure successful outcomes."@en ;
    rdfs:subClassOf schema:Action .

mlops:StandardizationProcess a owl:Class ;
    rdfs:label "Standardization Process"@en ;
    rdfs:comment "A process that enforces consistent practices, tools, and methodologies across MLOps workflows to ensure reproducibility, reliability, and efficiency."@en ;
    rdfs:subClassOf schema:Action .

mlops:TalentShortageChallenge a owl:Class ;
    rdfs:label "Talent Shortage Challenge"@en ;
    rdfs:comment "The scarcity of specialized professionals with expertise in machine learning, data engineering, and MLOps practices to support organizational needs."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:MLQualifiedPersonnelShortage .

mlops:detectsModelDrift a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "detects model drift"@en ;
    rdfs:comment "Relates a model drift detection process to the model or data distribution it monitors for changes."@en ;
    rdfs:domain mlops:ModelDriftDetection ;
    rdfs:range schema:Thing .

mlops:enablesCollaboration a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "enables collaboration"@en ;
    rdfs:comment "Relates a collaborative environment or CI/CD process to the teams or stakeholders it brings together for MLOps workflows."@en,
        "Relates a collaborative environment to the teams or stakeholders it brings together for MLOps workflows."@en ;
    rdfs:domain mlops:CollaborativeEnvironment ;
    rdfs:range schema:Organization .

mlops:generatesMLTechnicalDebt a owl:ObjectProperty ;
    rdfs:label "generates technical debt"@en ;
    rdfs:comment "Relates a development practice or process to the technical debt it generates in machine learning projects."@en ;
    rdfs:domain mlops:MLDevelopmentPractice ;
    rdfs:range mlops:MLTechnicalDebt ;
    rdfs:subPropertyOf prov:generated .

mlops:hasAdoptionBarrier a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has adoption barrier"@en ;
    rdfs:comment "Relates an MLOps process or workflow to a barrier that hinders its adoption or implementation."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLAdoptionBarrier ;
    rdfs:subPropertyOf prov:wasInfluencedBy .

mlops:hasArtifact a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has artifact"@en ;
    rdfs:comment "Relates an MLOps process or workflow to an artifact it produces or consumes."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLOpsArtifact ;
    rdfs:subPropertyOf prov:used .

mlops:hasBenefit a owl:ObjectProperty ;
    rdfs:label "has benefit"@en ;
    rdfs:comment "Relates an MLOps practice or process to a benefit it contributes to, such as operational efficiency or product quality."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:CrossTeamCollaboration,
        mlops:MLProductQuality,
        mlops:OperationalEfficiency ;
    rdfs:subPropertyOf prov:generated .

mlops:hasChallenge a owl:ObjectProperty ;
    rdfs:label "has challenge"@en ;
    rdfs:comment "Relates an MLOps practice or process to a challenge it faces, such as data management or experimental nature."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:DataManagementChallenge,
        mlops:ExpectationManagementChallenge,
        mlops:ExperimentalNatureChallenge,
        mlops:TalentShortageChallenge,
        mlops:TeamIntegrationChallenge ;
    rdfs:subPropertyOf prov:wasDerivedFrom .

mlops:hasCollaborationChallenge a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has collaboration challenge"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the collaboration challenges it encounters."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:CollaborationChallenge .

mlops:hasCollaborationContext a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has collaboration context"@en ;
    rdfs:comment "Relates an MLOps process or workflow to the collaborative environment or teams involved in its execution."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:CollaborativeEnvironment ;
    rdfs:subPropertyOf prov:wasAssociatedWith .

mlops:hasCommunication a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has communication"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the communication processes or artifacts involved."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLCommunication .

mlops:hasComplianceFramework a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has compliance framework"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the compliance framework it adheres to."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLComplianceFramework .

mlops:hasContinuousTraining a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has continuous training"@en ;
    rdfs:comment "Relates a model or pipeline to its continuous training process."@en ;
    rdfs:domain mlops:ModelVersioning ;
    rdfs:range mlops:ContinuousTraining ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasDataQualityMetric a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has data quality metric"@en ;
    rdfs:comment "Relates a data quality assessment process to the specific metrics or criteria used to evaluate data quality."@en ;
    rdfs:domain mlops:DataQualityAssessment ;
    rdfs:range schema:Thing .

mlops:hasDataStrategy a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has data strategy"@en ;
    rdfs:comment "Relates an MLOps process or workflow to the data strategy it adheres to or implements."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:DataStrategy ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasDocumentation a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has documentation"@en ;
    rdfs:comment "Relates an ML-enabled system, workflow, or artifact to its associated documentation."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLDocumentation .

mlops:hasEffectiveness a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has effectiveness"@en ;
    rdfs:comment "Relates a model to its effectiveness characteristics."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:ModelEffectiveness .

mlops:hasEthicsRequirement a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has ethics requirement"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the ethics requirements it must satisfy."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLEthics .

mlops:hasExperiment a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has experiment"@en ;
    rdfs:comment "Relates an MLOps process or workflow to an ML experiment it conducts or manages."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLExperiment ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasExplainabilityRequirement a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has explainability requirement"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the explainability requirements it must satisfy."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLExplainability .

mlops:hasFairnessRequirement a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has fairness requirement"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the fairness requirements it must satisfy."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLFairness .

mlops:hasFramework a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has framework"@en ;
    rdfs:comment "Relates an MLOps process or workflow to the framework it adheres to or is governed by."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLOpsFramework ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasGovernanceRequirement a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has governance requirement"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the governance requirements it must satisfy."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLGovernance .

mlops:hasLifecycle a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has lifecycle"@en ;
    rdfs:comment "Relates a machine learning model or its development process to the comprehensive ML model lifecycle it belongs to."@en,
        "Relates a machine learning system or workflow to its encompassing lifecycle."@en,
        "Relates an MLOps process or workflow to the ML project lifecycle it belongs to."@en ;
    rdfs:domain schema:Action,
        schema:Thing ;
    rdfs:range mlops:MLLifecycle,
        mlops:MLModelLifecycle,
        mlops:MLProjectLifecycle ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasMLChallenge a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has ML challenge"@en ;
    rdfs:comment "Relates an MLOps process or workflow to a specific challenge it faces or addresses."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLChallenge ;
    rdfs:subPropertyOf prov:wasInfluencedBy .

mlops:hasMLRole a owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    rdfs:comment "Relates a collaborative environment or team to the roles involved in MLOps workflows."@en ;
    rdfs:domain mlops:CollaborativeEnvironment ;
    rdfs:range mlops:MLRole ;
    rdfs:subPropertyOf prov:involved .

mlops:hasMaturityLevel a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has maturity level"@en ;
    rdfs:comment "Relates an MLOps practice or process to its maturity level within an organization."@en,
        "Relates an MLOps process or organization to its maturity level classification."@en,
        "Relates an MLOps process or workflow to its maturity level as defined by a maturity framework."@en,
        "Relates an MLOps process, framework, or organization to its maturity level."@en,
        "Relates an organization or workflow to its MLOps maturity level as defined by a maturity model."@en ;
    rdfs:domain schema:Action,
        schema:Organization ;
    rdfs:range mlops:MLOpsMaturityLevel ;
    rdfs:subPropertyOf dcterms:hasPart,
        prov:wasAssociatedWith,
        schema:additionalProperty .

mlops:hasMetadata a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has metadata"@en ;
    rdfs:comment "Relates an ML-enabled system, workflow, or artifact to its associated metadata."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:Thing .

mlops:hasModelPerformanceMetric a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has model performance metric"@en ;
    rdfs:comment "Relates a model monitoring process to the performance metrics or KPIs used to evaluate model efficacy in production."@en ;
    rdfs:domain mlops:ModelMonitoringStage ;
    rdfs:range schema:Thing .

mlops:hasOrganizationalStandard a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has organizational standard"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the organizational standards it adheres to."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLOrganizationalStandard .

mlops:hasPrinciple a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has principle"@en ;
    rdfs:comment "Relates an MLOps process or practice to a foundational principle it adheres to."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLOpsPrinciple ;
    rdfs:subPropertyOf schema:additionalProperty .

mlops:hasPrivacyRequirement a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has privacy requirement"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the privacy requirements it must satisfy."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLPrivacy .

mlops:hasProcess a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has process"@en ;
    rdfs:comment "Relates an MLOps workflow or system to a specific process or activity it encompasses."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:MLOpsProcess ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:hasPublicationType a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has publication type"@en ;
    rdfs:comment "Relates a publication or research output to its type, such as peer-reviewed or conference proceedings."@en ;
    rdfs:domain schema:CreativeWork ;
    rdfs:range mlops:PeerReviewedPublication ;
    rdfs:subPropertyOf dcterms:type .

mlops:hasRegulatoryRequirement a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has regulatory requirement"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the regulatory requirements it must satisfy."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLRegulatoryRequirement .

mlops:hasReliability a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has reliability"@en ;
    rdfs:comment "Relates a model to its reliability characteristics."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:ModelReliability .

mlops:hasResearchObjective a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has research objective"@en ;
    rdfs:comment "Relates a research protocol to the research objectives it defines to guide the systematic review process."@en ;
    rdfs:domain mlops:ResearchProtocol ;
    rdfs:range mlops:ResearchObjective ;
    rdfs:subPropertyOf prov:used .

mlops:hasResearchQuestion a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has research question"@en ;
    rdfs:comment "Relates a systematic literature review to the research questions it addresses during the evaluation process."@en ;
    rdfs:domain mlops:SystematicLiteratureReview ;
    rdfs:range mlops:ResearchQuestion ;
    rdfs:subPropertyOf prov:used .

mlops:hasResourceConstraint a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has resource constraint"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the resource constraints it faces."@en,
        "Relates an MLOps process or workflow to a resource constraint it must address or optimize for."@en ;
    rdfs:domain schema:Action,
        schema:Thing ;
    rdfs:range mlops:MLResourceConstraint,
        mlops:ResourceConstraint ;
    rdfs:subPropertyOf schema:subjectOf .

mlops:hasRobustness a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has robustness"@en ;
    rdfs:comment "Relates a model to its robustness characteristics."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:ModelRobustness .

mlops:hasRole a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    rdfs:comment "Relates an ML team member to their defined role within the MLOps process."@en,
        "Relates an MLOps process or workflow to the roles or responsibilities involved in its execution."@en ;
    rdfs:domain schema:Action,
        schema:Person ;
    rdfs:range mlops:MLOpsRole,
        mlops:MLRole ;
    rdfs:subPropertyOf prov:wasAssociatedWith,
        schema:hasOccupation .

mlops:hasRoleDefinition a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has role definition"@en ;
    rdfs:comment "Relates a collaborative environment or MLOps process to the defined roles and responsibilities of individuals or teams involved."@en ;
    rdfs:domain mlops:CollaborativeEnvironment ;
    rdfs:range mlops:RoleDefinition ;
    rdfs:subPropertyOf prov:wasAssociatedWith .

mlops:hasSecurityRequirement a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has security requirement"@en ;
    rdfs:comment "Relates an ML-enabled system or workflow to the security requirements it must satisfy."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLSecurity .

mlops:hasStakeholder a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has stakeholder"@en ;
    rdfs:comment "Relates an ML-enabled system, workflow, or artifact to the stakeholders involved in its development, deployment, or operation."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLStakeholder .

mlops:hasTeam a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "has team"@en ;
    rdfs:comment "Relates an ML-enabled system, workflow, or artifact to the team responsible for its development, deployment, or operation."@en ;
    rdfs:domain schema:Thing ;
    rdfs:range mlops:MLTeam .

mlops:integratesMLWorkflow a owl:ObjectProperty ;
    rdfs:label "integrates workflow"@en ;
    rdfs:comment "Relates an integration process to the MLOps workflow it integrates with software development pipelines."@en ;
    rdfs:domain mlops:MLIntegration ;
    rdfs:range schema:Action ;
    rdfs:subPropertyOf prov:used .

mlops:isPartOfWorkflow a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "is part of workflow"@en ;
    rdfs:comment "Relates an MLOps process or artifact to the workflow it belongs to."@en ;
    rdfs:domain mlops:MLOpsProcess ;
    rdfs:range mlops:MLOpsWorkflow ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

mlops:mitigatesTechnicalDebt a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "mitigates technical debt"@en ;
    rdfs:comment "Relates a corrective action or intervention to the technical debt it addresses or reduces in machine learning model development or deployment."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:TechnicalDebt ;
    rdfs:subPropertyOf prov:actedOn .

mlops:monitorsModelDrift a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "monitors model drift"@en ;
    rdfs:comment "Relates a monitoring process to the model drift it tracks or evaluates."@en ;
    rdfs:domain mlops:ModelMonitoringStage ;
    rdfs:range mlops:ModelDrift ;
    rdfs:subPropertyOf prov:used .

mlops:requiresInfrastructure a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "requires infrastructure"@en ;
    rdfs:comment "Relates an MLOps process or workflow to the infrastructure resources it requires for execution, such as computational resources or cloud services."@en ;
    rdfs:domain schema:Action ;
    rdfs:range mlops:InfrastructureManagement ;
    rdfs:subPropertyOf prov:used .

mlops:ContinuousTraining a owl:Class ;
    rdfs:label "Continuous Training"@en ;
    rdfs:comment "An automated process of retraining machine learning models in response to detected performance degradation, data drift, or scheduled updates to maintain model effectiveness."@en,
        "The automated process of retraining and updating ML models based on new data, performance metrics, or environmental changes to maintain model relevance and accuracy."@en,
        "The practice of continuously retraining machine learning models to adapt to new data and evolving requirements, often integrated into CI/CD/CT pipelines."@en ;
    rdfs:subClassOf mlops:MLOpsParadigm,
        mlops:ModelTrainingStage,
        schema:Action .

mlops:CrossTeamCollaboration a owl:Class ;
    rdfs:label "Cross-Team Collaboration"@en ;
    rdfs:comment "A collaborative environment where multiple teams (e.g., data science, operations, domain experts) work together to align goals, share insights, and streamline MLOps workflows."@en,
        "The coordinated effort between data engineers, data scientists, operations professionals, and other stakeholders to streamline MLOps workflows and improve model development and deployment outcomes."@en ;
    rdfs:subClassOf mlops:CollaborativeEnvironment,
        schema:Thing .

mlops:DataDriftDetection a owl:Class ;
    rdfs:label "Data Drift Detection"@en ;
    rdfs:comment "A process or system monitoring and detecting changes in data distribution over time, which may impact model performance and require corrective action."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:DataManagementChallenge a owl:Class ;
    rdfs:label "Data Management Challenge"@en ;
    rdfs:comment "Challenges related to the acquisition, storage, processing, and governance of data required for MLOps workflows, including issues like data quality, accessibility, and consistency."@en ;
    rdfs:subClassOf schema:Thing .

mlops:DataQualityAssessment a owl:Class ;
    rdfs:label "Data Quality Assessment"@en ;
    rdfs:comment "A process or framework for evaluating the quality, consistency, and suitability of data used in MLOps workflows, including metrics for completeness, accuracy, timeliness, and relevance."@en ;
    rdfs:subClassOf schema:Action .

mlops:DataQuantity a owl:Class ;
    rdfs:label "Data Quantity"@en ;
    rdfs:comment "The volume of data available for training and evaluation in MLOps workflows, particularly relevant for deep learning techniques requiring large datasets."@en ;
    rdfs:subClassOf schema:Thing .

mlops:LifecycleEfficiency a owl:Class ;
    rdfs:label "Lifecycle Efficiency"@en ;
    rdfs:comment "The optimization of the machine learning lifecycle stages to reduce time-to-production, improve model quality, and enhance operational effectiveness in MLOps workflows."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLModelLifecycle a owl:Class ;
    rdfs:label "ML Model Lifecycle"@en ;
    rdfs:comment "The comprehensive lifecycle encompassing the development, deployment, monitoring, and maintenance of machine learning models in production environments."@en ;
    rdfs:subClassOf schema:Event .

mlops:MLOpsFramework a owl:Class ;
    rdfs:label "MLOps Framework"@en ;
    rdfs:comment "A structured set of guidelines, tools, and practices that define how MLOps processes are implemented and integrated within an organization."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLOpsParadigm a owl:Class ;
    rdfs:label "MLOps Paradigm"@en ;
    rdfs:comment "A paradigm and set of practices that extend DevOps principles to address the unique challenges of Machine Learning Operations, including continuous integration, deployment, monitoring, and maintenance of ML models."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLOpsProcess a owl:Class ;
    rdfs:label "MLOps Process"@en ;
    rdfs:comment "A systematic series of actions or steps within MLOps, such as data pipeline execution, model training, or deployment orchestration, designed to achieve a specific outcome."@en,
        "An abstract process or workflow within MLOps that encompasses activities such as data preparation, model training, deployment, monitoring, and infrastructure management."@en,
        "An abstract process or workflow within MLOps that encompasses one or more lifecycle stages, such as data preparation, model training, deployment, and monitoring."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLOpsWorkflow a owl:Class ;
    rdfs:label "MLOps Workflow"@en ;
    rdfs:comment "A structured sequence of MLOps processes and stages that are orchestrated to achieve a specific goal, such as model deployment or monitoring."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLProjectLifecycle a owl:Class ;
    rdfs:label "ML Project Lifecycle"@en ;
    rdfs:comment "The structured sequence of phases and processes required to develop, deploy, and maintain ML models, including data preparation, model training, deployment, and monitoring."@en ;
    rdfs:subClassOf schema:Event .

mlops:MLQualifiedPersonnelShortage a owl:Class ;
    rdfs:label "ML Qualified Personnel Shortage"@en ;
    rdfs:comment "The scarcity of skilled professionals in data science and related fields required to implement and maintain MLOps workflows effectively."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLResourceConstraint a owl:Class ;
    rdfs:label "ML Resource Constraint"@en ;
    rdfs:comment "A limitation in computational, financial, or human resources that impacts the development, deployment, or operation of machine learning models."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLSocialDebt a owl:Class ;
    rdfs:label "ML Social Debt"@en ;
    rdfs:comment "The organizational and team-related costs arising from ambiguity in roles, overloaded responsibilities, and lack of collaboration in machine learning development projects."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLTechnicalDebt a owl:Class ;
    rdfs:label "ML Technical Debt"@en ;
    rdfs:comment "The accumulated cost of poor design and implementation choices in machine learning projects, leading to increased maintenance effort, reduced performance, and future rewriting needs."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLTesting a owl:Class ;
    rdfs:label "ML Testing"@en ;
    rdfs:comment "The systematic evaluation of machine learning models and systems to ensure correctness, robustness, and reliability, including unit, integration, and system testing."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLWorkflowOrchestration a owl:Class ;
    rdfs:label "ML Workflow Orchestration"@en ;
    rdfs:comment "The coordination and scheduling of MLOps workflows, including data pipelines, training jobs, and deployment processes, to ensure end-to-end automation and reliability."@en ;
    rdfs:subClassOf schema:Action .

mlops:ModelDeploymentStage a owl:Class ;
    rdfs:label "Model Deployment Stage"@en ;
    rdfs:comment "A lifecycle stage responsible for deploying trained models into production environments for inference and serving."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:ModelDrift a owl:Class ;
    rdfs:label "Model Drift"@en ;
    rdfs:comment "The degradation of a model's performance over time due to changes in data distribution, feature relevance, or underlying patterns, necessitating retraining or updates."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ModelDriftDetection a owl:Class ;
    rdfs:label "Model Drift Detection"@en ;
    rdfs:comment "A specialized monitoring process focused on identifying and quantifying changes in model performance or data distribution over time, enabling proactive adjustments to maintain model efficacy."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:ModelVersioning a owl:Class ;
    rdfs:label "Model Versioning"@en ;
    rdfs:comment "The systematic tracking and management of different versions of machine learning models to enable rollback, comparison, and reproducibility."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ResearchProtocol a owl:Class ;
    rdfs:label "Research Protocol"@en ;
    rdfs:comment "A predefined and documented procedure outlining the steps, criteria, and methods for conducting a systematic review or study to ensure reproducibility and rigor."@en ;
    rdfs:subClassOf schema:Action .

mlops:ResearchQuestion a owl:Class ;
    rdfs:label "Research Question"@en ;
    rdfs:comment "A specific inquiry formulated to guide the systematic review process, typically derived from research objectives to focus and structure the evaluation of relevant papers."@en ;
    rdfs:subClassOf schema:Thing ;
    owl:sameAs mlops:ResearchObjective .

mlops:SystematicLiteratureReview a owl:Class ;
    rdfs:label "Systematic Literature Review"@en ;
    rdfs:comment "A structured and rigorous method for identifying, evaluating, and synthesizing research papers to establish the state of the art or address specific research questions in a domain."@en ;
    rdfs:subClassOf schema:Action .

mlops:TeamIntegrationChallenge a owl:Class ;
    rdfs:label "Team Integration Challenge"@en ;
    rdfs:comment "Challenges in integrating cross-functional teams (e.g., data science, engineering, operations) to align goals, processes, and workflows in MLOps environments."@en ;
    rdfs:subClassOf schema:Thing .

mlops:DataPreparationStage a owl:Class ;
    rdfs:label "Data Preparation Stage"@en ;
    rdfs:comment "A lifecycle stage focused on the acquisition, cleaning, transformation, and feature engineering of data required for model development."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:MLDocumentation a owl:Class ;
    rdfs:label "ML Documentation"@en ;
    rdfs:comment "The structured documentation of machine learning models, including requirements, design decisions, data lineage, model cards, and operational procedures."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLProcess a owl:Class ;
    rdfs:label "ML Process"@en ;
    rdfs:comment "A defined procedure or method within MLOps, such as data validation, model training, or deployment, that contributes to the lifecycle."@en ;
    rdfs:subClassOf schema:Action .

mlops:MLRole a owl:Class ;
    rdfs:label "ML Role"@en ;
    rdfs:comment "A defined function or responsibility within an MLOps team, such as data scientist, ML engineer, data engineer, product owner, or DevOps engineer."@en,
        "A defined function or responsibility within an MLOps team, such as data scientist, software engineer, operations professional, or MLOps engineer, that contributes to the lifecycle of machine learning systems."@en ;
    rdfs:subClassOf schema:Role .

mlops:MLSecurity a owl:Class ;
    rdfs:label "ML Security"@en ;
    rdfs:comment "The practices and controls that protect machine learning models, data, and systems from threats, including adversarial attacks, data poisoning, and unauthorized access."@en ;
    rdfs:subClassOf schema:Action .

mlops:ModelFairnessMonitoring a owl:Class ;
    rdfs:label "Model Fairness Monitoring"@en ;
    rdfs:comment "A process or system dedicated to monitoring and evaluating machine learning models for fairness, bias, and ethical compliance throughout their lifecycle."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:OrganizationalCulture a owl:Class ;
    rdfs:label "Organizational Culture"@en ;
    rdfs:comment "The cultural aspects and interdisciplinary collaboration practices that support the adoption and effectiveness of MLOps processes within an organization."@en,
        "The shared values, practices, and behaviors within an organization that influence the adoption and effectiveness of MLOps, including collaboration, experimentation, and continuous learning."@en ;
    rdfs:subClassOf schema:Thing .

mlops:PrivacyAndSecurityManagement a owl:Class ;
    rdfs:label "Privacy and Security Management"@en ;
    rdfs:comment "A process or system ensuring the protection of data privacy and security throughout the MLOps lifecycle, including compliance with regulations and ethical standards."@en ;
    rdfs:subClassOf mlops:ModelMonitoringStage .

mlops:TechnicalDebt a owl:Class ;
    rdfs:label "Technical Debt"@en ;
    rdfs:comment "The accumulated cost of shortcuts or suboptimal decisions in machine learning model development that compromise long-term maintainability, scalability, and integration in production environments."@en,
        "The accumulation of suboptimal decisions, shortcuts, or deficiencies in the design, implementation, or maintenance of ML systems that lead to increased long-term costs, reduced maintainability, or technical challenges in MLOps workflows."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ResearchObjective a owl:Class ;
    rdfs:label "Research Objective"@en ;
    rdfs:comment "A high-level goal or purpose that guides the design and execution of a systematic review, often aligned with measurement frameworks like Goal-Question-Metric (GQM)."@en ;
    rdfs:subClassOf schema:Thing .

mlops:MLGovernance a owl:Class ;
    rdfs:label "ML Governance"@en ;
    rdfs:comment "The set of policies, processes, and controls that ensure responsible, compliant, and auditable development and deployment of machine learning models within an organization."@en ;
    rdfs:subClassOf schema:Action .

mlops:ModelTrainingStage a owl:Class ;
    rdfs:label "Model Training Stage"@en ;
    rdfs:comment "A lifecycle stage where machine learning models are trained, validated, and optimized using prepared datasets."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

mlops:InfrastructureManagement a owl:Class ;
    rdfs:label "Infrastructure Management"@en ;
    rdfs:comment "The process of provisioning, configuring, and maintaining computational resources required for MLOps workflows, including cloud, edge, and hybrid environments."@en ;
    rdfs:subClassOf schema:Action .

mlops:CollaborativeEnvironment a owl:Class ;
    rdfs:label "Collaborative Environment"@en ;
    rdfs:comment "A shared workspace enabling collaboration among data engineers, data scientists, and operations professionals to streamline MLOps workflows, particularly in CI/CD pipelines."@en,
        "A shared workspace enabling collaboration among data engineers, data scientists, and operations professionals to streamline MLOps workflows."@en,
        "A shared workspace enabling collaboration among data engineers, data scientists, operations professionals, and other stakeholders to align machine learning models with business objectives and ensure proper integration into existing systems."@en ;
    rdfs:subClassOf schema:Action ;
    mlops:enablesCollaboration mlops:CrossTeamCollaboration .

mlops:MLLifecycleStage a owl:Class ;
    rdfs:label "ML Lifecycle Stage"@en ;
    rdfs:comment "An abstract stage within the Machine Learning lifecycle, encompassing phases such as data preparation, model training, deployment, and monitoring."@en ;
    rdfs:subClassOf schema:Event .

mlops:MLOpsMaturityLevel a owl:Class ;
    rdfs:label "MLOps Maturity Level"@en ;
    rdfs:comment "A classification level indicating the degree of capability, automation, and integration of MLOps processes within an organization, ranging from ad-hoc to fully automated and optimized."@en,
        "A classification representing the maturity of an organization's MLOps practices, ranging from ad-hoc to fully automated and optimized."@en,
        "A classification representing the maturity of an organization's MLOps practices, ranging from no automation to fully automated continuous training and deployment."@en,
        "A classification representing the maturity or capability level of MLOps processes in an organization, ranging from ad-hoc manual processes to fully automated and integrated pipelines."@en,
        "An abstract representation of the maturity level of MLOps practices within an organization, ranging from manual processes to fully automated operations."@en ;
    rdfs:subClassOf schema:Thing .

mlops:ModelMonitoringStage a owl:Class ;
    rdfs:label "Model Monitoring Stage"@en ;
    rdfs:comment "A lifecycle stage focused on continuous evaluation, logging, and performance tracking of deployed models in production."@en ;
    rdfs:subClassOf mlops:MLLifecycleStage .

