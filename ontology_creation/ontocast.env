# EMP API
# gpt-4.1, gpt-5.1, gpt-5.2
LLM_MODEL_NAME=gpt-5.4-mini
LLM_BASE_URL=https://chat.kiconnect.nrw/api/v1
LLM_API_KEY=69dcd949e567cef9f7852bd3:waBtTEMmddfzVefH1MyZ+UKOKHzkJdHn6uB0FpYoWk0=

ONTOCAST_WORKING_DIRECTORY=./workspace
PARALLEL_WORKERS=1
SERVER_PARALLEL_WORKERS=1

# Retry settings for robustness
PARALLEL_FACTS_RETRIES=5
PARALLEL_ONTOLOGY_RETRIES=5

PORT=8990
LOGGING_LEVEL=DEBUG
RENDER_MODE=ontology
ENABLE_ONTOLOGY_CONSOLIDATION=True
ONTOCAST_CACHE_DIR=./cache

CURRENT_DOMAIN=https://example.com/
PROVENANCE_MODE=owl2
CUDA_VISIBLE_DEVICES=""
