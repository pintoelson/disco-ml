@inproceedings{10011505,
 abstract = {DevOps has become increasingly widespread, with companies employing its methods in different fields. In this context, MLOps automates Machine Learning pipelines by applying DevOps practices. Considering the high number of tools available and the high interest of the practitioners to be supported by tools to automate the steps of Machine Learning pipelines, little is known concerning MLOps tools and their functionalities. To this aim, we conducted a Multivocal Literature Review (MLR) to (i) extract tools that allow for and support the creation of MLOps pipelines and (ii) analyze their main characteristics and features to provide a comprehensive overview of their value. Overall, we investigate the functionalities of 13 MLOps Tools. Our results show that most MLOps Tools support the same features but apply different approaches that can bring different advantages, depending on user requirements.},
 author = {Recupito, Gilberto and Pecorelli, Fabiano and Catolino, Gemma and Moreschini, Sergio and Nucci, Dario Di and Palomba, Fabio and Tamburri, Damian A.},
 booktitle = {2022 48th Euromicro Conference on Software Engineering and Advanced Applications (SEAA)},
 doi = {10.1109/SEAA56994.2022.00021},
 keywords = {Bibliographies;Pipelines;Machine learning;Companies;Feature extraction;Software engineering;MLOps;Multivocal Literature Review;DevOps;Machine Learning},
 number = {},
 pages = {84-91},
 title = {A Multivocal Literature Review of MLOps Tools and Features},
 volume = {},
 year = {2022}
}

@inproceedings{10386139,
 abstract = {Data Science (DS) has gained increased relevance due to the potential to extract useful insights from data. Quite commonly, this involves the utilization of Machine Learning (ML). The challenging pursuit of developing and productionizing ML models can be supported and automated through MLOps, a specialization of the DevOps paradigm from software development. Therefore, MLOps offers significant potential for DS projects, which are suffering from notable failure rates. Accordingly, this literature review focuses on examining the current state-of-the-art of the publications in this area. Most importantly, the analysis showed that the current MLOps approaches in the literature predominantly emphasize model development and deployment, while organizational aspects (business understanding, evaluation) in a DS project are neglected. As DS project success is not exclusively dependent on technical matters, advancing the MLOps field by bridging the gap between business objectives and the modeling perspective through appropriate frameworks should be pursued in future research.},
 author = {Haertel, Christian and Staegemann, Daniel and Daase, Christian and Pohl, Matthias and Nahhas, Abdulrahman and Turowski, Klaus},
 booktitle = {2023 IEEE International Conference on Big Data (BigData)},
 doi = {10.1109/BigData59044.2023.10386139},
 keywords = {Analytical models;DevOps;Bibliographies;Machine learning;Data science;Big Data;Software;Data Science;MLOps;DevOps;Literature Review;Project Management},
 number = {},
 pages = {2396-2404},
 title = {MLOps in Data Science Projects: A Review},
 volume = {},
 year = {2023}
}

@inproceedings{11214628,
 abstract = {Software development companies (SDCs) have started to include Machine Learning (ML) within their projects, which has allowed ML models to not be left behind to the experimentation stage, but to move to the production stage, here Machine Learning Operations (MLOps) arises to decrease the gap between operations, development and data science teams. Therefore, this article presents a systematic literature review on the adoption of MLOps in SDCs, based on the analysis of 28 primary studies. The findings of this article reflect the efforts of the scientific community to define the principles, roles, artifacts, benefits, challenges, and crucial factors for the implementation of MLOps in SDCs.},
 author = {Arteaga, Esteban and Pardo, César and Suescún, Elizabeth and Villarreal, Vladimir},
 booktitle = {2025 IEEE VIII Congreso Internacional en Inteligencia Ambiental, Ingenieria de Software y Salud Electronica y Movil (AmITIC)},
 doi = {10.1109/AmITIC68284.2025.11214628},
 keywords = {DevOps;Pipelines;Machine learning;Companies;Production;Data science;Software;Data models;Systematic literature review;Machine Learning Operations (MLOps);Pipeline;Software Development;Machine Learning (ML);DevOps;Systematic Literature Review (SLR)},
 number = {},
 pages = {1-8},
 title = {A Systematic Literature Review of MLOps Adoption in Software Development Companies: Attributes, Maturity, Benefits and Challenges},
 volume = {},
 year = {2025}
}

@inproceedings{11311934,
 abstract = {Machine Learning Operations (MLOps) extends Development and Operations (DevOps) practices to manage the end-to-end lifecycle of machine learning models. However, the alignment between MLOps and the traditional software development lifecycle (SDLC) remains insufficiently defined. This study presents a systematic literature review of peer-reviewed works published between 2018 and 2025 in IEEE Xplore, Scopus, and the ACM Digital Library. The review was conducted following a protocol for evidence-based software engineering. A total of 71 primary studies were included after deduplication and screening. A phase-based taxonomy of MLOps tools was synthesized and an SDLC-MLOps compatibility framework was derived to classify alignment levels as high, medium, or low across development phases. Inter-rater agreement, measured using Cohen's Kappa, yielded a value of 0.91, while the average study quality score was 0.73. The results show convergence around pipelines, model registries, and containerized deployment, alongside persistent fragmentation in process models and organizational practices. The findings provide implications for practice, including maturity-based adoption strategies, role definition, governance mechanisms, and continuous monitoring. Additionally, opportunities for future research are identified in the areas of ML-specific testing and harmonized metrics across software engineering and data science disciplines.},
 author = {Cancañón-Rodríguez, Kenia and Muñoz, Mirna and Avila-George, Himer},
 booktitle = {2025 Mexican International Conference on Computer Science (ENC)},
 doi = {10.1109/ENC68268.2025.11311934},
 keywords = {Protocols;Biological system modeling;Taxonomy;Organizations;Machine learning;Libraries;Monitoring;Systematic literature review;Testing;Software engineering;systematic literature review;MLOps;MLOps practices;SDLC;methodological resources},
 number = {},
 pages = {1-6},
 title = {Integration of MLOps into the Software Development Lifecycle: A Systematic Review},
 volume = {},
 year = {2025}
}
