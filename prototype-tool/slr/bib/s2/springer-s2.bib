@incollection{aiello_mlops_2026,
 abstract = {MLOps promises to help practitioners integrate ML features into their software systems. However, practitioners are struggling to adopt the MLOps paradigm. In this case study, we interviewed 12 practitioners at Zeiss SMT, a low-volume optics manufacturing company, about challenges and solutions in their adoption of MLOps. Our results identify 13 challenges, the key one being security requirements prohibiting the use of cloud-based platforms. We also identify 13 solutions practitioners use to cope with these challenges. Our results highlight important areas for future work to streamline MLOps adoption in the manufacturing industry.},
 address = {Cham},
 author = {Haug, Markus and Azamnouri, Aidin and Fritz, Manuel and Woltmann, Lucas and Schriever, Christian and Wagner, Stefan},
 booktitle = {Service-{Oriented} {Computing}},
 doi = {10.1007/978-3-032-07313-6_2},
