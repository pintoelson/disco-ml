abstract = {On behalf of the ACM CCS 2025 Organizing Committee, we warmly welcome you to the 32nd ACM SIGSAC Conference on Computer and Communications Security (CCS). We are delighted that, for the first time, ACM CCS is being held in Taipei, Taiwan. This year’s conference theme is “Continuity, Creativity, Community”, reflecting our shared commitment to building on the rich legacy of CCS, fostering innovation in security and privacy research, and strengthening our global community.The main conference this year features 316 research presentations, showcasing the latest innovations and developments in security and privacy. We are honored to welcome two distinguished keynote speakers—Prof. Giovanni Vigna (University of California, Santa Barbara) and Prof. David Basin (ETH Zurich)—who will share their insights on pressing challenges shaping the future of our discipline. Complementing the main program, 21 specialized workshops will be held on the pre- and post-conference days, offering venues for in-depth discussion and collaboration on focused research topics.},
location = {Taipei, Taiwan}
}

