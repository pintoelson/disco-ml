 year = {2020}
}

@incollection{johannesson_design_2021,
 abstract = {The third activity of the method framework is Design and Develop Artefact, which creates an artefact fulfilling the requirements from the previous activity. This includes designing both the functionality and structure of the artefact. In other words, the activity can be expressed as follows: Create an artefact that addresses the explicated problem and fulfils the defined requirements. This chapter describes a number of creative and practice-oriented methods for artefact design and development, moving iteratively between imagining and brainstorming, assessing and selecting ideas, sketching and building, and justifying and reflecting.},
