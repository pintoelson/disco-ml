@incollection{knodel_how_2016,
 abstract = {The main goal of the Solution Adequacy Check (SAC) is to check whether the architecture solutions at hand are adequate for the architecture drivers identified and whether there is enough confidence in the adequacy. We present a pragmatic workshop-based approach that is based on ideas of ATAM. We provide guidance for the documentation of evaluation results, such as the discussed architecture decisions and how they impact the adequacy of the overall solution. We also provide concrete templates and examples and show how evaluation results and specific findings can be rated and represented.},
 address = {Cham},
 author = {Knodel, Jens and Naab, Matthias},
 booktitle = {Pragmatic {Evaluation} of {Software} {Architectures}},
 collaborator = {Knodel, Jens and Naab, Matthias},
